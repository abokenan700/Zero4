<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@style/AppBaseTheme">
        <item name="android:statusBarColor">@color/sushi_grey_100</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:autofilledHighlight">@android:color/transparent</item>
    </style>
    <style name="AppTheme.BackgroundDim" parent="@style/AppTheme.NoActionBar.SlideUpTransitions">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="AppTheme.ForeverDark" parent="@style/AppTheme.ForeverDarkBase">
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="AppTheme.Transparent" parent="@style/AppTheme.NoActionBar.SlideUpTransitions">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    <style name="AppTheme.ZStories.Fullscreen" parent="@style/AppTheme.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/SlideUpActivityTransition</item>
        <item name="android:immersive">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
    <style name="AppThemeLogin" parent="@style/AppTheme.NoActionBar">
        <item name="android:windowAnimationStyle">@style/SlideInActivityTransition</item>
        <item name="android:statusBarColor">@color/color_transparent</item>
        <item name="android:navigationBarColor">@color/sushi_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">true</item>
    </style>
    <style name="AppThemeNoToolbarTranslucent" parent="@style/AppTheme.NoActionBar">
        <item name="android:windowBackground">@color/color_transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="AppThemeSlideInTransition" parent="@style/AppTheme.NoActionBar">
        <item name="android:windowAnimationStyle">@style/SlideInActivityTransition</item>
    </style>
    <style name="AppThemeSlideInTransitionToolbar" parent="@style/AppTheme">
        <item name="android:windowAnimationStyle">@style/SlideInActivityTransition</item>
    </style>
    <style name="AppThemeToolbarTranslucent" parent="@style/AppTheme">
        <item name="android:windowBackground">@color/color_transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="AppThemeToolbarTranslucentLegacy" parent="@style/AppThemeNoToolbarTranslucent">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    <style name="Base.Theme.AppCompat" parent="@style/Base.V26.Theme.AppCompat" />
    <style name="Base.Theme.AppCompat.Light" parent="@style/Base.V26.Theme.AppCompat.Light" />
    <style name="Base.Widget.AppCompat.Toolbar" parent="@style/Base.V26.Widget.AppCompat.Toolbar" />
    <style name="CartActivityTheme" parent="@style/AppTheme.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="FullPageAnimationStyle" parent="@style/AppTheme.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:immersive">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    <style name="FullScreenDialogStyle">
        <item name="android:windowBackground">@color/color_black_alpha_sixty</item>
        <item name="android:statusBarColor">@color/color_black_alpha_sixty</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="TranslucentNoToolbarTheme" parent="@style/AppTheme.NoActionBar">
        <item name="android:windowBackground">@color/color_black_alpha_forty_four</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
    <style name="Widget.Design.AppBarLayout" parent="@android:style/Widget">
        <item name="android:background">?colorPrimary</item>
        <item name="android:stateListAnimator">@animator/design_appbar_state_list_animator</item>
        <item name="android:touchscreenBlocksFocus">true</item>
        <item name="android:keyboardNavigationCluster">true</item>
    </style>
    <style name="Base.V26.Theme.AppCompat" parent="@style/Base.V23.Theme.AppCompat">
        <item name="colorError">?android:colorError</item>
    </style>
    <style name="Base.V26.Theme.AppCompat.Light" parent="@style/Base.V23.Theme.AppCompat.Light">
        <item name="colorError">?android:colorError</item>
    </style>
    <style name="Base.V26.Widget.AppCompat.Toolbar" parent="@style/Base.V7.Widget.AppCompat.Toolbar">
        <item name="android:touchscreenBlocksFocus">true</item>
        <item name="android:keyboardNavigationCluster">true</item>
    </style>
</resources>
