<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:id="@id/container"
    android:background="@color/sushi_transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/cart_top_shadow"
        android:background="@drawable/bg_shadow"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/tv_cart_message"
        android:background="@color/menu_button_message_bg"
        android:paddingTop="@dimen/sushi_spacing_between"
        android:paddingBottom="@dimen/sushi_spacing_between"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/sushi_spacing_page_side"
        android:paddingEnd="@dimen/sushi_spacing_page_side"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cart_top_shadow"
        app:textViewType="REGULAR_100" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/cl_cart_payment"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_cart_message"
        app:layout_constraintWidth_percent="0.35">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@id/iv_payment_type"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/sushi_spacing_extra"
            android:adjustViewBounds="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040466"
            android:ellipsize="end"
            android:id="@id/tv_payment_title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textAllCaps="true"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            app:drawableEnd="@string/icon_font_up_triangle_small"
            app:layout_constraintBottom_toBottomOf="@id/iv_payment_type"
            app:layout_constraintStart_toEndOf="@id/iv_payment_type"
            app:layout_constraintTop_toTopOf="@id/iv_payment_type"
            app:textViewType="REGULAR_100" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040466"
            android:ellipsize="end"
            android:id="@id/tv_payment_subtitle1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:maxLines="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_payment_title"
            app:textViewType="MEDIUM_300" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040466"
            android:ellipsize="end"
            android:id="@id/tv_payment_subtitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:maxLines="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_payment_subtitle1"
            app:textViewType="MEDIUM_100" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?themeColor500"
            android:ellipsize="end"
            android:id="@id/payment_right_subtitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@id/tv_payment_subtitle2"
            app:layout_constraintStart_toEndOf="@id/tv_payment_subtitle2"
            app:layout_constraintTop_toTopOf="@id/tv_payment_subtitle2"
            app:textViewType="MEDIUM_100" />
        <com.zomato.ui.atomiclib.molecules.ShimmerView
            android:id="@id/shimmer_cart_payment"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/transparent_white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shimmer_layout_id="@layout/qd_shimmer_payment" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/cl_combined_container"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cl_cart_payment"
        app:layout_constraintTop_toBottomOf="@id/tv_cart_message">
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/top_strip_title"
            android:paddingTop="@dimen/sushi_spacing_micro"
            android:paddingBottom="@dimen/sushi_spacing_micro"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="@dimen/sushi_spacing_micro"
            app:layout_constraintEnd_toStartOf="@id/top_strip_timer"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/top_strip_timer"
            android:paddingTop="@dimen/sushi_spacing_micro"
            android:paddingBottom="@dimen/sushi_spacing_micro"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/top_strip_title"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/cv_checkout_container"
            android:focusable="true"
            android:clickable="true"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:elevation="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_strip_title">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@id/cl_cart_checkout"
                android:background="?selectableItemBackground"
                android:padding="@dimen/sushi_spacing_macro"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:id="@id/layer_1"
                    android:layout_width="@dimen/size_36"
                    android:layout_height="@dimen/size_36"
                    android:src="@drawable/bg_rounded_white"
                    android:alpha="0.25"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:id="@id/layer_2"
                    android:layout_width="@dimen/size_36"
                    android:layout_height="@dimen/size_36"
                    android:src="@drawable/bg_rounded_white"
                    android:alpha="0.25"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:id="@id/layer_3"
                    android:layout_width="@dimen/size_36"
                    android:layout_height="@dimen/size_36"
                    android:src="@drawable/bg_rounded_white"
                    android:alpha="0.25"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <FrameLayout
                    android:id="@id/left_icon_container"
                    android:background="@drawable/bg_rounded_white"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_36"
                    android:layout_height="@dimen/size_36"
                    android:layout_marginEnd="@dimen/sushi_spacing_base"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                        android:id="@id/left_icon"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:scaleType="centerCrop"
                        android:adjustViewBounds="true"
                        app:cornerRadius="@dimen/dimen_10" />
                </FrameLayout>
                <androidx.constraintlayout.widget.Group
                    android:id="@id/left_images_group"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="layer_1,layer_2,layer_3,left_icon_container" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_white"
                    android:id="@id/tv_checkout_title"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/left_icon_container"
                    app:layout_constraintTop_toTopOf="parent"
                    app:textViewType="REGULAR_400" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_white"
                    android:id="@id/tv_checkout_subtitle"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:textAllCaps="true"
                    android:layout_marginEnd="@dimen/sushi_spacing_micro"
                    app:layout_constraintStart_toEndOf="@id/left_icon_container"
                    app:layout_constraintTop_toBottomOf="@id/tv_checkout_title"
                    app:textViewType="REGULAR_100" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_white"
                    android:id="@id/tv_checkout_subtitle_2"
                    android:visibility="gone"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:textAllCaps="true"
                    android:layout_marginStart="@dimen/sushi_spacing_mini"
                    android:layout_marginEnd="@dimen/sushi_spacing_micro"
                    app:layout_constraintBottom_toBottomOf="@id/tv_checkout_subtitle"
                    app:layout_constraintStart_toEndOf="@id/tv_checkout_subtitle"
                    app:layout_constraintTop_toTopOf="@id/tv_checkout_subtitle"
                    app:textViewType="REGULAR_100" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_white"
                    android:gravity="end"
                    android:id="@id/tv_action_text"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_macro"
                    app:layout_constraintBottom_toTopOf="@id/tv_action_subtitle_text"
                    app:layout_constraintEnd_toStartOf="@id/iv_right_arrow"
                    app:layout_constraintStart_toEndOf="@id/tv_checkout_title"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:textViewType="REGULAR_500" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_white"
                    android:gravity="end"
                    android:id="@id/tv_action_subtitle_text"
                    android:visibility="gone"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_macro"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/iv_right_arrow"
                    app:layout_constraintStart_toEndOf="@id/tv_checkout_subtitle"
                    app:layout_constraintTop_toBottomOf="@id/tv_action_text"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:textViewType="REGULAR_100" />
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:textColor="@color/sushi_white"
                    android:id="@id/iv_right_arrow"
                    android:paddingLeft="@dimen/dimen_4"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/icon_font_left_triangle_small"
                    app:layout_constraintBottom_toBottomOf="@id/tv_action_subtitle_text"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_action_text" />
                <ProgressBar
                    android:id="@id/pb_checkout_cart"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/sushi_white"
                    android:indeterminateTintMode="src_atop"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    style="?android:progressBarStyleSmall" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@id/disabled_checkout_container"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:elevation="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/cl_combined_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cl_cart_payment"
        app:layout_constraintTop_toTopOf="@id/cl_combined_container" />
</androidx.constraintlayout.widget.ConstraintLayout>