<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="@color/color_transparent"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_800"
        android:textColor="@color/color_white"
        android:layout_gravity="center_horizontal"
        android:id="@id/closeButton"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingTop="@dimen/size_8"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:paddingBottom="@dimen/size_8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:text="@string/icon_font_cross"
        android:fontFamily="@font/wasabicons"
        android:backgroundTint="@color/tokenised_slate_700"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        android:paddingVertical="@dimen/size_8" />
    <androidx.core.widget.NestedScrollView
        android:id="@id/innerLayout"
        android:background="?attr_7f04017d"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingTop="@dimen/sushi_spacing_base"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/sushi_spacing_base">
        <LinearLayout
            android:orientation="vertical"
            android:paddingBottom="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/titleLayout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <EditText
                android:gravity="top"
                android:layout_gravity="top"
                android:id="@id/editText"
                android:padding="@dimen/size_6"
                android:scrollbars="vertical"
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:layout_marginTop="@dimen/size_12"
                android:layout_marginBottom="@dimen/size_12"
                android:minLines="4"
                android:layout_weight="1.0" />
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/submitButtom"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>