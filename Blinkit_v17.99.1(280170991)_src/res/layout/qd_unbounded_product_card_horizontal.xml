<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/image_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
            android:id="@id/image"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/image_container"
            app:layout_constraintEnd_toEndOf="@id/image_container"
            app:layout_constraintStart_toStartOf="@id/image_container"
            app:layout_constraintTop_toTopOf="@id/image_container" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textStyle="bold"
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:layout_gravity="start"
            android:id="@id/tv_offer_tag"
            android:background="@drawable/bg_product_card_offer"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingBottom="@dimen/sushi_spacing_micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="0.75"
            android:layout_marginStart="-1.0dip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_goneMarginStart="@dimen/dimen_4" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_white"
        android:id="@id/tv_out_of_stock_tag"
        android:paddingLeft="@dimen/qd_padding_8"
        android:paddingTop="@dimen/qd_padding_2"
        android:paddingRight="@dimen/qd_padding_8"
        android:paddingBottom="@dimen/qd_padding_2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/qd_out_of_stock"
        android:paddingHorizontal="@dimen/qd_padding_8"
        android:paddingVertical="@dimen/qd_padding_2"
        app:layout_constraintBottom_toBottomOf="@id/image_container"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toTopOf="@id/image_container"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040466"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@id/tv_name_fixed_height"
        android:visibility="invisible"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/qd_margin_8"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:maxLines="2"
        android:lines="2"
        android:includeFontPadding="false"
        android:elevation="0.100000024dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/image_barrier"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040466"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@id/tv_name"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:maxLines="2"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/size_8"
        android:elevation="0.100000024dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/image_barrier"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f04047c"
        android:ellipsize="end"
        android:gravity="start"
        android:layout_gravity="start"
        android:id="@id/tv_variant_fixed_height"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        android:lines="1"
        android:includeFontPadding="false"
        android:elevation="0.100000024dip"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/rating_star_view_fixed_height"
        app:layout_constraintEnd_toStartOf="@id/stepper_barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/tv_name_fixed_height"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintVertical_chainStyle="packed"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f04047c"
        android:ellipsize="end"
        android:layout_gravity="start"
        android:id="@id/tv_variant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/qd_margin_8"
        android:layout_marginTop="@dimen/dimen_4"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:layout_marginEnd="@dimen/dimen_12"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/rating_star_view_fixed_height"
        app:layout_constraintEnd_toStartOf="@id/stepper_barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/tv_name"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintVertical_chainStyle="packed"
        app:textViewType="REGULAR_400" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.rating.RatingSnippetItemViewStub
        android:id="@id/rating_star_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/tv_variant" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.text.ZTextViewStub
        android:id="@id/rating_star_view_fixed_height"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/tv_variant_fixed_height" />
    <androidx.constraintlayout.widget.Barrier
        android:orientation="horizontal"
        android:id="@id/title_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="tv_name,tv_name_fixed_height,tv_variant,tv_variant_fixed_height,rating_star_view,rating_star_view_fixed_height" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/ll_price_container"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/qd_margin_8"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        android:layout_marginRight="@dimen/qd_margin_12"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/stepper_barrier"
        app:layout_constraintStart_toStartOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/title_barrier"
        app:layout_constraintVertical_bias="1.0">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040466"
            android:ellipsize="end"
            android:gravity="start"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            app:textViewType="REGULAR_400" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_600"
            android:ellipsize="end"
            android:gravity="start"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_mrp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            android:layout_marginStart="@dimen/dimen_4"
            app:textViewType="REGULAR_400" />
    </LinearLayout>
    <com.blinkit.commons.ui.ui.customviews.stepper.Stepper
        android:id="@id/stepper"
        android:visibility="gone"
        android:layout_width="@dimen/size_72"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/qd_margin_2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:stepper_type="SMALL" />
    <ViewStub
        android:id="@id/notify_me"
        android:layout="@layout/layout_notify_me"
        android:inflatedId="@id/notify_me"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/stepper"
        app:layout_constraintStart_toStartOf="@id/stepper" />
    <androidx.constraintlayout.widget.Barrier
        android:orientation="horizontal"
        android:id="@id/stepper_barrier"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        app:barrierDirection="start"
        app:constraint_referenced_ids="stepper" />
    <androidx.constraintlayout.widget.Barrier
        android:orientation="horizontal"
        android:id="@id/image_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="image_container" />
</androidx.constraintlayout.widget.ConstraintLayout>