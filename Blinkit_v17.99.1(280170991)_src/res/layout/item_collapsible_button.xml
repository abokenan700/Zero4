<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:orientation="vertical"
    android:id="@id/root"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:layout_gravity="center_vertical"
        android:id="@id/separator"
        android:background="@color/sushi_grey_200"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_pico" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040475"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/collapsibleButton"
        android:paddingTop="@dimen/dimen_10"
        android:paddingBottom="@dimen/dimen_10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:drawablePadding="@dimen/sushi_spacing_micro"
        app:textViewType="MEDIUM_200" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
        android:textColor="@color/sushi_black"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/collapsibleIcon"
        android:padding="@dimen/sushi_spacing_macro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="@dimen/cardview_compat_inset_shadow"
        app:drawablePadding="@dimen/sushi_spacing_micro" />
</FrameLayout>