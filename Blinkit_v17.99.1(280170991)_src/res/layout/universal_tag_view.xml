<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/containerView"
    android:paddingTop="@dimen/sushi_spacing_macro"
    android:paddingBottom="@dimen/sushi_spacing_macro"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/sushi_spacing_mini"
    android:paddingEnd="@dimen/sushi_spacing_mini"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/titleContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/dimen_10"
            android:textColor="@color/sushi_white"
            android:id="@id/tagViewIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1.7999878dip"
            android:paddingEnd="2.5dip"
            app:textFontWeight="semibold" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:ellipsize="end"
            android:id="@id/tagViewText"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:textViewType="SEMIBOLD_300" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_white"
        android:ellipsize="end"
        android:id="@id/subtitle"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:textViewType="REGULAR_100" />
</LinearLayout>