<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:id="@id/root_card_view"
    android:background="#00000000"
    android:layout_width="fill_parent"
    android:layout_height="0.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <include
        android:id="@id/closeButtonContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        layout="@layout/qd_layout_bottom_sheet_close_btn" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/safe_secure_constraint_layout"
        android:background="@drawable/qd_bottom_sheet_circular"
        android:paddingTop="@dimen/qd_padding_10"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textSize="@dimen/dimen_15"
                android:id="@id/title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/qd_padding_32"
                android:layout_marginTop="@dimen/qd_margin_10"
                android:layout_marginRight="@dimen/qd_padding_32"
                android:text="Add file from"
                android:layout_marginHorizontal="@dimen/qd_padding_32" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/upload_options"
                android:paddingLeft="@dimen/qd_margin_22"
                android:paddingRight="@dimen/qd_margin_22"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/qd_margin_22">
                <include
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    layout="@layout/qd_print_type_selected" />
                <include
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    layout="@layout/qd_print_type_selected" />
                <include
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    layout="@layout/qd_print_type_selected" />
                <include
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    layout="@layout/qd_print_type_selected" />
            </LinearLayout>
        </LinearLayout>
        <com.blinkit.commons.ui.ui.customviews.loadingErrorOverlay.LoadingErrorOverlay
            android:id="@id/loading_error_overlay"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>