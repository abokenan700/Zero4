<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/parent_container"
    android:paddingLeft="@dimen/sushi_spacing_mini"
    android:paddingTop="@dimen/sushi_spacing_base"
    android:paddingRight="@dimen/sushi_spacing_mini"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:paddingHorizontal="@dimen/sushi_spacing_mini"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/image_container"
        android:background="@drawable/qd_white_rounded_12dp"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@id/delete_icon"
        android:padding="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/sushi_spacing_mini"
        android:text="@string/icon_font_cross"
        android:elevation="@dimen/sushi_spacing_macro"
        android:outlineSpotShadowColor="@color/color_transparent"
        android:outlineAmbientShadowColor="@color/color_transparent"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintTop_toTopOf="@id/image_container" />
    <View
        android:id="@id/image_overlay"
        android:background="@drawable/qd_top_semi_rounded"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:elevation="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toTopOf="@id/image_separator"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toTopOf="@id/image_container" />
    <View
        android:id="@id/image_frame"
        android:background="?attr_7f0403d7"
        android:paddingLeft="@dimen/sushi_spacing_micro"
        android:paddingRight="@dimen/sushi_spacing_micro"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        android:layout_margin="@dimen/sushi_spacing_macro"
        android:paddingHorizontal="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toTopOf="@id/image_separator"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toTopOf="@id/image_container" />
    <FrameLayout
        android:id="@id/polaroid_frame"
        android:background="@drawable/color_background_with_border"
        android:paddingLeft="@dimen/elevation_huge"
        android:paddingTop="@dimen/sushi_spacing_base"
        android:paddingRight="@dimen/elevation_huge"
        android:paddingBottom="@dimen/sushi_listing_image_size"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginLeft="@dimen/sushi_spacing_macro"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
        android:paddingHorizontal="@dimen/elevation_huge"
        app:layout_constraintBottom_toTopOf="@id/image_separator"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toTopOf="@id/image_container">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/polaroid_image"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="fitXY" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/edit_button"
        android:padding="@dimen/sushi_spacing_mini"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        android:elevation="@dimen/normal_lock"
        android:outlineSpotShadowColor="@color/color_transparent"
        android:outlineAmbientShadowColor="@color/color_transparent"
        app:layout_constraintBottom_toTopOf="@id/image_separator"
        app:layout_constraintEnd_toEndOf="@id/parent_container" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_margin="@dimen/sushi_spacing_nano"
        android:scaleType="fitCenter"
        android:elevation="@dimen/sushi_spacing_mini"
        android:outlineSpotShadowColor="@color/color_transparent"
        android:outlineAmbientShadowColor="@color/color_transparent"
        app:layout_constraintBottom_toBottomOf="@id/image_frame"
        app:layout_constraintEnd_toEndOf="@id/image_frame"
        app:layout_constraintStart_toStartOf="@id/image_frame"
        app:layout_constraintTop_toTopOf="@id/image_frame" />
    <androidx.constraintlayout.widget.Group
        android:id="@id/group"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:constraint_referenced_ids="progress,image_overlay,progress_title" />
    <ProgressBar
        android:id="@id/progress"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_loose"
        android:layout_height="@dimen/sushi_spacing_loose"
        android:elevation="@dimen/sushi_spacing_macro"
        android:indeterminateTint="@color/white"
        app:layout_constraintBottom_toTopOf="@id/image_separator"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toTopOf="@id/image_container" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/progress_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Processing..."
        android:maxLines="1"
        android:elevation="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/progress"
        app:textViewType="MEDIUM_100" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/image_separator"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/custom_section1"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/image_frame"
        app:zseparator_color="?attr_7f040295" />
    <include
        android:id="@id/custom_section1"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/bottom_separator1"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/image_separator"
        layout="@layout/image_text_right_button" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/bottom_separator1"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_margin="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/custom_section2"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/custom_section1"
        app:zseparator_color="?attr_7f040295" />
    <include
        android:id="@id/custom_section2"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/setting_feature1"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/bottom_separator1"
        layout="@layout/image_text_right_button" />
    <include
        android:orientation="vertical"
        android:id="@id/setting_feature1"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/bottom_separator2"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/custom_section2"
        layout="@layout/qd_print_settings_card" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/bottom_separator2"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_margin="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/setting_feature2"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/setting_feature1"
        app:zseparator_color="?attr_7f040295" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/setting_feature2"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/bottom_section_color1"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/bottom_separator2" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5" />
    <include
        android:id="@id/bottom_section_color1"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toTopOf="@id/bottom_separator3"
        app:layout_constraintEnd_toStartOf="@id/guideline"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/setting_feature2"
        layout="@layout/qd_print_selection" />
    <include
        android:id="@id/bottom_section_color2"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/bottom_section_color1"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toEndOf="@id/guideline"
        app:layout_constraintTop_toTopOf="@id/bottom_section_color1"
        layout="@layout/qd_print_selection" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/bottom_separator3"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_margin="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/setting_feature3"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/bottom_section_color1"
        app:zseparator_color="?attr_7f040295" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/setting_feature3"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/bottom_section_size1"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/bottom_separator3" />
    <include
        android:id="@id/bottom_section_size1"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toTopOf="@id/bottom_section_size4"
        app:layout_constraintEnd_toStartOf="@id/bottom_section_size2"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/setting_feature3"
        layout="@layout/qd_print_selection" />
    <include
        android:id="@id/bottom_section_size2"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/bottom_section_size1"
        app:layout_constraintEnd_toStartOf="@id/bottom_section_size3"
        app:layout_constraintStart_toEndOf="@id/bottom_section_size1"
        app:layout_constraintTop_toTopOf="@id/bottom_section_size1"
        layout="@layout/qd_print_selection" />
    <include
        android:id="@id/bottom_section_size3"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/sushi_spacing_micro_negative"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/bottom_section_size1"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toEndOf="@id/bottom_section_size2"
        app:layout_constraintTop_toTopOf="@id/bottom_section_size1"
        layout="@layout/qd_print_selection" />
    <include
        android:id="@id/bottom_section_size4"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toTopOf="@id/feature_toggle_separator"
        app:layout_constraintEnd_toStartOf="@id/bottom_section_size5"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/bottom_section_size1"
        layout="@layout/qd_print_selection" />
    <include
        android:id="@id/bottom_section_size5"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/bottom_section_size4"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toEndOf="@id/bottom_section_size4"
        app:layout_constraintTop_toTopOf="@id/bottom_section_size4"
        layout="@layout/qd_print_selection" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/feature_toggle_separator"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        app:layout_constraintBottom_toTopOf="@id/switch_view"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/bottom_section_size4"
        app:zseparator_color="?attr_7f040295" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:id="@id/toggle_title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/switch_view"
        app:layout_constraintEnd_toStartOf="@id/switch_view"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toTopOf="@id/switch_view" />
    <com.zomato.ui.atomiclib.molecules.ZSwitch
        android:theme="@style/QdTheme.Switch"
        android:id="@id/switch_view"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/sushi_action_item_drawable_size"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        android:layout_marginVertical="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/image_container"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toEndOf="@id/toggle_title"
        app:layout_constraintTop_toBottomOf="@id/feature_toggle_separator" />
    <androidx.constraintlayout.widget.Group
        android:id="@id/toggle_group"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:constraint_referenced_ids="switch_view,toggle_title,feature_toggle_separator" />
    <include
        android:id="@id/bottom_container"
        android:visibility="invisible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toBottomOf="@id/parent_container"
        app:layout_constraintEnd_toEndOf="@id/image_container"
        app:layout_constraintStart_toStartOf="@id/image_container"
        app:layout_constraintTop_toBottomOf="@id/image_container"
        app:layout_constraintVertical_bias="1.0"
        layout="@layout/image_text_right_button" />
</androidx.constraintlayout.widget.ConstraintLayout>