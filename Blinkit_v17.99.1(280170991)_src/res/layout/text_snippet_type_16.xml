<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center_horizontal"
        android:id="@id/title"
        android:padding="@dimen/sushi_spacing_micro"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:layout_gravity="center_horizontal"
        android:id="@id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/subtitle2"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/item_container_divider"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_pico"
        android:layout_marginTop="@dimen/size_5"
        android:layout_marginBottom="@dimen/size_5"
        android:layout_marginVertical="@dimen/size_5"
        app:zseparator_color="@color/sushi_grey_100"
        app:zseparator_type="STRAIGHT" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/subtitle3"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
</merge>