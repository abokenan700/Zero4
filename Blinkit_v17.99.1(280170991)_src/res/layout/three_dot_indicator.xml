<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:textColor="@color/sushi_grey_600"
        android:gravity="center"
        android:id="@id/count_text"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/first_dot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:textViewType="MEDIUM_200" />
    <View
        android:id="@id/first_dot"
        android:background="@color/sushi_grey_300"
        android:layout_width="@dimen/size_4"
        android:layout_height="@dimen/size_4"
        android:layout_marginLeft="@dimen/qd_margin_1"
        android:layout_marginRight="@dimen/qd_margin_1"
        android:layout_marginHorizontal="@dimen/qd_margin_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/second_dot"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent" />
    <View
        android:id="@id/second_dot"
        android:background="@color/black"
        android:layout_width="@dimen/size_4"
        android:layout_height="@dimen/size_4"
        android:layout_marginLeft="@dimen/qd_margin_1"
        android:layout_marginRight="@dimen/qd_margin_1"
        android:layout_marginHorizontal="@dimen/qd_margin_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/third_dot"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/first_dot" />
    <View
        android:id="@id/third_dot"
        android:background="@color/sushi_grey_300"
        android:layout_width="@dimen/size_4"
        android:layout_height="@dimen/size_4"
        android:layout_marginLeft="@dimen/qd_margin_1"
        android:layout_marginRight="@dimen/qd_margin_1"
        android:layout_marginHorizontal="@dimen/qd_margin_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/second_dot" />
</androidx.constraintlayout.widget.ConstraintLayout>