<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/container"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:stateListAnimator="@animator/scale_animator"
    android:clipToOutline="false"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.snippets.promoTicketSnippet.BTicketBackground
        android:id="@id/ticket_view"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginLeft="-5.0dip"
        android:layout_marginTop="-5.0dip"
        android:layout_marginRight="-5.0dip"
        android:layout_marginBottom="-5.0dip"
        android:layout_marginHorizontal="-5.0dip"
        android:layout_marginVertical="-5.0dip"
        app:bticketBackgroundColor="@color/white"
        app:bticketBorderColor="@color/sushi_grey_300"
        app:bticketBorderDashGap="@dimen/ticket_dash_gap"
        app:bticketBorderDashLength="@dimen/ticket_dash_gap"
        app:bticketBorderType="dash"
        app:bticketBorderWidth="@dimen/qd_ticket_border_width"
        app:bticketCornerRadius="@dimen/dimen_16"
        app:bticketCornerType="rounded"
        app:bticketElevation="@dimen/dimen_20"
        app:bticketOrientation="vertical"
        app:bticketScallopPosition="@dimen/scallop_position"
        app:bticketScallopRadius="@dimen/scallop_radius"
        app:bticketShowBorder="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="@dimen/dimen_60"
        android:layout_height="@dimen/dimen_60"
        android:layout_marginTop="@dimen/dimen_12"
        android:layout_marginBottom="@dimen/dimen_12"
        android:layout_marginStart="@dimen/dimen_12"
        app:cornerRadius="@dimen/dimen_12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/header_title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_12"
        android:layout_marginEnd="@dimen/dimen_18"
        app:layout_constraintBottom_toTopOf="@id/header_subtitle"
        app:layout_constraintEnd_toEndOf="@id/ticket_view"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/header_subtitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_12"
        android:layout_marginEnd="@dimen/dimen_18"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/ticket_view"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toBottomOf="@id/header_title" />
</androidx.constraintlayout.widget.ConstraintLayout>