<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="?attr_7f04017d"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@id/appBarLayout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:elevation="@dimen/dimen_0">
        <androidx.appcompat.widget.Toolbar
            android:id="@id/toolbar"
            android:background="?attr_7f04017d"
            android:layout_width="fill_parent"
            android:layout_height="?actionBarSize"
            android:layout_marginLeft="@dimen/sushi_spacing_micro"
            app:contentInsetStart="@dimen/dimen_0"
            app:elevation="@dimen/dimen_0">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/dimen_16"
                android:layout_gravity="start"
                android:id="@id/back_arrow"
                android:padding="@dimen/sushi_spacing_macro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/icon_font_back" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/grant_permission"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <LinearLayout
                android:id="@id/partial_media_access"
                android:background="@color/sushi_grey_200"
                android:paddingLeft="@dimen/sushi_spacing_base"
                android:paddingTop="@dimen/sushi_spacing_extra"
                android:paddingRight="@dimen/sushi_spacing_base"
                android:paddingBottom="@dimen/sushi_spacing_extra"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_extra"
                android:paddingHorizontal="@dimen/sushi_spacing_base"
                android:paddingVertical="@dimen/sushi_spacing_extra">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/partial_selected_message"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingEnd="@dimen/sushi_spacing_base"
                    app:textViewType="REGULAR_400" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:layout_gravity="center_vertical"
                    android:id="@id/manage_access"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/media_kit_manage"
                    app:buttonDimension="large"
                    app:buttonType="text" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:id="@id/album_name_layout"
                    android:padding="@dimen/nitro_side_padding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="@color/sushi_green_500"
                        android:id="@id/album_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:textViewType="MEDIUM_500" />
                    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                        android:textSize="@dimen/sushi_textsize_300"
                        android:textColor="@color/sushi_green_500"
                        android:id="@id/album_name_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/icon_font_pull_down_thick"
                        android:paddingStart="@dimen/sushi_spacing_micro"
                        android:paddingEnd="0.0dip" />
                </LinearLayout>
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:gravity="end"
                    android:layout_gravity="center"
                    android:id="@id/selected_media_count"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingStart="0.0dip"
                    android:paddingEnd="@dimen/sushi_spacing_base"
                    app:textViewType="REGULAR_300" />
            </LinearLayout>
            <FrameLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <FrameLayout
                    android:id="@id/camera_preview_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_base">
                    <androidx.camera.view.PreviewView
                        android:id="@id/camera_preview"
                        android:layout_width="@dimen/select_media_camera_icon_size"
                        android:layout_height="@dimen/select_media_camera_icon_size" />
                    <FrameLayout
                        android:id="@id/camera_preview_layout_container"
                        android:background="@drawable/circular_frame"
                        android:layout_width="@dimen/select_media_camera_icon_size"
                        android:layout_height="@dimen/select_media_camera_icon_size">
                        <LinearLayout
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                                android:textSize="@dimen/iconfont_size_largest"
                                android:textColor="@color/sushi_white"
                                android:layout_gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/icon_font_camera_fill" />
                            <com.zomato.ui.atomiclib.atom.ZTextView
                                android:textColor="@color/sushi_white"
                                android:layout_gravity="center"
                                android:padding="@dimen/sushi_spacing_micro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/use_camera"
                                app:textViewType="MEDIUM_200" />
                        </LinearLayout>
                    </FrameLayout>
                </FrameLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@id/recycler_view"
                    android:clipToPadding="false"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:paddingStart="@dimen/grid_divider"
                    android:paddingEnd="@dimen/grid_divider" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:layout_gravity="bottom"
                    android:id="@id/button_preview"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_extra"
                    android:layout_marginBottom="@dimen/sushi_spacing_extra"
                    android:layout_marginStart="@dimen/sushi_spacing_base"
                    android:layout_marginEnd="@dimen/sushi_spacing_base"
                    app:buttonColor="?android:colorAccent"
                    app:textViewType="MEDIUM_500" />
            </FrameLayout>
        </LinearLayout>
        <com.zomato.android.zcommons.nocontentview.NoContentView
            android:id="@id/no_content_view"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:nocontentview_message="@string/grant_permission_description"
            app:nocontentview_title="@string/grant_permission_title" />
    </FrameLayout>
</LinearLayout>