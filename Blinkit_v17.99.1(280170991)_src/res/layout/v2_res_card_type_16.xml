<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/left_tag_container"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@id/left_tag_spacing"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/sushi_spacing_mini"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/left_tag_container" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/floating_container"
        android:paddingLeft="@dimen/sushi_spacing_mini"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:paddingRight="@dimen/sushi_spacing_mini"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="@dimen/sushi_spacing_pico"
        android:paddingHorizontal="@dimen/sushi_spacing_mini"
        android:paddingVertical="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:id="@id/floating_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
            android:id="@id/floating_dismiss_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_mini" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTriangle
        android:id="@id/floating_triangle_below_border"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_base"
        android:layout_height="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        android:elevation="@dimen/sushi_spacing_pico"
        app:layout_constraintEnd_toEndOf="@id/floating_container"
        app:layout_constraintTop_toBottomOf="@id/floating_container"
        app:triangle_color="?attr_7f040297"
        app:triangle_type="SOUTH" />
    <com.zomato.ui.atomiclib.atom.ZTriangle
        android:id="@id/floating_triangle_below"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_base"
        android:layout_height="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_pico_negative"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        android:elevation="@dimen/sushi_spacing_pico"
        app:layout_constraintEnd_toEndOf="@id/floating_container"
        app:layout_constraintTop_toBottomOf="@id/floating_container"
        app:triangle_color="@color/sushi_grey_100"
        app:triangle_type="SOUTH" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/top_container_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="floating_triangle_below, left_tag_spacing" />
    <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
        android:id="@id/rating_snippet"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/top_container_barrier" />
    <LinearLayout
        android:id="@id/rating_button_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        app:layout_constraintEnd_toEndOf="@id/rating_snippet"
        app:layout_constraintTop_toBottomOf="@id/rating_snippet">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
            android:layout_gravity="center_vertical"
            android:id="@id/rating_prefix_icon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_micro" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/rating_button"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false" />
    </LinearLayout>
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/end_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="start"
        app:constraint_referenced_ids="rating_button_container, rating_snippet" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toStartOf="@id/end_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/top_container_barrier" />
    <com.zomato.ui.atomiclib.molecules.ShimmerView
        android:id="@id/subtitle_container_shimmer"
        android:visibility="gone"
        android:layout_width="@dimen/size_200"
        android:layout_height="@dimen/sushi_spacing_extra"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        app:layout_constraintBottom_toTopOf="@id/mid_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title">
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:shimmer_corner_radius="@dimen/sushi_spacing_base" />
    </com.zomato.ui.atomiclib.molecules.ShimmerView>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/subtitle_container"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        app:layout_constraintEnd_toStartOf="@id/end_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center_vertical"
            android:id="@id/prefix_image"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_extra"
            android:layout_height="@dimen/sushi_spacing_extra"
            android:layout_marginEnd="@dimen/sushi_spacing_mini" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:layout_gravity="center_vertical"
            android:id="@id/subtitle"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_mini" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/secondary_subtitle_container"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        app:layout_constraintEnd_toStartOf="@id/end_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle_container">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center_vertical"
            android:id="@id/secondary_prefix_image"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_extra"
            android:layout_height="@dimen/sushi_spacing_extra"
            android:layout_marginEnd="@dimen/sushi_spacing_mini" />
        <LinearLayout
            android:gravity="start|center"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/secondary_subtitle_container_children"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
            android:layout_gravity="center"
            android:id="@id/secondary_suffix_icon"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_extra"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_nano"
            android:layout_marginEnd="@dimen/sushi_spacing_mini" />
    </LinearLayout>
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/mid_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="title,subtitle_container,rating_button_container,rating_snippet,subtitle_container_shimmer,secondary_subtitle_container" />
    <com.zomato.ui.atomiclib.molecules.ShimmerView
        android:id="@id/info_container_shimmer"
        android:visibility="gone"
        android:layout_width="@dimen/size_200"
        android:layout_height="@dimen/sushi_spacing_extra"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        app:layout_constraintBottom_toTopOf="@id/bottom_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mid_barrier">
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:shimmer_corner_radius="@dimen/sushi_spacing_base" />
    </com.zomato.ui.atomiclib.molecules.ShimmerView>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/info_container"
        android:background="?attr_7f04017d"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        android:translationZ="@dimen/sushi_spacing_pico"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mid_barrier">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center_vertical"
            android:id="@id/info_prefix_image"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_extra"
            android:layout_height="@dimen/sushi_spacing_extra"
            android:layout_marginEnd="@dimen/sushi_spacing_mini" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:layout_gravity="center_vertical"
            android:id="@id/info_title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:layout_gravity="center_vertical"
        android:id="@id/sub_info_title"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toStartOf="@id/end_barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/info_container"
        app:layout_constraintTop_toBottomOf="@id/mid_barrier" />
    <View
        android:id="@id/sub_info_title_shine"
        android:background="@drawable/bg_text_shine"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_alone"
        android:layout_height="0.0dip"
        android:rotation="30.0"
        app:layout_constraintBottom_toBottomOf="@id/sub_info_title"
        app:layout_constraintStart_toStartOf="@id/sub_info_title"
        app:layout_constraintTop_toTopOf="@id/sub_info_title" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/bottom_container"
        android:background="?attr_7f04017d"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/info_container">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center_vertical"
            android:id="@id/bottom_prefix_image"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_extra"
            android:layout_height="@dimen/sushi_spacing_extra"
            android:layout_marginEnd="@dimen/sushi_spacing_mini" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:layout_gravity="center_vertical"
            android:id="@id/bottom_title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/bottom_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="info_container, subtitle_container, bottom_container, secondary_subtitle_container" />
</merge>