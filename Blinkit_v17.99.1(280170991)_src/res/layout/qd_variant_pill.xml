<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="wrap_content"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/right_tag"
        android:background="@color/green"
        android:visibility="visible"
        android:layout_width="24.0dip"
        android:layout_height="24.0dip"
        android:layout_marginTop="-8.0dip"
        android:layout_marginEnd="-8.0dip"
        android:elevation="@dimen/qd_padding_1"
        app:layout_constraintEnd_toEndOf="@id/container"
        app:layout_constraintTop_toTopOf="@id/container" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/container"
        android:padding="0.5dip"
        android:clipChildren="false"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="1.0dip"
        app:layout_constraintBottom_toTopOf="@id/bottom_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed">
        <com.blinkit.commons.ui.ui.customviews.productCard.FlipperView
            android:gravity="center|top"
            android:layout_gravity="top"
            android:id="@id/offer"
            android:padding="@dimen/sushi_tag_rounded_corner_radius"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:lines="1"
            app:layout_constraintBottom_toTopOf="@id/main_body"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <View
            android:id="@id/tag_bg"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/main_body"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/main_body" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/tv_offer_tag"
            android:background="@drawable/ic_special_tag"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:layout_marginBottom="@dimen/sushi_spacing_pico"
            android:textAlignment="center"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            app:drawablePadding="@dimen/sushi_spacing_micro"
            app:layout_constraintBottom_toTopOf="@id/tv_title"
            app:layout_constraintEnd_toEndOf="@id/end_guideline"
            app:layout_constraintStart_toEndOf="@id/text_barrier"
            app:layout_constraintTop_toTopOf="parent" />
        <View
            android:id="@id/main_body"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/offer"
            app:layout_constraintVertical_bias="0.0" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.image.BShapeableImageViewStub
            android:id="@id/bg_image"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/main_body"
            app:layout_constraintEnd_toEndOf="@id/main_body"
            app:layout_constraintStart_toStartOf="@id/main_body"
            app:layout_constraintTop_toTopOf="@id/main_body" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center_vertical"
            android:id="@id/left_image"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:scaleType="fitCenter"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="@id/bottom_guideline"
            app:layout_constraintEnd_toStartOf="@id/text_barrier"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@id/start_guideline"
            app:layout_constraintTop_toTopOf="@id/main_body" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:id="@id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@id/tv_left_subtitle"
            app:layout_constraintEnd_toEndOf="@id/end_guideline"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/text_barrier"
            app:layout_constraintTop_toTopOf="@id/main_body"
            app:layout_constraintVertical_chainStyle="packed"
            app:textViewType="BOLD_500" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/text_barrier"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:barrierAllowsGoneWidgets="false"
            app:barrierDirection="right"
            app:constraint_referenced_ids="left_image, start_guideline" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/start_guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_begin="@dimen/sushi_spacing_base" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/end_guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_end="@dimen/sushi_spacing_base" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="horizontal"
            android:id="@id/bottom_guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_end="@dimen/sushi_spacing_base" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:ellipsize="end"
            android:id="@id/tv_left_subtitle"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAllCaps="false"
            android:textAlignment="center"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@id/offer_flipper"
            app:layout_constraintEnd_toEndOf="@id/end_guideline"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/start_guideline"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintVertical_bias="0.0"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintWidth_default="wrap"
            app:textViewType="REGULAR_200" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/tv_subtitle"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/end_guideline"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/start_guideline"
            app:layout_constraintTop_toBottomOf="@id/offer_flipper"
            app:layout_constraintVertical_chainStyle="packed"
            app:textViewType="REGULAR_200" />
        <com.blinkit.commons.ui.ui.customviews.productCard.FlipperView
            android:id="@id/offer_flipper"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@id/tv_subtitle"
            app:layout_constraintEnd_toEndOf="@id/end_guideline"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@id/start_guideline"
            app:layout_constraintTop_toBottomOf="@id/tv_left_subtitle"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_goneMarginBottom="@dimen/sushi_spacing_base" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:gravity="center"
        android:id="@id/bottom_title"
        android:paddingLeft="@dimen/sushi_spacing_mini"
        android:paddingRight="@dimen/sushi_spacing_mini"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6.0dip"
        android:paddingHorizontal="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toTopOf="@id/bottom_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/container"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:gravity="center"
        android:id="@id/bottom_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_title"
        app:layout_constraintVertical_bias="1.0" />
</merge>