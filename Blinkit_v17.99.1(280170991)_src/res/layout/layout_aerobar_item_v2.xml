<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_gravity="center"
        android:id="@id/imageRadiusContainer"
        android:layout_width="@dimen/aerobar_imageview_radius_dimentation"
        android:layout_height="@dimen/aerobar_imageview_radius_dimentation"
        android:layout_marginTop="@dimen/padding_small"
        android:layout_marginBottom="@dimen/padding_small"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/padding_side"
        android:layout_alignParentStart="true">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center"
            android:id="@id/iv_aerobar"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="centerCrop" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:layout_gravity="center"
            android:id="@id/animated_image"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_margin="@dimen/sushi_spacing_micro"
            android:contentDescription="@null"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_repeatMode="restart" />
        <com.zomato.ui.atomiclib.atom.progress.progressView.ZProgressView
            android:layout_gravity="center"
            android:id="@id/pb_aerobar"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:indeterminate="true" />
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/container_tv_aerobar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:animateLayoutChanges="true"
        android:paddingStart="@dimen/padding_side"
        android:layout_toStartOf="@id/container_action_aerobar"
        android:layout_toEndOf="@id/imageRadiusContainer">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?android:textColorPrimary"
                android:ellipsize="end"
                android:id="@id/tv_title_aerobar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_marginEnd="@dimen/dimen_17"
                app:textViewType="SEMIBOLD_300" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_iconsize_300"
                android:id="@id/title_suffix_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/icon_font_left_triangle_small"
                android:paddingStart="@dimen/sushi_spacing_micro"
                android:layout_marginStart="@dimen/title_subtext_icon_margin" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="8.0sp"
            android:textColor="?android:textColorSecondary"
            android:ellipsize="end"
            android:id="@id/tv_subtext_aerobar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:textViewType="REGULAR_200" />
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/container_action_aerobar"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/padding_small"
        android:layout_marginBottom="@dimen/padding_small"
        android:layout_centerVertical="true"
        android:animateLayoutChanges="true"
        android:layout_marginStart="@dimen/padding_small"
        android:layout_marginEnd="@dimen/nitro_between_padding"
        android:layout_alignParentEnd="true">
        <LinearLayout
            android:gravity="center_horizontal"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:id="@id/compound_action_container"
            android:background="?themeColor500"
            android:paddingLeft="@dimen/sushi_spacing_base"
            android:paddingTop="@dimen/sushi_spacing_micro"
            android:paddingRight="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/sushi_spacing_micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_micro"
            android:stateListAnimator="@animator/scale_animator"
            android:paddingHorizontal="@dimen/sushi_spacing_base"
            android:paddingVertical="@dimen/sushi_spacing_micro">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_white"
                android:id="@id/compound_action_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:textViewType="SEMIBOLD_200" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_white"
                android:id="@id/compound_action_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:textViewType="REGULAR_100" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.snippets.FeedbackRatingBar
            android:gravity="end"
            android:layout_gravity="center_vertical"
            android:id="@id/ratingBar"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            android:layout_marginEnd="@dimen/sushi_spacing_extra" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:textStyle="bold"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_left_action_aerobar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_side"
            android:layout_marginBottom="@dimen/padding_side"
            android:layout_marginStart="@dimen/padding_side"
            android:layout_marginEnd="@dimen/padding_side"
            app:buttonColor="?accentColor"
            app:buttonDimension="small"
            app:buttonType="text" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_gravity="center_vertical"
            android:id="@id/tv_left_action_aerobar_container"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sushi_spacing_mini"
            android:paddingEnd="@dimen/sushi_spacing_micro">
            <com.zomato.ui.atomiclib.atom.ZButton
                android:layout_gravity="center_vertical"
                android:id="@id/tv_left_action_aerobar_solid"
                android:paddingLeft="@dimen/sushi_spacing_base"
                android:paddingTop="@dimen/sushi_spacing_mini"
                android:paddingRight="@dimen/sushi_spacing_base"
                android:paddingBottom="@dimen/sushi_spacing_mini"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/sushi_spacing_base"
                android:paddingVertical="@dimen/sushi_spacing_mini"
                app:buttonDimension="small"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <View
                android:id="@id/aeroShine"
                android:background="@drawable/button_shine"
                android:visibility="gone"
                android:layout_width="@dimen/size_34"
                android:layout_height="fill_parent"
                android:layout_marginTop="@dimen/menu_button_shimmer_adjust_top_padding"
                android:rotation="@integer/glow_shimmer_angle"
                android:layout_marginStart="@dimen/cart_shimmer_adjust_start_padding"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_wrapBehaviorInParent="skipped" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.zomato.ui.atomiclib.atom.IconFont
            android:textSize="@dimen/iconfont_size_small"
            android:textColor="@color/color_black"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@id/icon_left_action_aerobar"
            android:background="@drawable/uikit_aerobar_action_bg"
            android:layout_width="@dimen/aerobar_action_icon_size"
            android:layout_height="@dimen/aerobar_action_icon_size"
            android:layout_margin="@dimen/nitro_vertical_padding_4"
            android:elevation="@dimen/elevation_small"
            app:iconfont_enable_feedback="true" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:textStyle="bold"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_right_action_aerobar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_side"
            android:layout_marginBottom="@dimen/padding_side"
            android:layout_marginStart="@dimen/padding_side"
            android:layout_marginEnd="@dimen/padding_side"
            app:buttonColor="?accentColor"
            app:buttonDimension="small"
            app:buttonType="text" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/iconfont_size_small"
            android:textColor="@color/color_black"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@id/icon_right_action_aerobar"
            android:background="@drawable/uikit_aerobar_action_bg"
            android:layout_width="@dimen/aerobar_action_icon_size"
            android:layout_height="@dimen/aerobar_action_icon_size"
            android:layout_margin="@dimen/nitro_vertical_padding_4"
            android:elevation="@dimen/elevation_micro"
            app:iconfont_enable_feedback="true" />
    </LinearLayout>
</RelativeLayout>