<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/dimen_16"
    app:cardElevation="@dimen/dimen_0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/root_container"
        android:clipChildren="true"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.lib.organisms.snippets.videoSnippets.ZVideoAllControlsView1
            android:id="@id/video_all_control_view"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textStyle="bold"
            android:textColor="@color/sushi_white"
            android:layout_gravity="start"
            android:id="@id/tv_offer_tag"
            android:paddingTop="@dimen/sushi_spacing_pico"
            android:paddingBottom="@dimen/sushi_spacing_pico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:paddingStart="@dimen/sushi_spacing_nano"
            android:paddingEnd="@dimen/size_3_and_half"
            android:paddingVertical="@dimen/sushi_spacing_pico"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:textViewType="REGULAR_300" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/image"
            android:layout_width="@dimen/size_72"
            android:layout_height="@dimen/size_72"
            android:layout_marginLeft="@dimen/dimen_16"
            android:layout_marginTop="@dimen/dimen_16"
            android:layout_marginBottom="@dimen/dimen_16"
            android:layout_marginVertical="@dimen/dimen_16"
            app:cornerRadius="@dimen/radius_12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/video_all_control_view" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:ellipsize="end"
            android:gravity="start"
            android:id="@id/title"
            android:paddingRight="@dimen/dimen_16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_16"
            android:layout_marginTop="@dimen/dimen_16"
            android:layout_marginRight="@dimen/dimen_16"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2.0sp"
            android:layout_marginHorizontal="@dimen/dimen_16"
            app:layout_constrainedWidth="true"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintLeft_toRightOf="@id/image"
            app:layout_constraintRight_toRightOf="@id/root_container"
            app:layout_constraintTop_toBottomOf="@id/video_all_control_view" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:ellipsize="end"
            android:layout_gravity="start"
            android:id="@id/quantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_16"
            android:layout_marginTop="@dimen/dimen_4"
            android:layout_marginRight="@dimen/dimen_16"
            android:maxLines="1"
            android:layout_marginHorizontal="@dimen/dimen_16"
            app:layout_constrainedWidth="true"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toRightOf="@id/image"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:textViewType="REGULAR_400" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="12.0sp"
            android:textColor="@color/white"
            android:ellipsize="end"
            android:gravity="start"
            android:layout_gravity="center_vertical"
            android:id="@id/selling_price_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_16"
            android:lines="1"
            app:layout_constraintBottom_toBottomOf="@id/image"
            app:layout_constraintLeft_toRightOf="@id/image"
            app:textViewType="REGULAR_400" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="12.0sp"
            android:textColor="@color/white"
            android:ellipsize="end"
            android:id="@id/mrp_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_4"
            android:lines="1"
            app:layout_constraintBottom_toBottomOf="@id/image"
            app:layout_constraintLeft_toRightOf="@id/selling_price_txt"
            app:textViewType="REGULAR_400" />
        <com.blinkit.commons.ui.ui.customviews.stepper.Stepper
            android:id="@id/stepper"
            android:layout_width="72.0dip"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/qd_margin_2"
            android:layout_marginEnd="@dimen/dimen_16"
            app:layout_constraintBottom_toBottomOf="@id/image"
            app:layout_constraintRight_toLeftOf="@id/sold_out_text"
            app:stepper_type="SMALL" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/white"
            android:id="@id/sold_out_text"
            android:background="@drawable/qd_rounded_rectangle_corner_radius_4"
            android:paddingLeft="@dimen/dimen_10"
            android:paddingTop="@dimen/size_6"
            android:paddingRight="@dimen/dimen_10"
            android:paddingBottom="@dimen/size_6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen_16"
            android:layout_marginBottom="@dimen/dimen_16"
            android:lines="1"
            android:includeFontPadding="false"
            android:paddingHorizontal="@dimen/dimen_10"
            android:paddingVertical="@dimen/size_6"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>