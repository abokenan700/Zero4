<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/qd_white_rounded_12dp"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:padding="@dimen/padding_2"
        android:layout_width="@dimen/size_48"
        android:layout_height="@dimen/size_48"
        android:scaleType="centerInside"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/location_title" />
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:id="@id/top_left_icon"
        android:padding="@dimen/dimen_2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:translationX="@dimen/sushi_spacing_micro_negative"
        android:translationY="@dimen/sushi_spacing_micro_negative"
        app:layout_constraintStart_toStartOf="@id/left_image_container"
        app:layout_constraintTop_toTopOf="@id/left_image_container" />
    <View
        android:id="@id/left_image_container"
        android:visibility="gone"
        android:layout_width="@dimen/size_48"
        android:layout_height="@dimen/dimen_0"
        app:layout_constraintBottom_toBottomOf="@id/bottom_text"
        app:layout_constraintEnd_toEndOf="@id/left_image"
        app:layout_constraintStart_toStartOf="@id/left_image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <View
        android:id="@id/left_image_bgView"
        android:visibility="gone"
        android:layout_width="@dimen/size_47"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/left_image"
        app:layout_constraintEnd_toEndOf="@id/left_image"
        app:layout_constraintStart_toStartOf="@id/left_image"
        app:layout_constraintTop_toTopOf="@id/left_image" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/left_image"
        android:paddingTop="@dimen/size_4"
        android:paddingBottom="@dimen/size_4"
        android:layout_width="@dimen/size_47"
        android:layout_height="@dimen/size28"
        android:layout_margin="@dimen/qd_margin_0.5"
        android:scaleType="centerInside"
        android:paddingVertical="@dimen/size_4"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:id="@id/bottom_text"
        android:paddingLeft="@dimen/sushi_spacing_micro"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingRight="@dimen/sushi_spacing_micro"
        android:paddingBottom="@dimen/dimen_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/sushi_spacing_micro"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@id/left_image_container"
        app:layout_constraintEnd_toEndOf="@id/left_image_container"
        app:layout_constraintStart_toStartOf="@id/left_image_container"
        app:layout_constraintTop_toBottomOf="@id/left_image" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/location_title"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:maxLines="2"
        android:layout_marginStart="@dimen/margin_12"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintEnd_toStartOf="@id/title_label"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        app:textViewType="MEDIUM_400" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040494"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/title_label"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_marginStart="@dimen/margin_4"
        android:layout_marginEnd="@dimen/margin_8"
        app:layout_constraintBottom_toBottomOf="@id/location_title"
        app:layout_constraintEnd_toStartOf="@id/right_icon"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/location_title"
        app:layout_constraintTop_toTopOf="@id/location_title"
        app:layout_constraintWidth_default="wrap"
        app:textViewType="REGULAR_100" />
    <include
        android:gravity="center"
        android:id="@id/tag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/margin_8"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/location_title"
        app:layout_constraintEnd_toStartOf="@id/pin"
        app:layout_constraintTop_toTopOf="@id/pin"
        app:layout_goneMarginEnd="@dimen/margin_8"
        layout="@layout/qd_product_card_tag" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:textColor="?themeColor500"
        android:gravity="center"
        android:id="@id/pin"
        android:padding="@dimen/margin_12"
        android:layout_width="@dimen/size_44"
        android:layout_height="@dimen/size_44"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/location_subtitle"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f04047c"
        android:ellipsize="end"
        android:id="@id/location_subtitle"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_4"
        android:layout_marginBottom="@dimen/margin_4"
        android:maxLines="3"
        android:layout_marginStart="@dimen/margin_12"
        android:layout_marginVertical="@dimen/margin_4"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/pin"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toBottomOf="@id/location_title"
        app:layout_goneMarginEnd="@dimen/sushi_spacing_base"
        app:textViewType="REGULAR_300" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f04047c"
        android:ellipsize="end"
        android:id="@id/location_subtitle_2"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_4"
        android:layout_marginBottom="@dimen/margin_4"
        android:maxLines="3"
        android:layout_marginStart="@dimen/margin_12"
        android:layout_marginEnd="@dimen/margin_8"
        android:layout_marginVertical="@dimen/margin_4"
        app:layout_constraintEnd_toStartOf="@id/right_icon"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toBottomOf="@id/location_subtitle"
        app:textViewType="REGULAR_300" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textColor="?attr_7f0402a3"
        android:gravity="center"
        android:id="@id/first_icon"
        android:visibility="gone"
        android:layout_width="@dimen/size24"
        android:layout_height="@dimen/size24"
        android:layout_marginTop="@dimen/margin_8"
        android:layout_marginBottom="@dimen/margin_8"
        android:text="@string/icon_font_3_dot_horizontal"
        app:layout_constraintBottom_toTopOf="@id/view_stub_bottom_container"
        app:layout_constraintStart_toStartOf="@id/location_subtitle"
        app:layout_constraintTop_toBottomOf="@id/location_subtitle_2"
        app:layout_constraintVertical_bias="0.0" />
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@id/second_icon_container"
        android:visibility="gone"
        android:layout_width="@dimen/size24"
        android:layout_height="@dimen/size24"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/first_icon"
        app:layout_constraintStart_toEndOf="@id/first_icon"
        app:layout_constraintTop_toTopOf="@id/first_icon">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textColor="?attr_7f0402a3"
            android:gravity="center"
            android:id="@id/second_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.zomato.ui.atomiclib.atom.progress.progressView.ZProgressView
            android:layout_gravity="center"
            android:id="@id/second_icon_progress"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:zprogressview_custom_color="?themeColor500"
            app:zprogressview_size="MINI"
            app:zprogressview_type="circular" />
    </LinearLayout>
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:textColor="?themeColor500"
        android:gravity="center"
        android:id="@id/right_icon"
        android:layout_width="@dimen/size24"
        android:layout_height="@dimen/size24"
        android:text="@string/icon_font_3_dot_vertical"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/location_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/location_title" />
    <ViewStub
        android:id="@id/view_stub_bottom_container"
        android:layout="@layout/address_tooltip_layout"
        android:inflatedId="@id/view_stub_bottom_container"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/first_icon" />
    <Space
        android:id="@id/bottom_spacer"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_stub_bottom_container" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:id="@id/info"
        android:padding="@dimen/qd_margin_12"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_8"
        android:layout_marginBottom="2.0dip"
        android:layout_marginStart="2.0dip"
        android:layout_marginEnd="2.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_stub_bottom_container" />
</androidx.constraintlayout.widget.ConstraintLayout>