<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:stateListAnimator="@animator/scale_animator"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/iv_transaction"
        android:layout_width="@dimen/size_36"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:layout_marginEnd="@dimen/sushi_spacing_base" />
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:id="@id/tv_transaction_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/tv_transaction_subtitle"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_nano" />
            <com.zomato.ui.atomiclib.atom.ZTag
                android:ellipsize="end"
                android:id="@id/tag"
                android:paddingLeft="@dimen/sushi_spacing_micro"
                android:paddingTop="@dimen/sushi_spacing_nano"
                android:paddingRight="@dimen/sushi_spacing_micro"
                android:paddingBottom="@dimen/sushi_spacing_nano"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_nano"
                android:maxLines="1"
                android:layout_marginStart="@dimen/sushi_spacing_macro"
                android:paddingHorizontal="@dimen/sushi_spacing_micro"
                android:paddingVertical="@dimen/sushi_spacing_nano"
                app:tagSize="tiny"
                app:tagType="capsule" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_macro">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:layout_gravity="end|center"
            android:id="@id/tv_transaction_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:layout_gravity="center_vertical"
        android:id="@id/iftv_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/sushi_spacing_macro" />
</merge>