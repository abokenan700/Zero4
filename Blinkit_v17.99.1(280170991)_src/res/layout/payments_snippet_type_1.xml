<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/root"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/parent_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@id/top_container"
            android:paddingLeft="@dimen/sushi_spacing_base"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingRight="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/sushi_spacing_macro"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_base"
            android:paddingVertical="@dimen/sushi_spacing_macro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center_vertical"
                android:id="@id/top_container_left_image"
                android:visibility="gone"
                android:layout_width="@dimen/size_48"
                android:layout_height="wrap_content" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:layout_gravity="center_vertical"
                android:id="@id/top_container_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sushi_spacing_mini" />
        </LinearLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_container">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/payments_container"
                android:clipChildren="false"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/barrier2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/left_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_base" />
                <LinearLayout
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_base">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                            android:ellipsize="end"
                            android:id="@id/title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            android:lines="1"
                            android:includeFontPadding="false"
                            android:layout_marginEnd="@dimen/sushi_spacing_micro"
                            app:layout_constrainedWidth="true"
                            app:layout_constraintBottom_toTopOf="@id/subtitle"
                            app:layout_constraintEnd_toStartOf="@id/title_tag"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />
                        <com.zomato.ui.atomiclib.atom.ZTag
                            android:layout_gravity="center_vertical"
                            android:id="@id/title_tag"
                            android:paddingLeft="@dimen/sushi_spacing_micro"
                            android:paddingTop="@dimen/sushi_spacing_nano"
                            android:paddingRight="@dimen/sushi_spacing_micro"
                            android:paddingBottom="@dimen/sushi_spacing_nano"
                            android:visibility="visible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/sushi_spacing_micro"
                            android:layout_marginEnd="@dimen/sushi_spacing_base"
                            android:paddingHorizontal="@dimen/sushi_spacing_micro"
                            android:paddingVertical="@dimen/sushi_spacing_nano"
                            app:layout_constraintBottom_toBottomOf="@id/title"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintStart_toEndOf="@id/title"
                            app:layout_constraintTop_toTopOf="@id/title"
                            app:tagSize="nano" />
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                            android:ellipsize="end"
                            android:id="@id/subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/sushi_spacing_nano"
                            android:maxLines="1"
                            android:lines="1"
                            android:layout_marginEnd="@dimen/sushi_spacing_micro"
                            app:layout_constrainedWidth="true"
                            app:layout_constraintBottom_toTopOf="@id/subtitle1"
                            app:layout_constraintEnd_toStartOf="@id/subtitle_tag"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toStartOf="@id/title"
                            app:layout_constraintTop_toBottomOf="@id/title"
                            app:layout_constraintVertical_chainStyle="packed" />
                        <com.zomato.ui.atomiclib.atom.ZButton
                            android:id="@id/subtitle_button"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/sushi_spacing_nano"
                            android:layout_marginEnd="@dimen/sushi_spacing_base"
                            app:buttonType="text" />
                        <com.zomato.ui.atomiclib.atom.ZTag
                            android:id="@id/subtitle_tag"
                            android:paddingLeft="@dimen/sushi_spacing_mini"
                            android:paddingTop="@dimen/sushi_spacing_nano"
                            android:paddingRight="@dimen/sushi_spacing_mini"
                            android:paddingBottom="@dimen/sushi_spacing_nano"
                            android:visibility="visible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/sushi_spacing_micro"
                            android:layout_marginEnd="@dimen/sushi_spacing_base"
                            android:paddingHorizontal="@dimen/sushi_spacing_mini"
                            android:paddingVertical="@dimen/sushi_spacing_nano"
                            app:tagSize="nano"
                            app:tagType="capsule" />
                    </LinearLayout>
                    <LinearLayout
                        android:clipChildren="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/sushi_spacing_pico">
                        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                            android:ellipsize="end"
                            android:layout_gravity="center_vertical"
                            android:id="@id/subtitle1"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/sushi_spacing_micro"
                            android:maxLines="1"
                            android:lines="1"
                            android:layout_marginEnd="@dimen/sushi_spacing_micro"
                            app:layout_constrainedWidth="true"
                            app:layout_constraintEnd_toStartOf="@id/subtitle1_tag"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toStartOf="@id/subtitle"
                            app:layout_constraintTop_toBottomOf="@id/subtitle"
                            app:layout_constraintVertical_chainStyle="packed" />
                        <com.zomato.ui.atomiclib.atom.ZTag
                            android:ellipsize="end"
                            android:layout_gravity="center_vertical"
                            android:id="@id/subtitle1_tag"
                            android:paddingLeft="@dimen/sushi_spacing_mini"
                            android:paddingTop="@dimen/sushi_spacing_nano"
                            android:paddingRight="@dimen/sushi_spacing_mini"
                            android:paddingBottom="@dimen/sushi_spacing_nano"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/sushi_spacing_micro"
                            android:maxLines="1"
                            android:layout_marginEnd="@dimen/sushi_spacing_base"
                            android:paddingHorizontal="@dimen/sushi_spacing_mini"
                            android:paddingVertical="@dimen/sushi_spacing_nano"
                            app:layout_constraintEnd_toStartOf="@id/barrier2"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toEndOf="@id/subtitle1"
                            app:layout_constraintTop_toBottomOf="@id/subtitle"
                            app:layout_constraintVertical_chainStyle="packed"
                            app:tagSize="nano"
                            app:tagType="rounded" />
                        <com.zomato.ui.atomiclib.atom.ZTag
                            android:ellipsize="end"
                            android:layout_gravity="center_vertical"
                            android:id="@id/subtitle1_tag2"
                            android:paddingLeft="@dimen/sushi_spacing_mini"
                            android:paddingTop="@dimen/sushi_spacing_nano"
                            android:paddingRight="@dimen/sushi_spacing_mini"
                            android:paddingBottom="@dimen/sushi_spacing_nano"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/sushi_spacing_micro"
                            android:maxLines="1"
                            android:layout_marginEnd="@dimen/sushi_spacing_base"
                            android:paddingHorizontal="@dimen/sushi_spacing_mini"
                            android:paddingVertical="@dimen/sushi_spacing_nano"
                            app:layout_constraintEnd_toStartOf="@id/barrier2"
                            app:layout_constraintHorizontal_bias="0.0"
                            app:layout_constraintHorizontal_chainStyle="packed"
                            app:layout_constraintStart_toEndOf="@id/subtitle1"
                            app:layout_constraintTop_toBottomOf="@id/subtitle"
                            app:layout_constraintVertical_chainStyle="packed"
                            app:tagSize="nano"
                            app:tagType="rounded" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZSeparator
                android:id="@id/top_separator"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_extra"
                app:layout_constraintEnd_toEndOf="@id/right_icon"
                app:layout_constraintStart_toStartOf="@id/title"
                app:layout_constraintTop_toBottomOf="@id/payments_container"
                app:zseparator_type="STRAIGHT" />
            <include
                android:id="@id/check_box"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:layout_marginBottom="@dimen/sushi_spacing_micro"
                android:layout_marginEnd="@dimen/sushi_spacing_pico"
                android:layout_marginVertical="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toTopOf="@id/barrier3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/top_separator"
                app:layout_constraintTop_toBottomOf="@id/top_separator"
                app:layout_constraintVertical_bias="1.0"
                layout="@layout/payments_sticky_checkout" />
            <View
                android:id="@id/triangle_view_below"
                android:visibility="gone"
                android:layout_width="@dimen/dimen_10"
                android:layout_height="@dimen/dimen_10"
                android:layout_marginTop="@dimen/sushi_spacing_nano"
                android:translationX="@dimen/sushi_spacing_extra"
                android:translationY="@dimen/sushi_spacing_micro"
                android:rotation="45.0"
                android:layout_marginStart="@dimen/sushi_spacing_extra"
                app:layout_constraintBottom_toTopOf="@id/bottom_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/barrier3"
                app:layout_constraintVertical_chainStyle="packed" />
            <View
                android:id="@id/triangle_view_above"
                android:visibility="gone"
                android:layout_width="@dimen/dimen_10"
                android:layout_height="@dimen/dimen_10"
                android:layout_marginTop="@dimen/sushi_spacing_nano"
                android:translationX="@dimen/sushi_spacing_extra"
                android:translationY="@dimen/sushi_spacing_mini"
                android:rotation="45.0"
                android:layout_marginStart="@dimen/sushi_spacing_extra"
                android:translationZ="@dimen/sushi_spacing_nano"
                android:outlineProvider="none"
                app:layout_constraintBottom_toTopOf="@id/bottom_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/barrier3"
                app:layout_constraintVertical_chainStyle="packed" />
            <FrameLayout
                android:id="@id/bottom_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_base"
                android:layout_marginTop="@dimen/dimen_10"
                android:layout_marginRight="@dimen/sushi_spacing_base"
                android:layout_marginHorizontal="@dimen/sushi_spacing_base"
                app:layout_constraintTop_toBottomOf="@id/barrier3">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/sushi_spacing_macro">
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:id="@id/bottom_container_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false" />
                    <com.zomato.ui.atomiclib.atom.ZButton
                        android:gravity="left"
                        android:id="@id/bottom_container_button"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        app:buttonType="text" />
                </LinearLayout>
            </FrameLayout>
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_200"
                android:id="@id/right_icon"
                android:padding="@dimen/sushi_spacing_macro"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:layout_constraintBottom_toBottomOf="@id/payments_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/payments_container" />
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/right_button"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:buttonType="text"
                app:layout_constraintBottom_toBottomOf="@id/payments_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/payments_container" />
            <com.zomato.ui.atomiclib.atom.ZRadioButton
                android:id="@id/radio_button"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:layout_constraintBottom_toBottomOf="@id/payments_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/payments_container" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:id="@id/right_title"
                android:paddingTop="@dimen/sushi_spacing_macro"
                android:paddingBottom="@dimen/sushi_spacing_macro"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_micro"
                android:paddingVertical="@dimen/sushi_spacing_macro"
                app:layout_constraintBottom_toBottomOf="@id/payments_container"
                app:layout_constraintEnd_toStartOf="@id/right_icon"
                app:layout_constraintTop_toTopOf="@id/payments_container" />
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/barrier2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="left"
                app:constraint_referenced_ids="right_button,radio_button, right_icon, right_title" />
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/barrier3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="payments_container, top_separator, check_box" />
            <com.zomato.ui.atomiclib.atom.ZSeparator
                android:id="@id/separator"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_base"
                android:layout_marginTop="@dimen/sushi_spacing_extra"
                android:layout_marginRight="@dimen/sushi_spacing_base"
                android:layout_marginHorizontal="@dimen/sushi_spacing_base"
                app:layout_constraintTop_toBottomOf="@id/bottom_container"
                app:layout_goneMarginTop="@dimen/sushi_spacing_extra"
                app:zseparator_type="STRAIGHT" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>