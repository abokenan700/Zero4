<?xml version="1.0" encoding="utf-8"?>
<merge
    android:background="@color/sushi_white"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/top_image"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/size24"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:aspectRatio="4.87"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/top_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="top_image" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:visibility="gone"
        android:layout_width="@dimen/restaurant_image_small_width"
        android:layout_height="@dimen/restaurant_image_small_width"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_barrier" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/image_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierAllowsGoneWidgets="true"
        app:barrierDirection="end"
        app:constraint_referenced_ids="image" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040475"
        android:ellipsize="end"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:lineSpacingMultiplier="0.86"
        android:paddingEnd="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintStart_toEndOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/top_barrier" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_600"
        android:ellipsize="end"
        android:id="@id/subtitle1"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:paddingEnd="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintStart_toEndOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:textViewType="MEDIUM_200" />
    <FrameLayout
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintStart_toEndOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/bottom_button">
        <com.zomato.ui.lib.snippets.ZImageTagView
            android:gravity="start"
            android:layout_gravity="start"
            android:id="@id/tagView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginStart="@dimen/sushi_spacing_base"
            android:layout_marginEnd="@dimen/sushi_spacing_base" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZButton
        android:textColor="@color/sushi_grey_600"
        android:gravity="start"
        android:id="@id/bottom_button"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:buttonColor="@color/sushi_grey_600"
        app:buttonDimension="small"
        app:buttonType="text"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintStart_toEndOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/subtitle1" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/header_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="rightContainerView, subtitle1, bottom_button" />
    <HorizontalScrollView
        android:orientation="horizontal"
        android:id="@id/scrollview_subtitle"
        android:scrollbars="none"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_between"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/header_barrier">
        <com.zomato.ui.lib.snippets.ZImageWithTextView
            android:textColor="@color/sushi_grey_600"
            android:id="@id/subtitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:maxLines="1"
            app:textViewType="MEDIUM_300" />
    </HorizontalScrollView>
    <LinearLayout
        android:gravity="bottom"
        android:orientation="horizontal"
        android:id="@id/bottom_container"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_10"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintStart_toEndOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/scrollview_subtitle" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="start"
        app:constraint_referenced_ids="trailing_block_1, trailing_block_2, rightContainerView" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/rightContainerView"
        android:layout_width="@dimen/size_64"
        android:layout_height="@dimen/size_64"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintVertical_bias="0.0">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@id/topView"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_32"
            android:layout_weight="1.0">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textSize="@dimen/sushi_textsize_600"
                android:textColor="@color/sushi_white"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/topTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/sushi_spacing_nano"
                android:textAlignment="center"
                app:autoSizeMaxTextSize="@dimen/sushi_textsize_600"
                app:autoSizeMinTextSize="@dimen/sushi_textsize_100"
                app:autoSizeStepGranularity="1.0sp"
                app:autoSizeTextType="uniform"
                app:textViewType="SEMIBOLD_600" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_100"
                android:textColor="@color/sushi_white"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/titleIconView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/icon_font_star_fill"
                android:textAlignment="center"
                android:layout_marginStart="@dimen/sushi_spacing_micro"
                app:autoSizeMaxTextSize="@dimen/sushi_textsize_300"
                app:autoSizeMinTextSize="@dimen/sushi_textsize_100"
                app:autoSizeStepGranularity="1.0sp"
                app:autoSizeTextType="uniform" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@id/bottomView"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_32"
            android:layout_weight="1.0">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textSize="@dimen/sushi_textsize_300"
                android:textColor="@color/sushi_grey_800"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/topSubtitleTextView1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_pico"
                android:textAlignment="center"
                app:autoSizeMaxTextSize="@dimen/sushi_textsize_300"
                app:autoSizeMinTextSize="@dimen/sushi_textsize_100"
                app:autoSizeStepGranularity="1.0sp"
                app:autoSizeTextType="uniform"
                app:textViewType="SEMIBOLD_300" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_600"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/topSubtitleTextView2"
                android:paddingBottom="@dimen/sushi_spacing_nano"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:textAlignment="center"
                android:paddingStart="@dimen/sushi_spacing_nano"
                android:paddingEnd="@dimen/sushi_spacing_nano"
                app:autoSizeMaxTextSize="@dimen/dimen_11"
                app:autoSizeMinTextSize="@dimen/size_9"
                app:autoSizeStepGranularity="@dimen/text_size_step_increase"
                app:autoSizeTextType="uniform"
                app:textViewType="MEDIUM_100" />
        </LinearLayout>
    </LinearLayout>
    <com.zomato.ui.lib.atom.ZTrailingBlock
        android:id="@id/trailing_block_1"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:minWidth="@dimen/trailing_block_min_width"
        android:minHeight="@dimen/trailing_block_min_height"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/barrier"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.lib.atom.ZTrailingBlock
        android:id="@id/trailing_block_2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:minWidth="@dimen/trailing_block_min_width"
        android:minHeight="@dimen/trailing_block_min_height"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/barrier"
        app:layout_constraintTop_toBottomOf="@id/trailing_block_1" />
</merge>