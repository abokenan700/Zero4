<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/fab_layout"
        android:padding="@dimen/sushi_spacing_mini"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="@dimen/elevation_medium">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@id/fab_iconfont"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_pico" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_blue_500"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@id/audio_fab_button"
            android:background="@color/color_transparent"
            android:layout_width="@dimen/size_40"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_pico"
            android:layout_marginStart="@dimen/sushi_spacing_pico"
            app:textViewType="MEDIUM_100" />
    </LinearLayout>
</merge>