<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/header_section"
        android:paddingLeft="@dimen/size_8"
        android:paddingTop="@dimen/size_6"
        android:paddingRight="@dimen/size_8"
        android:paddingBottom="20.0dip"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="-14.0dip"
        android:paddingHorizontal="@dimen/size_8">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/header_left_image"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/header_text"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6.0dip" />
    </LinearLayout>
    <ViewStub
        android:layout_gravity="center"
        android:id="@id/top_tooltip_stub"
        android:layout="@layout/tooltip_type_6_layout"
        android:inflatedId="@id/top_tooltip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/root_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:id="@id/top_tag"
            android:paddingLeft="@dimen/sushi_spacing_micro"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingRight="@dimen/sushi_spacing_micro"
            android:paddingBottom="@dimen/sushi_spacing_nano"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_6"
            android:layout_marginStart="@dimen/size_6"
            android:elevation="@dimen/corner_stroke_one"
            android:paddingHorizontal="@dimen/sushi_spacing_micro"
            android:paddingVertical="@dimen/sushi_spacing_nano"
            app:layout_constraintStart_toStartOf="@id/imageContainer"
            app:layout_constraintTop_toTopOf="@id/imageContainer">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center_vertical"
                android:id="@id/tag_prefix_image"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:ellipsize="end"
                android:layout_gravity="center_vertical"
                android:id="@id/tag_text"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_marginStart="@dimen/sushi_spacing_micro" />
        </LinearLayout>
        <include
            android:id="@id/imageContainer"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4.0dip"
            android:layout_marginTop="4.0dip"
            android:layout_marginRight="4.0dip"
            android:layout_marginHorizontal="4.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            layout="@layout/layout_image_collage_three_or_less" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:textColor="@color/sushi_black"
            android:id="@id/left_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_10"
            android:layout_marginStart="12.0dip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageContainer" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:id="@id/textContentContainer"
            android:paddingTop="@dimen/dimen_4"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/left_image">
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="@color/sushi_black"
                android:id="@id/title"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:layout_marginStart="@dimen/sushi_spacing_base"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:layout_constraintEnd_toStartOf="@id/ratingSnippet"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:textViewType="LIGHT_200" />
            <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
                android:id="@id/shimmerTitle"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="@id/title"
                app:layout_constraintEnd_toEndOf="@id/title"
                app:layout_constraintStart_toStartOf="@id/title"
                app:layout_constraintTop_toTopOf="@id/title"
                style="@style/ShimmerDefaultStyle" />
            <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                android:id="@id/ratingSnippet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/title"
                app:ratedBlockDimenConfig="200" />
            <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
                android:id="@id/shimmerRatingSnippet"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="@id/ratingSnippet"
                app:layout_constraintEnd_toEndOf="@id/ratingSnippet"
                app:layout_constraintStart_toStartOf="@id/ratingSnippet"
                app:layout_constraintTop_toTopOf="@id/ratingSnippet"
                style="@style/ShimmerDefaultStyle" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/subtitle1_prefix_image"
                android:layout_width="@dimen/sushi_spacing_base"
                android:layout_height="@dimen/sushi_spacing_base"
                android:layout_marginStart="@dimen/sushi_spacing_base"
                app:layout_constraintBottom_toBottomOf="@id/subtitle1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/subtitle1" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="@color/sushi_black"
                android:id="@id/subtitle1"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:layout_marginStart="@dimen/sushi_spacing_micro"
                android:layout_marginEnd="@dimen/dimen_12"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/subtitle1_prefix_image"
                app:layout_constraintTop_toBottomOf="@id/title"
                app:textViewType="LIGHT_200" />
            <com.zomato.ui.atomiclib.atom.ZTag
                android:textColor="@color/sushi_black"
                android:gravity="start"
                android:id="@id/bottom_container_tag"
                android:paddingLeft="@dimen/dimen_12"
                android:paddingTop="@dimen/dimen_2"
                android:paddingRight="@dimen/dimen_12"
                android:paddingBottom="@dimen/dimen_2"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen_12"
                android:layout_marginTop="@dimen/dimen_4"
                android:layout_marginRight="@dimen/dimen_12"
                android:layout_marginHorizontal="@dimen/dimen_12"
                android:paddingHorizontal="@dimen/dimen_12"
                android:paddingVertical="@dimen/dimen_2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/vertical_subtitles"
                app:textViewType="LIGHT_200" />
            <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
                android:id="@id/shimmerSubtitle1"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="@id/subtitle1"
                app:layout_constraintEnd_toEndOf="@id/subtitle1"
                app:layout_constraintStart_toStartOf="@id/subtitle1"
                app:layout_constraintTop_toTopOf="@id/subtitle1"
                style="@style/ShimmerDefaultStyle" />
            <com.zomato.ui.lib.snippets.GenericSeparatorView
                android:id="@id/subtitle_separator"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/subtitle1" />
            <com.zomato.ui.lib.utils.VerticalSubtitleView
                android:textColor="@color/sushi_black"
                android:id="@id/vertical_subtitles"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12.0dip"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:layout_marginRight="12.0dip"
                android:layout_marginHorizontal="12.0dip"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/subtitle_separator"
                app:textViewType="LIGHT_200" />
            <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="@id/vertical_subtitles"
                app:layout_constraintEnd_toEndOf="@id/vertical_subtitles"
                app:layout_constraintStart_toStartOf="@id/vertical_subtitles"
                app:layout_constraintTop_toTopOf="@id/vertical_subtitles"
                style="@style/ShimmerDefaultStyle" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/left_button"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_12"
            android:layout_marginTop="@dimen/size_8"
            android:layout_marginRight="@dimen/dimen_12"
            android:layout_marginBottom="@dimen/dimen_12"
            android:layout_marginHorizontal="@dimen/dimen_12"
            app:layout_constraintBottom_toTopOf="@id/bottom_barrier"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textContentContainer" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/button"
            android:paddingLeft="@dimen/dimen_2"
            android:paddingRight="@dimen/dimen_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.0dip"
            android:layout_marginBottom="@dimen/dimen_12"
            android:layout_marginEnd="12.0dip"
            android:paddingHorizontal="@dimen/dimen_2"
            app:layout_constraintBottom_toTopOf="@id/bottom_barrier"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textContentContainer" />
        <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
            android:id="@id/shimmerButton"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/button"
            app:layout_constraintEnd_toEndOf="@id/button"
            app:layout_constraintStart_toStartOf="@id/button"
            app:layout_constraintTop_toTopOf="@id/button"
            style="@style/ShimmerDefaultStyle" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/subtitle_container"
            android:visibility="visible"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_12"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toTopOf="@id/subtitle3"
            app:layout_constraintEnd_toStartOf="@id/button"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/button"
            app:layout_constraintVertical_chainStyle="packed">
            <com.zomato.ui.atomiclib.atom.ZBgImageTagView
                android:id="@id/bg_image_tag_view"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_nano" />
            <LinearLayout
                android:visibility="visible"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <FrameLayout
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/sushi_spacing_nano">
                    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                        android:textColor="@color/sushi_black"
                        android:ellipsize="end"
                        android:id="@id/subtitle2"
                        android:layout_width="wrap_content"
                        android:layout_height="fill_parent"
                        android:maxLines="1"
                        app:textViewType="LIGHT_200" />
                    <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
                        android:id="@id/shimmerSubtitle2"
                        android:visibility="gone"
                        android:layout_width="0.0dip"
                        android:layout_height="0.0dip"
                        style="@style/ShimmerDefaultStyle" />
                </FrameLayout>
                <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                    android:textColor="@color/sushi_black"
                    android:ellipsize="end"
                    android:id="@id/subtitle4"
                    android:background="?attr_7f0403d7"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:layout_marginStart="@dimen/sushi_spacing_nano"
                    app:textViewType="LIGHT_200" />
            </LinearLayout>
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:textColor="@color/sushi_black"
            android:id="@id/subtitle3"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12.0dip"
            android:layout_marginRight="12.0dip"
            android:layout_marginHorizontal="12.0dip"
            app:layout_constraintBottom_toBottomOf="@id/button"
            app:layout_constraintEnd_toStartOf="@id/button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle_container"
            app:layout_constraintVertical_chainStyle="packed"
            app:textViewType="LIGHT_200" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/bottom_barrier"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="subtitle3, button, subtitle_container" />
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/bottom_separator"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
            app:zseparator_color="?attr_7f040297"
            app:zseparator_type="DASHED" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/subtitle5"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_macro"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bottom_separator"
            app:textViewType="REGULAR_300" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/top_icons_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginStart="@dimen/dimen_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
            android:id="@id/shimmerImage"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/imageContainer"
            app:layout_constraintEnd_toEndOf="@id/imageContainer"
            app:layout_constraintStart_toStartOf="@id/imageContainer"
            app:layout_constraintTop_toTopOf="@id/imageContainer"
            style="@style/ShimmerDefaultStyle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>