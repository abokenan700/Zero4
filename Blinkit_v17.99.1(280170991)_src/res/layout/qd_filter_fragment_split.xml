<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="?attr_7f040180"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:id="@id/title"
        android:paddingLeft="@dimen/dimen_10"
        android:paddingTop="@dimen/sushi_spacing_extra"
        android:paddingRight="@dimen/dimen_10"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/dimen_10"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@id/toolbar_shadow_view"
        android:background="@color/color_black_trans_ten"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <FrameLayout
        android:id="@id/fl_search_bar"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_shadow_view">
        <com.blinkit.commons.ui.ui.snippets.searchBar.QdSearchBar
            android:id="@id/qd_search_bar"
            android:paddingLeft="@dimen/dimen_10"
            android:paddingRight="@dimen/dimen_10"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/dimen_10"
            app:is_disabled="false" />
    </FrameLayout>
    <com.blinkit.commons.ui.ui.customviews.stickyoverlay.suboverlays.StickyHeaderContainer
        android:id="@id/sticky_header"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fl_search_bar"
        app:layout_constraintVertical_bias="0.0" />
    <FrameLayout
        android:id="@id/fl_primary"
        android:background="?attr_7f0403d7"
        android:visibility="visible"
        android:clipChildren="true"
        android:layout_width="@dimen/size_100"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/size_6"
        android:layout_marginBottom="@dimen/dimen_10"
        android:layout_marginStart="@dimen/dimen_10"
        app:layout_constraintBottom_toTopOf="@id/sticky_footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sticky_header" />
    <FrameLayout
        android:id="@id/fl_detail"
        android:tag="fl_detail"
        android:background="?attr_7f0403d7"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:clipChildren="true"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/size_6"
        android:layout_marginBottom="@dimen/dimen_10"
        android:layout_marginEnd="@dimen/dimen_10"
        app:layout_constraintBottom_toTopOf="@id/sticky_footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/fl_primary"
        app:layout_constraintTop_toBottomOf="@id/sticky_header" />
    <com.blinkit.commons.ui.ui.customviews.loadingErrorOverlay.LoadingErrorOverlay
        android:id="@id/loading_error_overlay"
        android:visibility="visible"
        android:clipChildren="true"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/size_6"
        android:layout_marginBottom="@dimen/dimen_10"
        android:layout_marginStart="@dimen/dimen_10"
        android:layout_marginEnd="@dimen/dimen_10"
        app:layout_constraintBottom_toTopOf="@id/sticky_footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sticky_header" />
    <com.blinkit.commons.ui.ui.customviews.stickyoverlay.suboverlays.StickyFooterContainer
        android:id="@id/sticky_footer"
        android:background="@color/transparent_white"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:elevation="@dimen/elevation_big"
        app:layout_constraintBottom_toBottomOf="parent" />
    <com.blinkit.commons.ui.ui.customviews.stickyoverlay.suboverlays.OverlayContainer
        android:id="@id/overlay_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:elevation="@dimen/elevation_big"
        app:layout_constraintTop_toBottomOf="@id/toolbar_shadow_view" />
</androidx.constraintlayout.widget.ConstraintLayout>