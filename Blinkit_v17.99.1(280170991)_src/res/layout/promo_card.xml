<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/container"
    android:paddingTop="@dimen/sushi_spacing_base"
    android:paddingBottom="@dimen/sushi_spacing_base"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/sushi_spacing_base"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="@dimen/size_40"
        android:layout_height="@dimen/size_40"
        android:scaleType="centerInside"
        android:layout_marginStart="@dimen/qd_margin_12"
        app:cornerRadius="@dimen/radius_8dp"
        app:layout_constraintBottom_toBottomOf="@id/header_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/header_title" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/header_title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:lines="1"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toStartOf="@id/right_button"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/header_subtitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/header_title"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/header_title"
        app:layout_constraintTop_toBottomOf="@id/header_title"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZButtonWithLoader
        android:id="@id/right_button"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/sushi_spacing_base"
        app:buttonDimension="medium"
        app:layout_constraintBottom_toBottomOf="@id/header_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/header_title"
        app:layout_constraintTop_toTopOf="@id/header_title" />
    <androidx.constraintlayout.widget.Group
        android:id="@id/partially_expanded_group"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:constraint_referenced_ids="separator_view,bullet_points_bottom_overlay,bullet_points_shown_list"
        app:layout_constraintBottom_toBottomOf="@id/bottom_button"
        app:layout_constraintEnd_toEndOf="@id/separator_view"
        app:layout_constraintStart_toStartOf="@id/separator_view"
        app:layout_constraintTop_toTopOf="@id/separator_view" />
    <com.blinkit.commons.ui.ui.customviews.zigzagview.SeparatorV2View
        android:id="@id/separator_view"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_16"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_subtitle"
        app:separator_color="@color/sushi_grey_300" />
    <ViewStub
        android:id="@id/view_stub_offer"
        android:layout="@layout/layout_view_promo_offer"
        android:inflatedId="@id/view_stub_offer"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/separator_view" />
    <com.blinkit.commons.ui.ui.customviews.collapsibleBulletPointList.CollapsibleBulletPointList
        android:gravity="left"
        android:orientation="vertical"
        android:id="@id/bullet_points_shown_list"
        android:background="?attr_7f0403d7"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toBottomOf="@id/view_stub_offer" />
    <com.blinkit.commons.ui.ui.customviews.collapsibleBulletPointList.CollapsibleBulletPointList
        android:gravity="left"
        android:orientation="vertical"
        android:id="@id/bullet_points_hidden_list"
        android:background="?attr_7f0403d7"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toBottomOf="@id/bullet_points_shown_list" />
    <View
        android:id="@id/bullet_points_bottom_overlay"
        android:background="@drawable/gradient_bottom"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_mini"
        android:layout_marginTop="@dimen/sushi_spacing_micro_negative"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintTop_toBottomOf="@id/bullet_points_hidden_list" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:gravity="center|left"
        android:id="@id/bottom_button"
        android:background="#00ffffff"
        android:paddingTop="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        android:paddingVertical="@dimen/sushi_spacing_base"
        app:buttonType="text"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toBottomOf="@id/bullet_points_bottom_overlay" />
</androidx.constraintlayout.widget.ConstraintLayout>