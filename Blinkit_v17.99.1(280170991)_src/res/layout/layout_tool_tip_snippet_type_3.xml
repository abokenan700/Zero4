<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/triangle_view_below"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_macro"
        android:layout_height="@dimen/sushi_spacing_macro"
        android:translationY="@dimen/sushi_spacing_micro"
        android:rotation="45.0"
        app:layout_constraintBottom_toTopOf="@id/container"
        app:layout_constraintVertical_chainStyle="packed" />
    <View
        android:id="@id/triangle_view_above"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_macro"
        android:layout_height="@dimen/sushi_spacing_macro"
        android:translationY="@dimen/sushi_spacing_mini"
        android:rotation="45.0"
        android:translationZ="@dimen/sushi_spacing_nano"
        android:outlineProvider="none"
        app:layout_constraintBottom_toTopOf="@id/container"
        app:layout_constraintVertical_chainStyle="packed" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/container"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:translationZ="@dimen/sushi_spacing_pico"
        android:outlineProvider="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/left_image"
            android:layout_width="@dimen/dimen_14"
            android:layout_height="@dimen/dimen_14"
            android:layout_marginTop="@dimen/dimen_10"
            android:layout_marginStart="@dimen/sushi_spacing_extra"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:textSize="@dimen/sushi_textsize_100"
            android:ellipsize="end"
            android:id="@id/container_text"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:maxLines="2"
            android:layout_marginStart="@dimen/sushi_spacing_micro"
            app:layout_constraintBottom_toTopOf="@id/container_subtitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/left_image"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_goneMarginBottom="@dimen/sushi_spacing_macro"
            app:layout_goneMarginStart="@dimen/sushi_spacing_extra"
            app:textFontWeight="medium"
            app:textViewType="MEDIUM_200" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:textSize="@dimen/sushi_textsize_100"
            android:ellipsize="end"
            android:id="@id/container_subtitle"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginBottom="@dimen/sushi_spacing_macro"
            android:maxLines="2"
            android:layout_marginStart="@dimen/sushi_spacing_micro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/left_image"
            app:layout_constraintTop_toBottomOf="@id/container_text"
            app:textFontWeight="medium"
            app:textViewType="MEDIUM_200" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>