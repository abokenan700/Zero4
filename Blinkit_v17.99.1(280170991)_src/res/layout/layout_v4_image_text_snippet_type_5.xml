<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/bg_image"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/bg_lottie"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true" />
    <FrameLayout
        android:id="@id/video_container"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/custom_thumbnail"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="2.5dip" />
    <View
        android:id="@id/top_overlay"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_femto"
        android:layout_marginBottom="@dimen/sushi_spacing_loose_negative"
        app:layout_constraintBottom_toBottomOf="@id/top_left_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ProgressBar
        android:layout_gravity="center"
        android:id="@id/buffering_icon"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:indeterminateTint="@color/sushi_white_alpha_seventy_five"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <LinearLayout
        android:gravity="center"
        android:id="@id/top_left_container"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingBottom="@dimen/sushi_spacing_nano"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:paddingStart="@dimen/sushi_spacing_micro"
        android:paddingEnd="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        android:layout_marginVertical="@dimen/sushi_spacing_extra"
        android:paddingVertical="@dimen/sushi_spacing_nano"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/top_right_container_1"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/top_left_image"
            android:visibility="gone"
            android:layout_width="@dimen/size_30"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:layout_marginBottom="@dimen/sushi_spacing_nano"
            android:scaleType="centerCrop"
            android:layout_marginEnd="@dimen/sushi_spacing_micro"
            android:layout_marginVertical="@dimen/sushi_spacing_nano" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:id="@id/top_left_animation"
            android:visibility="gone"
            android:layout_width="@dimen/size_30"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:layout_marginEnd="@dimen/sushi_spacing_micro" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:id="@id/top_left_title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginBottom="@dimen/sushi_spacing_micro"
            android:maxLines="1"
            android:layout_marginVertical="@dimen/sushi_spacing_micro"
            app:textViewType="REGULAR_200" />
    </LinearLayout>
    <FrameLayout
        android:id="@id/top_right_container_1"
        android:padding="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="@dimen/size_40"
        android:layout_height="@dimen/size_40"
        android:layout_marginLeft="@dimen/sushi_spacing_macro"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
        android:layout_marginVertical="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toStartOf="@id/top_right_container_2"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
            android:textSize="@dimen/sushi_textsize_400"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/top_right_icon"
            android:visibility="gone"
            android:layout_width="@dimen/size_28"
            android:layout_height="@dimen/size_28"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </FrameLayout>
    <FrameLayout
        android:id="@id/top_right_container_2"
        android:padding="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="@dimen/size_40"
        android:layout_height="@dimen/size_40"
        android:layout_margin="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <FrameLayout
            android:layout_gravity="end|center|top"
            android:id="@id/rightActionContainer"
            android:paddingTop="@dimen/dimen_two_point_two"
            android:visibility="gone"
            android:layout_width="@dimen/size_28"
            android:layout_height="@dimen/size_28"
            android:layout_margin="@dimen/dimen_one_point_five"
            android:translationZ="@dimen/sushi_spacing_pico">
            <com.zomato.ui.atomiclib.atom.ZButton
                android:layout_gravity="center"
                android:id="@id/rightAction"
                android:padding="@dimen/dimen_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dimen_0"
                app:buttonDimension="small"
                app:buttonType="text" />
        </FrameLayout>
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:layout_gravity="center"
            android:id="@id/top_right_lottie"
            android:visibility="gone"
            android:layout_width="@dimen/size_32"
            android:layout_height="@dimen/size_32"
            android:adjustViewBounds="true"
            app:lottie_autoPlay="false"
            app:lottie_fileName="bookmark_lottie_light.json"
            app:lottie_loop="false"
            app:lottie_repeatCount="0"
            app:lottie_repeatMode="restart" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/center_image"
        android:visibility="gone"
        android:layout_width="@dimen/size_70"
        android:layout_height="@dimen/size_70"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toTopOf="@id/center_animation"
        app:layout_constraintEnd_toEndOf="@id/center_title"
        app:layout_constraintStart_toStartOf="@id/center_title"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.35"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/center_animation"
        android:visibility="gone"
        android:layout_width="@dimen/size_70"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        app:layout_constraintBottom_toTopOf="@id/center_title"
        app:layout_constraintEnd_toEndOf="@id/center_title"
        app:layout_constraintStart_toStartOf="@id/center_title"
        app:layout_constraintTop_toBottomOf="@id/center_image"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/center_title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_extra"
        android:layout_marginRight="@dimen/sushi_spacing_extra"
        android:layout_marginHorizontal="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toTopOf="@id/center_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/center_animation"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintWidth_default="wrap"
        app:layout_goneMarginBottom="@dimen/sushi_spacing_extra"
        app:layout_goneMarginTop="@dimen/sushi_spacing_extra"
        app:textViewType="BOLD_800" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/center_subtitle"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_extra"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_marginRight="@dimen/sushi_spacing_extra"
        android:layout_marginHorizontal="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/center_title"
        app:layout_constraintWidth_default="wrap"
        app:layout_goneMarginBottom="@dimen/sushi_spacing_extra"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/center_button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        app:buttonColor="@color/sushi_white"
        app:buttonDimension="small"
        app:buttonType="outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/center_subtitle" />
    <View
        android:id="@id/title_overlay"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_femto"
        android:layout_marginTop="@dimen/sushi_spacing_loose_negative"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintEnd_toStartOf="@id/rating_snippet"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_default="wrap"
        app:layout_goneMarginBottom="@dimen/sushi_spacing_extra"
        app:textViewType="SEMIBOLD_500" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:ellipsize="end"
        android:id="@id/subtitle"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_extra"
        android:layout_marginRight="@dimen/sushi_spacing_extra"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:layout_marginHorizontal="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_default="wrap"
        app:textViewType="MEDIUM_300" />
    <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
        android:id="@id/rating_snippet"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_extra"
        android:layout_marginRight="@dimen/sushi_spacing_extra"
        android:layout_marginHorizontal="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/title"
        app:layout_constraintVertical_bias="0.0"
        app:ratedBlockDimenConfig="300"
        app:ratingType="tag_v2" />
</merge>