<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@color/color_transparent"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/outer_icon"
        android:padding="@dimen/sushi_spacing_macro"
        android:layout_width="40.0dip"
        android:layout_height="40.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/main_container"
        android:background="@drawable/qd_bottom_sheet_circular"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/dimen_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/outer_icon">
        <com.blinkit.commons.ui.ui.customviews.loadingErrorOverlay.LoadingErrorOverlay
            android:id="@id/nitro_overlay_full_screen"
            android:background="@color/color_transparent"
            android:visibility="visible"
            android:clipToPadding="false"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_marginTop="@dimen/dimen_point_five"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_tv" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:id="@id/title_tv"
            android:paddingLeft="@dimen/dimen_12"
            android:paddingTop="@dimen/dimen_16"
            android:paddingRight="@dimen/dimen_12"
            android:paddingBottom="@dimen/dimen_16"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:paddingHorizontal="@dimen/dimen_12"
            android:paddingVertical="@dimen/dimen_16"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/rv_left_widgetized"
            android:paddingTop="@dimen/dimen_12"
            android:clipToPadding="false"
            android:layout_width="@dimen/size_105"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toTopOf="@id/horizontal_separator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_tv"
            app:layout_constraintVertical_bias="0.0" />
        <View
            android:id="@id/vertical_separator"
            android:background="?attr_7f040296"
            android:layout_width="@dimen/dimen_one_point_one"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toTopOf="@id/horizontal_separator"
            app:layout_constraintStart_toEndOf="@id/rv_left_widgetized"
            app:layout_constraintTop_toBottomOf="@id/title_tv" />
        <FrameLayout
            android:id="@id/indicator_container"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/rv_main_widgetized"
            app:layout_constraintEnd_toEndOf="@id/rv_left_widgetized"
            app:layout_constraintTop_toBottomOf="@id/title_tv">
            <View
                android:id="@id/selected_indicator"
                android:visibility="gone"
                android:layout_width="@dimen/size_4"
                android:layout_height="0.0dip" />
        </FrameLayout>
        <View
            android:id="@id/bottom_separator"
            android:background="?attr_7f040296"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dimen_one_point_one"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_tv" />
        <com.blinkit.commons.ui.ui.snippets.searchBar.QdSearchBar
            android:id="@id/qd_search_bar"
            android:visibility="visible"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_12"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginRight="@dimen/dimen_12"
            android:layout_marginHorizontal="@dimen/dimen_12"
            app:is_disabled="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/rv_left_widgetized"
            app:layout_constraintTop_toBottomOf="@id/title_tv"
            app:vsb_hint="Search" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/rv_main_widgetized"
            android:clipToPadding="false"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_marginTop="@dimen/size_4"
            app:layout_constraintBottom_toTopOf="@id/horizontal_separator"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/vertical_separator"
            app:layout_constraintTop_toBottomOf="@id/qd_search_bar" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:id="@id/no_content_view"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_12"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/rv_left_widgetized"
            app:layout_constraintTop_toBottomOf="@id/qd_search_bar" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/guide_vertical_50"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            app:layout_constraintGuide_percent="0.5"
            app:layout_constraintTop_toBottomOf="parent" />
        <View
            android:id="@id/horizontal_separator"
            android:background="?attr_7f040296"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dimen_one_point_one"
            android:layout_marginBottom="@dimen/dimen_12"
            app:layout_constraintBottom_toTopOf="@id/apply_filter_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:enabled="false"
            android:textSize="@dimen/font_icon_size_18"
            android:textColor="?attr_7f0402af"
            android:id="@id/apply_filter_button"
            android:background="@drawable/all_rounded_theme_8dp"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/action_card_elevation"
            android:layout_marginBottom="@dimen/action_card_elevation"
            android:text="@string/qd_apply_button"
            android:textAllCaps="false"
            android:fontFamily="@font/okra"
            android:layout_marginStart="@dimen/circular_icon_padding_smaller"
            android:layout_marginEnd="@dimen/action_card_elevation"
            android:layout_marginVertical="@dimen/action_card_elevation"
            app:buttonColor="?attr_7f0402a9"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="@id/guide_vertical_50" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:enabled="false"
            android:textSize="@dimen/font_icon_size_18"
            android:textColor="?themeColor500"
            android:gravity="center"
            android:id="@id/clear_all_filter_button"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/action_card_elevation"
            android:layout_marginBottom="@dimen/action_card_elevation"
            android:text="@string/clear_filters"
            android:textAllCaps="false"
            android:fontFamily="@font/okra"
            android:layout_marginStart="@dimen/action_card_elevation"
            android:layout_marginEnd="@dimen/circular_icon_padding_smaller"
            android:layout_marginVertical="@dimen/action_card_elevation"
            app:buttonColor="@color/sushi_grey_050"
            app:layout_constraintBottom_toBottomOf="@id/apply_filter_button"
            app:layout_constraintEnd_toEndOf="@id/guide_vertical_50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/apply_filter_button"
            app:strokeColor="?themeColor500"
            app:strokeWidth="@dimen/border_stroke_width" />
        <com.blinkit.commons.ui.ui.customviews.loadingErrorOverlay.LoadingErrorOverlay
            android:id="@id/nitro_overlay_main"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_marginTop="@dimen/dimen_point_five"
            app:layout_constraintBottom_toTopOf="@id/guide_vertical_50"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/vertical_separator"
            app:layout_constraintTop_toBottomOf="@id/title_tv" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>