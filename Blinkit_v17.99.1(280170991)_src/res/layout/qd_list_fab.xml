<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="end|bottom|center"
        android:orientation="vertical"
        android:id="@id/layout_holder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <FrameLayout
            android:id="@id/fab_list_holder"
            android:background="@drawable/qd_list_fab_list_corner"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_extra"
            android:layout_marginEnd="@dimen/sushi_spacing_extra">
            <com.blinkit.commons.ui.ui.customviews.listfab.utils.MaxHeightRecyclerView
                android:scrollbarSize="@dimen/size_3"
                android:scrollbarThumbVertical="@drawable/qd_list_scrollbar_thumb"
                android:scrollbarAlwaysDrawVerticalTrack="true"
                android:id="@id/fab_list"
                android:scrollbars="vertical"
                android:layout_width="@dimen/qd_list_fab_list_width"
                android:layout_height="wrap_content"
                android:fadeScrollbars="false"
                android:layout_marginEnd="@dimen/sushi_spacing_nano"
                android:nestedScrollingEnabled="false"
                app:max_recycler_view_height="@dimen/qd_list_fab_list_max_height" />
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="end"
            android:id="@id/fab_button_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/fab_button"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/qd_list_fab_height"
                android:layout_margin="@dimen/sushi_spacing_extra"
                android:minWidth="@dimen/qd_list_fab_width"
                android:elevation="@dimen/elevation_medium"
                app:buttonColor="@color/sushi_grey_900"
                app:buttonDimension="large"
                app:cornerRadius="@dimen/qd_list_fab_corner_radius" />
        </FrameLayout>
    </LinearLayout>
</merge>