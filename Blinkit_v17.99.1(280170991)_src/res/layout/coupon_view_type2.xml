<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/parent_container"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.bottomClipLottieImageView.BottomClipLottieImageView
        android:id="@id/top_bg"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:scaleType="fitXY"
        android:elevation="@dimen/elevation_0.5"
        app:layout_constraintBottom_toBottomOf="@id/top_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/top_container"
        android:paddingBottom="@dimen/size_40"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginBottom="@dimen/qd_margin_2"
        android:elevation="1.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_default="wrap"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintVertical_chainStyle="packed">
        <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
            android:id="@id/iv_logo"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_marginTop="@dimen/dimen_20"
            android:translationZ="10.0dip"
            app:layout_constraintBottom_toTopOf="@id/title"
            app:layout_constraintDimensionRatio="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.4" />
        <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
            android:id="@id/title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_16"
            android:textAlignment="center"
            app:layout_constraintBottom_toTopOf="@id/subtitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_logo"
            app:layout_constraintWidth_percent="0.8" />
        <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
            android:id="@id/subtitle"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            app:layout_constraintBottom_toTopOf="@id/item_info_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintWidth_percent="0.8" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/item_info_container"
            android:paddingTop="@dimen/size_8"
            android:paddingBottom="@dimen/size_8"
            android:visibility="visible"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_2"
            android:layout_marginTop="12.0dip"
            android:layout_marginRight="@dimen/dimen_2"
            android:layout_marginHorizontal="@dimen/dimen_2"
            android:paddingVertical="@dimen/size_8"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle">
            <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
                android:gravity="center"
                android:id="@id/left_text"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/qd_margin_6"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/right_text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <View
                android:id="@id/separator"
                android:background="@color/white"
                android:layout_width="@dimen/dimen_2"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/right_text"
                app:layout_constraintStart_toEndOf="@id/left_text"
                app:layout_constraintTop_toTopOf="parent" />
            <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@id/right_text"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:layout_marginStart="@dimen/qd_margin_6"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/left_text"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.blinkit.commons.ui.ui.customviews.RevealLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@id/bottom_container"
        android:paddingLeft="@dimen/dimen_14"
        android:paddingTop="@dimen/dimen_16"
        android:paddingRight="@dimen/dimen_14"
        android:paddingBottom="@dimen/qd_padding_40"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_2"
        android:layout_marginRight="@dimen/dimen_2"
        android:layout_marginBottom="@dimen/dimen_2"
        android:alpha="0.0"
        android:paddingHorizontal="@dimen/dimen_14"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/container_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="bottom_container,top_container" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/view_more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="@dimen/elevation_1dp"
        app:layout_constraintBottom_toBottomOf="@id/background_view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
            android:textColor="@color/white"
            android:id="@id/top_center_overlay_text"
            android:paddingLeft="@dimen/dimen_12"
            android:paddingTop="4.0dip"
            android:paddingRight="@dimen/dimen_12"
            android:paddingBottom="4.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/dimen_115"
            android:paddingHorizontal="@dimen/dimen_12"
            android:paddingVertical="4.0dip"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/overlay_text_right_view"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/overlay_text_left_view"
            app:layout_constraintTop_toTopOf="parent" />
        <View
            android:id="@id/overlay_text_left_view"
            android:background="@drawable/right_curve_3"
            android:layout_width="8.0dip"
            android:layout_height="0.0dip"
            android:rotationY="180.0"
            android:layout_marginStart="4.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1"
            app:layout_constraintEnd_toStartOf="@id/top_center_overlay_text"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/top_center_overlay_text"
            app:layout_constraintVertical_bias="1.0" />
        <View
            android:id="@id/overlay_text_right_view"
            android:background="@drawable/right_curve_3"
            android:layout_width="8.0dip"
            android:layout_height="0.0dip"
            android:layout_marginEnd="4.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/top_center_overlay_text"
            app:layout_constraintTop_toTopOf="@id/top_center_overlay_text"
            app:layout_constraintVertical_bias="1.0" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <View
        android:id="@id/background_view"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/top_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</merge>