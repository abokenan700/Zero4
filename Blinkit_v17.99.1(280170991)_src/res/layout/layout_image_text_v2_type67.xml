<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/v2_67_root"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/start_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="@dimen/sushi_spacing_micro" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/end_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="@dimen/sushi_spacing_micro" />
    <com.zomato.ui.lib.organisms.snippets.viewpager2.ZViewPagerV2
        android:id="@id/viewPager"
        android:background="@color/color_transparent"
        android:clipChildren="false"
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:viewPagerType="CIRCULAR" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />
    <View
        android:id="@id/imageOverlay"
        android:background="@drawable/gradient_bottom_dark_center"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/sushi_spacing_alone_negative"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/text_container" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:gravity="center_vertical"
        android:layout_gravity="start|bottom|center"
        android:orientation="horizontal"
        android:id="@id/top_left_tag_text"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        android:paddingVertical="@dimen/sushi_spacing_micro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/top_left_image"
        android:visibility="gone"
        android:layout_width="@dimen/size24"
        android:layout_height="@dimen/size24"
        android:layout_marginTop="@dimen/dimen_14"
        android:layout_marginStart="@dimen/dimen_14"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toTopOf="parent" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/text_container"
        android:padding="@dimen/sushi_spacing_extra"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintVertical_bias="1.0">
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/title_subtitle_container"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="@color/sushi_white"
                android:gravity="bottom"
                android:id="@id/subtitle1"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_nano"
                android:includeFontPadding="false"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:textViewType="SEMIBOLD_300" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="@color/sushi_white"
                android:gravity="bottom"
                android:id="@id/title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:textViewType="BOLD_500" />
            <com.zomato.ui.lib.utils.HorizontalSubtitleView
                android:gravity="center_vertical"
                android:id="@id/horizontal_subtitle_layout"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_mini" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
            android:layout_gravity="top"
            android:id="@id/ratingSnippet"
            android:paddingLeft="@dimen/sushi_spacing_nano"
            android:paddingRight="@dimen/sushi_spacing_nano"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginBottom="@dimen/sushi_spacing_nano"
            android:paddingHorizontal="@dimen/sushi_spacing_nano"
            app:ratedBlockDimenConfig="300"
            app:ratingType="stars" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/top_right_lottie"
        android:layout_width="@dimen/size_45"
        android:layout_height="@dimen/size_45"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="false"
        app:lottie_fileName="bookmark_lottie.json"
        app:lottie_loop="false"
        app:lottie_repeatCount="0"
        app:lottie_repeatMode="restart" />
    <com.zomato.ui.atomiclib.snippets.FoldedCornerTagView
        android:id="@id/top_left_tag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_pico_negative"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:layout_gravity="start|center"
            android:id="@id/top_left_tag_tv"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingTop="@dimen/dimen_3"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/dimen_3"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            android:paddingVertical="@dimen/dimen_3" />
    </com.zomato.ui.atomiclib.snippets.FoldedCornerTagView>
    <include
        android:layout_gravity="end|center|top"
        android:id="@id/outer_right_action_container"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_page_side"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.5"
        layout="@layout/layout_res_card_action_item" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:layout_gravity="end|center|top"
        android:id="@id/top_right_tag"
        android:paddingLeft="@dimen/sushi_spacing_micro"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingRight="@dimen/sushi_spacing_micro"
        android:paddingBottom="@dimen/sushi_spacing_nano"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:paddingHorizontal="@dimen/sushi_spacing_micro"
        android:paddingVertical="@dimen/sushi_spacing_nano"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintTop_toBottomOf="@id/outer_right_action_container"
        app:tagColor="@color/sushi_black"
        app:tagSize="tiny"
        app:tagType="rounded" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@id/outer_right_action_container_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.45" />
    <com.zomato.ui.lib.organisms.snippets.viewpager2.indicator.ViewPager2OverflowIndicator
        android:id="@id/dotsRightIndicator"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:rotation="90.0"
        android:layout_marginEnd="@dimen/sushi_spacing_macro_negative"
        app:indicatorDefaultColor="@color/sushi_grey_200"
        app:indicatorSelectedColor="@color/sushi_grey_800"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintTop_toBottomOf="@id/outer_right_action_container_guideline"
        app:layout_constraintVertical_bias="0.0" />
    <LinearLayout
        android:gravity="top"
        android:orientation="vertical"
        android:id="@id/topLeftImageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_micro_negative"
        android:elevation="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/outer_right_action_container"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toTopOf="@id/outer_right_action_container">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/topImage1"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_18"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"
            app:aspectRatio="2.5" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/topImage2"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_18"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"
            app:aspectRatio="2.5" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>