<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/root_layout"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/info_layout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/edit_text_input_field"
        app:layout_constraintTop_toTopOf="@id/root_layout">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/image"
            android:layout_width="@dimen/sushi_action_item_size"
            android:layout_height="@dimen/sushi_action_item_size"
            app:layout_constraintBottom_toBottomOf="@id/info_layout"
            app:layout_constraintStart_toStartOf="@id/info_layout"
            app:layout_constraintTop_toTopOf="@id/info_layout" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:ellipsize="end"
            android:id="@id/title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:lines="1"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toTopOf="@id/subtitle1"
            app:layout_constraintEnd_toStartOf="@id/remove_file_text"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/image"
            app:layout_constraintTop_toTopOf="@id/info_layout"
            app:layout_constraintVertical_chainStyle="packed"
            app:maxLines="1" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:id="@id/subtitle1"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="@id/info_layout"
            app:layout_constraintEnd_toStartOf="@id/remove_file_text"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/title"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintVertical_chainStyle="packed" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/remove_file_text"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            app:buttonType="text"
            app:layout_constraintBottom_toBottomOf="@id/info_layout"
            app:layout_constraintEnd_toEndOf="@id/info_layout"
            app:layout_constraintTop_toTopOf="@id/info_layout" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.zomato.ui.atomiclib.molecules.ZTextInputField
        android:textColorHint="@color/sushi_grey_400"
        android:id="@id/edit_text_input_field"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:inputType="textPassword"
        android:translationZ="10.0dip"
        android:elevation="@dimen/sushi_spacing_pico"
        app:boxCornerRadiusBottomEnd="@dimen/sushi_spacing_macro"
        app:boxCornerRadiusBottomStart="@dimen/sushi_spacing_macro"
        app:boxCornerRadiusTopEnd="@dimen/sushi_spacing_macro"
        app:boxCornerRadiusTopStart="@dimen/sushi_spacing_macro"
        app:boxStrokeColor="@color/sushi_grey_500"
        app:drawablePadding="@dimen/sushi_spacing_macro"
        app:editTextType="MEDIUM_400"
        app:errorEnabled="true"
        app:hintEnabled="true"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintEnd_toEndOf="@id/root_layout"
        app:layout_constraintStart_toStartOf="@id/root_layout"
        app:layout_constraintTop_toBottomOf="@id/info_layout"
        app:maxLines="1"
        style="@style/TextInputLayoutV3" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/root_layout"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintLeft_toLeftOf="@id/root_layout"
        app:layout_constraintTop_toBottomOf="@id/edit_text_input_field"
        app:layout_constraintVertical_chainStyle="packed" />
</androidx.constraintlayout.widget.ConstraintLayout>