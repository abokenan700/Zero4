<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/videoSnippetParent"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.lib.organisms.snippets.videoSnippets.ZPlayerViewContainer
        android:id="@id/layoutVideoBase"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <View
        android:id="@id/controlsShowHideHelperView"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/controlsViewGroup"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <View
            android:id="@id/pausePlayRewindForward"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toTopOf="@id/bottomBarBackgroundView"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_900"
            android:textColor="@color/sushi_color_white"
            android:id="@id/rewindIcon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_font_rewind"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.25"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_900"
            android:textColor="@color/sushi_color_white"
            android:id="@id/forwardIcon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_font_forward"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.75"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_600"
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/exo_play"
            android:background="@drawable/bg_video_control_button"
            android:layout_width="@dimen/video_large_action_button_width"
            android:layout_height="@dimen/video_large_action_button_height"
            android:src="@android:drawable/ic_media_play"
            android:scaleType="centerInside"
            android:text="@string/icon_font_play"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_600"
            android:textColor="@color/sushi_color_white"
            android:id="@id/backButton"
            android:paddingTop="@dimen/sushi_spacing_page_side"
            android:paddingBottom="@dimen/sushi_spacing_loose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_font_back_thick"
            android:paddingStart="@dimen/sushi_spacing_page_side"
            android:paddingEnd="@dimen/sushi_spacing_loose"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/fullScreenButton"
            android:background="@drawable/bg_video_control_button"
            android:layout_width="@dimen/video_small_action_button_width"
            android:layout_height="@dimen/video_small_action_button_height"
            android:layout_marginTop="@dimen/sushi_spacing_page_side"
            android:layout_marginBottom="@dimen/sushi_spacing_macro"
            android:text="@string/icon_font_max_frame"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <View
            android:id="@id/bottomBarBackgroundView"
            android:background="@color/color_black_alpha_fifty"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="@id/muteButton" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/seekbarTime"
            android:layout_width="@dimen/sushi_action_item_size"
            android:layout_height="@dimen/video_small_action_button_height"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:textViewType="REGULAR_200" />
        <com.zomato.ui.lib.organisms.snippets.video.customViews.ZExoSeekbar
            android:gravity="center"
            android:id="@id/seekBar"
            android:layout_width="0.0dip"
            android:layout_height="@dimen/video_small_action_button_height"
            android:paddingStart="@dimen/sushi_spacing_micro"
            android:paddingEnd="@dimen/sushi_spacing_micro"
            app:actualBarHeight="@dimen/zexoseekbar_height"
            app:actualBufferedColor="@color/sushi_grey_300"
            app:actualUnplayedColor="@color/sushi_grey_600"
            app:bar_height="@dimen/zexoseekbar_height"
            app:buffered_color="@android:color/transparent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/muteButton"
            app:layout_constraintStart_toEndOf="@id/seekbarTime"
            app:played_color="@color/sushi_white"
            app:scrubber_color="@color/sushi_white"
            app:scrubber_disabled_size="@dimen/zexoseekbar_scrubber_small_size"
            app:scrubber_dragged_size="@dimen/zexoseekbar_scrubber_big_size"
            app:scrubber_enabled_size="@dimen/zexoseekbar_scrubber_small_size"
            app:unplayed_color="@android:color/transparent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/muteButton"
            android:layout_width="@dimen/video_small_action_button_width"
            android:layout_height="@dimen/video_small_action_button_height"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>