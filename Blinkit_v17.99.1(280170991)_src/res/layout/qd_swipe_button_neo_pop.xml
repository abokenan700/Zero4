<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="@dimen/neo_pop_slider_track_height"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.neopop.TiltFrameLayout
        android:id="@id/tilt_container"
        android:focusable="false"
        android:clickable="false"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/neo_pop_slider_track_height"
        android:layout_marginLeft="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_macro"
        android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:neopop_animate_on_touch="false"
        app:neopop_corner_radius="8.0dip"
        app:neopop_gravity="on_ground"
        app:neopop_is_stroked_button="true"
        app:neopop_shimmer_duration="700"
        app:neopop_shimmer_repeat_delay="700"
        app:neopop_shimmer_width="24.0dip"
        app:neopop_show_shimmer="true"
        app:neopop_stroke_color="@color/black"
        app:neopop_stroke_width="2.0dip">
        <com.blinkit.commons.ui.ui.customviews.bmediaview.BMediaView
            android:layout_gravity="bottom"
            android:id="@id/bg_media"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
            android:layout_gravity="bottom"
            android:id="@id/image_overlay"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </com.blinkit.commons.ui.ui.customviews.neopop.TiltFrameLayout>
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:gravity="start|center"
        android:id="@id/slider_track_text"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/tilt_container"
        app:layout_constraintEnd_toEndOf="@id/tilt_container"
        app:layout_constraintHorizontal_bias="0.2"
        app:layout_constraintStart_toEndOf="@id/slider"
        app:layout_constraintTop_toTopOf="@id/tilt_container" />
    <View
        android:id="@id/slider"
        android:layout_width="@dimen/neo_pop_slider_width"
        android:layout_height="@dimen/neo_pop_slider_height"
        app:layout_constraintBottom_toBottomOf="@id/tilt_container"
        app:layout_constraintStart_toStartOf="parent" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:gravity="center"
        android:id="@id/slider_text"
        android:paddingBottom="@dimen/sushi_spacing_page_side"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/slider"
        app:layout_constraintEnd_toEndOf="@id/slider"
        app:layout_constraintStart_toStartOf="@id/slider"
        app:layout_constraintTop_toTopOf="@id/slider" />
</merge>