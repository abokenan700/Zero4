<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/bg_image"
        android:background="@color/sushi_green_500"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/ticket_bg_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/size24"
        android:layout_marginRight="@dimen/size24"
        android:layout_marginHorizontal="@dimen/size24"
        app:layout_constraintBottom_toBottomOf="@id/bg_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bg_image">
        <com.zomato.ui.lib.atom.ZTicketBackground
            android:id="@id/ticket_bg"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:ticketBackgroundColor="?attr_7f0403d7"
            app:ticketBorderColor="@color/sushi_grey_200"
            app:ticketBorderWidth="@dimen/sushi_spacing_nano"
            app:ticketCornerRadius="@dimen/sushi_spacing_base"
            app:ticketCornerType="rounded"
            app:ticketDividerPadding="@dimen/dimen_2"
            app:ticketDividerWidth="@dimen/dimen_0"
            app:ticketElevation="@dimen/elevation_micro"
            app:ticketOrientation="horizontal"
            app:ticketScallopPositionPercent="50.0"
            app:ticketScallopRadius="@dimen/sushi_spacing_macro"
            app:ticketShowBorder="true" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:gravity="start"
            android:id="@id/left_container_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:maxLines="1"
            android:layout_marginStart="@dimen/size18"
            android:layout_marginEnd="@dimen/dimen_4"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toStartOf="@id/ticket_bg_guideline"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/ticket_bg"
            app:layout_constraintTop_toTopOf="@id/ticket_bg" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:gravity="start"
            android:id="@id/left_container_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_mini"
            android:layout_marginBottom="@dimen/size18"
            android:maxLines="1"
            android:layout_marginStart="@dimen/size18"
            android:layout_marginEnd="@dimen/dimen_4"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="@id/ticket_bg"
            app:layout_constraintEnd_toStartOf="@id/ticket_bg_guideline"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/ticket_bg"
            app:layout_constraintTop_toBottomOf="@id/left_container_title" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/ticket_bg_guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.5" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:id="@id/right_container_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:maxLines="1"
            android:layout_marginStart="@dimen/dimen_4"
            android:layout_marginEnd="@dimen/size18"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="@id/ticket_bg"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toEndOf="@id/ticket_bg_guideline"
            app:layout_constraintTop_toTopOf="@id/ticket_bg" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:id="@id/right_container_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_2"
            android:layout_marginBottom="@dimen/size18"
            android:maxLines="1"
            android:layout_marginStart="@dimen/dimen_4"
            android:layout_marginEnd="@dimen/size18"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="@id/ticket_bg"
            app:layout_constraintEnd_toEndOf="@id/ticket_bg"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toEndOf="@id/ticket_bg_guideline"
            app:layout_constraintTop_toBottomOf="@id/right_container_title" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>