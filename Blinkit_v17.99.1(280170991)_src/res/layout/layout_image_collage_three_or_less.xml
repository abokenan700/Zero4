<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/imageCollage"
    android:background="@drawable/bg_rounded_corner"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image1"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/image2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.7" />
    <include
        android:id="@id/leftTagImage1"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/size_8"
        app:layout_constraintBottom_toBottomOf="@id/image1"
        app:layout_constraintEnd_toEndOf="@id/image1"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/image1"
        layout="@layout/layout_image_bottom_tag" />
    <View
        android:id="@id/image1_top_gradient"
        android:background="@drawable/bg_gradient_top_bottom"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintEnd_toEndOf="@id/image1"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintStart_toStartOf="@id/image1"
        app:layout_constraintTop_toTopOf="@id/image1" />
    <View
        android:id="@id/image1_bottom_gradient"
        android:background="@drawable/bg_gradient_bottom_top"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/image1"
        app:layout_constraintEnd_toEndOf="@id/image1"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintStart_toStartOf="@id/image1" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image2"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginStart="@dimen/dimen_2"
        app:layout_constraintBottom_toTopOf="@id/image3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/image1"
        app:layout_constraintTop_toTopOf="parent" />
    <include
        android:id="@id/leftTagImage2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/size_8"
        app:layout_constraintBottom_toBottomOf="@id/image2"
        app:layout_constraintEnd_toEndOf="@id/image2"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/image2"
        layout="@layout/layout_image_bottom_tag" />
    <View
        android:id="@id/image2_top_gradient"
        android:background="@drawable/bg_gradient_top_bottom"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintEnd_toEndOf="@id/image2"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintStart_toStartOf="@id/image2"
        app:layout_constraintTop_toTopOf="@id/image2" />
    <View
        android:id="@id/image2_bottom_gradient"
        android:background="@drawable/bg_gradient_bottom_top"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/image2"
        app:layout_constraintEnd_toEndOf="@id/image2"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintStart_toStartOf="@id/image2" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image3"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/dimen_2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/image2"
        app:layout_constraintStart_toStartOf="@id/image2"
        app:layout_constraintTop_toBottomOf="@id/image2" />
    <include
        android:id="@id/leftTagImage3"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/size_8"
        app:layout_constraintBottom_toBottomOf="@id/image3"
        app:layout_constraintEnd_toEndOf="@id/image3"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/image3"
        layout="@layout/layout_image_bottom_tag" />
    <View
        android:id="@id/image3_top_gradient"
        android:background="@drawable/bg_gradient_top_bottom"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintEnd_toEndOf="@id/image3"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintStart_toStartOf="@id/image3"
        app:layout_constraintTop_toTopOf="@id/image3" />
    <View
        android:id="@id/image3_bottom_gradient"
        android:background="@drawable/bg_gradient_bottom_top"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/image3"
        app:layout_constraintEnd_toEndOf="@id/image3"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintStart_toStartOf="@id/image3" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:layout_gravity="center"
        android:id="@id/overlayText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="@id/image3"
        app:layout_constraintEnd_toEndOf="@id/image3"
        app:layout_constraintStart_toStartOf="@id/image3"
        app:layout_constraintTop_toTopOf="@id/image3" />
</androidx.constraintlayout.widget.ConstraintLayout>