<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/media_container"
    android:background="@color/sushi_black"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/size24"
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/close_icon"
        android:layout_width="@dimen/sushi_button_medium_minheight"
        android:layout_height="@dimen/sushi_button_medium_minheight"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:text="@string/icon_font_cross"
        android:layout_marginStart="@dimen/sushi_spacing_extra"
        android:layout_marginVertical="@dimen/sushi_spacing_macro" />
</LinearLayout>