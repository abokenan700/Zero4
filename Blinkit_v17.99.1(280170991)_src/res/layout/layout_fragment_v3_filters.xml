<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:id="@id/bottom_sheet_ll"
    android:background="@color/color_transparent"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/crossButtonContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_800"
            android:textColor="@color/color_white"
            android:layout_gravity="center_horizontal"
            android:id="@id/crossButton"
            android:background="@drawable/grey_circle"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingTop="@dimen/size_8"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/size_8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:text="@string/icon_font_cross"
            android:backgroundTint="@color/tokenised_slate_700"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            android:paddingVertical="@dimen/size_8" />
    </FrameLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/dataContainer"
        android:background="?attr_7f0403d7"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@id/headerContainer"
            android:visibility="visible"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_700"
                android:textColor="@color/sushi_grey_900"
                android:id="@id/arrow_back"
                android:background="?android:selectableItemBackgroundBorderless"
                android:padding="@dimen/sushi_spacing_base"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/icon_font_chevron_left" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="?attr_7f040475"
                android:id="@id/headerTitle"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_extra"
                android:layout_marginBottom="@dimen/sushi_spacing_extra"
                android:layout_weight="1.0"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                android:layout_marginVertical="@dimen/sushi_spacing_extra"
                app:textViewType="REGULAR_500" />
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/filterDialogTopRightButton"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clearAll"
                android:layout_marginEnd="@dimen/sushi_spacing_page_side"
                app:buttonColor="?themeColor500"
                app:buttonDimension="medium"
                app:buttonType="text" />
        </LinearLayout>
        <View
            android:id="@id/filterDivider1"
            android:background="@color/sushi_home_seperator_color"
            android:layout_width="0.0dip"
            android:layout_height="@dimen/sushi_spacing_pico"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerContainer"
            app:layout_constraintVertical_bias="0.0" />
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/listingContainer"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toTopOf="@id/bottomButtonBarrier"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/filterDivider1"
            app:layout_constraintVertical_bias="0.0">
            <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
                android:id="@id/sidePanelRecyclerView"
                android:background="?attr_7f040180"
                android:clipToPadding="false"
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                android:layout_weight="1.0"
                android:overScrollMode="never" />
            <View
                android:id="@id/sidePanelRvSeparator"
                android:background="@color/sushi_home_seperator_color"
                android:layout_width="@dimen/sushi_spacing_pico"
                android:layout_height="fill_parent" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
            android:id="@id/recyclerView"
            android:background="?attr_7f040180"
            android:paddingLeft="@dimen/sushi_spacing_base"
            android:paddingRight="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/size_250"
            android:clipToPadding="false"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_weight="1.0"
            android:paddingHorizontal="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toTopOf="@id/bottomButtonBarrier"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/listingContainer"
            app:layout_constraintTop_toBottomOf="@id/filterDivider1"
            app:layout_constraintVertical_bias="0.0" />
        <View
            android:id="@id/containerTouchLayer"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/recyclerView"
            app:layout_constraintEnd_toEndOf="@id/recyclerView"
            app:layout_constraintStart_toStartOf="@id/recyclerView"
            app:layout_constraintTop_toTopOf="@id/recyclerView" />
        <FrameLayout
            android:id="@id/showMoreFragmentContainer"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/sushi_spacing_femto"
            android:layout_weight="1.0"
            app:layout_constrainedHeight="true"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@id/bottomButtonBarrier"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/filterDivider1" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/bottomButtonBarrier"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:barrierDirection="top"
            app:constraint_referenced_ids="topSpace, bottomButtonBarrier" />
        <Space
            android:id="@id/topSpace"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toTopOf="@id/bottomContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <View
            android:id="@id/filterDivider2"
            android:background="@color/sushi_home_seperator_color"
            android:layout_width="0.0dip"
            android:layout_height="@dimen/sushi_spacing_pico"
            app:layout_constraintBottom_toTopOf="@id/bottomContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <LinearLayout
            android:id="@id/bottomContainer"
            android:background="?attr_7f0403d7"
            android:paddingTop="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/sushi_spacing_page_side"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@id/bottomSpace"
            app:layout_constraintVertical_bias="1.0">
            <com.zomato.ui.atomiclib.atom.ZButton
                android:layout_gravity="center"
                android:id="@id/filterDialogClearButton"
                android:visibility="visible"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_page_side"
                android:layout_marginRight="@dimen/sushi_spacing_page_side"
                android:text="@string/drawer_close"
                android:layout_weight="0.45"
                android:layout_marginHorizontal="@dimen/sushi_spacing_page_side"
                app:buttonColor="?attr_7f040490"
                app:buttonDimension="large"
                app:buttonType="text"
                app:layout_constraintBottom_toBottomOf="@id/filterDialogApplyButton"
                app:layout_constraintEnd_toStartOf="@id/midGuideline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/filterDialogApplyButton" />
            <FrameLayout
                android:layout_gravity="center"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_page_side"
                android:layout_marginRight="@dimen/sushi_spacing_page_side"
                android:layout_weight="0.55"
                android:layout_marginHorizontal="@dimen/sushi_spacing_page_side">
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:id="@id/filterDialogApplyButton"
                    android:visibility="visible"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/apply"
                    app:buttonColor="?themeColor500"
                    app:buttonDimension="large"
                    app:layout_constraintBottom_toTopOf="@id/bottomSpace"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/midGuideline" />
                <ProgressBar
                    android:layout_gravity="center"
                    android:id="@id/button_loader"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen_18"
                    android:indeterminateTint="@color/sushi_white" />
            </FrameLayout>
        </LinearLayout>
        <Space
            android:id="@id/bottomSpace"
            android:layout_width="0.0dip"
            android:layout_height="@dimen/sushi_spacing_mini"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.zomato.android.zcommons.overlay.BaseNitroOverlay
            android:id="@id/overlay"
            android:background="?attr_7f04017d"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toTopOf="@id/bottomButtonBarrier"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/recyclerView"
            app:layout_constraintTop_toBottomOf="@id/filterDivider1"
            app:overlay_size_type="RECYCLER_VIEW_ITEM_FILL" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>