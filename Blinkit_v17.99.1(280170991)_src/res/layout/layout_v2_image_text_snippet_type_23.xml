<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/rootCardContainer"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/sushi_spacing_base"
    app:cardElevation="@dimen/dimen_10"
    app:cardUseCompatPadding="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/parentContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/parentLinearContainer"
            android:padding="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/textContainer"
                android:paddingTop="@dimen/sushi_spacing_pico"
                android:paddingBottom="@dimen/sushi_spacing_micro"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:paddingEnd="@dimen/dimen_12">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.zomato.ui.lib.snippets.ZImageTagView
                        android:id="@id/dietary_tag"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_mini"
                        android:layout_marginEnd="@dimen/sushi_spacing_mini"
                        app:tagSize="large"
                        app:tagType="rounded_outline" />
                    <LinearLayout
                        android:gravity="right"
                        android:id="@id/tertiary_pill_tag_container"
                        android:padding="@dimen/corner_stroke_one"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5.5dip"
                        android:layout_marginEnd="@dimen/sushi_spacing_mini">
                        <com.zomato.ui.lib.snippets.ZImageTagView
                            android:id="@id/tertiary_pill_tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:tagSize="large"
                            app:tagType="rounded_outline" />
                    </LinearLayout>
                </LinearLayout>
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textSize="@dimen/type23_title_size"
                    android:textColor="@color/sushi_grey_900"
                    android:ellipsize="end"
                    android:id="@id/title"
                    android:paddingTop="@dimen/sushi_spacing_micro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_2"
                    android:maxLines="2"
                    app:textViewType="SEMIBOLD_400" />
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                        android:id="@id/rating"
                        android:paddingTop="@dimen/sushi_spacing_pico"
                        android:paddingBottom="@dimen/sushi_spacing_pico"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_micro"
                        android:layout_marginEnd="@dimen/sushi_spacing_micro"
                        android:paddingVertical="@dimen/sushi_spacing_pico"
                        app:starFilledColor="@color/sushi_yellow_500" />
                    <com.google.android.flexbox.FlexboxLayout
                        android:orientation="horizontal"
                        android:id="@id/textTagsContainer"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_micro"
                        android:animateLayoutChanges="true"
                        android:layout_marginEnd="@dimen/sushi_spacing_micro"
                        app:flexDirection="row"
                        app:flexWrap="wrap"
                        app:justifyContent="center"
                        app:maxLine="1" />
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_10">
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="@color/sushi_grey_900"
                        android:id="@id/subtitle1"
                        android:paddingTop="@dimen/sushi_spacing_nano"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:includeFontPadding="false"
                        android:layout_marginEnd="@dimen/sushi_spacing_mini"
                        app:textViewType="SEMIBOLD_300" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="@color/sushi_grey_700"
                        android:id="@id/subtitle2"
                        android:paddingTop="@dimen/sushi_spacing_nano"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:includeFontPadding="false"
                        android:layout_marginEnd="@dimen/sushi_spacing_mini"
                        app:textViewType="REGULAR_300" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="@color/sushi_blue_500"
                        android:id="@id/subtitle3"
                        android:paddingTop="@dimen/sushi_spacing_nano"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:includeFontPadding="false"
                        app:textViewType="MEDIUM_100" />
                </LinearLayout>
                <com.zomato.ui.atomiclib.atom.ZTruncatedTextView
                    android:textColor="@color/sushi_grey_600"
                    android:ellipsize="end"
                    android:id="@id/subtitle4"
                    android:paddingTop="@dimen/sushi_spacing_micro"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:tailText="@string/read_more_all_small"
                    app:textViewType="REGULAR_200" />
                <com.google.android.flexbox.FlexboxLayout
                    android:orientation="horizontal"
                    android:id="@id/healthy_tags_container"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_mini"
                    android:animateLayoutChanges="true"
                    app:flexDirection="row"
                    app:flexWrap="wrap"
                    app:justifyContent="flex_start"
                    app:maxLine="1" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_12"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:textViewType="MEDIUM_100" />
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@id/bottom_rating_container"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_mini"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toEndOf="@id/dietary_guideline"
                    app:layout_constraintTop_toBottomOf="@id/subtitle6">
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:id="@id/rating_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/sushi_spacing_mini"
                        app:textViewType="MEDIUM_100" />
                    <com.zomato.ui.atomiclib.snippets.ZMenuRating
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical"
                        android:id="@id/rating_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/sushi_spacing_mini"
                        app:starFilledColor="@color/sushi_yellow_500" />
                </LinearLayout>
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_mini"
                    android:maxLines="1"
                    app:textViewType="MEDIUM_100" />
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/imageContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <FrameLayout
                    android:id="@id/imageFrameContainer"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_nano">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@id/image_border"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                            android:id="@id/image"
                            android:padding="@dimen/dimen_point_five"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cornerRadius="@dimen/sushi_spacing_macro" />
                    </LinearLayout>
                </FrameLayout>
                <com.zomato.ui.atomiclib.molecules.ZStepper
                    android:layout_gravity="center"
                    android:id="@id/stepper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_micro"
                    android:layout_marginRight="@dimen/sushi_spacing_micro"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_micro"
                    app:stepper_type="NORMAL"
                    app:stepper_version="V2" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:layout_gravity="center"
                    android:id="@id/stepper_button"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_micro"
                    android:layout_marginTop="@dimen/sushi_spacing_extra_negative"
                    android:layout_marginRight="@dimen/sushi_spacing_micro"
                    android:paddingStart="@dimen/size_22"
                    android:paddingEnd="@dimen/dimen_15"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_micro" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_500"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@id/subtitle5"
                    android:paddingTop="@dimen/sushi_spacing_micro"
                    android:paddingBottom="@dimen/sushi_spacing_micro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:textAlignment="center"
                    android:paddingVertical="@dimen/sushi_spacing_micro"
                    app:textViewType="MEDIUM_100" />
                <View
                    android:id="@id/dummy_view_for_spacing"
                    android:visibility="gone"
                    android:layout_width="@dimen/sushi_spacing_femto"
                    android:layout_height="@dimen/sushi_spacing_femto" />
            </LinearLayout>
        </LinearLayout>
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="parentLinearContainer" />
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/bottom_separator"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dimen_point_five"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/barrier"
            app:layout_constraintVertical_bias="1.0"
            app:separator_color="@color/sushi_grey_200" />
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/bottom_container_separator"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/parentLinearContainer" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/bottomContainer"
            android:paddingTop="@dimen/size_8"
            android:paddingBottom="@dimen/dimen_12"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bottom_container_separator">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:ellipsize="end"
                android:id="@id/bottom_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/size_160"
                android:maxLines="1"
                android:layout_marginStart="@dimen/size_12" />
            <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                android:id="@id/bottom_rating_with_star"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/size_8"
                app:starFilledColor="@color/sushi_yellow_500" />
            <LinearLayout
                android:gravity="right"
                android:id="@id/bottom_tag_container"
                android:paddingTop="@dimen/dimen_2"
                android:paddingBottom="@dimen/dimen_2"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/size_6"
                android:layout_marginEnd="@dimen/size_40">
                <com.zomato.ui.lib.snippets.ZImageTagView
                    android:id="@id/bottom_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:tagSize="medium"
                    app:tagType="rounded_outline" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:gravity="right"
                android:id="@id/bottom_tag_button"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:gravity="right"
                android:layout_gravity="center_vertical"
                android:id="@id/bottom_tag_button_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/size_4"
                android:layout_marginEnd="@dimen/dimen_20" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>