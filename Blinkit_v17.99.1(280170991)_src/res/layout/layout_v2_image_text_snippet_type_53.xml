<?xml version="1.0" encoding="utf-8"?>
<merge
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/tiltedView"
        android:background="@color/sushi_blue_400"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:rotation="4.0" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/root"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/bgImage"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:id="@id/bgLottieView"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <View
            android:id="@id/tag_triangle_view"
            android:background="@drawable/bg_image_red_tag_triangle"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_macro"
            android:layout_height="@dimen/sushi_spacing_mini"
            android:translationX="@dimen/sushi_spacing_pico_negative"
            android:translationY="@dimen/size_7_negative"
            android:backgroundTint="?themeColor800"
            app:layout_constraintStart_toEndOf="@id/rightTag"
            app:layout_constraintTop_toTopOf="@id/rightTag" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@id/leftContainer"
            android:paddingTop="@dimen/dimen_16"
            android:paddingRight="@dimen/size_6"
            android:paddingBottom="@dimen/dimen_16"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/barrier"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0">
            <com.zomato.ui.lib.snippets.ZImageTagView
                android:textColor="@color/sushi_white"
                android:gravity="center|left"
                android:id="@id/leftTag"
                android:background="?themeColor500"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/size_8"
                android:minWidth="@dimen/size_114"
                app:tagSize="small" />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:id="@id/title_left_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/sushi_spacing_nano" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textSize="@dimen/sushi_textsize_100"
                    android:textColor="@color/sushi_green_900"
                    android:id="@id/title"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:fontFamily="@font/okra_semibold"
                    app:autoSizeMaxTextSize="@dimen/sushi_textsize_100"
                    app:autoSizeMinTextSize="@dimen/sushi_textsize_050"
                    app:autoSizeStepGranularity="2.0sp" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textSize="@dimen/sushi_textsize_200"
                android:textColor="@color/sushi_grey_800"
                android:id="@id/subtitle3"
                android:paddingTop="@dimen/sushi_spacing_nano"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:drawablePadding="@dimen/size_4"
                android:fontFamily="@font/okra_medium"
                app:autoSizeMaxTextSize="@dimen/sushi_textsize_200"
                app:autoSizeMinTextSize="@dimen/sushi_textsize_050"
                app:autoSizeStepGranularity="2.0sp"
                app:autoSizeTextType="uniform" />
            <FrameLayout
                android:id="@id/subtitle_container"
                android:paddingTop="@dimen/spacing_between_2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textSize="@dimen/sushi_textsize_800"
                    android:textColor="?themeColor500"
                    android:id="@id/subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:fontFamily="@font/okra_bold"
                    app:autoSizeMaxTextSize="@dimen/sushi_textsize_800"
                    app:autoSizeMinTextSize="@dimen/sushi_textsize_100"
                    app:autoSizeStepGranularity="2.0sp" />
            </FrameLayout>
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textSize="@dimen/sushi_textsize_200"
                android:textColor="@color/sushi_grey_800"
                android:id="@id/subtitle2"
                android:paddingTop="@dimen/sushi_spacing_micro"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:drawablePadding="@dimen/size_4"
                android:fontFamily="@font/okra_medium"
                app:autoSizeMaxTextSize="@dimen/sushi_textsize_200"
                app:autoSizeMinTextSize="@dimen/sushi_textsize_050"
                app:autoSizeStepGranularity="2.0sp"
                app:autoSizeTextType="uniform" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/buttontext"
                android:padding="@dimen/sushi_spacing_macro"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_12" />
        </LinearLayout>
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="start"
            app:constraint_referenced_ids="image, lottieView" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/image"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/size_154"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:id="@id/lottieView"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.lib.snippets.ZImageTagView
            android:textColor="@color/sushi_white"
            android:gravity="center|left"
            android:id="@id/rightTag"
            android:background="?themeColor500"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/size_114"
            android:translationY="@dimen/sushi_spacing_macro_negative"
            android:layout_marginEnd="@dimen/dimen_18"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tagSize="small" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>