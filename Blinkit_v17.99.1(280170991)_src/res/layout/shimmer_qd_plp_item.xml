<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_image"
        android:layout_width="@dimen/size_120"
        android:layout_height="@dimen/size_120"
        app:layout_constraintBottom_toTopOf="@id/shimmer_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:shimmer_corner_radius="12.0dip" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_title"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/dimen_10"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/shimmer_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shimmer_image"
        app:layout_constraintVertical_weight="1.0"
        app:layout_constraintWidth_percent="0.7" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_subtitle"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/dimen_10"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shimmer_title"
        app:layout_constraintVertical_weight="1.0"
        app:layout_constraintWidth_percent="0.5" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/button3"
        android:layout_width="@dimen/size_72"
        android:layout_height="@dimen/size_26"
        android:layout_marginEnd="16.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button4" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/button4"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/size_8"
        android:layout_marginTop="@dimen/size_26"
        android:layout_marginEnd="@dimen/size_12"
        app:layout_constraintEnd_toStartOf="@id/button3"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shimmer_subtitle" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/button5"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/size_8"
        android:layout_marginTop="@dimen/size_8"
        android:layout_marginEnd="@dimen/size_26"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/button3"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button4" />
</androidx.constraintlayout.widget.ConstraintLayout>