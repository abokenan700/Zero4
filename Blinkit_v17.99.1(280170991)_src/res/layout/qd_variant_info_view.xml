<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:textColor="@color/sushi_grey_700"
        android:ellipsize="end"
        android:layout_gravity="start"
        android:id="@id/tv_variant_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lines="1"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/sushi_spacing_nano"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/variant_iv_3"
        app:layout_constraintTop_toTopOf="parent"
        app:textViewType="REGULAR_100" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/variant_iv_1"
        android:visibility="visible"
        android:layout_width="8.0dip"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/tv_variant_type"
        app:layout_constraintEnd_toStartOf="@id/variant_iv_2"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_variant_type" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/variant_iv_2"
        android:visibility="visible"
        android:layout_width="8.0dip"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/tv_variant_type"
        app:layout_constraintEnd_toStartOf="@id/variant_iv_3"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/variant_iv_1"
        app:layout_constraintTop_toTopOf="@id/tv_variant_type" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/variant_iv_3"
        android:visibility="visible"
        android:layout_width="8.0dip"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/tv_variant_type"
        app:layout_constraintEnd_toStartOf="@id/tv_variant_type"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/variant_iv_2"
        app:layout_constraintTop_toTopOf="@id/tv_variant_type" />
</merge>