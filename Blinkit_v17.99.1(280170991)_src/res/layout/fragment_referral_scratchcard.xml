<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/layoutPreferences"
    android:fitsSystemWindows="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@id/coordinatorLayout"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toTopOf="@id/bottomBtn"
        app:layout_constraintTop_toTopOf="parent">
        <com.google.android.material.appbar.AppBarLayout
            android:id="@id/restaurantAppBarLayout"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:elevation="0.0dip">
            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@id/collapsingLayout"
                android:fitsSystemWindows="true"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:layout_scrollFlags="scroll|exitUntilCollapsed">
                <FrameLayout
                    android:id="@id/header_parent"
                    android:fitsSystemWindows="true"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.6">
                    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                        android:id="@id/image"
                        android:layout_width="fill_parent"
                        android:layout_height="@dimen/size_200"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <LinearLayout
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:paddingBottom="@dimen/sushi_spacing_page_side"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="@dimen/sushi_spacing_page_side">
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="@color/sushi_white"
                            android:gravity="bottom"
                            android:layout_gravity="bottom"
                            android:id="@id/card_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:textViewType="SEMIBOLD_900" />
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="@color/sushi_white"
                            android:gravity="bottom"
                            android:layout_gravity="bottom"
                            android:id="@id/subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/sushi_spacing_micro"
                            app:textViewType="REGULAR_300" />
                        <com.zomato.ui.atomiclib.atom.ZButton
                            android:id="@id/button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/sushi_spacing_macro"
                            app:buttonColor="?themeColor500"
                            app:buttonType="text" />
                    </LinearLayout>
                </FrameLayout>
                <androidx.appcompat.widget.Toolbar
                    android:id="@id/toolbar_restaurant"
                    android:background="@color/color_transparent"
                    android:fitsSystemWindows="true"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/toolbar_height_restaurant"
                    android:paddingStart="0.0dip"
                    android:paddingEnd="0.0dip"
                    app:contentInsetLeft="0.0dip"
                    app:contentInsetStart="0.0dip"
                    app:layout_collapseMode="pin"
                    app:left_icon_type="TYPE_LEFT_ARROW">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@id/toolbar_container"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent">
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textSize="18.0sp"
                            android:textColor="?attr_7f040475"
                            android:ellipsize="end"
                            android:gravity="center_vertical"
                            android:id="@id/restaurantName"
                            android:visibility="visible"
                            android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/size18"
                            android:maxLines="1"
                            android:layout_marginStart="@dimen/dimen_10"
                            android:layout_marginEnd="@dimen/sushi_spacing_page_side"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/toolbar_arrow_back"
                            app:layout_constraintTop_toTopOf="parent"
                            app:textViewType="REGULAR_600" />
                        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                            android:textSize="@dimen/toolbar_back_icon_size"
                            android:textColor="@color/color_white"
                            android:gravity="center_vertical"
                            android:id="@id/toolbar_arrow_back"
                            android:padding="@dimen/nitro_side_padding"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="0.0dip"
                            android:text="@string/icon_font_back"
                            app:iconfont_enable_feedback="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                            android:textSize="@dimen/toolbar_back_icon_size"
                            android:textColor="@color/color_white"
                            android:gravity="center_vertical"
                            android:id="@id/rightIcon"
                            android:padding="@dimen/nitro_side_padding"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="0.0dip"
                            app:iconfont_enable_feedback="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.appcompat.widget.Toolbar>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
            android:id="@id/contentRecyclerView"
            android:background="?attr_7f04017d"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />
        <ViewStub
            android:id="@id/stickyHeaderStub"
            android:visibility="gone"
            android:inflatedId="@id/stickyHeader"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_75"
            android:layout_marginTop="@dimen/toolbar_height_restaurant"
            android:animateLayoutChanges="true" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <com.zomato.android.zcommons.overlay.BaseNitroOverlay
        android:id="@id/referralFragmentNitroOverlay"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:gravity="center"
        android:layout_gravity="bottom"
        android:id="@id/bottomBtn"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/coordinatorLayout" />
</androidx.constraintlayout.widget.ConstraintLayout>