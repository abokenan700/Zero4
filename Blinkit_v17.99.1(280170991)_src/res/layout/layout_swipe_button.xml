<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="fill_parent"
    android:layout_height="@dimen/size_54"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/swipe_button_background"
        android:background="?themeColor400"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="#ffffffff"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/swipe_text"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:textViewType="MEDIUM_500" />
    <View
        android:id="@id/overlay_view"
        android:background="@color/sushi_white"
        android:layout_width="0.0dip"
        android:layout_height="fill_parent" />
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_gravity="center_vertical"
        android:id="@id/icon"
        android:padding="@dimen/sushi_spacing_page_side"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/size_36"
        android:scaleType="fitXY"
        android:layout_marginStart="@dimen/size_32"
        app:srcCompat="@drawable/ic_swipe_right_arrow" />
</FrameLayout>