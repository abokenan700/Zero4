<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:layout_gravity="center_vertical"
    android:orientation="horizontal"
    android:id="@id/badge_body"
    android:background="@drawable/qd_grey_white_rounded_gradient"
    android:paddingLeft="@dimen/sushi_spacing_micro"
    android:paddingTop="@dimen/sushi_spacing_nano"
    android:paddingRight="@dimen/sushi_spacing_micro"
    android:paddingBottom="@dimen/sushi_spacing_nano"
    android:layout_width="wrap_content"
    android:layout_height="fill_parent"
    android:paddingHorizontal="@dimen/sushi_spacing_micro"
    android:paddingVertical="@dimen/sushi_spacing_nano"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/image"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/badge_image"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_macro"
        android:layout_height="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_nano" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:textColor="@color/sushi_black"
        android:ellipsize="end"
        android:gravity="start|center"
        android:id="@id/badge_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
</LinearLayout>