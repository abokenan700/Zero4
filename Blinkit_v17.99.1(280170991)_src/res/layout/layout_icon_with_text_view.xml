<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="top"
    android:layout_gravity="top"
    android:orientation="horizontal"
    android:id="@id/container"
    android:paddingTop="@dimen/sushi_spacing_mini"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:gravity="top"
        android:layout_gravity="top"
        android:id="@id/icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_pico_negative" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/sushi_spacing_mini" />
</LinearLayout>