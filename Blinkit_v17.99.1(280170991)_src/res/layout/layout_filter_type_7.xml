<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="horizontal"
    android:id="@id/checkbox_parent"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:layout_gravity="center_vertical"
        android:id="@id/checkbox_tile"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:layout_marginStart="@dimen/sushi_spacing_extra" />
    <com.zomato.ui.atomiclib.atom.ZCheckBox
        android:textSize="@dimen/sushi_textsize_400"
        android:layout_gravity="center_vertical"
        android:id="@id/checkbox_right"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="false"
        android:layout_marginEnd="@dimen/sushi_spacing_micro" />
</merge>