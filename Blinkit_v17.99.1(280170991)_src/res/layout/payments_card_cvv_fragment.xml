<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/banner"
        android:padding="@dimen/sushi_spacing_base"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_700"
            android:layout_gravity="center_vertical"
            android:id="@id/banner_icon"
            android:layout_width="@dimen/size_24"
            android:layout_height="@dimen/size_24" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_200"
            android:textColor="?attr_7f04048a"
            android:layout_gravity="center_vertical"
            android:id="@id/banner_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/okra_medium"
            android:layout_marginStart="@dimen/dimen_10" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/page_desc"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_36"
        android:textAlignment="center"
        android:paddingStart="@dimen/size_20"
        android:paddingEnd="@dimen/size_20" />
    <payments.zomato.paymentkit.ui.atoms.PaymentsOtpEditText
        android:gravity="center"
        android:id="@id/enter_cvv"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_40"
        android:inputType="number"
        android:layout_marginStart="@dimen/dimen_15"
        android:layout_marginEnd="@dimen/dimen_10"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:layout_gravity="center_horizontal"
        android:id="@id/what_is_cvv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_15" />
    <LinearLayout
        android:layout_gravity="bottom|center"
        android:orientation="horizontal"
        android:id="@id/bottom_container"
        android:paddingTop="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/size_40"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:paddingStart="@dimen/dimen_10"
        android:paddingEnd="@dimen/sushi_spacing_extra"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        android:paddingVertical="@dimen/sushi_spacing_base">
        <com.zomato.ui.atomiclib.atom.ZCheckBox
            android:id="@id/bottom_container_checkbox"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_3_negative" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/bottom_container_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/bottom_container_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_200"
        android:textColor="?attr_7f040496"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/consent_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:fontFamily="@font/okra_medium"
        android:textAlignment="center" />
    <com.zomato.ui.atomiclib.atom.ZButtonWithLoader
        android:id="@id/submit"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_20"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:text="@string/payments_proceed"
        android:paddingStart="@dimen/sushi_spacing_base"
        android:paddingEnd="@dimen/sushi_spacing_base" />
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@id/saveCardCheckBoxll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base">
        <com.zomato.ui.atomiclib.atom.ZCheckBox
            android:textSize="@dimen/sushi_textsize_100"
            android:textColor="?attr_7f040490"
            android:gravity="center_vertical"
            android:id="@id/save_card_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/okra_regular" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:textColor="?attr_7f040490"
            android:gravity="center_vertical"
            android:id="@id/save_card_checkbox_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_4"
            app:textViewType="REGULAR_100" />
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_textsize_200"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_base">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_300"
            android:textColor="?attr_7f04048d"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/proceedWithoutSecuring"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/okra_medium"
            app:buttonDimension="small"
            app:buttonType="text" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:layout_gravity="center"
            android:id="@id/proceedWithoutSecuringIcon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_nano"
            android:text="@string/icon_font_left_triangle_small" />
    </LinearLayout>
    <Space
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_0"
        android:layout_weight="1.0" />
</LinearLayout>