<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@id/root_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <include
        android:id="@id/type_4_shimmer"
        android:visibility="gone"
        layout="@layout/content_type_4_shimmer" />
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@id/retryContainer"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:id="@id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:textViewType="SEMIBOLD_400" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/retryButton"
            android:paddingBottom="@dimen/size_12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_12"
            android:text="@string/data_kit_try_again"
            app:buttonDimension="medium"
            app:buttonType="text" />
    </LinearLayout>
    <com.zomato.android.zcommons.zStories.ViewPagerCustomDuration
        android:id="@id/storiesContainer"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:behavior_hideable="true"
        app:layout_behavior="com.zomato.ui.lib.data.bottomsheet.behaviour.ViewPagerBottomSheetBehavior" />
    <androidx.viewpager2.widget.ViewPager2
        android:orientation="vertical"
        android:id="@id/view_pager_2"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:id="@id/bottom_swipe_up_layout"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_400"
            android:textColor="?attr_7f040475"
            android:id="@id/swipe_up_icon"
            android:padding="@dimen/sushi_spacing_micro"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_font_cross_large"
            app:iconfont_enable_feedback="true" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_500"
            android:textColor="?attr_7f040475"
            android:id="@id/swipe_up_text"
            android:padding="@dimen/sushi_spacing_micro"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:text="Swipe up for more" />
    </LinearLayout>
    <FrameLayout
        android:id="@id/fl_top_container"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/size_90">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="bottom|center"
            android:id="@id/top_image"
            android:visibility="gone"
            android:layout_width="@dimen/size_100"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/sushi_spacing_micro"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_500"
            android:textColor="@color/sushi_white"
            android:layout_gravity="bottom|center|right"
            android:id="@id/top_right_icon"
            android:padding="@dimen/size_8"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/size_6"
            android:text="@string/icon_font_cross_large"
            android:layout_marginEnd="@dimen/size_12"
            app:iconfont_enable_feedback="true" />
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>