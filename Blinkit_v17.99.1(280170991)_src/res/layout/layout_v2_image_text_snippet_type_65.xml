<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:clipChildren="true"
    android:clipToPadding="true"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/image_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/media_container_image"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:paddingLeft="@dimen/size_6"
            android:paddingTop="@dimen/dimen_2"
            android:paddingRight="@dimen/size_6"
            android:paddingBottom="@dimen/dimen_2"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_8"
            android:layout_marginStart="@dimen/size_8"
            android:paddingHorizontal="@dimen/size_6"
            android:paddingVertical="@dimen/dimen_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center_vertical"
                android:id="@id/top_leading_tag_prefix_image"
                android:visibility="gone"
                android:layout_width="@dimen/dimen_12"
                android:layout_height="@dimen/dimen_12"
                android:scaleType="centerCrop" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:ellipsize="end"
                android:layout_gravity="center_vertical"
                android:id="@id/top_leading_tag_text"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_marginStart="@dimen/sushi_spacing_micro" />
        </LinearLayout>
        <com.zomato.ui.lib.snippets.ZImageTagView
            android:id="@id/top_leading_tag"
            android:paddingLeft="@dimen/size_6"
            android:paddingTop="@dimen/dimen_2"
            android:paddingRight="@dimen/size_6"
            android:paddingBottom="@dimen/dimen_2"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_8"
            android:layout_marginStart="@dimen/size_8"
            android:paddingHorizontal="@dimen/size_6"
            android:paddingVertical="@dimen/dimen_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tagColor="@color/sushi_black"
            app:tagSize="nano"
            app:tagType="rounded" />
        <com.zomato.ui.lib.snippets.ZImageTagView
            android:id="@id/top_end_tag"
            android:paddingLeft="@dimen/sushi_spacing_micro"
            android:paddingRight="@dimen/sushi_spacing_micro"
            android:paddingBottom="@dimen/sushi_spacing_pico"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tagColor="@color/sushi_black"
            app:tagSize="nano"
            app:tagType="rounded" />
        <com.zomato.ui.lib.snippets.ZImageTagView
            android:id="@id/bottom_right_tag"
            android:paddingLeft="@dimen/sushi_spacing_mini"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingRight="@dimen/sushi_spacing_mini"
            android:paddingBottom="@dimen/sushi_spacing_nano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_macro"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            android:paddingHorizontal="@dimen/sushi_spacing_mini"
            android:paddingVertical="@dimen/sushi_spacing_nano"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tagColor="@color/sushi_white"
            app:tagSize="tiny"
            app:tagType="rounded" />
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:id="@id/bottom_container_tag"
            android:paddingLeft="@dimen/dimen_4"
            android:paddingTop="@dimen/dimen_2"
            android:paddingRight="@dimen/dimen_4"
            android:paddingBottom="@dimen/dimen_2"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/size_8"
            android:layout_marginStart="@dimen/size_8"
            android:paddingHorizontal="@dimen/dimen_4"
            android:paddingVertical="@dimen/dimen_2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center_vertical"
                android:id="@id/bottom_container_tag_prefix_image"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:ellipsize="end"
                android:layout_gravity="center_vertical"
                android:id="@id/bottom_container_tag_text"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_marginStart="@dimen/sushi_spacing_micro" />
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:visibility="gone"
            android:clipChildren="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/bottom_right_tag"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent">
            <com.zomato.ui.lib.organisms.snippets.rescards.imagebottomcontainer.ImageBottomContainerView
                android:id="@id/bottomContainer1"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_macro" />
            <com.zomato.ui.lib.organisms.snippets.rescards.imagebottomcontainer.ImageBottomContainerView
                android:id="@id/bottomContainer2"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_macro" />
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/image_bottom_left_item_container"
                android:visibility="gone"
                android:clipChildren="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_macro"
                android:layout_marginEnd="@dimen/sushi_spacing_macro" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/text_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@id/top_text_container"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_macro">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_900"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:id="@id/top_container_title"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginEnd="@dimen/sushi_spacing_macro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/top_container_rating"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                android:id="@id/top_container_rating"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:ratedBlockDimenConfig="300"
                app:ratingType="block" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/top_container_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/size_8"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            app:buttonDimension="medium"
            app:buttonType="text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/top_text_container"
            app:layout_constraintTop_toBottomOf="parent" />
        <View
            android:id="@id/separator1"
            android:background="@color/sushi_grey_100"
            android:layout_width="fill_parent"
            android:layout_height="1.0dip"
            android:layout_marginLeft="@dimen/sushi_spacing_macro"
            android:layout_marginRight="@dimen/sushi_spacing_macro"
            android:layout_marginBottom="@dimen/sushi_spacing_micro"
            android:layout_marginHorizontal="@dimen/sushi_spacing_macro" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/info_items_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <include
                android:id="@id/first_cart_item"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_macro"
                android:layout_marginTop="@dimen/sushi_spacing_mini"
                android:layout_marginRight="@dimen/sushi_spacing_macro"
                android:layout_marginBottom="@dimen/sushi_spacing_mini"
                android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
                android:layout_marginVertical="@dimen/sushi_spacing_mini"
                layout="@layout/layout_v2_image_text_snippet_type_65_info_items" />
            <include
                android:id="@id/second_cart_item"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_macro"
                android:layout_marginTop="@dimen/sushi_spacing_mini"
                android:layout_marginRight="@dimen/sushi_spacing_macro"
                android:layout_marginBottom="@dimen/sushi_spacing_mini"
                android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
                android:layout_marginVertical="@dimen/sushi_spacing_mini"
                layout="@layout/layout_v2_image_text_snippet_type_65_info_items" />
            <include
                android:id="@id/know_more_button"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_macro"
                android:layout_marginTop="@dimen/sushi_spacing_mini"
                android:layout_marginRight="@dimen/sushi_spacing_macro"
                android:layout_marginBottom="@dimen/sushi_spacing_mini"
                android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
                android:layout_marginVertical="@dimen/sushi_spacing_mini"
                layout="@layout/layout_v2_image_text_snippet_type_65_info_items" />
        </LinearLayout>
        <View
            android:id="@id/separator2"
            android:background="@color/sushi_grey_100"
            android:layout_width="fill_parent"
            android:layout_height="1.0dip"
            android:layout_marginLeft="@dimen/sushi_spacing_macro"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginRight="@dimen/sushi_spacing_macro"
            android:layout_marginHorizontal="@dimen/sushi_spacing_macro" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_macro">
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/bottom_container_ll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_900"
                    android:id="@id/bottom_container_subtitle2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_900"
                    android:id="@id/bottom_container_title1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/bottom_container_subtitle2" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_900"
                android:gravity="bottom"
                android:id="@id/bottom_container_subtitle1"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:lines="1"
                android:paddingEnd="@dimen/sushi_spacing_micro"
                android:layout_marginStart="@dimen/sushi_spacing_micro"
                app:autoSizeMaxTextSize="@dimen/sushi_textsize_200"
                app:autoSizeMinTextSize="@dimen/text_size_5"
                app:autoSizeStepGranularity="1.0sp"
                app:autoSizeTextType="uniform"
                app:layout_constraintBottom_toBottomOf="@id/bottom_container_button"
                app:layout_constraintEnd_toStartOf="@id/bottom_container_button"
                app:layout_constraintStart_toEndOf="@id/bottom_container_ll" />
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/bottom_container_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_10"
                android:layout_marginBottom="@dimen/dimen_10"
                android:layout_marginVertical="@dimen/dimen_10"
                app:buttonDimension="medium"
                app:buttonType="solid"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</merge>