<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:paddingLeft="@dimen/qd_padding_16"
    android:paddingRight="@dimen/qd_padding_16"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:paddingHorizontal="@dimen/qd_padding_16"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <ImageView
        android:layout_gravity="center_horizontal"
        android:id="@id/feature_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qd_margin_24" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:layout_gravity="center_horizontal"
        android:id="@id/feature_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qd_margin_10" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/feature_details"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qd_margin_16" />
</LinearLayout>