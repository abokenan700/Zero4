<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/dimen_20"
        app:layout_constraintEnd_toStartOf="@id/right_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_goneMarginEnd="@dimen/sushi_spacing_base" />
    <ViewStub
        android:id="@id/rating_stub"
        android:visibility="gone"
        android:layout="@layout/layout_rating_snippet"
        android:inflatedId="@id/rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:ratedBlockDimenConfig="300"
        app:ratingType="tag_v3" />
    <com.zomato.ui.lib.utils.HorizontalSubtitleView
        android:gravity="center_vertical"
        android:id="@id/horizontal_subtitle_layout"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/rating"
        app:layout_constraintStart_toEndOf="@id/rating"
        app:layout_constraintTop_toTopOf="@id/rating" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
        android:gravity="center"
        android:id="@id/right_icon"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/bottom_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:barrierMargin="@dimen/dimen_20"
        app:constraint_referenced_ids="title, horizontal_subtitle_layout, right_icon, rating" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/parent_ll"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier">
        <LinearLayout
            android:gravity="top"
            android:orientation="horizontal"
            android:id="@id/first_row"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.zomato.ui.lib.organisms.snippets.imagetext.v4type37.ZV4ImageTextSnippetType37
                android:id="@id/v4Type37_1"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <com.zomato.ui.lib.organisms.snippets.imagetext.v4type37.ZV4ImageTextSnippetType37
                android:id="@id/v4Type37_2"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_11" />
        </LinearLayout>
        <LinearLayout
            android:gravity="top"
            android:orientation="horizontal"
            android:id="@id/second_row"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_20">
            <com.zomato.ui.lib.organisms.snippets.imagetext.v4type37.ZV4ImageTextSnippetType37
                android:id="@id/v4Type37_3"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <com.zomato.ui.lib.organisms.snippets.imagetext.v4type37.ZV4ImageTextSnippetType37
                android:id="@id/v4Type37_4"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_11" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>