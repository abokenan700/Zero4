<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/bg_image"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingEnd="@dimen/sushi_spacing_base">
            <FrameLayout
                android:id="@id/image_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/text_layout"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:id="@id/image"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_32"
                    android:layout_height="@dimen/size_32"
                    android:scaleType="centerCrop"
                    android:layout_marginStart="@dimen/sushi_spacing_base" />
            </FrameLayout>
            <View
                android:id="@id/image_gradient"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="@id/image_container"
                app:layout_constraintEnd_toEndOf="@id/image_container"
                app:layout_constraintStart_toStartOf="@id/image_container"
                app:layout_constraintTop_toTopOf="@id/image_container" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_spacing_extra"
                android:textColor="@color/sushi_white"
                android:id="@id/overlay_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_macro"
                android:layout_marginEnd="@dimen/sushi_spacing_macro"
                app:layout_constraintBottom_toBottomOf="@id/image_container"
                app:layout_constraintEnd_toEndOf="@id/image_container" />
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/text_layout"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sushi_spacing_base"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@id/image_container"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="?attr_7f040475"
                    android:id="@id/title"
                    android:paddingBottom="@dimen/sushi_spacing_nano"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="@dimen/sushi_spacing_base"
                    app:textViewType="MEDIUM_400" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_700"
                    android:id="@id/subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="@dimen/sushi_spacing_base"
                    app:textViewType="MEDIUM_100" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <include
            android:layout_gravity="bottom"
            android:id="@id/button_layout_1"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            layout="@layout/layout_crystal_snippet_type_2_button_1" />
        <include
            android:layout_gravity="bottom"
            android:id="@id/button_layout_2"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            layout="@layout/layout_crystal_snippet_type_2_button_2" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="end"
        android:id="@id/right_image"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:scaleType="centerInside"
        android:translationZ="-4.0dip"
        app:layout_constraintBottom_toBottomOf="parent" />
</FrameLayout>