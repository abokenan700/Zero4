<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/root_container"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/selected_indicator"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_micro"
        android:layout_height="@dimen/sushi_spacing_femto"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/product_image_container"
        android:background="@drawable/qd_rounded_grey_border_12"
        android:padding="@dimen/qd_padding_1"
        android:visibility="gone"
        android:layout_width="@dimen/size_70"
        android:layout_height="@dimen/size_70"
        app:layout_constraintEnd_toStartOf="@id/dish_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/product_image"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:scaleType="centerCrop"
            app:cornerRadius="@dimen/radius_12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/tag_image"
            android:layout_width="@dimen/size_24"
            android:layout_height="@dimen/size_24"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/product_strip_information"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/product_image_container"
        app:layout_constraintTop_toTopOf="parent">
        <View
            android:id="@id/product_strip_information_indicator"
            android:layout_width="@dimen/sushi_spacing_nano"
            android:layout_height="fill_parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?android:textColorPrimary"
            android:gravity="center|left"
            android:id="@id/tv_product_strip_information"
            android:paddingLeft="@dimen/sushi_spacing_mini"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingRight="@dimen/sushi_spacing_mini"
            android:paddingBottom="@dimen/sushi_spacing_nano"
            android:visibility="visible"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:paddingHorizontal="@dimen/sushi_spacing_mini"
            android:paddingVertical="@dimen/sushi_spacing_nano" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?android:textColorPrimary"
        android:id="@id/dish_name"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/qd_margin_12"
        android:layout_marginEnd="@dimen/qd_margin_16"
        app:layout_constraintEnd_toStartOf="@id/price_stepper_barrier"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/product_image_container"
        app:layout_constraintTop_toBottomOf="@id/product_strip_information"
        app:textViewType="SEMIBOLD_300" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/price_stepper_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="start"
        app:constraint_referenced_ids="dish_stepper, total_price, dish_button"
        app:layout_constraintTop_toTopOf="@id/dish_name" />
    <com.blinkit.commons.ui.ui.customviews.stepper.Stepper
        android:id="@id/dish_stepper"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/product_image_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/product_image_container"
        app:stepper_type="SMALL" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_600"
        android:gravity="end"
        android:id="@id/total_price"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_4"
        android:layout_marginBottom="@dimen/size_4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/dish_button"
        android:paddingLeft="@dimen/sushi_spacing_page_side"
        android:paddingTop="@dimen/sushi_spacing_macro"
        android:paddingRight="@dimen/sushi_spacing_page_side"
        android:paddingBottom="@dimen/sushi_spacing_macro"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_6"
        android:includeFontPadding="false"
        android:paddingHorizontal="@dimen/sushi_spacing_page_side"
        android:paddingVertical="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/dish_name"
        app:layout_constraintVertical_bias="0.0"
        app:stepper_type="SMALL" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textColor="?themeColor500"
        android:gravity="end"
        android:id="@id/ellipsis"
        android:padding="@dimen/elevation_small"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/elevation_regular"
        android:layout_marginBottom="@dimen/elevation_regular"
        android:text="@string/icon_font_3_dot_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.google.android.flexbox.FlexboxLayout
        android:orientation="horizontal"
        android:id="@id/textTagsContainer"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_between"
        android:animateLayoutChanges="true"
        app:flexDirection="row"
        app:flexWrap="wrap"
        app:justifyContent="flex_start"
        app:layout_constraintBottom_toTopOf="@id/cost_container"
        app:layout_constraintEnd_toStartOf="@id/price_stepper_barrier"
        app:layout_constraintStart_toStartOf="@id/dish_name"
        app:layout_constraintTop_toBottomOf="@id/dish_name" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/cost_container"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_between"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="@id/dish_name"
        app:layout_constraintTop_toBottomOf="@id/textTagsContainer">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?android:textColorPrimary"
            android:id="@id/dish_final_price"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:paddingEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/unit"
            app:textViewType="SEMIBOLD_200" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:id="@id/tv_out_of_stock_tag"
            android:background="@color/sushi_grey_500"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:text="@string/qd_out_of_stock"
            android:paddingStart="@dimen/sushi_spacing_micro"
            android:paddingEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/unit"
            app:textViewType="REGULAR_100" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?android:textColorSecondary"
            android:id="@id/dish_original_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/qd_margin_2"
            android:paddingEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/dish_final_price"
            app:layout_constraintTop_toBottomOf="@id/unit"
            app:textViewType="REGULAR_100" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textStyle="bold"
            android:textColor="@color/sushi_white"
            android:layout_gravity="start"
            android:id="@id/tv_offer_tag"
            android:paddingLeft="@dimen/sushi_spacing_micro"
            android:paddingTop="@dimen/sushi_spacing_pico"
            android:paddingRight="@dimen/sushi_spacing_micro"
            android:paddingBottom="@dimen/sushi_spacing_pico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:paddingHorizontal="@dimen/sushi_spacing_micro"
            android:paddingVertical="@dimen/sushi_spacing_pico"
            app:layout_constraintBottom_toBottomOf="@id/dish_final_price"
            app:layout_constraintStart_toEndOf="@id/dish_original_price"
            app:layout_constraintTop_toBottomOf="@id/unit"
            app:textViewType="REGULAR_300" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_600"
            android:id="@id/unit"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@id/dish_final_price"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:textViewType="MEDIUM_100" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.helper.widget.Layer
        android:id="@id/left_layer"
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        android:layout_marginEnd="@dimen/sushi_spacing_extra"
        app:constraint_referenced_ids="cost_container,selected_indicator,product_image_container,product_strip_information,dish_name"
        app:layout_constraintEnd_toStartOf="@id/price_stepper_barrier"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>