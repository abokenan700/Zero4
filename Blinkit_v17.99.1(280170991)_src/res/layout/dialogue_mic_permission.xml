<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr_7f04017d"
    app:cardCornerRadius="@dimen/sushi_corner_radius"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <View
            android:layout_gravity="center"
            android:id="@id/mic_background"
            android:background="@color/sushi_yellow_100"
            android:layout_width="@dimen/size_72"
            android:layout_height="@dimen/size_72"
            android:layout_marginTop="@dimen/size_36"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textColor="@color/z_red"
            android:gravity="center"
            android:id="@id/permission_dialog_header_icon"
            android:layout_width="@dimen/size_38"
            android:layout_height="@dimen/size_38"
            android:layout_marginTop="@dimen/size_54"
            android:drawableStart="@drawable/ic_mic_off"
            android:drawableTint="@color/z_red"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/message_title"
            android:paddingLeft="@dimen/size_19"
            android:paddingRight="@dimen/size_19"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_16"
            android:text="@string/mic_permission_title"
            android:paddingHorizontal="@dimen/size_19"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mic_background"
            app:textViewType="MEDIUM_400" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_600"
            android:gravity="center"
            android:id="@id/message_box"
            android:paddingLeft="@dimen/size_42"
            android:paddingRight="@dimen/size_42"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:text="@string/mic_permission_body"
            android:paddingHorizontal="@dimen/size_42"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/message_title"
            app:textViewType="MEDIUM_300" />
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/separator"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size24"
            app:layout_constraintTop_toBottomOf="@id/message_box" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:textColor="@color/sushi_red_500"
            android:gravity="center"
            android:id="@id/grant_permission"
            android:layout_width="0.0dip"
            android:layout_height="@dimen/size_50"
            app:buttonDimension="large"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/separator"
            app:textViewType="MEDIUM_300" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>