<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/marker_info_window_v2"
    android:background="@color/color_transparent"
    android:paddingTop="@dimen/sushi_spacing_macro"
    android:paddingBottom="@dimen/sushi_spacing_macro"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/sushi_spacing_mini"
    android:paddingEnd="@dimen/sushi_spacing_macro"
    android:elevation="@dimen/sushi_spacing_micro"
    android:paddingVertical="@dimen/sushi_spacing_macro"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_spacing_macro"
        android:textColor="@color/sushi_green_500"
        android:id="@id/info_window_left_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/icon_font_check_circle_fill"
        android:layout_marginEnd="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/info_window_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/info_window_title" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/info_window_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/size_110"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/info_window_left_icon"
        app:layout_constraintTop_toTopOf="parent"
        app:textViewType="MEDIUM_200" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/info_window_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/size_110"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/info_window_title"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/info_window_title"
        app:layout_constraintTop_toBottomOf="@id/info_window_title"
        app:textViewType="MEDIUM_100" />
</androidx.constraintlayout.widget.ConstraintLayout>