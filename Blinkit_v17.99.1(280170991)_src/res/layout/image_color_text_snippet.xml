<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/container"
    android:clipChildren="true"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/sushi_spacing_micro"
    android:layout_marginBottom="@dimen/sushi_spacing_micro"
    android:stateListAnimator="@animator/scale_animator"
    android:layout_marginVertical="@dimen/sushi_spacing_micro"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center_vertical"
        android:id="@id/image_view"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/padding_very_small"
        android:scaleType="fitCenter"
        app:cornerRadius="@dimen/size_6"
        app:layout_constraintBottom_toBottomOf="@id/outer_view"
        app:layout_constraintEnd_toEndOf="@id/outer_view"
        app:layout_constraintStart_toStartOf="@id/outer_view"
        app:layout_constraintTop_toTopOf="@id/outer_view" />
    <View
        android:id="@id/outer_view"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginLeft="@dimen/sushi_spacing_micro"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginRight="@dimen/sushi_spacing_micro"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:layout_marginHorizontal="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toTopOf="@id/tv_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ViewStub
        android:id="@id/view_stub_image_tag"
        android:layout="@layout/view_stub_layout_rounded_image_view"
        android:inflatedId="@id/view_stub_image_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="@id/image_view"
        app:layout_constraintTop_toTopOf="@id/image_view" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center_vertical"
        android:id="@id/overlay_image"
        android:layout_width="@dimen/sushi_spacing_loose"
        android:layout_height="@dimen/sushi_spacing_loose"
        android:layout_margin="@dimen/padding_very_small"
        android:src="@drawable/selected_tick"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="@id/image_view"
        app:layout_constraintEnd_toEndOf="@id/image_view"
        app:layout_constraintStart_toStartOf="@id/image_view"
        app:layout_constraintTop_toTopOf="@id/image_view" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_black"
        android:gravity="center|top"
        android:id="@id/tv_title"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:lines="2"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/outer_view"
        app:layout_constraintStart_toStartOf="@id/outer_view"
        app:layout_constraintTop_toBottomOf="@id/outer_view"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintVertical_chainStyle="packed"
        app:textViewType="BOLD_500" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/bottom_tag"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingBottom="@dimen/sushi_spacing_nano"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:paddingVertical="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/outer_view"
        app:layout_constraintEnd_toEndOf="@id/outer_view"
        app:layout_constraintStart_toStartOf="@id/outer_view" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/right_tag"
        android:background="@color/green"
        android:padding="@dimen/sushi_spacing_micro"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:minWidth="20.0dip"
        android:minHeight="19.0dip"
        android:elevation="@dimen/sushi_spacing_pico"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        app:layout_constraintWidth_min="@dimen/size_24" />
</androidx.constraintlayout.widget.ConstraintLayout>