<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/no_content_layout"
    android:background="?android:colorBackground"
    android:paddingBottom="@dimen/sushi_spacing_extra"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:zomato_ui="http://schemas.android.com/apk/res-auto">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@id/emptycase_no_content_image"
        android:layout_width="@dimen/no_content_view_drawable_width"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:maxHeight="@dimen/no_content_view_drawable_height"
        zomato_ui:layout_constraintBottom_toTopOf="@id/ll_rootview"
        zomato_ui:layout_constraintEnd_toEndOf="parent"
        zomato_ui:layout_constraintStart_toStartOf="parent"
        zomato_ui:layout_constraintTop_toTopOf="parent"
        zomato_ui:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/ncv_lottie"
        android:visibility="gone"
        android:layout_width="@dimen/no_content_view_drawable_width"
        android:layout_height="wrap_content"
        android:maxHeight="@dimen/no_content_view_drawable_height"
        zomato_ui:layout_constraintBottom_toTopOf="@id/ll_rootview"
        zomato_ui:layout_constraintEnd_toEndOf="parent"
        zomato_ui:layout_constraintStart_toStartOf="parent" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/ll_rootview"
        android:padding="@dimen/no_content_padding_big"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        zomato_ui:layout_constraintBottom_toBottomOf="parent"
        zomato_ui:layout_constraintEnd_toEndOf="parent"
        zomato_ui:layout_constraintStart_toStartOf="parent"
        zomato_ui:layout_constraintTop_toBottomOf="@id/emptycase_no_content_image">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/iconfont_emptycase_size"
            android:textColor="?attr_7f040475"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/emptycase_no_iconfont"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/no_content_padding_regular" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040475"
            android:gravity="center"
            android:id="@id/emptycase_no_content_title"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/nitro_side_padding"
            zomato_ui:textViewType="REGULAR_500" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040490"
            android:gravity="center"
            android:id="@id/emptycases_no_content_text"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            zomato_ui:textViewType="REGULAR_300" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/refresh_button"
            android:padding="@dimen/no_content_padding_medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:text="@string/data_kit_try_again"
            zomato_ui:buttonColor="?colorAccent"
            zomato_ui:buttonDimension="medium"
            zomato_ui:buttonType="text" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:gravity="center"
            android:id="@id/custom_button"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/nitro_side_padding"
            zomato_ui:buttonColor="?colorAccent"
            zomato_ui:buttonDimension="medium"
            zomato_ui:buttonType="solid" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/ncv_ll_container"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_32">
            <FrameLayout
                android:id="@id/ncv_bottom_container"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/size_250">
                <ScrollView
                    android:orientation="vertical"
                    android:id="@id/ncv_scrollable"
                    android:paddingLeft="@dimen/sushi_spacing_mini"
                    android:paddingRight="@dimen/sushi_spacing_mini"
                    android:paddingBottom="@dimen/sushi_spacing_alone"
                    android:visibility="visible"
                    android:scrollbars="vertical"
                    android:clipToPadding="false"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:nestedScrollingEnabled="true"
                    android:paddingHorizontal="@dimen/sushi_spacing_mini">
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@id/ncv_order_items"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="@color/sushi_grey_600"
                            android:gravity="center"
                            android:layout_gravity="center_horizontal"
                            android:id="@id/o2_header"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableEnd="@drawable/ic_swipe_right_arrow"
                            zomato_ui:textViewType="REGULAR_300" />
                        <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
                            android:layout_gravity="center_horizontal"
                            android:id="@id/horizontal_recycler_view"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/sushi_spacing_macro"
                            android:layout_marginBottom="@dimen/sushi_spacing_loose" />
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="@color/sushi_grey_600"
                            android:gravity="center"
                            android:layout_gravity="center_horizontal"
                            android:id="@id/dining_header"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            zomato_ui:textViewType="REGULAR_300" />
                        <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
                            android:layout_gravity="center_horizontal"
                            android:id="@id/horizontal_recycler_view_dining"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/sushi_spacing_macro"
                            android:layout_marginBottom="@dimen/sushi_spacing_loose" />
                    </LinearLayout>
                </ScrollView>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>