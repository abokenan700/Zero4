<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/sushi_spacing_macro"
    app:cardElevation="@dimen/sushi_spacing_nano"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/dummyRoot"
            android:paddingTop="@dimen/sushi_spacing_extra"
            android:paddingBottom="@dimen/sushi_spacing_extra"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sushi_spacing_page_side"
            android:paddingEnd="@dimen/sushi_spacing_page_side">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/dummyImageContainer"
                android:layout_width="@dimen/sushi_spacing_extra"
                android:layout_height="@dimen/sushi_spacing_extra"
                android:scaleType="fitXY"
                android:adjustViewBounds="true" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_900"
                android:id="@id/dummyTitle"
                android:paddingTop="@dimen/sushi_spacing_macro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:textViewType="MEDIUM_400" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_700"
                android:id="@id/dummySubtitleTextView"
                android:paddingTop="@dimen/sushi_spacing_nano"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"
                app:textViewType="REGULAR_200" />
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/root"
            android:paddingTop="@dimen/sushi_spacing_extra"
            android:paddingBottom="@dimen/sushi_spacing_extra"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sushi_spacing_page_side"
            android:paddingEnd="@dimen/sushi_spacing_page_side">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/imageContainer"
                android:visibility="invisible"
                android:layout_width="@dimen/sushi_spacing_extra"
                android:layout_height="@dimen/sushi_spacing_extra"
                android:scaleType="fitXY"
                android:adjustViewBounds="true" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_900"
                android:id="@id/title"
                android:paddingTop="@dimen/sushi_spacing_macro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:textViewType="MEDIUM_400" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_700"
                android:id="@id/subtitleTextView"
                android:paddingTop="@dimen/sushi_spacing_nano"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"
                app:textViewType="REGULAR_200" />
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>