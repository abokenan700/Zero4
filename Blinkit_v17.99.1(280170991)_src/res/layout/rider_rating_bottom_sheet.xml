<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/rootLayout"
    android:background="@color/color_transparent"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:gravity="center"
        android:id="@id/crossButtonContainer"
        android:background="@color/color_transparent"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_800"
            android:textColor="@color/color_white"
            android:layout_gravity="center_horizontal"
            android:id="@id/cross_icon"
            android:background="@drawable/qd_cross_icon"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingTop="@dimen/size_8"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/size_8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_loose"
            android:text="@string/icon_font_cross"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            android:paddingVertical="@dimen/size_8" />
    </RelativeLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/content"
        android:background="@drawable/qd_bottom_sheet_circular"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/crossButtonContainer">
        <androidx.core.widget.NestedScrollView
            android:id="@id/scroll_view"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toTopOf="@id/submit_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                    android:id="@id/lottieAnimation"
                    android:layout_width="@dimen/size_108"
                    android:layout_height="@dimen/size_108"
                    android:layout_marginTop="@dimen/sushi_spacing_loose"
                    android:layout_marginBottom="@dimen/size_25" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:gravity="center"
                    android:id="@id/rating_header"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/sushi_spacing_base" />
                <com.blinkit.commons.ui.ui.customviews.starRating.BStarRatingBar
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@id/rating_bar"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/sushi_spacing_base"
                    android:paddingEnd="@dimen/sushi_spacing_base"
                    app:starSize="medium" />
                <com.zomato.ui.atomiclib.atom.ZSeparator
                    android:id="@id/separator"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_loose"
                    app:zseparator_color="@color/sushi_grey_200" />
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/et_feedback"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_extra"
                    android:paddingStart="@dimen/sushi_spacing_base"
                    android:paddingEnd="@dimen/sushi_spacing_base" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@id/pill_container_heading"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_20" />
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/pill_container"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_base"
                    android:layout_marginBottom="@dimen/sushi_spacing_base"
                    android:paddingStart="@dimen/sushi_spacing_base"
                    android:paddingEnd="@dimen/sushi_spacing_base" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:gravity="center"
                    android:id="@id/thank_you_header"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_base" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:gravity="center"
                    android:id="@id/thank_you_sub_header"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_macro"
                    android:layout_marginBottom="@dimen/padding_huge" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <com.zomato.ui.atomiclib.atom.ZButtonWithLoader
            android:gravity="center"
            android:id="@id/submit_button"
            android:background="@drawable/qd_all_rounded_green_8dp"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:text="@string/submit"
            app:cornerRadius="@dimen/sushi_spacing_nano"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>