<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="?attr_7f04017d"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ProgressBar
        android:id="@id/loading_progressbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:progressTint="?themeColor500"
        android:indeterminateTint="?themeColor500"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="?android:progressBarStyle" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/error_image"
        android:layout_width="250.0dip"
        android:layout_height="200.0dip"
        android:layout_marginBottom="@dimen/size_20"
        app:layout_constraintBottom_toTopOf="@id/error_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/error_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/size_20"
        app:layout_constraintBottom_toTopOf="@id/retry_button"
        app:layout_constraintEnd_toEndOf="@id/error_image"
        app:layout_constraintStart_toStartOf="@id/error_image"
        app:layout_constraintTop_toBottomOf="@id/error_image" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:gravity="center"
        android:id="@id/retry_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:buttonType="text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/error_image"
        app:layout_constraintStart_toStartOf="@id/error_image"
        app:layout_constraintTop_toBottomOf="@id/error_text" />
    <androidx.constraintlayout.widget.Group
        android:id="@id/error_group"
        android:layout_width="6.0dip"
        android:layout_height="3.0dip"
        app:constraint_referenced_ids="error_image,retry_button,error_text" />
</androidx.constraintlayout.widget.ConstraintLayout>