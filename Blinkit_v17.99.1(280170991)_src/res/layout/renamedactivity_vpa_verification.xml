<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:background="?attr_7f04017d"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/size_30">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/VPAImageView"
            android:layout_width="@dimen/size_100"
            android:layout_height="@dimen/size_100"
            android:layout_marginTop="@dimen/size_60"
            android:scaleType="fitCenter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/VPAHeader" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_500"
            android:textColor="?attr_7f04048a"
            android:gravity="center"
            android:id="@id/VPADescription1"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_20"
            android:fontFamily="@font/okra_semibold"
            android:layout_marginStart="@dimen/size_20"
            android:layout_marginEnd="@dimen/size_20"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/VPAImageView"
            app:layout_goneMarginTop="@dimen/size_100" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_300"
            android:textColor="?attr_7f040496"
            android:gravity="center"
            android:id="@id/VPADescription2"
            android:background="@drawable/payments_rounded_background_dark"
            android:paddingTop="@dimen/sushi_spacing_mini"
            android:paddingBottom="@dimen/sushi_spacing_mini"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:fontFamily="@font/okra_regular"
            android:paddingStart="@dimen/size_20"
            android:paddingEnd="@dimen/size_20"
            android:layout_marginStart="@dimen/size_20"
            android:layout_marginEnd="@dimen/size_20"
            app:fontFamily="@font/okra_regular"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/VPADescription1" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_300"
            android:textColor="?attr_7f040490"
            android:gravity="start"
            android:id="@id/VPAInstructionsMessage"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_28"
            android:layout_marginStart="@dimen/size_30"
            android:layout_marginEnd="@dimen/size_30"
            app:fontFamily="@font/okra_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/VPADescription2"
            app:layout_goneMarginTop="0.0dip" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_300"
            android:textColor="?attr_7f040490"
            android:gravity="center"
            android:id="@id/VPAVerificationTimer"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_15"
            android:text="@string/renamedvpa_verification_timer_message"
            android:layout_marginStart="@dimen/size_20"
            android:layout_marginEnd="@dimen/size_20"
            app:fontFamily="@font/okra_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/VPAProgressBar" />
        <ProgressBar
            android:id="@id/VPAProgressBar"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_70"
            android:max="300"
            android:progressDrawable="@drawable/renamedrounded_horizontal_progress_bar"
            android:layout_marginStart="@dimen/sushi_spacing_extra"
            android:layout_marginEnd="@dimen/sushi_spacing_extra"
            android:progressTint="?themeColor500"
            android:indeterminateTint="?themeColor500"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/VPAInstructionsMessage"
            style="?android:progressBarStyleHorizontal" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_100"
            android:textColor="?attr_7f040490"
            android:gravity="center"
            android:id="@id/VPAHeader"
            android:background="?attr_7f0403cd"
            android:padding="@dimen/sushi_spacing_macro"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/okra_regular"
            android:textAlignment="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <payments.zomato.paymentkit.ui.multiimagetext.MultiImageTextSnippetView
            android:id="@id/SnippetMultiImageTextVPA"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_alone"
            android:layout_marginStart="@dimen/sushi_spacing_base"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/VPAVerificationTimer" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>