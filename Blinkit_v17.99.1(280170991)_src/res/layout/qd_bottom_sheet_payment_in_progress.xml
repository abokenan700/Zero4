<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:id="@id/cancel_dialog_container"
    android:background="@drawable/rounded_top_corners_12_shadow"
    android:paddingTop="@dimen/qd_padding_24"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/top_image"
        android:padding="@dimen/qd_padding_20"
        android:layout_width="@dimen/size_72"
        android:layout_height="@dimen/size_72"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/qd_margin_12"
        android:layout_marginTop="@dimen/qd_margin_16"
        android:layout_marginRight="@dimen/qd_margin_12"
        android:maxLines="1"
        android:layout_marginHorizontal="@dimen/qd_margin_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_image" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center_horizontal"
        android:id="@id/subtitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/qd_margin_12"
        android:layout_marginTop="@dimen/qd_margin_4"
        android:layout_marginRight="@dimen/qd_margin_12"
        android:layout_marginHorizontal="@dimen/qd_margin_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <ProgressBar
        android:theme="@style/Theme.ProgressBar.Sushi"
        android:layout_gravity="start|center"
        android:id="@id/dialog_progress_view"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="@dimen/size_8"
        android:layout_marginLeft="@dimen/size_12"
        android:layout_marginTop="@dimen/qd_margin_16"
        android:layout_marginRight="@dimen/size_12"
        android:progress="0"
        android:progressDrawable="@drawable/qd_blinkit_horizontal_green_rounded_progress"
        android:layout_weight="9.0"
        android:layout_marginHorizontal="@dimen/size_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal" />
    <View
        android:background="?attr_7f040295"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/qd_margin_0.5"
        android:layout_marginTop="@dimen/qd_margin_16"
        app:layout_constraintTop_toBottomOf="@id/dialog_progress_view" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:textStyle="bold"
        android:textColor="?themeColor700"
        android:layout_gravity="end|center"
        android:id="@id/dialog_cancel_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qd_margin_12"
        android:text="@android:string/cancel"
        android:layout_weight="0.0"
        android:inputType="text"
        app:buttonColor="?attr_7f0402a6"
        app:buttonDimension="small"
        app:buttonType="text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dialog_progress_view" />
</androidx.constraintlayout.widget.ConstraintLayout>