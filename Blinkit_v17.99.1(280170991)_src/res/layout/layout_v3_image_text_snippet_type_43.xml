<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/bg_image"
        android:visibility="gone"
        android:clipChildren="true"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        android:clipToOutline="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/bg_lottie"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="@dimen/sushi_spacing_femto"
        app:layout_constraintBottom_toBottomOf="@id/bg_image"
        app:layout_constraintEnd_toEndOf="@id/bg_image"
        app:layout_constraintStart_toStartOf="@id/bg_image"
        app:layout_constraintTop_toTopOf="@id/bg_image"
        app:lottie_loop="true" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/top_title_view"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        android:layout_marginStart="@dimen/dimen_12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/top_right_image_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        android:layout_marginEnd="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/left_image_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerInside"
        android:layout_marginStart="@dimen/dimen_12"
        app:layout_constraintEnd_toStartOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_900"
        android:gravity="start"
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:autoSizeTextType="uniform"
        app:layout_constraintStart_toEndOf="@id/left_image_view"
        app:layout_constraintTop_toBottomOf="@id/top_title_view"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.75"
        app:textViewType="SEMIBOLD_300" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_600"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@id/subtitle1"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_pico"
        android:maxLines="2"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.7"
        app:textViewType="MEDIUM_200" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/top_option_bottom_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="subtitle1,title, bg_image,bg_lottie, left_image_view, top_right_image_view" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/bottom_button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_8"
        android:layout_marginBottom="@dimen/dimen_10"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/subtitle1" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/input_fields_container"
        android:paddingTop="@dimen/sushi_spacing_pico"
        android:paddingBottom="@dimen/size_6"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_option_bottom_barrier">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="top"
            android:id="@id/subtitle2_left_image_view"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_2"
            android:layout_marginStart="@dimen/dimen_12" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_12"
            android:layout_marginRight="@dimen/dimen_12"
            android:layout_weight="1.0"
            android:layout_marginHorizontal="@dimen/dimen_12">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/subtitle2"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:id="@id/subtitle4"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/size_4"
                android:layout_marginBottom="@dimen/dimen_2" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/subtitle3"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_nano" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.molecules.ZTextInputField
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/text_input_field_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/size_50"
            android:minHeight="@dimen/size_32"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            app:boxBackgroundMode="none"
            style="@style/OrderTextInputLayout" />
        <com.zomato.ui.atomiclib.atom.ZCheckBox
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/check_box"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/corner_radius_nano"
            app:controlColor="?themeColor500" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/button"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/corner_radius_nano"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:buttonType="text" />
        <com.zomato.ui.atomiclib.atom.ZButtonWithLoader
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/right_button"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_3"
            android:layout_marginStart="@dimen/sushi_spacing_micro"
            android:layout_marginEnd="@dimen/sushi_spacing_base" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/bottom_separator"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:layout_constraintVertical_chainStyle="packed" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="input_fields_container, bottom_separator" />
    <com.zomato.ui.atomiclib.atom.ZCheckBox
        android:id="@id/tip_check_box"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/sushi_spacing_base"
        app:controlColor="?themeColor500"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barrier" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/tip_check_box_lottie"
        android:visibility="gone"
        android:layout_width="@dimen/size24"
        android:layout_height="@dimen/size24"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_extra"
        android:layout_marginVertical="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barrier" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/tip_check_box_title_lottie"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:scaleType="fitXY"
        android:elevation="@dimen/size_6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barrier" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/tip_check_box_title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        android:layout_marginVertical="@dimen/sushi_spacing_macro"
        app:controlColor="?themeColor500"
        app:layout_constraintBottom_toBottomOf="@id/tip_check_box"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tip_check_box"
        app:layout_constraintTop_toTopOf="@id/tip_check_box" />
</merge>