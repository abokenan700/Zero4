<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/bg_overlapping_subtext"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/dimen_13"
        android:layout_marginTop="@dimen/sushi_spacing_mini_negative"
        app:layout_constraintEnd_toEndOf="@id/stepper_container"
        app:layout_constraintStart_toStartOf="@id/stepper_container"
        app:layout_constraintTop_toBottomOf="@id/stepper_container" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@id/stepper_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitIconViewStub
            android:textColor="?themeColor500"
            android:gravity="center"
            android:id="@id/icon_decrement"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:text="@string/icon_font_minus"
            android:contentDescription="@string/remove_one_more_item_from_cart"
            app:layout_constraintEnd_toStartOf="@id/tv_title"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="0.75"
            app:layout_constraintStart_toStartOf="parent" />
        <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
            android:textColor="?themeColor500"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/tv_title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:layout_marginBottom="@dimen/sushi_spacing_nano"
            android:maxLines="1"
            android:layout_marginVertical="@dimen/sushi_spacing_nano"
            app:layout_constraintBottom_toTopOf="@id/tv_subtext_inside"
            app:layout_constraintEnd_toStartOf="@id/icon_increment"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1.0"
            app:layout_constraintStart_toEndOf="@id/icon_decrement"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_goneMarginBottom="@dimen/sushi_spacing_nano"
            app:textViewType="SEMIBOLD_300" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:id="@id/tv_subtext_inside"
            android:background="?attr_7f04038f"
            android:paddingLeft="@dimen/sushi_spacing_nano"
            android:paddingTop="@dimen/sushi_spacing_pico"
            android:paddingRight="@dimen/sushi_spacing_nano"
            android:paddingBottom="@dimen/sushi_spacing_pico"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_pico"
            android:layout_marginRight="@dimen/sushi_spacing_pico"
            android:layout_marginBottom="@dimen/sushi_spacing_pico"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:layout_marginHorizontal="@dimen/sushi_spacing_pico"
            android:paddingHorizontal="@dimen/sushi_spacing_nano"
            android:paddingVertical="@dimen/sushi_spacing_pico"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitIconViewStub
            android:textColor="?themeColor500"
            android:gravity="center"
            android:id="@id/icon_increment"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:text="@string/icon_font_plus"
            android:contentDescription="@string/add_one_more_item_to_cart"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="0.75"
            app:layout_constraintStart_toEndOf="@id/tv_title" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/tv_subtext_overlapping"
        android:background="@drawable/stepper_sub_text_bg"
        android:paddingTop="@dimen/sushi_spacing_pico"
        android:paddingBottom="@dimen/sushi_spacing_pico"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_micro"
        android:layout_marginRight="@dimen/sushi_spacing_micro"
        android:layout_marginHorizontal="@dimen/sushi_spacing_micro"
        android:paddingVertical="@dimen/sushi_spacing_pico"
        app:layout_constraintBottom_toBottomOf="@id/stepper_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepper_container" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/tv_subtext_bottom"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepper_container" />
</merge>