<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_700"
        android:id="@id/text_view_delivery_title"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/nitro_side_padding"
        android:layout_marginEnd="@dimen/nitro_side_padding"
        app:textViewType="MEDIUM_200" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/tags_recycler_view"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:paddingStart="@dimen/nitro_side_padding"
        android:paddingEnd="@dimen/nitro_side_padding"
        android:nestedScrollingEnabled="false" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_red_700"
        android:id="@id/text_view_tag_error"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        android:layout_marginStart="@dimen/nitro_side_padding"
        android:layout_marginEnd="@dimen/nitro_side_padding"
        app:textViewType="MEDIUM_100" />
</LinearLayout>