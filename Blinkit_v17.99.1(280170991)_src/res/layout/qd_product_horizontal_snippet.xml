<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/offer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen_4"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@id/main_body"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />
    <View
        android:id="@id/main_body"
        android:background="?attr_7f04017d"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/offer_text" />
    <View
        android:id="@id/gradient_overlay"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen_4"
        app:layout_constraintBottom_toTopOf="@id/bottom_strip"
        app:layout_constraintStart_toStartOf="@id/main_body"
        app:layout_constraintTop_toTopOf="@id/main_body" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.OverlayBadgeViewStub
        android:id="@id/overlay_badge_view"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.CustomStripViewStub
        android:id="@id/bottom_strip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        android:layout_marginVertical="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/main_body"
        app:layout_constraintStart_toStartOf="@id/main_body"
        app:layout_constraintTop_toBottomOf="@id/image" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textStyle="bold"
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:layout_gravity="start"
        android:id="@id/tv_offer_tag"
        android:background="@drawable/bg_product_card_offer"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lineSpacingMultiplier="0.75"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        app:layout_constraintStart_toStartOf="@id/main_body"
        app:layout_constraintTop_toTopOf="@id/main_body" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/guide_50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_small"
        android:layout_marginEnd="@dimen/dimen_12"
        app:layout_constraintBottom_toTopOf="@id/secondary_title"
        app:layout_constraintEnd_toEndOf="@id/guide_50"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/main_body"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/secondary_title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_small"
        android:layout_marginEnd="@dimen/dimen_12"
        app:layout_constraintBottom_toTopOf="@id/bottom_strip"
        app:layout_constraintEnd_toEndOf="@id/guide_50"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.blinkit.commons.ui.ui.customviews.stepper.Stepper
        android:id="@id/stepper"
        android:layout_width="@dimen/size_72"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dimen_12"
        app:layout_constraintBottom_toTopOf="@id/bottom_strip"
        app:layout_constraintEnd_toEndOf="@id/main_body"
        app:layout_constraintTop_toTopOf="@id/main_body"
        app:stepper_type="SMALL" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.NotifyMeViewStub
        android:id="@id/notify_me"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginEnd="@dimen/dimen_12"
        app:layout_constraintBottom_toTopOf="@id/bottom_strip"
        app:layout_constraintEnd_toEndOf="@id/main_body"
        app:layout_constraintTop_toTopOf="@id/main_body" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_white"
        android:id="@id/tv_out_of_stock_tag"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:paddingBottom="@dimen/sushi_spacing_nano"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/qd_out_of_stock"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        android:paddingVertical="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toTopOf="@id/unit_price"
        app:layout_constraintStart_toEndOf="@id/guide_50"
        app:layout_constraintTop_toTopOf="@id/main_body"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/mrp"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/dimen_4"
        android:layout_marginEnd="@dimen/dimen_4"
        app:layout_constraintBottom_toBottomOf="@id/price"
        app:layout_constraintEnd_toStartOf="@id/stepper"
        app:layout_constraintStart_toEndOf="@id/price"
        app:layout_constraintTop_toTopOf="@id/price" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/unit_price"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/separator_height"
        app:layout_constraintBottom_toTopOf="@id/bottom_strip"
        app:layout_constraintEnd_toStartOf="@id/stepper"
        app:layout_constraintStart_toEndOf="@id/guide_50"
        app:layout_constraintTop_toBottomOf="@id/price"
        app:layout_constraintVertical_chainStyle="packed" />
</androidx.constraintlayout.widget.ConstraintLayout>