<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.neopop.TiltFrameLayout
        android:id="@id/tilt_container"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/qd_stepper_neo_pop_height"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.64"
        app:neopop_animate_on_touch="false"
        app:neopop_bottom_surface_color="@color/black"
        app:neopop_corner_radius="@dimen/sushi_spacing_micro"
        app:neopop_depth="9.0dip"
        app:neopop_gravity="on_ground"
        app:neopop_is_stroked_button="true"
        app:neopop_shimmer_color="#ffbff1ca"
        app:neopop_shimmer_duration="700"
        app:neopop_shimmer_repeat_delay="700"
        app:neopop_shimmer_width="24.0dip"
        app:neopop_show_shimmer="true"
        app:neopop_stroke_color="@color/black"
        app:neopop_stroke_width="1.0dip">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_gravity="center"
            android:id="@id/stepper_container"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitIconViewStub
                android:textColor="?themeColor500"
                android:gravity="center"
                android:id="@id/icon_decrement"
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                android:text="@string/icon_font_minus"
                android:contentDescription="@string/remove_one_more_item_from_cart"
                app:layout_constraintEnd_toStartOf="@id/tv_title"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintHorizontal_weight="0.75"
                app:layout_constraintStart_toStartOf="parent" />
            <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
                android:textColor="?themeColor500"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@id/tv_title"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:maxLines="1"
                app:layout_constraintBottom_toTopOf="@id/tv_subtext_inside"
                app:layout_constraintEnd_toStartOf="@id/icon_increment"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintHorizontal_weight="1.0"
                app:layout_constraintStart_toEndOf="@id/icon_decrement"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed"
                app:textViewType="SEMIBOLD_300" />
            <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
                android:ellipsize="end"
                android:gravity="center_horizontal"
                android:id="@id/tv_subtext_inside"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:includeFontPadding="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_title"
                app:layout_constraintVertical_chainStyle="packed" />
            <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitIconViewStub
                android:textColor="?themeColor500"
                android:gravity="center"
                android:id="@id/icon_increment"
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                android:text="@string/icon_font_plus"
                android:contentDescription="@string/add_one_more_item_to_cart"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintHorizontal_weight="0.75"
                app:layout_constraintStart_toEndOf="@id/tv_title" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.blinkit.commons.ui.ui.customviews.neopop.TiltFrameLayout>
    <com.blinkit.commons.ui.ui.customviews.neopop.tiltButton.TiltShadowView
        android:id="@id/shadow_view"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/size9"
        android:layout_marginLeft="12.0dip"
        android:layout_marginRight="12.0dip"
        android:layout_marginHorizontal="12.0dip"
        app:layout_constraintEnd_toEndOf="@id/tilt_container"
        app:layout_constraintStart_toStartOf="@id/tilt_container"
        app:layout_constraintTop_toBottomOf="@id/tilt_container"
        app:shadow_corner_radius="@dimen/sushi_spacing_micro" />
</merge>