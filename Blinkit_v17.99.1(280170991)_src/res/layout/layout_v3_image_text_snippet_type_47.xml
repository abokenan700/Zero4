<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="horizontal"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@id/timeline_container"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layout_marginStart="@dimen/sushi_spacing_base">
        <FrameLayout
            android:layout_gravity="center"
            android:id="@id/top_connecting_link_container"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_macro"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toTopOf="@id/bottom_connecting_link_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <View
                android:id="@id/top_connecting_link"
                android:visibility="gone"
                android:layout_width="@dimen/sushi_spacing_macro"
                android:layout_height="fill_parent"
                android:foregroundGravity="center_horizontal" />
            <View
                android:id="@id/top_connecting_link_overlay"
                android:background="@drawable/gradient_left_drawable"
                android:layout_width="@dimen/sushi_spacing_macro"
                android:layout_height="fill_parent"
                android:foregroundGravity="center_horizontal"
                android:backgroundTint="@color/sushi_white_alpha_seventy_five" />
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="center"
            android:id="@id/bottom_connecting_link_container"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_macro"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_connecting_link_container">
            <View
                android:id="@id/bottom_connecting_link"
                android:visibility="gone"
                android:layout_width="@dimen/sushi_spacing_macro"
                android:layout_height="fill_parent"
                android:foregroundGravity="center_horizontal" />
            <View
                android:id="@id/bottom_connecting_link_overlay"
                android:background="@drawable/gradient_left_drawable"
                android:layout_width="@dimen/sushi_spacing_macro"
                android:layout_height="fill_parent"
                android:foregroundGravity="center_horizontal"
                android:backgroundTint="@color/sushi_white_alpha_seventy_five" />
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="center"
            android:id="@id/timeline_image_container"
            android:background="@color/color_transparent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center_horizontal"
                android:id="@id/timeline_image_view"
                android:visibility="gone"
                android:layout_width="@dimen/size50"
                android:layout_height="@dimen/size50" />
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:layout_gravity="center|top"
                android:id="@id/timeline_animation_view"
                android:visibility="gone"
                android:layout_width="@dimen/size50"
                android:layout_height="@dimen/size50"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/root"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        android:layout_marginVertical="@dimen/sushi_spacing_macro">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/top_container"
            android:paddingTop="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/sushi_spacing_base"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:paddingStart="@dimen/sushi_spacing_base"
            android:paddingVertical="@dimen/sushi_spacing_base">
            <FrameLayout
                android:layout_gravity="center_vertical"
                android:id="@id/top_left_container"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_macro">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:layout_gravity="center"
                    android:id="@id/left_image"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_100"
                    android:layout_height="@dimen/size_100" />
                <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                    android:layout_gravity="center"
                    android:id="@id/left_animation_view"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_100"
                    android:layout_height="@dimen/size_100"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true" />
            </FrameLayout>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:id="@id/title_subtitle_container"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:ellipsize="end"
                    android:gravity="start|center"
                    android:layout_gravity="center"
                    android:id="@id/title"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:textViewType="MEDIUM_400" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:ellipsize="end"
                    android:gravity="start|center"
                    android:id="@id/subtitle"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_mini"
                    app:textViewType="SEMIBOLD_600" />
            </LinearLayout>
            <FrameLayout
                android:layout_gravity="center_vertical"
                android:id="@id/top_right_container"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sushi_spacing_macro">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:layout_gravity="center"
                    android:id="@id/right_image"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_100"
                    android:layout_height="@dimen/size_100" />
                <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                    android:layout_gravity="center"
                    android:id="@id/right_animation_view"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_100"
                    android:layout_height="@dimen/size_100"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true" />
            </FrameLayout>
        </LinearLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/bottom_container"
            android:paddingTop="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/sushi_spacing_base"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:paddingStart="@dimen/sushi_spacing_mini"
            android:paddingVertical="@dimen/sushi_spacing_base">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:ellipsize="end"
                android:gravity="start|center|top"
                android:id="@id/bottom_title"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_nano"
                android:layout_marginStart="@dimen/sushi_spacing_mini"
                app:layout_constraintBottom_toTopOf="@id/bottom_subtitle"
                app:layout_constraintEnd_toStartOf="@id/bottom_barrier"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                app:layout_constraintVertical_chainStyle="packed"
                app:textViewType="MEDIUM_400" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:ellipsize="end"
                android:gravity="start|center|top"
                android:id="@id/bottom_subtitle"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_macro"
                app:layout_constraintBottom_toTopOf="@id/progress_bar"
                app:layout_constraintEnd_toEndOf="@id/bottom_title"
                app:layout_constraintStart_toStartOf="@id/bottom_title"
                app:layout_constraintTop_toBottomOf="@id/bottom_title"
                app:layout_constraintVertical_bias="0.0"
                app:textViewType="MEDIUM_400" />
            <com.zomato.ui.lib.snippets.LinearProgressBar
                android:id="@id/progress_bar"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/bottom_barrier"
                app:layout_constraintStart_toStartOf="parent" />
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/bottom_barrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="start"
                app:constraint_referenced_ids="bottom_right_container" />
            <FrameLayout
                android:id="@id/bottom_right_container"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sushi_spacing_base"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/bottom_title"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:layout_gravity="center"
                    android:id="@id/bottom_right_image"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_100"
                    android:layout_height="@dimen/size_100" />
                <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                    android:layout_gravity="center"
                    android:id="@id/bottom_right_animation_view"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_100"
                    android:layout_height="@dimen/size_100"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/bottom_separator"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/sushi_spacing_pico"
            app:zseparator_type="DASHED" />
    </LinearLayout>
</merge>