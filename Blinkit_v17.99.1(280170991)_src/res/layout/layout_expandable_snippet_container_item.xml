<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="@dimen/sushi_spacing_page_side"
    android:paddingBottom="@dimen/sushi_spacing_page_side"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/sushi_spacing_extra"
    android:paddingEnd="@dimen/sushi_spacing_extra"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center_horizontal"
        android:id="@id/containerItemtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:textViewType="MEDIUM_100" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/containerItemsubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        app:textViewType="SEMIBOLD_600" />
</LinearLayout>