<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/container"
    android:background="@color/color_black"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ProgressBar
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:translationZ="@dimen/sushi_spacing_nano_negative"
        android:indeterminateTint="@color/sushi_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="?android:progressBarStyleSmall" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/bg_image"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.media3.ui.PlayerView
        android:id="@id/player_view"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:translationZ="@dimen/sushi_spacing_pico_negative"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="zoom"
        app:surface_type="texture_view">
        <ProgressBar
            android:layout_gravity="center"
            android:id="@id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/sushi_white"
            style="?android:progressBarStyleSmall" />
    </androidx.media3.ui.PlayerView>
    <FrameLayout
        android:id="@id/sticker_container"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintDimensionRatio="w,16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@id/bottom_gradient_container"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toTopOf="@id/dummy_stripe"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vibes_progress_bar" />
    <View
        android:id="@id/center_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZProgressBar
        android:id="@id/vibes_progress_bar"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_pico"
        android:max="1000000"
        android:secondaryProgress="0"
        android:progressDrawable="@drawable/zstory_progress_bar"
        android:layout_marginStart="@dimen/size_12"
        android:layout_marginEnd="@dimen/size_12"
        android:secondaryProgressTint="@color/color_transparent"
        app:layout_constraintBottom_toTopOf="@id/bottom_container"
        style="@style/Base.Widget.AppCompat.ProgressBar.Horizontal" />
    <include
        android:id="@id/bottom_container"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_18"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        layout="@layout/layout_top_info_story_container" />
    <View
        android:id="@id/dummy_stripe"
        android:background="@color/sushi_black"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_18"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_container" />
    <FrameLayout
        android:id="@id/fl_animation_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_18"
        android:layout_marginEnd="@dimen/dimen_18"
        app:layout_constraintBottom_toTopOf="@id/bottom_right_share"
        app:layout_constraintEnd_toEndOf="parent">
        <View
            android:layout_gravity="center"
            android:id="@id/dummy_animation_view"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/size_38" />
        <FrameLayout
            android:layout_gravity="end"
            android:id="@id/bookmark_container"
            android:paddingTop="@dimen/dimen_two_point_two"
            android:paddingRight="@dimen/size_3_and_half"
            android:layout_width="@dimen/size_38"
            android:layout_height="@dimen/size_38"
            android:translationZ="@dimen/sushi_spacing_nano">
            <com.zomato.ui.atomiclib.atom.ZButton
                android:textSize="@dimen/size18"
                android:textColor="@color/sushi_white"
                android:layout_gravity="center"
                android:id="@id/bottom_right_bookmark"
                android:padding="@dimen/sushi_spacing_femto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/sushi_spacing_femto"
                app:buttonDimension="medium"
                app:buttonType="text" />
        </FrameLayout>
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:gravity="end"
            android:layout_gravity="center|right"
            android:id="@id/animation_message"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saved to your liked restaurants"
            android:layout_marginStart="@dimen/dimen_12"
            android:layout_marginEnd="@dimen/size_12"
            app:textViewType="BOLD_400" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/size18"
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/bottom_right_share"
        android:layout_width="@dimen/size_38"
        android:layout_height="@dimen/size_38"
        android:layout_marginBottom="@dimen/size18"
        android:layout_marginEnd="@dimen/size18"
        android:elevation="@dimen/dimen_2"
        app:layout_constraintBottom_toTopOf="@id/bottom_right_more"
        app:layout_constraintEnd_toEndOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/size18"
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/bottom_right_more"
        android:layout_width="@dimen/size_38"
        android:layout_height="@dimen/size_38"
        android:layout_marginBottom="@dimen/size18"
        android:layout_marginEnd="@dimen/size18"
        android:elevation="@dimen/dimen_2"
        app:layout_constraintBottom_toTopOf="@id/vibes_progress_bar"
        app:layout_constraintEnd_toEndOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/volume_icon"
        android:visibility="gone"
        android:layout_width="@dimen/size_48"
        android:layout_height="@dimen/size_48"
        android:text="@string/iconfont_video_sound_mute"
        android:scaleX="1.5"
        android:scaleY="1.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>