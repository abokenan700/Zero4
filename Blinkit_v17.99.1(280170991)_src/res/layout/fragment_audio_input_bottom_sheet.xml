<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:id="@id/root_container"
    android:background="@color/color_transparent"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_800"
        android:textColor="@color/color_white"
        android:layout_gravity="center_horizontal"
        android:id="@id/closeButton"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingTop="@dimen/size_8"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:paddingBottom="@dimen/size_8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:text="@string/icon_font_cross"
        android:fontFamily="@font/wasabicons"
        android:backgroundTint="@color/tokenised_slate_700"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        android:paddingVertical="@dimen/size_8" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@id/innerConstraintLayout"
        android:background="?attr_7f04017d"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_loose"
            android:layout_marginTop="@dimen/sushi_spacing_loose"
            android:layout_marginRight="@dimen/sushi_spacing_loose"
            android:textAlignment="center"
            android:layout_marginHorizontal="@dimen/sushi_spacing_loose"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/subtitle"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:textAlignment="center"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toTopOf="@id/record_container"
            app:layout_constraintTop_toBottomOf="@id/title" />
        <FrameLayout
            android:id="@id/record_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginTop="@dimen/sushi_spacing_alone"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_alone"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            android:layout_marginVertical="@dimen/sushi_spacing_alone"
            app:layout_constraintBottom_toTopOf="@id/bottomBarrier"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:id="@id/recordLayout"
                android:background="@color/sushi_red_500"
                android:padding="@dimen/sushi_spacing_base"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="@dimen/size_150">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/color_white"
                    android:id="@id/recordLayout_start_text"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chat_sdk_start_recording"
                    app:layout_constraintBottom_toBottomOf="@id/recordLayout_mic_icon"
                    app:layout_constraintEnd_toStartOf="@id/recordLayout_mic_icon"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/recordLayout_mic_icon"
                    app:textViewType="MEDIUM_400" />
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:textSize="@dimen/sushi_textsize_800"
                    android:textColor="@color/color_white"
                    android:id="@id/recordLayout_mic_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/icon_font_microphone_fill"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toEndOf="@id/recordLayout_start_text"
                    app:layout_constraintTop_toTopOf="parent" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_white"
                    android:id="@id/record_length"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_micro"
                    app:layout_constraintBottom_toBottomOf="@id/recordLayout_mic_icon"
                    app:layout_constraintStart_toEndOf="@id/recordLayout_mic_icon"
                    app:layout_constraintTop_toTopOf="@id/recordLayout_mic_icon"
                    app:textViewType="SEMIBOLD_300" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_white"
                    android:id="@id/record_help_text"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chat_sdk_release_to_save"
                    android:layout_marginEnd="@dimen/sushi_spacing_macro"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/recordLayout_stop_icon"
                    app:layout_constraintTop_toTopOf="parent"
                    app:textViewType="MEDIUM_400" />
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:textSize="@dimen/sushi_textsize_800"
                    android:textColor="@color/color_white"
                    android:id="@id/recordLayout_stop_icon"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/icon_font_stop_button"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <include
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                layout="@layout/chat_sdk_audio_player" />
        </FrameLayout>
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/bottomBarrier"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_base"
            app:barrierDirection="top"
            app:constraint_referenced_ids="audioSubmitButton,exampleText" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/exampleText"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/sushi_spacing_base"
            android:textAlignment="center"
            app:layout_constraintBottom_toTopOf="@id/audioSubmitButton" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/audioSubmitButton"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>