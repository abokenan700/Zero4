<?xml version="1.0" encoding="utf-8"?>
<merge
    android:gravity="start"
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        android:id="@id/image_container"
        android:layout_width="@dimen/size_100"
        android:layout_height="fill_parent">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/image"
            android:layout_width="@dimen/size_100"
            android:layout_height="fill_parent"
            android:scaleType="centerCrop" />
        <FrameLayout
            android:layout_gravity="bottom"
            android:id="@id/overlay_container"
            android:background="@color/color_black_alpha_fifty"
            android:paddingTop="@dimen/sushi_spacing_between"
            android:paddingBottom="@dimen/sushi_spacing_between"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="@dimen/sushi_spacing_between">
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:id="@id/image_overlay_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </FrameLayout>
    </FrameLayout>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:id="@id/right_container"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingTop="@dimen/size_12"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:paddingBottom="@dimen/size_12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        android:paddingVertical="@dimen/size_12">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/subtitle"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_between" />
    </LinearLayout>
</merge>