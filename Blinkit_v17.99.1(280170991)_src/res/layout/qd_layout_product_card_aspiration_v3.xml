        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="@id/guide_padding_end"
        app:layout_constraintStart_toStartOf="@id/guide_padding_start"
        app:layout_constraintTop_toTopOf="parent">
