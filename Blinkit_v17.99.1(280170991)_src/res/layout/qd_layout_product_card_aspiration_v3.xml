        android:layout_marginStart="@dimen/sushi_spacing_macro"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/tv_uom_subtitle"
        app:layout_constraintEnd_toStartOf="@id/uom_guideline"
        app:layout_constraintStart_toStartOf="@id/uom_bg_view"
