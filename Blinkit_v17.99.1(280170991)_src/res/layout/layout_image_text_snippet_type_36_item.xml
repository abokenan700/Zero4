<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/hero_rail_snippet_container"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/top_container"
        android:paddingTop="@dimen/sushi_spacing_pico"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/sushi_spacing_pico"
        android:paddingEnd="@dimen/sushi_spacing_pico">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/bg_image"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"
            app:cornerRadius="@dimen/sushi_spacing_macro" />
        <LinearLayout
            android:layout_gravity="start|center|top"
            android:orientation="vertical"
            android:id="@id/image_bottom_left_item_container"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size18" />
        <LinearLayout
            android:layout_gravity="start|bottom|center"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_base"
            android:layout_marginStart="@dimen/sushi_spacing_base">
            <com.zomato.ui.lib.snippets.ZImageTagView
                android:id="@id/veg_non_veg_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_nano"
                android:layout_marginEnd="@dimen/sushi_spacing_mini"
                app:tagSize="large"
                app:tagType="rounded_outline" />
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@id/rating_container"
                    android:paddingLeft="@dimen/sushi_spacing_nano"
                    android:paddingRight="@dimen/sushi_spacing_nano"
                    android:paddingBottom="@dimen/sushi_spacing_pico"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_nano"
                    android:layout_marginBottom="@dimen/sushi_spacing_nano"
                    android:layout_marginEnd="@dimen/sushi_spacing_between"
                    android:paddingHorizontal="@dimen/sushi_spacing_nano">
                    <com.zomato.ui.atomiclib.snippets.ZMenuRating
                        android:layout_gravity="center_vertical"
                        android:id="@id/dish_rating_average"
                        android:paddingTop="@dimen/sushi_spacing_pico"
                        android:paddingBottom="@dimen/sushi_spacing_pico"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="@dimen/sushi_spacing_nano"
                        android:paddingVertical="@dimen/sushi_spacing_pico"
                        app:starFilledColor="@color/sushi_yellow_500" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textStyle="bold"
                        android:textColor="@color/sushi_grey_800"
                        android:id="@id/dish_rating_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        app:textViewType="REGULAR_100" />
                </LinearLayout>
                <com.google.android.flexbox.FlexboxLayout
                    android:orientation="horizontal"
                    android:id="@id/textTagsContainer"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_nano"
                    android:layout_marginBottom="@dimen/sushi_spacing_nano"
                    android:animateLayoutChanges="true"
                    app:flexDirection="row"
                    app:flexWrap="wrap"
                    app:justifyContent="flex_start" />
            </LinearLayout>
            <com.zomato.ui.lib.snippets.ZImageTagView
                android:id="@id/tertiary_pill_tag"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_mini"
                app:tagSize="large"
                app:tagType="rounded_outline" />
        </LinearLayout>
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:layout_gravity="bottom"
        android:id="@id/image_bottom_separator"
        android:background="@color/sushi_grey_600"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five" />
    <FrameLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_gravity="end"
            android:id="@id/text_layout_container_mock"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/sushi_spacing_macro"
            android:visibility="invisible"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:paddingStart="@dimen/sushi_spacing_base"
            android:paddingEnd="@dimen/sushi_spacing_base"
            android:paddingVertical="@dimen/sushi_spacing_macro">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/text_top_container_mock"
                android:visibility="invisible"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/left_text_container_mock"
                    android:visibility="invisible"
                    android:layout_width="@dimen/sushi_spacing_femto"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:layout_marginEnd="@dimen/sushi_spacing_mini">
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="?attr_7f040475"
                        android:ellipsize="end"
                        android:id="@id/dish_title_mock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_micro"
                        android:includeFontPadding="false"
                        app:textViewType="SEMIBOLD_400" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="@color/sushi_grey_800"
                        android:ellipsize="end"
                        android:id="@id/subtitle6_mock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_micro"
                        android:includeFontPadding="false"
                        app:textViewType="MEDIUM_200" />
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@id/price_container_mock"
                        android:visibility="invisible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_micro">
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="@color/sushi_grey_500"
                            android:id="@id/subtitle1_mock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:paddingEnd="@dimen/sushi_spacing_between"
                            app:textViewType="REGULAR_100" />
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="?attr_7f040475"
                            android:id="@id/subtitle2_mock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:paddingEnd="@dimen/sushi_spacing_between"
                            app:textViewType="REGULAR_100" />
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="?android:textColorSecondary"
                            android:id="@id/subtitle3_mock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:paddingEnd="@dimen/sushi_spacing_between"
                            app:textViewType="REGULAR_100" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_gravity="end|center|top"
                    android:orientation="vertical"
                    android:id="@id/stepper_view_mock"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_micro">
                    <com.zomato.ui.atomiclib.molecules.ZStepper
                        android:id="@id/dish_stepper_mock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:stepper_type="NORMAL"
                        app:stepper_version="V2" />
                    <com.zomato.ui.atomiclib.atom.ZTag
                        android:id="@id/out_of_stock_tag_mock"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:tagColor="@color/sushi_grey_300"
                        app:tagSize="small"
                        app:tagType="rounded" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="@color/sushi_grey_500"
                        android:gravity="center_horizontal"
                        android:layout_gravity="center_horizontal"
                        android:id="@id/dish_customisation_mock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_nano"
                        app:textViewType="REGULAR_100" />
                </LinearLayout>
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZTruncatedTextView
                android:textColor="@color/sushi_grey_800"
                android:id="@id/dish_desc_mock"
                android:visibility="invisible"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:layout_marginBottom="@dimen/sushi_spacing_micro"
                android:lines="2"
                android:layout_below="@id/text_top_container_mock"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true"
                android:layout_marginVertical="@dimen/sushi_spacing_micro"
                app:textViewType="REGULAR_200"
                app:truncateLength="70" />
            <LinearLayout
                android:id="@id/prevRatingLayout_mock"
                android:paddingTop="@dimen/sushi_spacing_micro"
                android:paddingBottom="@dimen/sushi_spacing_micro"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/dish_desc_mock"
                android:paddingEnd="@dimen/sushi_spacing_micro"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_800"
                    android:id="@id/previous_rating_text_mock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:textViewType="SEMIBOLD_100" />
                <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                    android:layout_gravity="center_vertical"
                    android:id="@id/previous_rating_tag_mock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_macro"
                    app:dimenConfig="100"
                    app:ratingType="stars" />
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:layout_gravity="end"
            android:id="@id/text_layout_container"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/sushi_spacing_macro"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:paddingStart="@dimen/sushi_spacing_base"
            android:paddingEnd="@dimen/sushi_spacing_base"
            android:paddingVertical="@dimen/sushi_spacing_macro">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/text_top_container"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/left_text_container"
                    android:layout_width="@dimen/sushi_spacing_femto"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:layout_marginEnd="@dimen/sushi_spacing_mini">
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="?attr_7f040475"
                        android:ellipsize="end"
                        android:id="@id/dish_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_micro"
                        android:includeFontPadding="false"
                        app:textViewType="SEMIBOLD_400" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="@color/sushi_grey_800"
                        android:ellipsize="end"
                        android:id="@id/subtitle6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_micro"
                        android:includeFontPadding="false"
                        app:textViewType="MEDIUM_200" />
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@id/price_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_micro">
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="@color/sushi_grey_500"
                            android:id="@id/subtitle1"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:paddingEnd="@dimen/sushi_spacing_between"
                            app:textViewType="REGULAR_100" />
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="?attr_7f040475"
                            android:id="@id/subtitle2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:paddingEnd="@dimen/sushi_spacing_between"
                            app:textViewType="REGULAR_100" />
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="?android:textColorSecondary"
                            android:id="@id/subtitle3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:paddingEnd="@dimen/sushi_spacing_between"
                            app:textViewType="REGULAR_100" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_gravity="end|center|top"
                    android:orientation="vertical"
                    android:id="@id/stepper_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_micro">
                    <com.zomato.ui.atomiclib.molecules.ZStepper
                        android:id="@id/dish_stepper"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:stepper_type="NORMAL"
                        app:stepper_version="V2" />
                    <com.zomato.ui.atomiclib.atom.ZTag
                        android:id="@id/out_of_stock_tag"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:tagColor="@color/sushi_grey_300"
                        app:tagSize="small"
                        app:tagType="rounded" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:textColor="@color/sushi_grey_500"
                        android:gravity="center_horizontal"
                        android:layout_gravity="center_horizontal"
                        android:id="@id/dish_customisation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_nano"
                        app:textViewType="REGULAR_100" />
                </LinearLayout>
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZTruncatedTextView
                android:textColor="@color/sushi_grey_800"
                android:id="@id/dish_desc"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:layout_marginBottom="@dimen/sushi_spacing_micro"
                android:lines="2"
                android:layout_below="@id/text_top_container"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true"
                android:layout_marginVertical="@dimen/sushi_spacing_micro"
                app:textViewType="REGULAR_200"
                app:truncateLength="70" />
            <LinearLayout
                android:id="@id/prevRatingLayout"
                android:paddingTop="@dimen/sushi_spacing_micro"
                android:paddingBottom="@dimen/sushi_spacing_micro"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/dish_desc"
                android:paddingEnd="@dimen/sushi_spacing_micro"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_800"
                    android:id="@id/previous_rating_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:textViewType="SEMIBOLD_100" />
                <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                    android:layout_gravity="center_vertical"
                    android:id="@id/previous_rating_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_macro"
                    app:dimenConfig="100"
                    app:ratingType="stars" />
            </LinearLayout>
        </RelativeLayout>
    </FrameLayout>
</LinearLayout>