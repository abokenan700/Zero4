<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.lib.organisms.snippets.viewpager2.indicator.ViewPager2OverflowIndicator
        android:layout_gravity="center"
        android:id="@id/dotsBottomIndicatorWithCount"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:indicatorDefaultColor="@color/sushi_grey_200"
        app:indicatorSelectedColor="@color/sushi_grey_800" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:layout_gravity="center"
        android:id="@id/indicator_count"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        app:textViewType="REGULAR_300" />
</merge>