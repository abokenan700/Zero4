<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.lib.organisms.snippets.videoSnippets.ZVideoSelectiveControlsType2
        android:id="@id/videoSelectiveControlsType2"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/resCard"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/resImage"
            android:layout_width="@dimen/size_48"
            android:layout_height="@dimen/size_48"
            app:cornerRadius="@dimen/corner_radius_base" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:layout_marginStart="@dimen/sushi_spacing_page_side">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:ellipsize="end"
                android:id="@id/resTitle"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                app:textViewType="MEDIUM_500" />
            <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                android:id="@id/ratingViewHorizontal"
                android:visibility="visible"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:ratingType="stars" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:ellipsize="end"
                android:id="@id/resSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                app:textViewType="REGULAR_300" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.ZTag
            android:id="@id/resRating"
            android:padding="@dimen/sushi_tag_small_vertical_padding"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/listing_rating_min_width"
            android:layout_marginStart="@dimen/sushi_spacing_page_side"
            app:tagSize="tiny"
            app:tagType="rounded" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/title"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/description"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:gravity="start"
        android:id="@id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        app:buttonDimension="small"
        app:buttonType="text" />
</LinearLayout>