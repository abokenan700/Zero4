<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/icon_title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_mini"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginRight="@dimen/sushi_spacing_mini"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:maxLines="1"
        android:textAlignment="center"
        android:layout_marginHorizontal="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:gravity="center"
        android:id="@id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_mini"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginRight="@dimen/sushi_spacing_mini"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:maxLines="2"
        android:textAlignment="center"
        android:layout_marginHorizontal="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.lib.snippets.separatornew.NitroZSeparator
        android:id="@id/separator"
        android:layout_width="@dimen/sushi_spacing_pico"
        android:layout_height="fill_parent"
        app:is_right_intended="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:new_zseparator_type="VERTICAL" />
</androidx.constraintlayout.widget.ConstraintLayout>