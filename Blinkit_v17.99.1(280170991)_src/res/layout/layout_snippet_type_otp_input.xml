<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:id="@id/onboarding_otp_type_view"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:gravity="center"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_12"
        android:layout_marginTop="@dimen/dimen_12"
        android:layout_marginRight="@dimen/dimen_12"
        android:textAlignment="center"
        android:layout_marginHorizontal="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:gravity="center"
        android:id="@id/subtitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_12"
        android:layout_marginTop="@dimen/dimen_12"
        android:layout_marginRight="@dimen/dimen_12"
        android:textAlignment="center"
        android:layout_marginHorizontal="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <com.zomato.ui.lib.atom.ZOtpEditText
        android:textSize="@dimen/sushi_textsize_400"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/otp_edit_text"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/size50"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:maxLength="6"
        android:digits="\ 1234567890"
        android:inputType="text"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:zotp_background_color="?attr_7f0403d7"
        app:zotp_border_color="@color/sushi_grey_300"
        app:zotp_focused_border_color="?attr_7f040475"
        app:zotp_item_border_width="@dimen/border_stroke_width"
        app:zotp_item_corner_radius="@dimen/corner_radius"
        app:zotp_item_height="@dimen/size_40"
        app:zotp_item_spacing="@dimen/sushi_spacing_base"
        app:zotp_item_width="@dimen/size_36" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/bottom_button1"
        android:padding="@dimen/sushi_spacing_extra"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_12"
        android:layout_marginTop="@dimen/dimen_16"
        android:layout_marginRight="@dimen/dimen_12"
        android:layout_marginHorizontal="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/otp_edit_text"
        app:textViewType="MEDIUM_500" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="bottom"
        android:id="@id/bottom_button2"
        android:padding="@dimen/sushi_spacing_extra"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_12"
        android:layout_marginTop="@dimen/size_24"
        android:layout_marginRight="@dimen/dimen_12"
        android:layout_marginHorizontal="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_button1"
        app:textViewType="MEDIUM_100" />
</merge>