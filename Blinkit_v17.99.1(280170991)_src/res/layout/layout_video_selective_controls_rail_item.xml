<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/videoSnippetParent"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.lib.organisms.snippets.videoSnippets.ZPlayerViewContainer
        android:id="@id/layoutVideoBase"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <View
        android:id="@id/controlsShowHideView"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <View
        android:id="@id/overlayView"
        android:background="@color/color_black_alpha_sixty"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/controlsViewGroup"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/showcase_logo_image"
            android:layout_width="70.0dip"
            android:layout_height="70.0dip"
            android:layout_margin="@dimen/sushi_spacing_base"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/title"
            android:paddingTop="@dimen/sushi_spacing_extra"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_page_side"
            android:textAlignment="center"
            android:paddingStart="@dimen/sushi_spacing_page_side"
            android:paddingEnd="@dimen/sushi_spacing_page_side"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/exo_play"
            app:textViewType="SEMIBOLD_200" />
        <View
            android:id="@id/pausePlayRewindForward"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_900"
            android:textColor="@color/sushi_white"
            android:id="@id/rewindIcon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_font_rewind"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.25"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_900"
            android:textColor="@color/sushi_white"
            android:id="@id/forwardIcon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_font_forward"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.75"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_700"
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/exo_play"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:text="@string/icon_font_play"
            android:textAlignment="center"
            android:paddingStart="@dimen/sushi_spacing_nano"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/muteButton" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/fullScreenButton"
            android:background="@drawable/bg_video_control_button"
            android:layout_width="@dimen/video_small_action_button_width"
            android:layout_height="@dimen/video_small_action_button_height"
            android:layout_marginTop="@dimen/sushi_spacing_mini"
            android:layout_marginBottom="@dimen/sushi_spacing_macro"
            android:text="@string/icon_font_max_frame"
            android:layout_marginEnd="@dimen/sushi_spacing_mini"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_700"
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/muteButton"
            android:background="@drawable/bg_video_control_button"
            android:layout_width="@dimen/video_small_action_button_width"
            android:layout_height="@dimen/video_small_action_button_height"
            android:layout_marginTop="@dimen/sushi_spacing_mini"
            android:layout_marginStart="@dimen/sushi_spacing_mini"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>