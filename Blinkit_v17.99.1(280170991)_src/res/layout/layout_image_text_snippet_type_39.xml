<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/rootContainerView"
    android:background="@color/sushi_white"
    android:clipChildren="true"
    android:clipToPadding="true"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:minHeight="100.0dip"
        app:aspectRatio="0.45"
        app:cornerRadiusTopLeft="@dimen/corner_radius_base"
        app:cornerRadiusTopRight="@dimen/corner_radius_base"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@id/imageGradient"
        android:background="@drawable/gradient_bottom_75"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/image_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:translationZ="@dimen/sushi_spacing_base"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:id="@id/image_tag_text"
            android:background="@drawable/bg_image_tag"
            android:padding="@dimen/sushi_spacing_between"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:textViewType="SEMIBOLD_300" />
        <View
            android:id="@id/tag_triangle_view"
            android:background="@drawable/bg_image_tag_triangle"
            android:layout_width="@dimen/sushi_spacing_mini"
            android:layout_height="@dimen/sushi_spacing_micro" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/overlayImageIcon"
        android:layout_width="@dimen/sushi_spacing_page_side"
        android:layout_height="@dimen/sushi_spacing_page_side"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/image" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_200"
        android:textColor="@color/sushi_blue_500"
        android:id="@id/rightImageIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/icon_font_info_line"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        android:layout_marginEnd="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toBottomOf="@id/tagLayout"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/tagLayout"
        app:layout_constraintTop_toTopOf="@id/tagLayout" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/leftImageIcon"
        android:layout_width="@dimen/sushi_spacing_page_side"
        android:layout_height="@dimen/sushi_spacing_page_side"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:ellipsize="end"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_page_side"
        android:maxLines="2"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toStartOf="@id/bottom_right_button"
        app:layout_constraintStart_toEndOf="@id/leftImageIcon"
        app:layout_constraintTop_toBottomOf="@id/image" />
    <com.google.android.flexbox.FlexboxLayout
        android:orientation="horizontal"
        android:id="@id/tagLayout"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/sushi_spacing_extra"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:animateLayoutChanges="true"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:flexDirection="row"
        app:flexWrap="wrap"
        app:justifyContent="flex_start"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:textColor="@color/sushi_white"
        android:id="@id/bottom_right_button"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        android:paddingHorizontal="@dimen/sushi_spacing_base"
        app:buttonDimension="medium"
        app:buttonType="solid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image" />
    <com.zomato.ui.atomiclib.atom.ZProgressBar
        android:id="@id/pb_btn"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="@dimen/sushi_spacing_femto"
        android:layout_marginLeft="@dimen/sushi_spacing_micro"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginRight="@dimen/sushi_spacing_micro"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:indeterminate="true"
        android:indeterminateTint="@color/sushi_white"
        android:indeterminateTintMode="src_atop"
        android:layout_marginHorizontal="@dimen/sushi_spacing_micro"
        android:layout_marginVertical="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/bottom_right_button"
        app:layout_constraintEnd_toEndOf="@id/bottom_right_button"
        app:layout_constraintStart_toStartOf="@id/bottom_right_button"
        app:layout_constraintTop_toTopOf="@id/bottom_right_button"
        style="?android:progressBarStyleSmall" />
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:id="@id/info_container"
        android:background="@color/sushi_white"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:paddingStart="@dimen/sushi_spacing_base"
        android:paddingEnd="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toStartOf="@id/bottom_right_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tagLayout">
        <Space
            android:id="@id/space"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_800"
            android:gravity="center"
            android:id="@id/subtitle3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:textViewType="MEDIUM_200" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_between">
            <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                android:gravity="center"
                android:id="@id/ratingSnippet"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:ratedBlockDimenConfig="200"
                app:ratingType="stars" />
            <Space
                android:id="@id/space2"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textColor="@color/sushi_grey_500"
                android:id="@id/subtitle4_suffix_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_micro" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_500"
                android:id="@id/subtitle4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:layout_marginBottom="@dimen/sushi_spacing_micro"
                app:textViewType="MEDIUM_100" />
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@id/divider"
        android:background="@color/sushi_grey_200"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:layout_constraintTop_toBottomOf="@id/info_container" />
    <RelativeLayout
        android:id="@id/bottom_container"
        android:paddingTop="@dimen/sushi_spacing_mini"
        android:paddingBottom="@dimen/sushi_spacing_mini"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">
        <LinearLayout
            android:gravity="bottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_500"
                    android:layout_gravity="center_vertical"
                    android:id="@id/subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/sushi_spacing_between_large"
                    app:textViewType="MEDIUM_300" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="?attr_7f040475"
                    android:layout_gravity="center_vertical"
                    android:id="@id/subtitle2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:textViewType="SEMIBOLD_300" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_blue_500"
                android:id="@id/subtitle5"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sushi_spacing_micro"
                app:textViewType="SEMIBOLD_300" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.molecules.ZStepper
            android:layout_gravity="center_vertical"
            android:id="@id/stepper"
            android:paddingTop="@dimen/sushi_spacing_between_large"
            android:paddingBottom="@dimen/sushi_spacing_between_large"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            app:stepper_type="NORMAL" />
    </RelativeLayout>
    <com.zomato.ui.lib.organisms.snippets.helper.CalorieInfoCardView
        android:id="@id/calorie_info_card_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image" />
</androidx.constraintlayout.widget.ConstraintLayout>