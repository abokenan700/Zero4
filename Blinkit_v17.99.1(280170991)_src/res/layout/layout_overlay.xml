<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android">
    <ProgressBar
        android:layout_gravity="center"
        android:id="@id/progress_bar"
        android:layout_width="@dimen/z_progressview_size_mini"
        android:layout_height="@dimen/z_progressview_size_mini"
        android:indeterminateTint="?accentColor"
        style="?android:progressBarStyleSmall" />
    <ViewStub
        android:layout_gravity="center"
        android:id="@id/view_stub_shimmer_import"
        android:layout="@layout/layout_shimmer_wrapper"
        android:inflatedId="@id/shimmer_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <ViewStub
        android:layout_gravity="center"
        android:id="@id/view_stub_ncv_import"
        android:layout="@layout/layout_ncv_wrapper"
        android:inflatedId="@id/no_content_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <ViewStub
        android:layout_gravity="center"
        android:id="@id/view_stub_shimmer_import_v2"
        android:layout="@layout/layout_shimmer_wrapper_v2"
        android:inflatedId="@id/shimmer_view_v2"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
</merge>