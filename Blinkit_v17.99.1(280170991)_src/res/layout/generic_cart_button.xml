<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:background="?attr_7f04017d"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/cart_top_shadow"
        android:background="@drawable/bg_shadow"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/tv_cart_message"
        android:background="@color/menu_button_message_bg"
        android:paddingTop="@dimen/sushi_spacing_between"
        android:paddingBottom="@dimen/sushi_spacing_between"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/sushi_spacing_page_side"
        android:paddingEnd="@dimen/sushi_spacing_page_side"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cart_top_shadow"
        app:textViewType="REGULAR_100" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/sticky_footer_view"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tv_cart_message" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/tooltip_container"
        android:padding="@dimen/sushi_spacing_macro"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sticky_footer_view">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:layout_gravity="center_vertical"
            android:id="@id/tooltip_title_view"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tooltip_container_right_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_goneMarginEnd="@dimen/sushi_spacing_macro" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:layout_gravity="end|center"
            android:id="@id/tooltip_container_right_icon"
            android:padding="@dimen/size_4"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_cross"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <View
        android:id="@id/anchor_view_1"
        android:visibility="gone"
        android:layout_width="@dimen/size_8"
        android:layout_height="@dimen/size_8"
        android:translationX="@dimen/dimen_20"
        android:translationY="@dimen/sushi_spacing_micro_negative"
        android:rotation="135.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tooltip_container" />
    <View
        android:id="@id/anchor_view_2"
        android:visibility="gone"
        android:layout_width="@dimen/size_8"
        android:layout_height="@dimen/size_8"
        android:translationX="@dimen/dimen_20"
        android:translationY="@dimen/size_4_5_negative"
        android:rotation="135.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tooltip_container" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/separator"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        app:layout_constraintTop_toBottomOf="@id/sticky_footer_view"
        app:zseparator_color="?attr_7f04029b"
        app:zseparator_type="STRAIGHT" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/tooltip_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="separator, anchor_view_1" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/cl_cart_payment"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tooltip_barrier"
        app:layout_constraintWidth_percent="0.35">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@id/iv_payment_type"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/sushi_spacing_extra"
            android:adjustViewBounds="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f04048d"
            android:ellipsize="end"
            android:id="@id/tv_payment_title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textAllCaps="true"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            app:drawableEnd="@string/icon_font_up_triangle_small"
            app:layout_constraintBottom_toBottomOf="@id/iv_payment_type"
            app:layout_constraintStart_toEndOf="@id/iv_payment_type"
            app:layout_constraintTop_toTopOf="@id/iv_payment_type"
            app:textViewType="REGULAR_100" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f04048a"
            android:ellipsize="end"
            android:id="@id/tv_payment_subtitle1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:maxLines="1"
            android:alpha="0.8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_payment_title"
            app:textViewType="MEDIUM_300" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f04048d"
            android:ellipsize="end"
            android:id="@id/tv_payment_subtitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:maxLines="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_payment_subtitle1"
            app:textViewType="MEDIUM_100" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040493"
            android:ellipsize="end"
            android:id="@id/tv_payment_right_subtitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@id/tv_payment_subtitle2"
            app:layout_constraintStart_toEndOf="@id/tv_payment_subtitle2"
            app:layout_constraintTop_toTopOf="@id/tv_payment_subtitle2"
            app:textViewType="MEDIUM_100" />
        <com.zomato.ui.atomiclib.molecules.ShimmerView
            android:id="@id/shimmer_cart_payment"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shimmer_layout_id="@layout/shimmer_cart_button_payment" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.cardview.widget.CardView
        android:id="@id/cv_checkout_container"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/sushi_spacing_macro"
        android:stateListAnimator="@animator/anim_elevation_scale"
        app:cardCornerRadius="@dimen/sushi_spacing_mini"
        app:cardElevation="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cl_cart_payment"
        app:layout_constraintTop_toBottomOf="@id/tooltip_barrier">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/cl_cart_checkout"
            android:background="?selectableItemBackground"
            android:padding="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/left_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/size_30"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"
                android:paddingEnd="@dimen/sushi_spacing_base"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f0402af"
                android:id="@id/tv_checkout_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toEndOf="@id/left_icon"
                app:layout_constraintTop_toTopOf="parent"
                app:textViewType="REGULAR_400" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f0402af"
                android:id="@id/tv_checkout_subtitle"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:textAllCaps="true"
                android:layout_marginEnd="@dimen/sushi_spacing_micro"
                app:layout_constraintStart_toEndOf="@id/left_icon"
                app:layout_constraintTop_toBottomOf="@id/tv_checkout_title"
                app:textViewType="REGULAR_100" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f0402af"
                android:gravity="end"
                android:id="@id/tv_action_text"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sushi_spacing_macro"
                app:drawableEnd="@string/icon_font_left_triangle_small"
                app:drawablePadding="@dimen/sushi_spacing_nano"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_checkout_title"
                app:layout_constraintTop_toTopOf="parent"
                app:textViewType="REGULAR_500" />
            <ProgressBar
                android:id="@id/pb_checkout_cart"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/sushi_spacing_macro"
                android:indeterminate="true"
                android:indeterminateTint="?attr_7f0402af"
                android:indeterminateTintMode="src_atop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                style="?android:progressBarStyleSmall" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <FrameLayout
        android:id="@id/disabled_checkout_container"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:elevation="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/cv_checkout_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cl_cart_payment"
        app:layout_constraintTop_toTopOf="@id/cv_checkout_container" />
</androidx.constraintlayout.widget.ConstraintLayout>