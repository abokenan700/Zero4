<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/root"
    android:background="?android:colorBackground"
    android:paddingBottom="@dimen/sushi_spacing_mini"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingEnd="@dimen/sushi_spacing_base"
    android:stateListAnimator="@animator/scale_animator"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.cardview.widget.CardView
        android:id="@id/imageCard"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:cardCornerRadius="@dimen/size_8"
        app:cardElevation="@dimen/size_8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/imageContainer"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_margin="@dimen/sushi_spacing_micro">
            <View
                android:id="@id/containerView"
                android:layout_width="@dimen/sushi_spacing_femto"
                android:layout_height="@dimen/sushi_spacing_femto"
                app:layout_constraintBottom_toBottomOf="@id/icon"
                app:layout_constraintEnd_toEndOf="@id/icon"
                app:layout_constraintStart_toStartOf="@id/icon"
                app:layout_constraintTop_toTopOf="@id/icon" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/icon"
                android:layout_width="@dimen/auto_suggest_search_image_size"
                android:layout_height="0.0dip"
                app:cornerRadius="@dimen/sushi_spacing_macro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
                android:id="@id/left_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.ZCircularImageView
                android:id="@id/circularIcon"
                android:visibility="gone"
                android:layout_width="@dimen/auto_suggest_search_image_size"
                android:layout_height="@dimen/auto_suggest_search_image_size"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/imageBarries"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                app:barrierDirection="end"
                app:constraint_referenced_ids="icon, circularIcon" />
            <com.zomato.ui.atomiclib.atom.ZCircularImageView
                android:id="@id/overlayView"
                android:visibility="gone"
                android:layout_width="@dimen/auto_suggest_search_image_size"
                android:layout_height="0.0dip"
                android:scaleType="centerCrop"
                android:layout_marginEnd="@dimen/nitro_side_padding"
                app:cornerRadius="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_800"
                android:textColor="@color/sushi_white"
                android:id="@id/overlayIcon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@id/icon"
                app:layout_constraintEnd_toEndOf="@id/icon"
                app:layout_constraintStart_toStartOf="@id/icon"
                app:layout_constraintTop_toTopOf="@id/icon" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:layout_gravity="center_vertical"
        android:id="@id/left_lottie"
        android:visibility="gone"
        android:layout_width="@dimen/size_38"
        android:layout_height="@dimen/size_38"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/left_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="imageCard, left_lottie" />
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@id/title_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/subtext"
        app:layout_constraintEnd_toStartOf="@id/rightTopTag"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/left_barrier"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center_vertical"
            android:id="@id/title_prefix_image"
            android:visibility="gone"
            android:layout_width="@dimen/dimen_12"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_mini" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040475"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:includeFontPadding="false"
            app:textViewType="MEDIUM_400" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTag
        android:id="@id/rightTopTag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/title_container"
        app:layout_constraintEnd_toStartOf="@id/end_barrier"
        app:layout_constraintStart_toEndOf="@id/title_container"
        app:layout_constraintTop_toTopOf="@id/title_container"
        app:tagSize="nano"
        app:tagType="rounded" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/subtext_prefix_image"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_12"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        android:layout_marginEnd="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/subtext"
        app:layout_constraintEnd_toStartOf="@id/subtext"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/title_container"
        app:layout_constraintTop_toTopOf="@id/subtext" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040490"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@id/subtext"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/infoText"
        app:layout_constraintEnd_toStartOf="@id/end_barrier"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/subtext_prefix_image"
        app:layout_constraintTop_toBottomOf="@id/title_container"
        app:textViewType="REGULAR_300" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040490"
        android:ellipsize="end"
        android:id="@id/infoText"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constraintBottom_toTopOf="@id/bottomTag"
        app:layout_constraintEnd_toStartOf="@id/end_barrier"
        app:layout_constraintStart_toStartOf="@id/title_container"
        app:layout_constraintTop_toBottomOf="@id/subtext"
        app:textViewType="REGULAR_300" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:id="@id/bottomTag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/title_container"
        app:layout_constraintTop_toBottomOf="@id/infoText"
        app:tagSize="nano"
        app:tagType="rounded" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/end_barrier"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        app:barrierDirection="start"
        app:barrierMargin="@dimen/sushi_spacing_macro_negative"
        app:constraint_referenced_ids="rightButton, right_tag , right_icon" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/rightButton"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZBgImageTagView
        android:id="@id/right_bg_image_tag_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:id="@id/right_tag"
        android:paddingLeft="@dimen/sushi_spacing_mini"
        android:paddingTop="@dimen/dimen_4"
        android:paddingRight="@dimen/sushi_spacing_mini"
        android:paddingBottom="@dimen/dimen_4"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:paddingHorizontal="@dimen/sushi_spacing_mini"
        android:paddingVertical="@dimen/dimen_4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
        android:gravity="end|center"
        android:layout_gravity="center_vertical"
        android:id="@id/right_icon"
        android:visibility="gone"
        android:layout_width="@dimen/size_24"
        android:layout_height="@dimen/size_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>