<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <include
        android:id="@id/shimmer_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/horizontal_product_asp_v3_shimmer" />
    <include
        android:id="@id/shimmer_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_12"
        app:layout_constraintStart_toEndOf="@id/shimmer_1"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/horizontal_product_asp_v3_shimmer" />
    <include
        android:id="@id/shimmer_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_12"
        app:layout_constraintStart_toEndOf="@id/shimmer_2"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/horizontal_product_asp_v3_shimmer" />
</androidx.constraintlayout.widget.ConstraintLayout>