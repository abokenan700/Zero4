<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:orientation="vertical"
    android:background="@color/sushi_white"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.android.zcommons.webview.views.ObservableWebView
        android:id="@id/renamedweb_view"
        android:scrollbars="none"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <payments.zomato.paymentkit.ui.molecules.PaymentsNoContentView
        android:id="@id/renamedweb_view_overlay"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:paymentsNoContentState="loading" />
</FrameLayout>