<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/color_transparent"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_800"
            android:textColor="@color/color_white"
            android:layout_gravity="center_horizontal"
            android:id="@id/closeButton"
            android:padding="@dimen/sushi_spacing_macro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:text="@string/icon_font_cross"
            android:backgroundTint="@color/tokenised_slate_700" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:id="@id/title"
            android:background="?attr_7f04017d"
            android:paddingLeft="@dimen/sushi_spacing_base"
            android:paddingTop="@dimen/sushi_spacing_base"
            android:paddingRight="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_base"
            android:paddingVertical="@dimen/sushi_spacing_base" />
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/separator"
            android:layout_width="fill_parent"
            android:layout_height="1.0dip"
            app:zseparator_color="@color/sushi_grey_200"
            app:zseparator_type="STRAIGHT" />
        <FrameLayout
            android:id="@id/container"
            android:background="@color/sushi_white"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <FrameLayout
        android:id="@id/fragment_container"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:elevation="@dimen/sushi_spacing_macro" />
</FrameLayout>