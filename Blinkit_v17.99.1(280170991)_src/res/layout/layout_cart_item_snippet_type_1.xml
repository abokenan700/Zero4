<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/primary_image_container"
        android:padding="@dimen/sushi_spacing_pico"
        android:visibility="gone"
        android:layout_width="@dimen/size_46"
        android:layout_height="@dimen/size_46"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/primary_image"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:cornerRadius="@dimen/size_8" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/left_image"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_between"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
        android:id="@id/left_icon"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_12"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/image_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="left_image, left_icon, primary_image_container" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_16"
        android:layout_marginEnd="@dimen/size_8"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/image_barrier"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.lib.snippets.ZExpandableGroupView
        android:id="@id/expandable_group_view"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/sushi_spacing_extra"
        android:layout_marginEnd="@dimen/dimen_20"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/image_barrier"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/subtitle"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        android:layout_marginEnd="@dimen/size_8"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/expandable_group_view" />
    <com.zomato.ui.atomiclib.atom.ZTruncatedTextView
        android:textColor="?attr_7f040490"
        android:id="@id/subtitle2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        android:layout_marginEnd="@dimen/size_8"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:textViewType="MEDIUM_100" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/subtitle3"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        android:layout_marginEnd="@dimen/size_8"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/subtitle2" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/subtitle4_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/subtitle3">
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:layout_gravity="center_vertical"
            android:id="@id/subtitle4_lottie"
            android:layout_width="@dimen/size_12"
            android:layout_height="@dimen/size_12"
            android:layout_marginEnd="@dimen/dimen_4" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/subtitle4"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/horizontal_imageview_1"
        android:visibility="gone"
        android:layout_width="@dimen/size_42"
        android:layout_height="@dimen/size_42"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:cornerRadius="@dimen/sushi_spacing_micro"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/subtitle4_layout" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/horizontal_imageview_2"
        android:visibility="gone"
        android:layout_width="@dimen/size_42"
        android:layout_height="@dimen/size_42"
        android:layout_marginStart="@dimen/size_8"
        app:cornerRadius="@dimen/sushi_spacing_micro"
        app:layout_constraintStart_toEndOf="@id/horizontal_imageview_1"
        app:layout_constraintTop_toTopOf="@id/horizontal_imageview_1" />
    <View
        android:id="@id/horizontal_image_overlay_1"
        android:background="@color/sushi_black"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:alpha="0.03"
        app:layout_constraintBottom_toBottomOf="@id/horizontal_imageview_1"
        app:layout_constraintEnd_toEndOf="@id/horizontal_imageview_1"
        app:layout_constraintStart_toStartOf="@id/horizontal_imageview_1"
        app:layout_constraintTop_toTopOf="@id/horizontal_imageview_1" />
    <View
        android:id="@id/horizontal_image_overlay_2"
        android:background="@color/sushi_black"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:alpha="0.03"
        app:layout_constraintBottom_toBottomOf="@id/horizontal_imageview_2"
        app:layout_constraintEnd_toEndOf="@id/horizontal_imageview_2"
        app:layout_constraintStart_toStartOf="@id/horizontal_imageview_2"
        app:layout_constraintTop_toTopOf="@id/horizontal_imageview_2" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        android:layout_marginEnd="@dimen/size_8"
        app:buttonDimension="small"
        app:buttonType="text"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/horizontal_imageview_1" />
    <com.zomato.ui.lib.snippets.ZImageTagView
        android:id="@id/cart_secondary_info_tag_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/button"
        app:tagSize="large"
        app:tagType="rounded" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/subtitle6"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        android:layout_marginEnd="@dimen/size_8"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/cart_secondary_info_tag_view" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/subtitle5"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        android:layout_marginEnd="@dimen/size_8"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/subtitle6" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/button_2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_6"
        android:layout_marginEnd="@dimen/size_8"
        app:buttonDimension="small"
        app:buttonType="text"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/subtitle5" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="start"
        app:constraint_referenced_ids="stepper, right_title" />
    <com.zomato.ui.atomiclib.molecules.ZStepper
        android:id="@id/stepper"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:stepper_type="SMALL"
        app:stepper_version="V2" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/stepper_bottom_label"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        app:layout_constraintEnd_toEndOf="@id/stepper"
        app:layout_constraintStart_toStartOf="@id/stepper"
        app:layout_constraintTop_toBottomOf="@id/stepper" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/right_title"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        app:layout_constraintEnd_toStartOf="@id/right_bg_image_tag_view"
        app:layout_constraintTop_toBottomOf="@id/stepper_bottom_label" />
    <com.zomato.ui.atomiclib.atom.ZBgImageTagView
        android:id="@id/right_bg_image_tag_view"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepper_bottom_label" />
</merge>