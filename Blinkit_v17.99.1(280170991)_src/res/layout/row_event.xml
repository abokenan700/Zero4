<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center"
    android:orientation="horizontal"
    android:id="@id/container_network_call"
    android:background="?selectableItemBackground"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/event_logger_margin_4"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <View
        android:id="@id/view_event_status_indicator"
        android:background="@color/green_73c04d"
        android:layout_width="@dimen/event_logger_margin_8"
        android:layout_height="fill_parent" />
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/event_logger_padding_8"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textStyle="bold"
                android:id="@id/txt_event_name"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/event_logger_margin_4"
                android:layout_weight="1.0" />
            <TextView
                android:id="@id/txt_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/event_logger_margin_8" />
        </LinearLayout>
        <TextView
            android:id="@id/txt_event_important_keys"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/event_logger_margin_4" />
    </LinearLayout>
</LinearLayout>