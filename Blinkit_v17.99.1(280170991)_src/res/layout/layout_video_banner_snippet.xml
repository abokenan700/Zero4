<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.bmediaview.BMediaView
        android:id="@id/player_view_container"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.lib.organisms.snippets.video.customViews.ZExoSeekbar
        android:id="@id/seekbar"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/qd_margin_6"
        app:actualBarHeight="@dimen/zexoseekbar_height"
        app:actualBufferedColor="@color/color_transparent"
        app:actualUnplayedColor="@color/sushi_grey_600"
        app:bar_height="@dimen/zexoseekbar_height"
        app:buffered_color="@color/sushi_grey_600"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@id/player_view_container"
        app:layout_constraintEnd_toStartOf="@id/remaining_time"
        app:layout_constraintStart_toStartOf="@id/player_view_container"
        app:layout_goneMarginStart="@dimen/sushi_spacing_mini"
        app:played_color="@color/sushi_white"
        app:scrubber_color="@color/sushi_white"
        app:scrubber_disabled_size="@dimen/zexoseekbar_scrubber_small_size"
        app:scrubber_dragged_size="@dimen/zexoseekbar_scrubber_big_size"
        app:scrubber_enabled_size="@dimen/zexoseekbar_scrubber_small_size"
        app:unplayed_color="@color/sushi_grey_600" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:id="@id/remaining_time"
        android:paddingBottom="@dimen/sushi_spacing_mini"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/size_32"
        android:layout_marginEnd="@dimen/event_logger_margin_12"
        app:layout_constraintBottom_toBottomOf="@id/player_view_container"
        app:layout_constraintEnd_toEndOf="@id/player_view_container"
        app:textViewType="MEDIUM_200" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitIconViewStub
        android:textSize="@dimen/sushi_textsize_500"
        android:textColor="@color/sushi_black"
        android:gravity="center"
        android:id="@id/expand_icon"
        android:background="@drawable/bg_video_control_button"
        android:visibility="gone"
        android:layout_width="@dimen/size_32"
        android:layout_height="@dimen/size_32"
        android:layout_marginTop="@dimen/qd_margin_8"
        android:text="@string/icon_font_expand"
        android:layout_marginEnd="@dimen/qd_margin_8"
        android:translationZ="@dimen/sushi_spacing_mini"
        android:backgroundTint="@color/sushi_white"
        app:layout_constraintEnd_toEndOf="@id/player_view_container"
        app:layout_constraintTop_toTopOf="@id/player_view_container" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitIconViewStub
        android:textSize="@dimen/sushi_textsize_700"
        android:textColor="@color/sushi_black"
        android:gravity="center"
        android:id="@id/mute_toggle_icon"
        android:background="@drawable/bg_video_control_button"
        android:visibility="gone"
        android:layout_width="@dimen/size_32"
        android:layout_height="@dimen/size_32"
        android:layout_marginTop="@dimen/qd_margin_8"
        android:layout_marginEnd="@dimen/qd_margin_10"
        android:translationZ="@dimen/sushi_spacing_mini"
        android:backgroundTint="@color/sushi_white"
        app:layout_constraintEnd_toStartOf="@id/expand_icon"
        app:layout_constraintTop_toTopOf="@id/player_view_container" />
    <com.blinkit.blink.elements.ui.atoms.button.BlinkitButtonView
        android:id="@id/bottom_button"
        android:padding="@dimen/sushi_spacing_base"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/qd_margin_20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitIconViewStub
        android:textSize="@dimen/dimen_20"
        android:textColor="@color/sushi_black"
        android:gravity="center"
        android:id="@id/pausePlayButton"
        android:background="@drawable/bg_video_control_button"
        android:visibility="gone"
        android:layout_width="@dimen/size_56"
        android:layout_height="@dimen/size_56"
        android:translationZ="@dimen/sushi_spacing_mini"
        android:backgroundTint="@color/sushi_white"
        app:layout_constraintBottom_toBottomOf="@id/player_view_container"
        app:layout_constraintEnd_toEndOf="@id/player_view_container"
        app:layout_constraintStart_toStartOf="@id/player_view_container"
        app:layout_constraintTop_toTopOf="@id/player_view_container" />
</merge>