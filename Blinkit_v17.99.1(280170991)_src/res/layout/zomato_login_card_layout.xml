<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:background="?attr_7f04017d"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:elevation="@dimen/dimen_point_one"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/container"
        android:background="?attr_7f0403d7"
        android:visibility="invisible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/qd_margin_20"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        android:layout_marginRight="@dimen/qd_margin_20"
        android:layout_marginBottom="@dimen/sushi_spacing_loose"
        android:layout_marginHorizontal="@dimen/qd_margin_20"
        android:layout_marginVertical="@dimen/sushi_spacing_loose">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040466"
            android:id="@id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_extra"
            android:layout_marginTop="@dimen/sushi_spacing_loose"
            android:layout_marginRight="@dimen/sushi_spacing_extra"
            android:text=" "
            android:lines="1"
            android:layout_marginHorizontal="@dimen/sushi_spacing_extra"
            app:layout_constraintBottom_toTopOf="@id/subtitle_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:textViewType="SEMIBOLD_400" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f04047c"
            android:id="@id/subtitle_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_extra"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginRight="@dimen/sushi_spacing_extra"
            android:text=" "
            android:lines="1"
            android:layout_marginHorizontal="@dimen/sushi_spacing_extra"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title_text"
            app:textViewType="SEMIBOLD_400" />
        <ProgressBar
            android:id="@id/pb_login_button"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/size_20"
            android:elevation="@dimen/sushi_spacing_micro"
            android:progressTint="@color/sushi_white"
            android:indeterminateTint="@color/sushi_white"
            android:indeterminateTintMode="src_atop"
            app:layout_constraintBottom_toBottomOf="@id/z_login_button"
            app:layout_constraintLeft_toLeftOf="@id/z_login_button"
            app:layout_constraintRight_toRightOf="@id/z_login_button"
            app:layout_constraintTop_toTopOf="@id/z_login_button"
            style="?android:progressBarStyleSmall" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/z_login_button"
            android:background="@drawable/qd_all_rounded_green_8dp"
            android:padding="@dimen/dimen_16"
            android:visibility="invisible"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_loose"
            android:layout_marginTop="@dimen/qd_margin_20"
            android:layout_marginRight="@dimen/sushi_spacing_loose"
            android:layout_marginBottom="@dimen/sushi_spacing_mini"
            android:contentDescription="@string/login_with_zomato"
            android:layout_marginHorizontal="@dimen/sushi_spacing_loose"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle_text">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textSize="@dimen/dimen_14"
                android:textColor="@color/white"
                android:layout_gravity="center_vertical"
                android:id="@id/login_button_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_text"
                android:fontFamily="@font/okra_semibold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@id/login_button_image"
                app:layout_constraintTop_toTopOf="parent" />
            <ImageView
                android:id="@id/login_button_image"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dimen_12"
                android:layout_marginLeft="@dimen/sushi_spacing_mini"
                android:layout_marginBottom="@dimen/dimen_2"
                android:src="@drawable/zomato"
                app:layout_constraintBottom_toBottomOf="@id/login_button_text"
                app:layout_constraintLeft_toRightOf="@id/login_button_text"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="@id/login_button_text" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/font_icon_size_10"
            android:gravity="center"
            android:id="@id/info_text"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_alone"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_alone"
            android:text="@string/zomato_login_info_text"
            android:layout_marginHorizontal="@dimen/sushi_spacing_alone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/z_login_button" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/font_size_mini"
            android:textColor="?themeColor500"
            android:id="@id/phonenumber_login"
            android:padding="@dimen/dimen_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_extra"
            android:layout_marginTop="@dimen/sushi_spacing_loose"
            android:layout_marginRight="@dimen/sushi_spacing_extra"
            android:layout_marginBottom="@dimen/sushi_spacing_loose"
            android:text="@string/phone_number_choice_text"
            android:fontFamily="@font/okra_semibold"
            android:stateListAnimator="@animator/sushi_text_button_click_animator"
            android:layout_marginHorizontal="@dimen/sushi_spacing_extra"
            android:layout_marginVertical="@dimen/sushi_spacing_loose"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/info_text" />
        <com.blinkit.consumerapp.ui.nitroerroroverlay.NitroOverlay
            android:id="@id/nitro_overlay"
            android:paddingBottom="@dimen/sushi_spacing_base"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@id/shimmer"
        android:background="@color/sushi_white"
        android:clickable="false"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginLeft="@dimen/margin_20"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        android:layout_marginRight="@dimen/margin_20"
        android:layout_marginBottom="@dimen/sushi_spacing_loose"
        android:elevation="@dimen/dimen_point_one"
        android:layout_marginHorizontal="@dimen/margin_20"
        android:layout_marginVertical="@dimen/sushi_spacing_loose">
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_20"
            android:layout_marginLeft="@dimen/size_64"
            android:layout_marginTop="@dimen/sushi_spacing_loose"
            android:layout_marginRight="@dimen/size_64"
            android:layout_marginHorizontal="@dimen/size_64"
            app:shimmer_corner_radius="@dimen/dimen_4" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="@dimen/size_120"
            android:layout_height="@dimen/size_12"
            android:layout_marginLeft="@dimen/size_64"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/size_64"
            android:layout_marginHorizontal="@dimen/size_64"
            app:shimmer_corner_radius="@dimen/dimen_4" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_48"
            android:layout_marginLeft="@dimen/size_24"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:layout_marginRight="@dimen/size_24"
            android:layout_marginHorizontal="@dimen/size_24"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_8"
            android:layout_marginLeft="@dimen/size_64"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginRight="@dimen/size_64"
            android:layout_marginHorizontal="@dimen/size_64"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_8"
            android:layout_marginLeft="@dimen/size_108"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginRight="@dimen/size_108"
            android:layout_marginHorizontal="@dimen/size_108"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dimen_18"
            android:layout_marginLeft="@dimen/dimen_40"
            android:layout_marginTop="@dimen/sushi_spacing_loose"
            android:layout_marginRight="@dimen/dimen_40"
            android:layout_marginHorizontal="@dimen/dimen_40"
            app:shimmer_corner_radius="@dimen/dimen_12" />
    </LinearLayout>
</FrameLayout>