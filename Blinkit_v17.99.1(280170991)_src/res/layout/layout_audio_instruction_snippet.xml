<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:padding="@dimen/sushi_spacing_base"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    app:layout_constraintDimensionRatio="1"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:textSize="@dimen/sushi_textsize_800"
        android:textColor="?attr_7f0402a6"
        android:gravity="center_vertical"
        android:id="@id/play_pause_icon"
        android:layout_width="@dimen/sushi_spacing_alone"
        android:layout_height="@dimen/sushi_spacing_alone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:gravity="end|center"
        android:id="@id/right_icon"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_alone"
        android:layout_height="@dimen/sushi_spacing_alone"
        app:layout_constraintBottom_toBottomOf="@id/play_pause_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@id/play_pause_icon"
        app:layout_constraintTop_toTopOf="@id/play_pause_icon" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/bottom_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="play_pause_icon,left_title,right_icon" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:textColor="?attr_7f0402a6"
        android:id="@id/left_title"
        android:layout_width="@dimen/dimen_80"
        android:layout_height="wrap_content"
        android:text="@string/record"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:textSize="@dimen/sushi_textsize_200"
        android:textColor="?attr_7f0402a6"
        android:id="@id/right_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/release_to_save"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:textColor="?attr_7f0402a6"
        android:id="@id/subtitle"
        android:layout_width="@dimen/dimen_80"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:text="@string/audio_press_and_hold"
        app:layout_constraintBottom_toTopOf="@id/play_timer_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
        app:layout_constraintVertical_bias="1.0" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:id="@id/play_timer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintVertical_bias="1.0" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:id="@id/record_timer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toTopOf="@id/recording_animation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.image.BLottieAnimationViewStub
        android:id="@id/recording_animation"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/sushi_spacing_extra"
        android:layout_marginEnd="@dimen/sushi_spacing_macro_negative"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>