<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:id="@id/root_container"
    android:paddingLeft="@dimen/sushi_spacing_base"
    android:paddingRight="@dimen/sushi_spacing_base"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/sushi_spacing_base"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@id/snippets_container"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_extra">
        <com.zomato.ui.lib.organisms.snippets.form.expandableFormSnippet.view.ExpandableFormSnippetType1
            android:id="@id/child_1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <com.zomato.ui.lib.organisms.snippets.form.expandableFormSnippet.view.ExpandableFormSnippetType1
            android:id="@id/child_2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="center"
        android:id="@id/bottom_button_1"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/size_200"
        app:buttonColor="?themeColor500"
        app:buttonDimension="large"
        app:buttonType="text" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:ellipsize="end"
        android:layout_gravity="center"
        android:id="@id/custom_form_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:maxLines="2"
        android:layout_marginEnd="@dimen/sushi_spacing_macro" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="center"
        android:id="@id/bottom_button_2"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:buttonColor="?themeColor500"
        app:buttonDimension="large"
        app:buttonType="solid" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="center"
        android:id="@id/bottom_button_3"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:maxWidth="@dimen/size_200"
        app:buttonColor="?themeColor500"
        app:buttonDimension="medium"
        app:buttonType="text" />
</merge>