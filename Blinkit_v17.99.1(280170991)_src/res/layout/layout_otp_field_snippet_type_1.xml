<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/data_container"
    android:padding="@dimen/sushi_spacing_extra"
    android:paddingLeft="@dimen/sushi_spacing_extra"
    android:paddingTop="@dimen/sushi_spacing_macro"
    android:paddingRight="@dimen/sushi_spacing_extra"
    android:paddingBottom="@dimen/sushi_spacing_extra"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/sushi_spacing_extra"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/subtitle"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro" />
    <com.zomato.ui.lib.atom.ZOtpEditText
        android:textSize="@dimen/sushi_textsize_600"
        android:id="@id/otp_edit_text"
        android:paddingLeft="@dimen/sushi_spacing_micro"
        android:paddingRight="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/size50"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        android:maxLength="6"
        android:digits="\ 1234567890"
        android:inputType="text"
        android:paddingHorizontal="@dimen/sushi_spacing_micro"
        app:zotp_background_color="?attr_7f0403d7"
        app:zotp_border_color="@color/sushi_grey_300"
        app:zotp_focused_border_color="?attr_7f040475"
        app:zotp_item_border_width="@dimen/border_stroke_width"
        app:zotp_item_corner_radius="@dimen/corner_radius"
        app:zotp_item_height="@dimen/size_44"
        app:zotp_item_spacing="@dimen/sushi_spacing_extra"
        app:zotp_item_width="@dimen/size_38" />
    <com.zomato.ui.atomiclib.atom.ZButtonWithLoader
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/resend_otp_button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_14" />
</LinearLayout>