<?xml version="1.0" encoding="utf-8"?>
<merge
    android:gravity="center"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1.0">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:textColor="?attr_7f040475"
            android:id="@id/title"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:textColor="?attr_7f040475"
            android:id="@id/subtitle1"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:layout_gravity="center"
        android:id="@id/separator"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_point_seven"
        android:layout_height="@dimen/sushi_spacing_loose"
        app:zseparator_color="?attr_7f040297"
        app:zseparator_type="VERTICAL" />
</merge>