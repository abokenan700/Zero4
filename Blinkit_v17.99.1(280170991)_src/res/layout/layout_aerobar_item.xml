<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_gravity="center"
        android:id="@id/imageRadiusContainer"
        android:layout_width="@dimen/size_36"
        android:layout_height="@dimen/size_36"
        android:layout_marginTop="@dimen/padding_5"
        android:layout_marginBottom="@dimen/padding_5"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/padding_12"
        android:layout_alignParentStart="true">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center"
            android:id="@id/iv_aerobar"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="centerCrop" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:layout_gravity="center"
            android:id="@id/animatedImage"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_margin="@dimen/sushi_spacing_micro"
            android:contentDescription="@null"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_repeatMode="restart" />
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/container_tv_aerobar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:paddingStart="@dimen/padding_12"
        android:layout_toStartOf="@id/container_action_aerobar"
        android:layout_toEndOf="@id/imageRadiusContainer">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?android:textColorPrimary"
            android:ellipsize="end"
            android:id="@id/tv_title_aerobar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            app:textViewType="SEMIBOLD_300" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="8.0sp"
            android:textColor="?android:textColorSecondary"
            android:ellipsize="end"
            android:id="@id/tv_subtext_aerobar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:textViewType="REGULAR_200" />
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/container_action_aerobar"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/padding_5"
        android:layout_marginBottom="@dimen/padding_5"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/padding_12"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        android:layout_alignParentEnd="true">
        <com.zomato.ui.lib.organisms.snippets.ratingBar.ZStarRatingBar
            android:gravity="end"
            android:layout_gravity="center_vertical"
            android:id="@id/ratingBar"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            app:starSize="small" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:textStyle="bold"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_right_action_aerobar"
            android:paddingTop="@dimen/padding_12"
            android:paddingBottom="@dimen/padding_12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen_12"
            android:paddingStart="@dimen/padding_12" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/iconfont_size"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@id/icon_right_action_aerobar"
            android:background="@drawable/uikit_aerobar_action_bg"
            android:layout_width="@dimen/size_24"
            android:layout_height="@dimen/size_24"
            android:layout_margin="@dimen/nitro_vertical_padding_4"
            app:iconfont_enable_feedback="true" />
    </LinearLayout>
</RelativeLayout>