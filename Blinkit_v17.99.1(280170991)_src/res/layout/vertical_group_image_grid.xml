<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_margin="@dimen/sushi_spacing_mini"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/image_1"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:cornerRadius="@dimen/corner_radius"
        app:layout_constraintBottom_toTopOf="@id/image_2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/image_2"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:cornerRadius="@dimen/corner_radius"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/image_1"
        app:layout_constraintTop_toBottomOf="@id/image_1" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/image_3"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        app:cornerRadius="@dimen/corner_radius"
        app:layout_constraintBottom_toBottomOf="@id/image_1"
        app:layout_constraintStart_toEndOf="@id/image_1"
        app:layout_constraintTop_toTopOf="@id/image_1" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/image_4"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:cornerRadius="@dimen/corner_radius"
        app:layout_constraintBottom_toBottomOf="@id/image_2"
        app:layout_constraintEnd_toEndOf="@id/image_3"
        app:layout_constraintStart_toStartOf="@id/image_3"
        app:layout_constraintTop_toTopOf="@id/image_2" />
</merge>