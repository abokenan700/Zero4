<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/constraintLayout"
    android:tag="layout/activity_scratch_card_detailed_v2_0"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_loose"
        android:layout_marginStart="@dimen/size_56"
        android:layout_marginEnd="@dimen/size_56"
        app:layout_constraintBottom_toTopOf="@id/cardView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/titleTop"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toTopOf="@id/subtitleTop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/subtitleTop"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toTopOf="@id/subtitle2Top"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/subtitle2Top"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center"
        android:id="@id/cardBgImage"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@id/cardView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/cardView" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:layout_gravity="center"
        android:id="@id/cardBgLottie"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.cardview.widget.CardView
        android:id="@id/cardView"
        android:visibility="invisible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/size_64"
        android:layout_marginRight="@dimen/size_64"
        android:transitionName="scratch_card"
        android:layout_marginHorizontal="@dimen/size_64"
        app:cardCornerRadius="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/closeButtonTop"
        app:layout_constraintVertical_bias="0.3">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/bottomBarier"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/sushi_spacing_femto"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/scratchCardSnippet" />
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/topBarrier"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sushi_spacing_femto"
                app:layout_constraintBottom_toTopOf="@id/scratchCardSnippet"
                app:layout_constraintStart_toStartOf="parent" />
            <FrameLayout
                android:id="@id/scratchCardSnippet"
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.lib.atom.ZScratchViewV2
                android:id="@id/scratchview"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@id/bottomBarier"
                app:layout_constraintTop_toTopOf="@id/topBarrier"
                app:tile_mode="CLAMP" />
            <FrameLayout
                android:id="@id/overlay_container"
                android:layout_width="@dimen/sushi_spacing_femto"
                android:layout_height="@dimen/sushi_spacing_femto"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:layout_gravity="center"
                    android:id="@id/overlayImage"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:scaleType="centerCrop" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@id/overlayTitle"
                    android:padding="@dimen/sushi_spacing_macro"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
            </FrameLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_gravity="center"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:gravity="center"
                    android:id="@id/overlayTitle2"
                    android:padding="@dimen/sushi_spacing_macro"
                    android:visibility="invisible"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <View
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@id/tv_shimmer"
                    android:layout_width="@dimen/size_30"
                    android:layout_height="@dimen/sushi_spacing_femto"
                    android:scaleY="2.0"
                    android:rotation="30.0"
                    app:layout_constraintBottom_toBottomOf="@id/overlayTitle2"
                    app:layout_constraintStart_toStartOf="@id/overlayTitle2"
                    app:layout_constraintTop_toTopOf="@id/overlayTitle2" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:id="@id/lottieAnimationView"
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:elevation="@dimen/size_6"
                app:layout_constraintBottom_toBottomOf="@id/scratchCardSnippet"
                app:layout_constraintEnd_toEndOf="@id/scratchCardSnippet"
                app:layout_constraintStart_toStartOf="@id/scratchCardSnippet"
                app:layout_constraintTop_toTopOf="@id/scratchCardSnippet" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/title"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        android:layout_marginStart="@dimen/size_56"
        android:layout_marginEnd="@dimen/size_56"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardView" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/subtitle"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/size_56"
        android:layout_marginEnd="@dimen/size_56"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/subtitle2"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/size_56"
        android:layout_marginEnd="@dimen/size_56"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_alone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle2" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_800"
        android:textColor="@color/color_black"
        android:layout_gravity="center_horizontal"
        android:id="@id/closeButton"
        android:padding="@dimen/sushi_spacing_macro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/icon_font_cross"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button"
        app:layout_constraintVertical_bias="0.7" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_900"
        android:textColor="@color/sushi_white"
        android:layout_gravity="center_horizontal"
        android:id="@id/closeButtonTop"
        android:padding="@dimen/sushi_spacing_macro"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_40"
        android:text="@string/icon_font_cross"
        android:layout_marginEnd="@dimen/size_30"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@id/bottom_sheet_coordinator_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:elevation="@dimen/sushi_spacing_nano">
        <androidx.cardview.widget.CardView
            android:id="@id/bottom_card_view"
            android:background="?attr_7f04017d"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
            <LinearLayout
                android:orientation="vertical"
                android:background="?attr_7f04017d"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:id="@id/bottomsheet_title"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_page_side"
                    android:layout_marginTop="@dimen/sushi_spacing_extra"
                    android:layout_marginRight="@dimen/sushi_spacing_page_side"
                    android:layout_marginBottom="@dimen/sushi_spacing_extra"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_page_side"
                    android:layout_marginVertical="@dimen/sushi_spacing_extra" />
                <com.zomato.ui.atomiclib.atom.ZSeparator
                    android:id="@id/bottom_sheet_title_separator"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/dimen_point_five"
                    app:zseparator_color="@color/sushi_grey_200" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@id/bottom_card_rv"
                    android:paddingTop="@dimen/sushi_spacing_between"
                    android:paddingBottom="@dimen/size_100"
                    android:clipToPadding="false"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <FrameLayout
            android:layout_gravity="bottom"
            android:id="@id/bottom_card_button_container"
            android:background="?attr_7f04017d"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:elevation="@dimen/sushi_spacing_loose">
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/bottom_card_button"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/sushi_spacing_page_side" />
        </FrameLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <com.zomato.android.zcommons.overlay.BaseNitroOverlay
        android:id="@id/nitroOverlay"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:elevation="@dimen/size_5" />
</androidx.constraintlayout.widget.ConstraintLayout>