<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/product_image_overlay"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/product_image"
        app:layout_constraintEnd_toEndOf="@id/product_image"
        app:layout_constraintStart_toStartOf="@id/product_image"
        app:layout_constraintTop_toTopOf="@id/product_image" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/product_image"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toTopOf="@id/product_name"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
        android:id="@id/shimmer_view"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/negative_dimen_18"
        android:backgroundTint="@color/transparent_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/product_image" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildTextView
        android:id="@id/pdp_product_name"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_26"
        android:layout_marginStart="@dimen/size24"
        app:layout_constraintEnd_toEndOf="@id/shimmer_view"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/shimmer_view"
        app:layout_constraintTop_toTopOf="@id/shimmer_view"
        app:layout_constraintWidth_percent="0.85"
        app:shimmer_corner_radius="@dimen/size_8"
        app:textFontWeight="extrabold"
        app:textViewType="BOLD_800" />
</merge>