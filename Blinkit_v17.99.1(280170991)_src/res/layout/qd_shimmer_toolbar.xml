        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shimmer_corner_radius="18.0dip" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/text_shimmer"
        android:background="@color/color_white"
        android:layout_width="120.0dip"
        android:layout_height="14.0dip"
        android:layout_marginStart="@dimen/dimen_12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/icon_shimmer"
        app:layout_constraintTop_toTopOf="parent"
        app:shimmer_corner_radius="4.0dip" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/right_icon_shimmer"
        android:background="@color/color_white"
        android:layout_width="@dimen/size_36"
        android:layout_height="@dimen/size_36"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shimmer_corner_radius="18.0dip" />
</androidx.constraintlayout.widget.ConstraintLayout>