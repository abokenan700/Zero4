<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:paddingTop="@dimen/dimen_4"
    android:paddingBottom="@dimen/sushi_spacing_macro"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:layout_marginLeft="@dimen/sushi_spacing_mini"
    android:layout_marginTop="@dimen/sushi_spacing_micro"
    android:layout_marginRight="@dimen/sushi_spacing_mini"
    android:layout_marginBottom="@dimen/sushi_spacing_micro"
    android:layout_marginHorizontal="@dimen/sushi_spacing_mini"
    android:layout_marginVertical="@dimen/sushi_spacing_micro"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/icon_shimmer"
        android:background="@color/color_white"
        android:layout_width="@dimen/size_36"
        android:layout_height="@dimen/size_36"
        app:layout_constraintBottom_toBottomOf="parent"
