<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_horizontal"
    android:orientation="horizontal"
    android:paddingLeft="@dimen/size_12"
    android:paddingTop="@dimen/sushi_spacing_macro"
    android:paddingRight="@dimen/size_12"
    android:paddingBottom="@dimen/sushi_spacing_macro"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/sushi_spacing_macro"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <Space
        android:layout_gravity="center"
        android:id="@id/custom_tag_dummy_space"
        android:visibility="visible"
        android:layout_width="@dimen/size_6"
        android:layout_height="@dimen/size_6" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAlignment="center" />
</LinearLayout>