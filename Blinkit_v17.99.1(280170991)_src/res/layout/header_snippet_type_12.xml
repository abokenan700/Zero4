<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/bg_gradient_view"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/constraint_root"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:id="@id/top_banner_lottie"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/top_banner_image"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/top_banner_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="top_banner_lottie, top_banner_image" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/title"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/size_8"
            android:layout_marginTop="@dimen/size_24"
            android:layout_marginRight="@dimen/size_8"
            android:layout_marginBottom="@dimen/size_6"
            android:textAlignment="center"
            android:layout_marginHorizontal="@dimen/size_8"
            app:layout_constraintBottom_toTopOf="@id/title_separator"
            app:layout_constraintEnd_toStartOf="@id/right_barrier"
            app:layout_constraintStart_toEndOf="@id/left_barrier"
            app:layout_constraintTop_toBottomOf="@id/top_banner_barrier" />
        <View
            android:id="@id/title_separator"
            android:background="@color/color_black"
            android:layout_width="@dimen/size_60"
            android:layout_height="1.0dip"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:layout_marginBottom="@dimen/sushi_spacing_nano"
            android:layout_marginVertical="@dimen/sushi_spacing_nano"
            app:layout_constraintBottom_toTopOf="@id/subtitle"
            app:layout_constraintEnd_toEndOf="@id/right_barrier"
            app:layout_constraintStart_toStartOf="@id/left_barrier"
            app:layout_constraintTop_toBottomOf="@id/title" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/subtitle"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/right_separator"
            app:layout_constraintStart_toEndOf="@id/left_separator"
            app:layout_constraintTop_toBottomOf="@id/title_separator" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/left_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="end"
            app:constraint_referenced_ids="left_image,left_lottie" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/right_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="start"
            app:constraint_referenced_ids="right_image,right_lottie" />
        <View
            android:id="@id/left_separator"
            android:background="@color/sushi_grey_100"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="@dimen/sushi_spacing_pico"
            android:layout_marginStart="@dimen/sushi_spacing_micro"
            android:layout_marginEnd="4.0dip"
            app:layout_constraintBottom_toBottomOf="@id/subtitle"
            app:layout_constraintEnd_toStartOf="@id/subtitle"
            app:layout_constraintStart_toEndOf="@id/left_barrier"
            app:layout_constraintTop_toTopOf="@id/subtitle" />
        <View
            android:id="@id/right_separator"
            android:background="@color/sushi_grey_100"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="@dimen/sushi_spacing_pico"
            android:layout_marginStart="4.0dip"
            android:layout_marginEnd="@dimen/sushi_spacing_micro"
            app:layout_constraintBottom_toBottomOf="@id/subtitle"
            app:layout_constraintEnd_toStartOf="@id/right_barrier"
            app:layout_constraintStart_toEndOf="@id/subtitle"
            app:layout_constraintTop_toTopOf="@id/subtitle" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/left_image"
            android:visibility="gone"
            android:layout_width="@dimen/size_70"
            android:layout_height="@dimen/size_70"
            android:layout_marginStart="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:id="@id/left_lottie"
            android:visibility="gone"
            android:layout_width="@dimen/size_70"
            android:layout_height="@dimen/size_70"
            android:layout_marginStart="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/right_image"
            android:visibility="gone"
            android:layout_width="@dimen/size_70"
            android:layout_height="@dimen/size_70"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:id="@id/right_lottie"
            android:visibility="gone"
            android:layout_width="@dimen/size_70"
            android:layout_height="@dimen/size_70"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/banner_lottie"
        android:paddingTop="@dimen/size_32"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/subtitle"
        app:lottie_autoPlay="true" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/banner_image"
        android:paddingTop="@dimen/size_32"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/subtitle" />
</merge>