<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:layout_gravity="center_horizontal"
        android:id="@id/image_background"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:translationZ="0.20000005dip"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/image"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:cornerRadius="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.OverlayBadgeViewStub
        android:id="@id/overlay_badge_view"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.HorizontalGroupImageGridViewStub
        android:id="@id/group_image_grid"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/tv_product_offer"
        android:paddingLeft="@dimen/sushi_spacing_nano"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:paddingRight="@dimen/sushi_spacing_nano"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:textAlignment="center"
        android:paddingHorizontal="@dimen/sushi_spacing_nano"
        android:paddingVertical="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:textStyle="bold"
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:layout_gravity="start"
        android:id="@id/tv_offer_tag"
        android:background="@drawable/bg_product_card_offer"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lineSpacingMultiplier="0.75"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:elevation="@dimen/sushi_spacing_micro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/tag_chip_group"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layout_marginTop="8.0dip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.rating.RatingSnippetItemViewStub
        android:id="@id/rating_star_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginStart="-2.0dip"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_variant" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:id="@id/rating_star_view_fixed_height"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_variant" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:id="@id/tv_out_of_stock_tag"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:paddingBottom="@dimen/sushi_spacing_nano"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        android:paddingVertical="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/image"
        app:layout_constraintStart_toStartOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:textColor="@color/sushi_black"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@id/tv_name_fix_height"
        android:visibility="invisible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qd_margin_4"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2.0sp"
        android:elevation="0.100000024dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progress_info" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.ProgressInfoViewStub
        android:id="@id/progress_info"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="@id/tv_name"
        app:layout_constraintStart_toStartOf="@id/tv_name"
        app:layout_constraintTop_toBottomOf="@id/tag_chip_group" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:ellipsize="end"
        android:gravity="start"
        android:id="@id/tv_brand_name"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:maxLines="1"
        android:includeFontPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progress_info" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:textColor="@color/sushi_black"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@id/tv_name"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qd_margin_4"
        android:maxLines="2"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2.0sp"
        android:elevation="0.100000024dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_brand_name" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:textColor="@color/sushi_grey_700"
        android:ellipsize="end"
        android:layout_gravity="start"
        android:id="@id/tv_variant"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:includeFontPadding="false"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/ic_variant_dropdown"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_name"
        app:textViewType="REGULAR_400" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitIconViewStub
        android:layout_gravity="center"
        android:id="@id/ic_variant_dropdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/tv_variant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/tv_variant"
        app:layout_constraintTop_toTopOf="@id/tv_variant" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@id/ll_price_container"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/size_35"
        android:layout_marginTop="8.0dip"
        android:layout_marginEnd="@dimen/dimen_2"
        app:layout_constraintEnd_toStartOf="@id/stepper_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_name_fix_height">
        <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
            android:textColor="@color/sushi_black"
            android:ellipsize="end"
            android:gravity="start"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_text_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            app:textViewType="REGULAR_400" />
        <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
            android:textColor="@color/sushi_grey_600"
            android:ellipsize="end"
            android:gravity="start"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_text_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            app:textViewType="REGULAR_400" />
    </LinearLayout>
    <View
        android:id="@id/stepper_bottom_fix_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ll_price_container"
        app:layout_constraintVertical_bias="1.0" />
    <com.blinkit.commons.ui.ui.customviews.stepper.Stepper
        android:id="@id/stepper"
        android:visibility="gone"
        android:layout_width="@dimen/size_72"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/qd_margin_2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/stepper_bottom_fix_view"
        app:stepper_type="SMALL" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.ZButtonWithLoaderViewStub
        android:id="@id/custom_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/qd_margin_2"
        app:layout_constraintBottom_toBottomOf="@id/ll_price_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ll_price_container" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
        android:gravity="center"
        android:id="@id/notify_me_text"
        android:paddingLeft="@dimen/sushi_spacing_micro"
        android:paddingRight="@dimen/sushi_spacing_micro"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:textAlignment="center"
        android:paddingHorizontal="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/stepper"
        app:layout_constraintEnd_toEndOf="@id/stepper"
        app:layout_constraintStart_toStartOf="@id/stepper"
        app:layout_constraintTop_toTopOf="@id/stepper" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.image.BShapeableImageViewStub
        android:id="@id/notify_me_image"
        android:paddingLeft="@dimen/sushi_spacing_mini"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingRight="@dimen/sushi_spacing_mini"
        android:paddingBottom="@dimen/sushi_spacing_nano"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        android:paddingHorizontal="@dimen/sushi_spacing_mini"
        android:paddingVertical="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/stepper"
        app:layout_constraintEnd_toEndOf="@id/stepper"
        app:layout_constraintTop_toTopOf="@id/stepper" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/stepper_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="start"
        app:constraint_referenced_ids="stepper,custom_button" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/start_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="@dimen/size_12"
        app:layout_constraintStart_toStartOf="parent" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/end_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintGuide_end="@dimen/size_12" />
</androidx.constraintlayout.widget.ConstraintLayout>