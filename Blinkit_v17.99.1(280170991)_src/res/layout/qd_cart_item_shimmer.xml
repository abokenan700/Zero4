<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/image"
        android:layout_width="@dimen/size_58"
        android:layout_height="@dimen/size_58"
        android:layout_marginStart="@dimen/qd_margin_12"
        android:layout_alignParentStart="true"
        app:bgColor="?attr_7f0403d1"
        app:shimmer_corner_radius="@dimen/radius_12dp" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/details"
        android:layout_width="@dimen/size_154"
        android:layout_height="@dimen/size_38"
        android:layout_marginTop="@dimen/qd_margin_4"
        android:layout_marginStart="@dimen/qd_margin_8"
        android:layout_toEndOf="@id/image">
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="@dimen/qd_shimmer_126"
            android:layout_height="@dimen/qd_shimmer_14"
            app:bgColor="?attr_7f0403d1"
            app:shimmer_corner_radius="@dimen/radius_2dp" />
        <Space
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:layout_width="@dimen/size_72"
            android:layout_height="@dimen/qd_shimmer_10"
            android:layout_marginEnd="@dimen/qd_margin_12"
            app:bgColor="?attr_7f0403d1"
            app:shimmer_corner_radius="@dimen/qd_margin_2" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:layout_width="@dimen/size_72"
        android:layout_height="@dimen/size_26"
        android:layout_marginBottom="@dimen/qd_margin_32"
        android:layout_centerVertical="true"
        android:layout_marginEnd="@dimen/qd_margin_12"
        android:layout_alignParentEnd="true"
        app:bgColor="?attr_7f0403d1"
        app:shimmer_corner_radius="@dimen/qd_margin_2" />
</RelativeLayout>