<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="#00000000"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:gravity="center"
        android:id="@id/crossButtonContainer"
        android:background="#00000000"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_800"
            android:textColor="@color/color_white"
            android:layout_gravity="center_horizontal"
            android:id="@id/crossButton"
            android:background="@drawable/qd_cross_icon"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingTop="@dimen/size_8"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/size_8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:text="@string/icon_font_cross"
            android:contentDescription="@string/qd_drawer_close"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            android:paddingVertical="@dimen/size_8" />
    </RelativeLayout>
    <View
        android:id="@id/corner_round_bg"
        android:background="@drawable/qd_bottom_sheet_circular_indigo_50"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/crossButtonContainer" />
    <include
        android:id="@id/error_view"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/corner_round_bg"
        layout="@layout/location_off_layout" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_600"
        android:textColor="?attr_7f040466"
        android:gravity="center"
        android:id="@id/top_left_icon"
        android:paddingLeft="@dimen/sushi_spacing_extra"
        android:paddingRight="@dimen/sushi_spacing_extra"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        android:text="@string/icon_font_chevron_down_large"
        android:paddingHorizontal="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="@id/search_address_title"
        app:layout_constraintEnd_toStartOf="@id/search_address_title"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/error_view" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040466"
        android:id="@id/search_address_title"
        android:padding="@dimen/padding_12"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:text="@string/select_a_location"
        app:layout_constraintEnd_toStartOf="@id/import_button"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toEndOf="@id/top_left_icon"
        app:layout_constraintTop_toBottomOf="@id/error_view"
        app:textViewType="BOLD_500" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/import_button"
        android:paddingTop="@dimen/padding_12"
        android:paddingBottom="@dimen/padding_12"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/sushi_spacing_macro"
        android:paddingVertical="@dimen/padding_12"
        app:layout_constraintBottom_toBottomOf="@id/search_address_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toEndOf="@id/search_address_title"
        app:layout_constraintTop_toTopOf="@id/search_address_title" />
    <com.blinkit.commons.ui.ui.snippets.searchBar.QdSearchBar
        android:id="@id/search_bar"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:is_disabled="false"
        app:layout_constraintTop_toBottomOf="@id/search_address_title" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/search_address_bg"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_bar" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/rvSearchAddress"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/padding_12"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:paddingHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_bar" />
    <com.blinkit.consumerapp.ui.nitroerroroverlay.NitroOverlay
        android:id="@id/nitro_overlay"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/crossButtonContainer" />
</androidx.constraintlayout.widget.ConstraintLayout>