<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_mini" />
    <com.zomato.ui.atomiclib.molecules.ZTextInputField
        android:id="@id/inputLayout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:boxBackgroundColor="@color/sushi_grey_050"
        app:boxCornerRadiusBottomEnd="@dimen/sushi_corner_radius"
        app:boxCornerRadiusBottomStart="@dimen/sushi_corner_radius"
        app:boxCornerRadiusTopEnd="@dimen/sushi_corner_radius"
        app:boxCornerRadiusTopStart="@dimen/sushi_corner_radius"
        app:boxStrokeColor="@color/sushi_grey_300"
        app:boxStrokeWidth="@dimen/half_dp"
        app:boxStrokeWidthFocused="@dimen/half_dp"
        app:errorEnabled="false"
        app:hintEnabled="true"
        style="@style/OrderTextInputLayout" />
</merge>