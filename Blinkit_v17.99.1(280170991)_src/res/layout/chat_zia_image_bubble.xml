<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/root_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center"
        android:id="@id/placeholder_image"
        android:layout_width="@dimen/size_98"
        android:layout_height="@dimen/size_90"
        android:scaleType="centerInside" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/chat_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true" />
    <com.zomato.chatsdk.chatuikit.atoms.ImageBubbleProgressBar
        android:layout_gravity="center"
        android:id="@id/image_bubble_progress_bar"
        android:layout_width="@dimen/size_42"
        android:layout_height="@dimen/size_42" />
    <com.zomato.chatsdk.chatuikit.molecules.VideoInfoView
        android:layout_gravity="bottom"
        android:id="@id/video_info"
        android:padding="@dimen/sushi_spacing_macro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/sushi_spacing_macro" />
    <com.zomato.ui.atomiclib.atom.ZCircleIconView
        android:textColor="@color/sushi_white"
        android:layout_gravity="center"
        android:id="@id/play_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/icon_font_play" />
</FrameLayout>