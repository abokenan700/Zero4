<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/root_container"
    android:layout_width="@dimen/size_250"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/image_border"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_mini" />
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/size14"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/size14">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/iconfont_size_medium"
            android:layout_gravity="start"
            android:id="@id/play_button"
            android:padding="@dimen/sushi_spacing_macro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_font_play" />
        <LinearLayout
            android:gravity="bottom"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@id/play_lottie"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            android:layout_marginTop="@dimen/sushi_spacing_base">
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:id="@id/lottie_animation_view"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"
                android:layout_weight="1.0" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textSize="@dimen/iconfont_size_big"
                android:id="@id/audio_durations"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_12" />
        </LinearLayout>
    </LinearLayout>
    <FrameLayout
        android:id="@id/upload_overlay"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_mini">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/iconfont_size_medium"
            android:textColor="@color/sushi_white"
            android:ellipsize="end"
            android:layout_gravity="bottom"
            android:id="@id/uploading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_micro"
            android:text="@string/chat_uploading"
            android:maxLines="1"
            android:layout_marginStart="@dimen/sushi_spacing_micro" />
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@id/retry_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/iconfont_size_bit_bigger"
                android:textColor="@color/sushi_white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/icon_font_upload_up" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:text="@string/chat_sdk_retry_small"
                app:textViewType="REGULAR_100" />
        </LinearLayout>
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/dimen_18"
        android:layout_gravity="end"
        android:id="@id/cross_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/icon_font_cross_circle_fill" />
</FrameLayout>