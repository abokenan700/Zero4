<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@id/left_overlay"
        android:background="@drawable/gradient_alpha_forty_to_zero"
        android:paddingTop="@dimen/sushi_spacing_extra"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:paddingEnd="@dimen/sushi_spacing_extra">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/left_overlay_image"
            android:visibility="gone"
            android:layout_width="@dimen/size_64"
            android:layout_height="@dimen/size_64"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/left_overlay_text"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            app:layout_constraintEnd_toEndOf="@id/left_overlay_image"
            app:layout_constraintStart_toStartOf="@id/left_overlay_image"
            app:layout_constraintTop_toBottomOf="@id/left_overlay_image" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@id/right_overlay"
        android:background="@drawable/gradient_alpha_forty_to_zero"
        android:paddingTop="@dimen/sushi_spacing_extra"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:paddingStart="@dimen/sushi_spacing_extra">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/right_overlay_image"
            android:visibility="gone"
            android:layout_width="@dimen/size_64"
            android:layout_height="@dimen/size_64"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/right_overlay_text"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            app:layout_constraintEnd_toEndOf="@id/right_overlay_image"
            app:layout_constraintStart_toStartOf="@id/right_overlay_image"
            app:layout_constraintTop_toBottomOf="@id/right_overlay_image" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>