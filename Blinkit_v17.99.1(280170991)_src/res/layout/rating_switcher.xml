<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:animateLayoutChanges="false"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:gravity="center_vertical"
        android:layout_gravity="center_horizontal"
        android:id="@id/track"
        android:padding="@dimen/sushi_spacing_nano"
        android:layout_width="@dimen/size_46"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@id/tail_text_left"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAlignment="center"
            android:layout_marginStart="@dimen/sushi_spacing_micro" />
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:id="@id/thumb_icon_container"
            android:padding="@dimen/sushi_spacing_nano"
            android:layout_width="@dimen/size14"
            android:layout_height="@dimen/size14"
            android:layout_margin="@dimen/sushi_spacing_pico">
            <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
                android:layout_gravity="center"
                android:id="@id/thumb_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </FrameLayout>
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:layout_gravity="end|center"
            android:id="@id/tail_text_right"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textAlignment="center"
            android:layout_marginEnd="@dimen/sushi_spacing_micro" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="center_horizontal"
        android:id="@id/bottom_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_2"
        app:buttonType="text" />
</merge>