<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/root_view"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/root_view_c1"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingTop="@dimen/sushi_spacing_extra"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/sushi_spacing_base">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/prefix_image"
            android:background="@drawable/button_shine"
            android:layout_width="@dimen/size22"
            android:layout_height="@dimen/size22"
            app:cornerRadius="@dimen/corner_radius_micro"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/titlePrefixImageBarrier"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            app:barrierDirection="end"
            app:constraint_referenced_ids="prefix_image" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:ellipsize="end"
            android:id="@id/title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/titlePrefixImageBarrier"
            app:layout_constraintTop_toTopOf="@id/prefix_image"
            app:layout_goneMarginStart="@dimen/sushi_spacing_macro"
            app:textViewType="BOLD_500" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:ellipsize="end"
            android:id="@id/subtitle2"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_10"
            android:includeFontPadding="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/title"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:textViewType="MEDIUM_300" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:ellipsize="end"
            android:id="@id/subtitle"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_10"
            android:includeFontPadding="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/title"
            app:layout_constraintTop_toBottomOf="@id/subtitle2"
            app:textViewType="MEDIUM_300" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/shimmerSavingsBarrier"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="subtitle, promo_bottom_container_shimmer,title" />
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/promo_container"
            android:padding="@dimen/sushi_spacing_mini"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_page_side"
            android:layout_marginEnd="@dimen/dimen_10"
            app:layout_constraintStart_toStartOf="@id/title"
            app:layout_constraintTop_toBottomOf="@id/shimmerSavingsBarrier">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:ellipsize="end"
                android:id="@id/display_code_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                app:textViewType="SEMIBOLD_300" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.ZButton
            android:layout_gravity="top"
            android:id="@id/know_more_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:buttonDimension="small"
            app:buttonType="text"
            app:layout_constraintBottom_toBottomOf="@id/promo_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/promo_container" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/promoCodeContainerBarrier"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="know_more_button, promo_container" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:id="@id/promoDetailsContainer"
            android:paddingBottom="@dimen/dimen_10"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/promoCodeContainerBarrier">
            <com.zomato.ui.atomiclib.atom.ZSeparator
                android:id="@id/promoSeparator"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/dimen_point_five"
                android:layout_marginTop="@dimen/sushi_spacing_base"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:zseparator_color="@color/sushi_grey_300"
                app:zseparator_type="DASHED" />
            <com.zomato.ui.lib.organisms.snippets.multilineTextSnippets.type5.MultiLineTextSnippetType5
                android:orientation="vertical"
                android:id="@id/promoDetailsListing"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_10"
                android:layout_marginStart="@dimen/dimen_5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/promoSeparator" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.zomato.ui.atomiclib.molecules.ShimmerView
            android:id="@id/promo_bottom_container_shimmer"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="20.0dip"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            app:layout_constraintTop_toBottomOf="@id/title">
            <com.zomato.ui.atomiclib.molecules.ShimmerChildView
                android:id="@id/promo_code_shimmer"
                android:visibility="visible"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                app:shimmer_corner_radius="@dimen/sushi_spacing_macro" />
        </com.zomato.ui.atomiclib.molecules.ShimmerView>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@id/apply_button_container"
        android:padding="@dimen/sushi_spacing_nano"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/root_view_c1">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_blue_500"
            android:ellipsize="end"
            android:layout_gravity="center"
            android:id="@id/apply_button"
            android:padding="@dimen/sushi_spacing_page_side"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAP TO APPLY"
            android:includeFontPadding="false"
            app:textViewType="BOLD_400" />
        <com.zomato.ui.atomiclib.atom.progress.progressView.ZProgressView
            android:layout_gravity="center"
            android:id="@id/progress"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            app:zprogressview_custom_color="@color/sushi_blue_500"
            app:zprogressview_size="MINI"
            app:zprogressview_type="circular" />
    </FrameLayout>
</merge>