<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/bg_image"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.commons.ui.ui.snippets.autoSizeEditTextSnippet.AutoSizeEditText
        android:gravity="center"
        android:id="@id/edit_text"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:lineSpacingExtra="4.0sp"
        android:fontFamily="@font/kurale_regular"
        app:layout_constraintBottom_toBottomOf="@id/bg_image"
        app:layout_constraintEnd_toEndOf="@id/bg_image"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="@id/bg_image"
        app:layout_constraintTop_toTopOf="@id/bg_image"
        app:layout_constraintVertical_bias="0.5" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:layout_gravity="center"
        android:id="@id/hint_text"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/edit_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/edit_text" />
</merge>