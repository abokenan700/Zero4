<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@id/root_linear_layout"
    android:paddingTop="@dimen/size_6"
    android:paddingBottom="@dimen/size_6"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/size_6"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/background_top"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toTopOf="@id/background_middle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@id/background_middle"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/size_60"
        app:layout_constraintBottom_toBottomOf="@id/category"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/category" />
    <View
        android:id="@id/background_bottom"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/background_middle" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:gravity="center"
        android:id="@id/pull_up_lottie"
        android:layout_width="@dimen/size_30"
        android:layout_height="@dimen/size_30"
        android:contentDescription="@null"
        android:rotation="180.0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_cacheComposition="false"
        app:lottie_colorFilter="?themeColor500"
        app:lottie_fileName="lottie/pull_down.json"
        app:lottie_loop="true"
        app:lottie_repeatMode="restart" />
    <com.blinkit.commons.ui.ui.snippets.autoSwitchTextImageCard.AutoSwitchTextImageCardSnippetType
        android:id="@id/category"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/pull_up_lottie" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/pull_down_lottie"
        android:layout_width="@dimen/size_30"
        android:layout_height="@dimen/size_30"
        android:contentDescription="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/category"
        app:lottie_autoPlay="true"
        app:lottie_cacheComposition="false"
        app:lottie_colorFilter="?themeColor500"
        app:lottie_fileName="lottie/pull_down.json"
        app:lottie_loop="true"
        app:lottie_repeatMode="restart" />
</androidx.constraintlayout.widget.ConstraintLayout>