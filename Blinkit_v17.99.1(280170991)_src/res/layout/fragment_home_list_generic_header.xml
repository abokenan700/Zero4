<?xml version="1.0" encoding="utf-8"?>
<com.zomato.ui.lib.utils.SwipeRefreshLayout
    android:id="@id/swipe_refresh_layout"
    android:paddingTop="@dimen/sushi_spacing_macro"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:orientation="vertical"
        android:id="@id/root"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:gravity="top"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:id="@id/header_root"
            android:fitsSystemWindows="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:elevation="@dimen/sushi_spacing_femto">
            <include
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                layout="@layout/layout_header_snippet_type_1" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@id/header_layout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:textSize="@dimen/toolbar_back_icon_size"
                    android:layout_gravity="center_vertical"
                    android:id="@id/rv_back_arrow"
                    android:paddingTop="@dimen/sushi_spacing_extra"
                    android:paddingBottom="@dimen/sushi_spacing_extra"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/icon_font_back"
                    android:paddingStart="@dimen/sushi_spacing_extra"
                    android:paddingVertical="@dimen/sushi_spacing_extra"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
                    android:id="@id/rv_header"
                    android:layout_width="@dimen/sushi_spacing_femto"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/rv_back_arrow"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <com.zomato.ui.atomiclib.utils.video.toro.widget.Container
            android:id="@id/homeRecyclerView"
            android:paddingBottom="@dimen/size_170"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />
        <com.zomato.android.zcommons.overlay.BaseNitroOverlay
            android:layout_gravity="center"
            android:id="@id/homeNitroOverlay"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <FrameLayout
            android:id="@id/shimmerLayout"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:layout_gravity="bottom"
            android:id="@id/bottomButton"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/sushi_spacing_page_side" />
        <LinearLayout
            android:gravity="bottom"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@id/ll_buttons"
            android:background="@color/sushi_white"
            android:padding="@dimen/sushi_spacing_base"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:elevation="@dimen/size14" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</com.zomato.ui.lib.utils.SwipeRefreshLayout>