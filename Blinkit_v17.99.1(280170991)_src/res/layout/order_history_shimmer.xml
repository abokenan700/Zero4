<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="?attr_7f040180"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/start_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="@dimen/dimen_12" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/end_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="@dimen/dimen_12" />
    <Toolbar
        android:id="@id/toolbar_shimmer"
        android:background="?attr_7f0403d7"
        android:paddingTop="@dimen/qd_padding_32"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/size_80"
        android:elevation="@dimen/size_6"
        app:bgColor="?attr_7f0403d7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:paddingTop="@dimen/dimen_4"
            android:paddingBottom="@dimen/size_8"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.molecules.ShimmerChildView
                android:id="@id/search"
                android:layout_width="@dimen/size_36"
                android:layout_height="@dimen/size_36"
                app:bgColor="?attr_7f040180"
                app:shimmer_corner_radius="@dimen/size_36" />
            <com.zomato.ui.atomiclib.molecules.ShimmerChildView
                android:layout_width="@dimen/size_80"
                android:layout_height="@dimen/dimen_16"
                android:layout_marginStart="@dimen/qd_margin_12"
                app:bgColor="?attr_7f0403d0" />
        </LinearLayout>
    </Toolbar>
    <View
        android:id="@id/toolbar_shimmer_separator"
        android:layout_width="0.0dip"
        android:layout_height="1.0dip"
        app:bgColor="?attr_7f0403e1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_shimmer" />
    <include
        android:id="@id/first_item"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/toolbar_shimmer_separator"
        layout="@layout/shimmer_order_history_item" />
    <include
        android:id="@id/second_item"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/first_item"
        layout="@layout/shimmer_order_history_item" />
    <include
        android:id="@id/third_item"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/second_item"
        layout="@layout/shimmer_order_history_item" />
    <include
        android:id="@id/fourth_item"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/third_item"
        layout="@layout/shimmer_order_history_item" />
    <include
        android:id="@id/fifth_item"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/fourth_item"
        layout="@layout/shimmer_order_history_item" />
    <include
        android:id="@id/sixth_item"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/fifth_item"
        layout="@layout/shimmer_order_history_item" />
    <include
        android:id="@id/seventh_item"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/sixth_item"
        layout="@layout/shimmer_order_history_item" />
</androidx.constraintlayout.widget.ConstraintLayout>