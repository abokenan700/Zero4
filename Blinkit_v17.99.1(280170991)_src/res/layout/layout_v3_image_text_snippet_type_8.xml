<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:paddingLeft="@dimen/sushi_spacing_extra"
    android:paddingTop="@dimen/sushi_spacing_loose"
    android:paddingRight="@dimen/sushi_spacing_extra"
    android:paddingBottom="@dimen/sushi_spacing_loose"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/sushi_spacing_extra"
    android:paddingVertical="@dimen/sushi_spacing_loose"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center"
        android:id="@id/center_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24.0dip" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/items_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
</merge>