<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/parent_container"
    android:background="?attr_7f040180"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.lib.utils.SwipeRefreshLayout
        android:id="@id/swipe_refresh_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/toolbar_container"
                android:background="?attr_7f040180"
                android:paddingTop="@dimen/sushi_spacing_mini"
                android:paddingBottom="@dimen/sushi_spacing_mini"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/sushi_spacing_mini">
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:textSize="20.0sp"
                    android:textColor="@color/sushi_grey_900"
                    android:id="@id/toolbar_arrow_back"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:padding="@dimen/sushi_spacing_base"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/icon_font_chevron_left" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_900"
                    android:id="@id/header_title"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    app:textViewType="SEMIBOLD_500" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:layout_gravity="center_vertical"
                    android:id="@id/header_button"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="@dimen/sushi_spacing_macro"
                    android:layout_marginEnd="@dimen/sushi_spacing_base"
                    app:buttonDimension="medium"
                    app:buttonType="text" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
                android:id="@id/recycler_view"
                android:paddingLeft="@dimen/sushi_spacing_base"
                android:paddingRight="@dimen/sushi_spacing_base"
                android:paddingBottom="@dimen/size_100"
                android:clipToPadding="false"
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:layout_weight="1.0"
                android:overScrollMode="never"
                android:paddingHorizontal="@dimen/sushi_spacing_base" />
        </LinearLayout>
    </com.zomato.ui.lib.utils.SwipeRefreshLayout>
    <com.zomato.android.zcommons.overlay.BaseNitroOverlay
        android:id="@id/overlay"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@id/refreshProgressContainer"
        android:background="@color/color_white_trans_seventy"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <ProgressBar
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro" />
    </LinearLayout>
</FrameLayout>