<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center"
        android:id="@id/bg_image"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scaleType="fitXY" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/top_container"
        android:paddingBottom="@dimen/sushi_spacing_extra"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center"
            android:id="@id/top_image"
            android:layout_width="@dimen/size_100"
            android:layout_height="@dimen/size_100"
            android:layout_marginTop="@dimen/dimen_16" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:layout_gravity="center"
            android:id="@id/top_lottie"
            android:layout_width="@dimen/size_250"
            android:layout_height="@dimen/size_250"
            android:layout_marginTop="@dimen/dimen_16" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_page_side"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginRight="@dimen/sushi_spacing_page_side"
            android:layout_marginHorizontal="@dimen/sushi_spacing_page_side" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:id="@id/subtitle1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_page_side"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginRight="@dimen/sushi_spacing_page_side"
            android:layout_marginHorizontal="@dimen/sushi_spacing_page_side" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:layout_gravity="center"
            android:id="@id/buttonView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_page_side"
            android:layout_marginTop="@dimen/sushi_spacing_page_side"
            android:layout_marginRight="@dimen/sushi_spacing_page_side"
            android:layout_marginHorizontal="@dimen/sushi_spacing_page_side"
            app:buttonType="outline" />
    </LinearLayout>
</merge>