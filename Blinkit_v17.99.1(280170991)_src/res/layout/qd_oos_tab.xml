<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/container"
    android:background="@drawable/qd_oos_tab_rounded_rectangle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/qd_margin_8"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/product_image"
        android:layout_width="@dimen/size_52"
        android:layout_height="@dimen/size_52"
        android:layout_marginTop="@dimen/qd_margin_7"
        android:layout_marginBottom="@dimen/qd_margin_7"
        android:layout_marginStart="@dimen/qd_margin_4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dip"
        android:layout_marginBottom="@dimen/qd_margin_8"
        android:layout_marginEnd="@dimen/qd_margin_8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/product_image"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/dimen_12"
            android:ellipsize="end"
            android:id="@id/title"
            android:layout_width="90.0dip"
            android:layout_height="wrap_content"
            android:maxLines="2" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/dimen_10"
            android:ellipsize="end"
            android:id="@id/quantity"
            android:layout_width="90.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="4.0dip" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>