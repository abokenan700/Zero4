<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/crossButtonContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_800"
            android:textColor="@color/sushi_white"
            android:layout_gravity="center_horizontal"
            android:id="@id/crossButton"
            android:background="@drawable/grey_circle"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingTop="@dimen/size_8"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/size_8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:text="@string/icon_font_cross"
            android:backgroundTint="@color/tokenised_slate_700"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            android:paddingVertical="@dimen/size_8" />
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/content_container"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f04048a"
            android:id="@id/page_title"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/sushi_spacing_base"
            app:layout_constraintEnd_toStartOf="@id/end_guideline"
            app:layout_constraintStart_toEndOf="@id/start_guideline"
            app:layout_constraintTop_toTopOf="parent"
            app:textViewType="BOLD_600" />
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/top_separator"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/sushi_spacing_pico"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/page_title"
            app:zseparator_color="?attr_7f04029b"
            app:zseparator_type="STRAIGHT" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f04048a"
            android:id="@id/hint"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_between"
            android:text="@string/select_option_to_pick_image"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            app:layout_constraintEnd_toStartOf="@id/end_guideline"
            app:layout_constraintStart_toEndOf="@id/start_guideline"
            app:layout_constraintTop_toBottomOf="@id/top_separator"
            app:textViewType="MEDIUM_500" />
        <LinearLayout
            android:gravity="start|center"
            android:orientation="horizontal"
            android:id="@id/camera_option_container"
            android:padding="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_mini">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_400"
                android:textColor="?attr_7f0402f7"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/pick_from_camera"
                android:background="@color/sushi_grey_100"
                android:padding="@dimen/sushi_spacing_micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/icon_font_camera_add" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="?attr_7f040475"
                android:gravity="center"
                android:id="@id/pick_from_camera_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/change_photo_from_camera"
                android:layout_marginStart="@dimen/sushi_spacing_macro"
                app:textViewType="REGULAR_400" />
        </LinearLayout>
        <LinearLayout
            android:gravity="start|center"
            android:orientation="horizontal"
            android:id="@id/gallery_option_container"
            android:padding="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_300"
                android:textColor="?attr_7f0402f7"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/pick_from_gallery"
                android:background="@color/sushi_grey_100"
                android:padding="@dimen/size_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/icon_font_image_box" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="?attr_7f040475"
                android:id="@id/pick_from_gallery_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/change_photo_from_gallery"
                android:layout_marginStart="@dimen/sushi_spacing_macro"
                app:textViewType="REGULAR_400" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>