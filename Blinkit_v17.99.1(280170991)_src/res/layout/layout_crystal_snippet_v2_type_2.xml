<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:orientation="horizontal"
    android:background="?attr_7f0403d7"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/bg_image"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/ll_container"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sushi_spacing_base"
            android:paddingEnd="@dimen/sushi_spacing_base">
            <FrameLayout
                android:id="@id/left_image_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_macro"
                app:layout_constraintEnd_toStartOf="@id/text_layout"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:id="@id/image"
                    android:visibility="visible"
                    android:layout_width="@dimen/size_32"
                    android:layout_height="@dimen/size_32"
                    android:scaleType="centerCrop" />
                <View
                    android:id="@id/image_gradient"
                    android:layout_width="@dimen/size_32"
                    android:layout_height="@dimen/size_32" />
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:textSize="@dimen/sushi_spacing_extra"
                    android:textColor="@color/sushi_white"
                    android:layout_gravity="end|bottom|center"
                    android:id="@id/overlay_icon"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/sushi_spacing_macro"
                    android:layout_marginEnd="@dimen/sushi_spacing_macro" />
            </FrameLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:orientation="vertical"
                android:id="@id/text_layout"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:layout_constraintBottom_toTopOf="@id/button_layout"
                app:layout_constraintEnd_toStartOf="@id/right_barrier"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@id/left_image_container"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="?attr_7f040475"
                    android:id="@id/title"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toTopOf="@id/subtitle"
                    app:layout_constraintEnd_toStartOf="@id/title_tag"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0"
                    app:layout_constraintWidth_default="wrap"
                    app:textViewType="MEDIUM_100" />
                <com.zomato.ui.atomiclib.atom.ZTag
                    android:gravity="center"
                    android:id="@id/title_tag"
                    android:paddingLeft="@dimen/corner_radius_nano"
                    android:paddingRight="@dimen/corner_radius_nano"
                    android:visibility="gone"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/listing_rating_min_width"
                    android:includeFontPadding="true"
                    android:layout_marginStart="@dimen/sushi_spacing_macro"
                    android:paddingHorizontal="@dimen/corner_radius_nano"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toEndOf="@id/title"
                    app:layout_constraintTop_toTopOf="@id/title"
                    app:layout_constraintWidth_default="wrap"
                    app:tagSize="tiny" />
                <androidx.constraintlayout.widget.Barrier
                    android:id="@id/horizontal_barrier"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="title, title_tag" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_700"
                    android:id="@id/subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_nano"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/horizontal_barrier"
                    app:textViewType="MEDIUM_100" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <LinearLayout
                android:id="@id/button_layout"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_macro_negative"
                app:layout_constraintBottom_toTopOf="@id/subtitle_rating_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/left_image_container"
                app:layout_constraintTop_toBottomOf="@id/text_layout">
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:id="@id/button1"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/size_3"
                    android:layout_marginRight="@dimen/size_3"
                    android:maxLines="1"
                    android:layout_weight="0.5"
                    android:layout_marginHorizontal="@dimen/size_3" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:id="@id/button2"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/size_3"
                    android:layout_marginRight="@dimen/size_3"
                    android:maxLines="1"
                    android:layout_weight="0.5"
                    android:layout_marginHorizontal="@dimen/size_3" />
            </LinearLayout>
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/right_barrier"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                app:barrierDirection="start"
                app:constraint_referenced_ids="right_icon, right_image, bottom_right_image" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textColor="@color/sushi_grey_900"
                android:gravity="center"
                android:id="@id/right_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/right_barrier"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/right_image"
                android:visibility="gone"
                android:layout_width="@dimen/sushi_spacing_extra"
                android:layout_height="@dimen/sushi_spacing_extra"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/subtitle_rating_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toTopOf="@id/bottom_button"
                app:layout_constraintStart_toStartOf="@id/text_layout"
                app:layout_constraintTop_toBottomOf="@id/button_layout">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_700"
                    android:id="@id/subtitle2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:textViewType="MEDIUM_100" />
                <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                    android:id="@id/rating_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_micro"
                    app:ratedBlockDimenConfig="200"
                    app:ratingType="tag_v2" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/bottom_button"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/text_layout"
                app:layout_constraintTop_toBottomOf="@id/subtitle_rating_container" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <include
                android:layout_gravity="bottom"
                android:id="@id/button_layout_1"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                layout="@layout/layout_crystal_snippet_v2_type_2_button_1" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="end|bottom|center"
                android:id="@id/bottom_right_image"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base" />
        </LinearLayout>
        <include
            android:layout_gravity="bottom"
            android:id="@id/button_layout_2"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            layout="@layout/layout_crystal_snippet_v2_type_2_button_2" />
    </LinearLayout>
</FrameLayout>