<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/cardContainer"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZTag
            android:id="@id/top_left_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:layout_marginStart="@dimen/sushi_spacing_base"
            android:elevation="@dimen/sushi_spacing_pico"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tagType="rounded" />
        <FrameLayout
            android:id="@id/top_tag"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingBottom="@dimen/sushi_spacing_nano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sushi_spacing_macro"
            android:paddingEnd="@dimen/sushi_spacing_macro"
            android:elevation="@dimen/sushi_spacing_pico"
            android:paddingVertical="@dimen/sushi_spacing_nano"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:layout_gravity="center"
                android:id="@id/tag_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:drawablePadding="@dimen/sushi_spacing_micro"
                app:textViewType="MEDIUM_200" />
        </FrameLayout>
        <FrameLayout
            android:id="@id/imageBackground"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:elevation="@dimen/sushi_spacing_pico"
            app:layout_constraintBottom_toBottomOf="@id/image"
            app:layout_constraintTop_toTopOf="@id/image" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/image"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:ellipsize="end"
            android:id="@id/title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_base"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="@id/image"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:textViewType="SEMIBOLD_500" />
        <FrameLayout
            android:id="@id/toggleButtonContainer"
            android:paddingTop="@dimen/dimen_two_point_two"
            android:paddingRight="@dimen/size_3_and_half"
            android:layout_width="@dimen/size28"
            android:layout_height="@dimen/size28"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            android:translationZ="@dimen/sushi_spacing_nano"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.zomato.ui.atomiclib.atom.ZButton
                android:layout_gravity="center"
                android:id="@id/toggleButton"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonDimension="small"
                app:buttonType="text" />
        </FrameLayout>
        <com.google.android.flexbox.FlexboxLayout
            android:id="@id/tagsFlexBox"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginStart="@dimen/sushi_spacing_page_side"
            android:layout_marginEnd="@dimen/sushi_spacing_mini"
            app:flexWrap="wrap"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/image" />
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/subtitleLayout"
            android:paddingLeft="@dimen/sushi_spacing_page_side"
            android:paddingRight="@dimen/sushi_spacing_page_side"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:paddingHorizontal="@dimen/sushi_spacing_page_side"
            app:layout_constraintEnd_toStartOf="@id/stepper"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tagsFlexBox">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_200"
                android:id="@id/subtitleIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_mini" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="@color/sushi_grey_500"
                android:ellipsize="end"
                android:id="@id/subtitle"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:textViewType="MEDIUM_100" />
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/subtitle2Layout"
            android:paddingLeft="@dimen/sushi_spacing_page_side"
            android:paddingRight="@dimen/sushi_spacing_page_side"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:paddingHorizontal="@dimen/sushi_spacing_page_side"
            app:layout_constraintEnd_toStartOf="@id/stepper"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitleLayout">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_200"
                android:id="@id/subtitle2Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_mini" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:textColor="@color/sushi_grey_500"
                android:ellipsize="end"
                android:id="@id/subtitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="@dimen/sushi_spacing_mini"
                app:textViewType="MEDIUM_100" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.molecules.ZStepper
            android:id="@id/stepper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="@id/subtitleLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/subtitleLayout"
            app:stepper_type="NORMAL" />
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/subtitle3Layout"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginStart="@dimen/sushi_spacing_page_side"
            app:layout_constraintTop_toBottomOf="@id/subtitle2Layout">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_200"
                android:id="@id/subtitle3Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_mini" />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                    android:ellipsize="end"
                    android:id="@id/subtitle3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/sushi_spacing_mini"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:textViewType="MEDIUM_300" />
                <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                    android:textColor="@color/sushi_grey_700"
                    android:ellipsize="end"
                    android:id="@id/subtitle4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_nano"
                    android:layout_marginEnd="@dimen/sushi_spacing_mini"
                    app:textViewType="MEDIUM_200" />
            </LinearLayout>
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:textColor="@color/sushi_grey_800"
            android:ellipsize="end"
            android:id="@id/subtitle5"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginStart="@dimen/sushi_spacing_mini"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/subtitle5Icon"
            app:layout_constraintTop_toBottomOf="@id/subtitle3Layout"
            app:textViewType="MEDIUM_200" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_200"
            android:id="@id/subtitle5Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_page_side"
            app:layout_constraintBottom_toBottomOf="@id/subtitle5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/subtitle5" />
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/bottom_container_separator"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/dimen_point_five"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle5"
            app:layout_constraintVertical_bias="1.0"
            app:zseparator_color="@color/sushi_grey_200"
            app:zseparator_type="DOTTED" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/bottom_container_title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginStart="@dimen/sushi_spacing_page_side"
            app:layout_constraintEnd_toStartOf="@id/ratingSnippet"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bottom_container_separator" />
        <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
            android:id="@id/ratingSnippet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/bottom_container_title"
            app:ratingType="tag_v2" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/bottom_container_subtitle"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:paddingEnd="@dimen/sushi_spacing_macro"
            android:layout_marginStart="@dimen/sushi_spacing_page_side"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bottom_container_title" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>