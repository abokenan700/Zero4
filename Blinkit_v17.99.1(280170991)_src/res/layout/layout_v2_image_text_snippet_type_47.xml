<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/top_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:foreground="?android:selectableItemBackground">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/top_image"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_150" />
        <FrameLayout
            android:id="@id/top_container_gradient"
            android:background="@drawable/gradient_white_bottom"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_150" />
        <LinearLayout
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:id="@id/top_container_header"
            android:background="@color/black_with_8_alpha"
            android:paddingLeft="@dimen/sushi_spacing_base"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingRight="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/sushi_spacing_macro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_mini"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            android:paddingHorizontal="@dimen/sushi_spacing_base"
            android:paddingVertical="@dimen/sushi_spacing_macro">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_500"
                android:ellipsize="end"
                android:id="@id/top_container_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                app:textViewType="MEDIUM_100" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f040475"
                android:ellipsize="end"
                android:id="@id/top_container_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2" />
        </LinearLayout>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/res_cards_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base">
        <com.zomato.ui.lib.organisms.snippets.imagetext.v2_type2.ZV2ImageTextSnippetType2
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <com.zomato.ui.lib.organisms.snippets.imagetext.v2_type2.ZV2ImageTextSnippetType2
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <com.zomato.ui.lib.organisms.snippets.imagetext.v2_type2.ZV2ImageTextSnippetType2
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <com.zomato.ui.lib.organisms.snippets.imagetext.v2_type2.ZV2ImageTextSnippetType2
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/bottom_separator"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:zseparator_color="@color/sushi_grey_100" />
    <FrameLayout
        android:id="@id/bottom_button_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZButton
            android:layout_gravity="center_horizontal"
            android:id="@id/bottom_button"
            android:background="@color/sushi_white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:buttonDimension="medium"
            app:buttonType="text" />
    </FrameLayout>
</merge>