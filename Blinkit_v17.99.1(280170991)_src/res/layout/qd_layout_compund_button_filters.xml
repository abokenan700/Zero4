<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_gravity="center_vertical"
    android:paddingTop="@dimen/size_4"
    android:paddingBottom="@dimen/size_4"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/size_4"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/image_overlay"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:elevation="@dimen/dimen_point_five"
        app:layout_constraintBottom_toBottomOf="@id/image_view"
        app:layout_constraintEnd_toEndOf="@id/image_view"
        app:layout_constraintStart_toStartOf="@id/image_view"
        app:layout_constraintTop_toTopOf="@id/image_view" />
    <RadioButton
        android:layout_gravity="center_vertical"
        android:id="@id/radio_button"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        android:buttonTint="?accentColor"
        app:layout_constraintBottom_toBottomOf="@id/title_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title_tv" />
    <CheckBox
        android:layout_gravity="center_vertical"
        android:id="@id/check_box"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="?accentColor"
        app:layout_constraintBottom_toBottomOf="@id/radio_button"
        app:layout_constraintStart_toStartOf="@id/radio_button"
        app:layout_constraintTop_toTopOf="@id/radio_button" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        android:layout_marginBottom="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_goneMarginBottom="@dimen/sushi_spacing_femto"
        app:layout_goneMarginStart="@dimen/sushi_spacing_femto"
        app:layout_goneMarginTop="@dimen/sushi_spacing_femto" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@id/title_tv"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/suffix_tv"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/image_view"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/suffix_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>