<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/settings_container"
    android:background="@drawable/bg_rounded_surface_primary"
    android:paddingTop="@dimen/sushi_spacing_macro"
    android:paddingBottom="@dimen/sushi_spacing_macro"
    android:visibility="gone"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/sushi_spacing_macro"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:gravity="center_vertical"
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_pico"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintEnd_toStartOf="@id/stepper_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:gravity="center_vertical"
        android:id="@id/subtitle"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_pico"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/stepper_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <View
        android:layout_gravity="center"
        android:id="@id/stepper_layout"
        android:background="@drawable/qd_all_rounded_green_8dp"
        android:layout_width="@dimen/size_70"
        android:layout_height="@dimen/sushi_rating_tag_tiny_minwidth"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/title"
        app:layout_constraintTop_toTopOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textColor="@color/color_white_alpha_fifty"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/stepper_decrement_icon"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        android:text="@string/icon_font_minus"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/stepper_layout"
        app:layout_constraintEnd_toStartOf="@id/stepper_number"
        app:layout_constraintStart_toStartOf="@id/stepper_layout"
        app:layout_constraintTop_toTopOf="@id/stepper_layout" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/stepper_number"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        android:text="1"
        app:layout_constraintBottom_toBottomOf="@id/stepper_layout"
        app:layout_constraintEnd_toStartOf="@id/stepper_increment_icon"
        app:layout_constraintStart_toEndOf="@id/stepper_decrement_icon"
        app:layout_constraintTop_toTopOf="@id/stepper_layout" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/stepper_increment_icon"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        android:text="@string/icon_font_plus"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/stepper_layout"
        app:layout_constraintEnd_toEndOf="@id/stepper_layout"
        app:layout_constraintStart_toEndOf="@id/stepper_number"
        app:layout_constraintTop_toTopOf="@id/stepper_layout" />
    <androidx.constraintlayout.widget.Group
        android:id="@id/stepper_group"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="stepper_layout,stepper_decrement_icon,stepper_increment_icon,stepper_number" />
</androidx.constraintlayout.widget.ConstraintLayout>