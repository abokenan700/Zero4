<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@color/color_transparent"
    android:paddingTop="@dimen/sushi_spacing_loose"
    android:paddingBottom="@dimen/sushi_spacing_loose"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/sushi_spacing_loose"
    android:paddingStart="@dimen/sushi_spacing_extra"
    android:paddingEnd="@dimen/sushi_spacing_extra"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040475"
        android:gravity="start"
        android:id="@id/message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:textViewType="MEDIUM_600" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/negative_button"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        app:buttonColor="?android:colorAccent"
        app:buttonType="outline" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/positive_button"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        app:buttonColor="?android:colorAccent"
        app:buttonType="solid" />
</LinearLayout>