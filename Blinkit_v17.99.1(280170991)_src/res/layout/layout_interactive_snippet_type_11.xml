<?xml version="1.0" encoding="utf-8"?>
<merge
    android:paddingLeft="@dimen/sushi_spacing_base"
    android:paddingTop="@dimen/sushi_spacing_base"
    android:paddingRight="@dimen/sushi_spacing_base"
    android:paddingBottom="@dimen/sushi_spacing_base"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/sushi_spacing_base"
    android:paddingVertical="@dimen/sushi_spacing_base"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/header_title"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_macro"
        android:maxLines="1"
        android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:textViewType="SEMIBOLD_500" />
    <com.zomato.ui.lib.organisms.snippets.slider.snap.type2.ZSnapHorizontalSliderViewType2
        android:id="@id/snap_slider_view"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/size_60"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        app:indicatorBgColor="?attr_7f040268"
        app:indicatorBorderColor="?attr_7f040291"
        app:indicatorRadius="@dimen/sushi_spacing_macro"
        app:indicatorStrokeWidth="@dimen/sushi_spacing_pico"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_title"
        app:trackHeight="@dimen/sushi_spacing_micro" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/left_title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:maxLines="1"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toStartOf="@id/right_title"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/snap_slider_view"
        app:layout_constraintWidth_default="wrap"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/right_title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:maxLines="1"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toEndOf="@id/left_title"
        app:layout_constraintTop_toBottomOf="@id/snap_slider_view"
        app:layout_constraintWidth_default="wrap"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:layout_gravity="center"
        android:id="@id/separator"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_pico"
        android:layout_marginLeft="@dimen/sushi_spacing_macro"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        android:layout_marginRight="@dimen/sushi_spacing_macro"
        android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constraintTop_toBottomOf="@id/left_title"
        app:zseparator_color="?attr_7f040297"
        app:zseparator_type="DOTTED" />
</merge>