<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/item_selected_image"
        android:background="@android:color/darker_gray"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:scaleType="centerCrop"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:cornerRadius="@dimen/sushi_spacing_base" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_400"
        android:textColor="@color/color_white"
        android:gravity="center"
        android:layout_gravity="end|center|top"
        android:id="@id/item_remove_selected_image"
        android:background="@drawable/white_circle"
        android:padding="@dimen/sushi_spacing_nano"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/icon_cross" />
</merge>