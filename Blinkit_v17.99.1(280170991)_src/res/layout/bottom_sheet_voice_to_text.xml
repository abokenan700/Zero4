<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/crossButtonContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_800"
            android:textColor="@color/sushi_white"
            android:layout_gravity="center_horizontal"
            android:id="@id/crossButton"
            android:background="@drawable/grey_circle"
            android:padding="@dimen/sushi_spacing_macro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:text="@string/icon_font_cross"
            android:backgroundTint="@color/tokenised_slate_700" />
    </FrameLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/dataContainer"
        android:padding="@dimen/sushi_spacing_alone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_500"
            android:layout_gravity="center_horizontal"
            android:id="@id/title"
            android:padding="@dimen/sushi_spacing_nano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:textViewType="SEMIBOLD_600" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_500"
            android:gravity="center_horizontal"
            android:id="@id/suggestion"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:text="@string/mic_suggestion"
            app:layout_constraintBottom_toTopOf="@id/mic_circle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />
        <com.zomato.ui.lib.atom.ripplePulse.RippleBackground
            android:layout_gravity="center_horizontal"
            android:id="@id/ripple_ring"
            android:visibility="visible"
            android:layout_width="@dimen/sound_ripple_size"
            android:layout_height="@dimen/sound_ripple_size"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/suggestion"
            app:rb_color="@color/sushi_grey_600"
            app:rb_config_type="zoom"
            app:rb_duration="1600"
            app:rb_radius="@dimen/size14"
            app:rb_rippleAmount="5"
            app:rb_scale="4.0"
            app:rb_type="strokeRipple" />
        <com.zomato.ui.atomiclib.atom.ZCircularImageView
            android:layout_gravity="center_horizontal"
            android:id="@id/mic_circle"
            android:background="@color/z_red"
            android:padding="@dimen/sushi_spacing_mini"
            android:layout_width="@dimen/size_56"
            android:layout_height="@dimen/size_56"
            android:layout_marginTop="@dimen/size28"
            android:elevation="@dimen/sushi_spacing_micro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/suggestion" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/size_30"
            android:textColor="@color/sushi_white"
            android:layout_gravity="center_horizontal"
            android:id="@id/mic"
            android:padding="@dimen/sushi_spacing_mini"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/size_35"
            android:text="@string/icon_font_microphone_fill"
            android:elevation="@dimen/sushi_spacing_micro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/suggestion" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_900"
            android:gravity="center"
            android:id="@id/try_again"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:text="@string/mic_try_again"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mic_circle"
            app:textViewType="MEDIUM_200" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>