<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/phone_login_linear_white_transparent_gradient"
    android:padding="@dimen/sushi_spacing_extra"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:gravity="center_horizontal"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:lines="1"
        app:layout_constraintBottom_toTopOf="@id/phone_number_holder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/phone_number_holder"
        android:background="@drawable/all_rounded_white_grey_border_stroke"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/continue_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/font_size_mini"
            android:textColor="@color/black"
            android:id="@id/tv_isd_ind"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/isd_ind"
            android:fontFamily="@font/okra_bold"
            android:layout_marginStart="@dimen/sushi_spacing_extra"
            android:letterSpacing="0.075"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/input_phone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <EditText
            android:textSize="@dimen/font_size_mini"
            android:textColor="@color/black"
            android:textColorHighlight="@color/sushi_green_200"
            android:textColorHint="@color/grey_D6D6D6"
            android:id="@id/input_phone"
            android:background="@null"
            android:paddingTop="@dimen/sushi_spacing_extra"
            android:paddingRight="@dimen/sushi_spacing_extra"
            android:paddingBottom="@dimen/sushi_spacing_extra"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:hint="@string/enter_mobile_num"
            android:maxLines="1"
            android:singleLine="true"
            android:maxLength="16"
            android:digits="\ 0123456789"
            android:inputType="number"
            android:imeOptions="actionDone"
            android:textCursorDrawable="@drawable/cursor_black"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            android:letterSpacing="0.075"
            android:paddingVertical="@dimen/sushi_spacing_extra"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ic_cross"
            app:layout_constraintStart_toEndOf="@id/tv_isd_ind"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.sushilib.atoms.textviews.SushiIconTextView
            android:textSize="@dimen/qd_padding_18"
            android:layout_gravity="center"
            android:id="@id/ic_cross"
            android:padding="@dimen/sushi_spacing_extra"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_cross_filled"
            android:contentDescription="@string/clear"
            android:paddingStart="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:gravity="center"
        android:id="@id/continue_button"
        android:background="@drawable/all_rounded_grey_500_12dp"
        android:padding="@dimen/qd_padding_16"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toTopOf="@id/middle_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_goneMarginBottom="@dimen/sushi_spacing_femto" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:id="@id/middle_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_marginBottom="@dimen/qd_margin_12"
        app:layout_constraintBottom_toTopOf="@id/login_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <View
        android:id="@id/login_button_background"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:stateListAnimator="@animator/login_alpha_animator"
        app:layout_constraintBottom_toBottomOf="@id/login_button"
        app:layout_constraintEnd_toEndOf="@id/login_button"
        app:layout_constraintStart_toStartOf="@id/login_button"
        app:layout_constraintTop_toTopOf="@id/login_button" />
    <ProgressBar
        android:id="@id/pb_login_button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/size_20"
        android:elevation="@dimen/sushi_spacing_micro"
        android:progressTint="@color/sushi_white"
        android:indeterminateTint="@color/sushi_white"
        android:indeterminateTintMode="src_atop"
        app:layout_constraintBottom_toBottomOf="@id/login_button"
        app:layout_constraintEnd_toEndOf="@id/login_button"
        app:layout_constraintStart_toStartOf="@id/login_button"
        app:layout_constraintTop_toTopOf="@id/login_button"
        style="?android:progressBarStyleSmall" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:id="@id/login_button"
        android:padding="@dimen/sushi_spacing_extra"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/middle_text" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:gravity="center"
        android:id="@id/info_text"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/login_button" />
</androidx.constraintlayout.widget.ConstraintLayout>