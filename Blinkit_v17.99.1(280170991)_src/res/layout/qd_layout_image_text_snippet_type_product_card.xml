<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/root_container"
    android:clipChildren="true"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/media_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <include
            android:id="@id/layout_video_includeId"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            layout="@layout/layout_video_base" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/image"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.blinkit.commons.ui.ui.customviews.overlayBadges.OverlayBadgeView
            android:id="@id/overlay_view"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:cornerRadius="@dimen/dimen_12"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_white"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/zigzag_offer_text"
        android:paddingLeft="@dimen/sushi_spacing_nano"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:paddingRight="@dimen/sushi_spacing_nano"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/qd_margin_0.5"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:textAlignment="center"
        android:paddingHorizontal="@dimen/sushi_spacing_nano"
        android:paddingVertical="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:textViewType="BOLD_500" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textStyle="bold"
        android:textColor="@color/sushi_white"
        android:gravity="center"
        android:layout_gravity="start"
        android:id="@id/tv_offer_tag"
        android:background="@drawable/bg_product_card_offer"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lineSpacingMultiplier="0.75"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <include
        android:id="@id/top_right_icon_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/zigzag_offer_text"
        layout="@layout/qd_top_right_icon" />
    <com.google.android.material.chip.ChipGroup
        android:layout_gravity="center_vertical"
        android:id="@id/tag_chip_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_12"
        android:layout_marginRight="@dimen/dimen_12"
        android:layout_marginHorizontal="@dimen/dimen_12"
        app:chipSpacingHorizontal="@dimen/sushi_spacing_micro"
        app:chipSpacingVertical="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/media_container"
        app:singleLine="true" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_white"
        android:id="@id/tv_out_of_stock_tag"
        android:paddingLeft="@dimen/qd_padding_8"
        android:paddingTop="@dimen/qd_padding_2"
        android:paddingRight="@dimen/qd_padding_8"
        android:paddingBottom="@dimen/qd_padding_2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/qd_out_of_stock"
        android:paddingHorizontal="@dimen/qd_padding_8"
        android:paddingVertical="@dimen/qd_padding_2"
        app:layout_constraintBottom_toBottomOf="@id/media_container"
        app:layout_constraintEnd_toEndOf="@id/media_container"
        app:layout_constraintStart_toStartOf="@id/media_container"
        app:layout_constraintTop_toTopOf="@id/media_container"
        app:textViewType="REGULAR_400" />
    <ViewStub
        android:id="@id/view_stub_progress_info"
        android:layout="@layout/view_stub_layout_progress_info"
        android:inflatedId="@id/view_stub_progress_info"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="@id/tv_name"
        app:layout_constraintStart_toStartOf="@id/tv_name"
        app:layout_constraintTop_toBottomOf="@id/tag_chip_group" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_black"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@id/tv_name"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/qd_margin_4"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:lines="2"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2.0sp"
        android:elevation="0.100000024dip"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_stub_progress_info" />
    <ViewStub
        android:id="@id/view_stub_variant_info"
        android:layout="@layout/layout_variant_info_view"
        android:inflatedId="@id/view_stub_variant_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/tv_name" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_700"
        android:ellipsize="end"
        android:layout_gravity="start"
        android:id="@id/tv_variant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:lines="1"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/ic_variant_dropdown"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_stub_variant_info"
        app:textViewType="REGULAR_400" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:layout_gravity="center"
        android:id="@id/ic_variant_dropdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/tv_variant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/tv_variant"
        app:layout_constraintTop_toTopOf="@id/tv_variant" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/variant_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="tv_variant,ic_variant_dropdown" />
    <View
        android:id="@id/variant_view_space"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_extra"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/variant_barrier" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@id/ll_price_container"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:minHeight="@dimen/size_40"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_pico"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/barrier_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/variant_view_space">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:ellipsize="end"
            android:gravity="start"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_text_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            app:textViewType="REGULAR_400" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_600"
            android:ellipsize="end"
            android:gravity="start"
            android:layout_gravity="center_vertical"
            android:id="@id/tv_text_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            app:textViewType="REGULAR_400" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/custom_button_cta"
        android:visibility="gone"
        android:layout_width="@dimen/size_72"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:maxLines="1"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:cornerRadius="@dimen/radius_4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/variant_view_space" />
    <com.blinkit.commons.ui.ui.customviews.stepper.Stepper
        android:id="@id/stepper"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/variant_view_space"
        app:layout_constraintVertical_bias="0.5" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/notify_me_image"
        android:paddingLeft="@dimen/sushi_spacing_mini"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingRight="@dimen/sushi_spacing_mini"
        android:paddingBottom="@dimen/sushi_spacing_nano"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        android:src="@drawable/ic_notified"
        android:paddingHorizontal="@dimen/sushi_spacing_mini"
        android:paddingVertical="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/notify_me_text"
        app:layout_constraintEnd_toEndOf="@id/notify_me_text"
        app:layout_constraintTop_toTopOf="@id/notify_me_text" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:id="@id/notify_me_text"
        android:paddingLeft="@dimen/sushi_spacing_mini"
        android:paddingRight="@dimen/sushi_spacing_mini"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:textAlignment="center"
        android:paddingHorizontal="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toBottomOf="@id/stepper"
        app:layout_constraintEnd_toEndOf="@id/stepper"
        app:layout_constraintStart_toStartOf="@id/stepper"
        app:layout_constraintTop_toTopOf="@id/stepper" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrier_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="stepper,custom_button_cta" />
    <View
        android:id="@id/product_card_egde"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:elevation="@dimen/dimen_2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/start_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="12.0dip"
        app:layout_constraintStart_toStartOf="parent" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/end_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintGuide_end="@dimen/size_12" />
</androidx.constraintlayout.widget.ConstraintLayout>