<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@id/ll_container"
        android:padding="@dimen/sushi_spacing_extra"
        android:layout_width="@dimen/dimen_300"
        android:layout_height="wrap_content"
        android:elevation="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            app:textViewType="MEDIUM_500" />
        <FrameLayout
            android:layout_gravity="center_horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:layout_gravity="center"
                android:id="@id/success_image"
                android:visibility="visible"
                android:layout_width="@dimen/size_100"
                android:layout_height="@dimen/size_100"
                android:layout_marginTop="@dimen/sushi_spacing_base"
                android:layout_marginBottom="@dimen/sushi_spacing_base"
                app:lottie_autoPlay="true"
                app:lottie_repeatCount="2" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center_horizontal"
                android:id="@id/image"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/size_36"
                android:layout_marginTop="@dimen/sushi_spacing_macro"
                android:layout_marginBottom="@dimen/sushi_spacing_loose"
                android:scaleType="fitCenter" />
        </FrameLayout>
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:textAlignment="center"
            app:textViewType="SEMIBOLD_700" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/subtitle"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            app:textViewType="MEDIUM_400" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/subtitle2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center" />
        <com.zomato.ui.atomiclib.atom.ZTag
            android:id="@id/tag"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            app:tagSize="medium"
            app:tagType="rounded" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/subtitle3"
            android:paddingTop="@dimen/sushi_spacing_page_side"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/actionButton"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_loose"
            app:buttonColor="@color/sushi_red_500"
            app:buttonDimension="large"
            app:buttonType="text" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/button"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_loose"
            app:buttonDimension="large"
            app:buttonType="text" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:layout_gravity="bottom"
        android:id="@id/crystal_success_confetti"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:scaleType="centerCrop"
        android:elevation="@dimen/size_8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_loop="false" />
</androidx.constraintlayout.widget.ConstraintLayout>