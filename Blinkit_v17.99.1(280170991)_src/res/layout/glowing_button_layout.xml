<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/image_bg"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:translationY="8.0dip"
        app:layout_constraintBottom_toBottomOf="@id/main_image"
        app:layout_constraintDimensionRatio="4.583"
        app:layout_constraintEnd_toEndOf="@id/main_image"
        app:layout_constraintStart_toStartOf="@id/main_image"
        app:layout_constraintTop_toTopOf="@id/main_image" />
    <com.blinkit.commons.ui.ui.customviews.BLottieAnimationView
        android:id="@id/main_image"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginBottom="8.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="4.583"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:textSize="20.0sp"
        android:textStyle="bold"
        android:gravity="center"
        android:id="@id/button_text"
        android:padding="8.0dip"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:textAlignment="center"
        app:layout_constraintBottom_toBottomOf="@id/main_image"
        app:layout_constraintEnd_toEndOf="@id/main_image"
        app:layout_constraintStart_toStartOf="@id/main_image"
        app:layout_constraintTop_toTopOf="@id/main_image" />
</merge>