<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/container"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/start_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="@dimen/sushi_spacing_page_side" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/end_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="@dimen/sushi_spacing_page_side" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/media_barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <FrameLayout
        android:id="@id/player_container_layout"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/media_barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/top_right_lottie"
        android:visibility="gone"
        android:layout_width="@dimen/size_48"
        android:layout_height="@dimen/size_48"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@id/image1"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="false"
        app:lottie_fileName="bookmark_lottie_dark.json"
        app:lottie_loop="false"
        app:lottie_repeatCount="0"
        app:lottie_repeatMode="restart" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image1"
        android:layout_width="@dimen/size_20"
        android:layout_height="@dimen/size_20"
        android:layout_marginTop="@dimen/dimen_14"
        app:aspectRatio="1.0"
        app:layout_constraintBottom_toTopOf="@id/media_barrier"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:id="@id/top_left_tag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen_18"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/image1"
        app:layout_constraintStart_toEndOf="@id/image1"
        app:layout_constraintTop_toTopOf="@id/image1"
        app:tagColor="@color/sushi_black"
        app:tagSize="tiny"
        app:tagType="rounded" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/right_image"
        android:layout_width="@dimen/size_100"
        android:layout_height="@dimen/size_100"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        app:aspectRatio="1.0"
        app:layout_constraintBottom_toTopOf="@id/media_barrier"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/media_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="image, player_container_layout" />
    <com.zomato.ui.lib.snippets.CurvedTextViewType1
        android:id="@id/curved_tv"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginBottom="@dimen/dimen_eleven_point_nine"
        app:layout_constraintBottom_toTopOf="@id/title"
        app:layout_constraintEnd_toEndOf="@id/subtitle5"
        app:layout_constraintStart_toStartOf="@id/subtitle5"
        app:layout_constraintTop_toTopOf="@id/subtitle5" />
    <com.zomato.ui.lib.snippets.CurvedTextViewType2
        android:id="@id/curved_tv_type2"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginBottom="@dimen/dimen_eleven_point_nine"
        app:layout_constraintBottom_toTopOf="@id/title"
        app:layout_constraintEnd_toEndOf="@id/subtitle5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/subtitle5" />
    <View
        android:id="@id/subtitle5_image_border"
        android:background="@color/sushi_white"
        android:visibility="gone"
        android:layout_width="@dimen/size_44"
        android:layout_height="@dimen/size_44"
        android:layout_marginTop="@dimen/v3_type45_subtitle5_image_topMargin"
        android:layout_marginStart="@dimen/v3_type45_subtitle5_image_startMargin"
        app:cornerRadius="@dimen/size_200"
        app:layout_constraintEnd_toStartOf="@id/subtitle5"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toTopOf="@id/subtitle5" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/subtitle5_image"
        android:padding="@dimen/sushi_spacing_pico"
        android:visibility="gone"
        android:layout_width="@dimen/size_44"
        android:layout_height="@dimen/size_44"
        android:layout_marginTop="@dimen/v3_type45_subtitle5_image_topMargin"
        android:layout_marginStart="@dimen/v3_type45_subtitle5_image_startMargin"
        app:cornerRadius="@dimen/size_200"
        app:layout_constraintEnd_toStartOf="@id/subtitle5"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toTopOf="@id/subtitle5" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/subtitle5"
        android:paddingLeft="@dimen/sushi_spacing_loose"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingRight="@dimen/sushi_spacing_loose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_mini_negative"
        android:drawablePadding="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/sushi_spacing_micro_negative"
        android:paddingHorizontal="@dimen/sushi_spacing_loose"
        app:layout_constraintBottom_toBottomOf="@id/media_barrier"
        app:layout_constraintEnd_toStartOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/start_guideline" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:id="@id/top_tag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        app:layout_constraintEnd_toStartOf="@id/stepper_container"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/media_barrier" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/additional_info_container"
        app:layout_constraintEnd_toStartOf="@id/stepper_container"
        app:layout_constraintStart_toEndOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/top_tag"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_800"
        android:ellipsize="end"
        android:id="@id/subtitle1"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toTopOf="@id/stepper_container"
        app:layout_constraintEnd_toStartOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@id/title"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintVertical_bias="0.0"
        app:textViewType="MEDIUM_300" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/additional_info_container"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toTopOf="@id/subtitle3"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/title">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:gravity="center_vertical"
            android:id="@id/serveInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="@dimen/sushi_spacing_micro" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center_vertical"
            android:id="@id/rating_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="@dimen/sushi_spacing_micro"
            android:paddingEnd="@dimen/sushi_spacing_micro" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:gravity="center_vertical"
            android:id="@id/rating_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTruncatedTextView
        android:textColor="@color/color_black"
        android:ellipsize="end"
        android:id="@id/subtitle3"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_loose"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/stepper_container"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/start_guideline"
        app:layout_constraintTop_toBottomOf="@id/additional_info_container"
        app:textViewType="LIGHT_200" />
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@id/stepper_container"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/end_guideline"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@id/subtitle3"
        app:layout_constraintTop_toTopOf="@id/subtitle3"
        app:layout_constraintVertical_bias="0.0">
        <com.zomato.ui.atomiclib.molecules.ZStepper
            android:layout_gravity="center"
            android:id="@id/dish_stepper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:stepper_type="MEDIUM"
            app:stepper_version="V2" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:id="@id/subtitle4"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano" />
    </LinearLayout>
</merge>