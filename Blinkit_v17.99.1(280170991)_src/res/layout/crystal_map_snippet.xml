<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/font_icon_size_22"
        android:textColor="@color/black"
        android:gravity="center_horizontal"
        android:layout_gravity="center"
        android:id="@id/header"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:paddingBottom="@dimen/qd_margin_22"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/okra_bold"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@id/header_bottom_line"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_goneMarginBottom="@dimen/sushi_spacing_femto" />
    <com.blinkit.commons.ui.ui.customviews.viewstub.BottomClipLottieImageViewStub
        android:id="@id/bg_image_lottie"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_femto"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.motion.widget.MotionLayout
        android:id="@id/motion_layout"
        android:clickable="true"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layoutDescription="@xml/crystal_map_snippet_v2_scene"
        app:layoutDuringTransition="honorRequest"
        app:layout_constraintTop_toBottomOf="@id/header_bottom_line"
        app:layout_goneMarginTop="@dimen/sushi_spacing_femto">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/black"
            android:id="@id/title"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingBottom="@dimen/sushi_spacing_nano"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:fontFamily="@font/okra_bold"
            android:layout_marginStart="@dimen/sushi_spacing_base"
            android:layout_marginEnd="@dimen/qd_margin_168"
            android:paddingVertical="@dimen/sushi_spacing_nano"
            app:layout_constraintBottom_toTopOf="@id/subtitle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/black"
            android:id="@id/collapsed_subtitle"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingBottom="@dimen/sushi_spacing_nano"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/okra_bold"
            android:paddingVertical="@dimen/sushi_spacing_nano"
            app:layout_constraintBottom_toTopOf="@id/subtitle2"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_goneMarginBottom="@dimen/sushi_spacing_extra" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/black"
            android:id="@id/expanded_subtitle"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingBottom="@dimen/sushi_spacing_nano"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/okra_bold"
            android:paddingVertical="@dimen/sushi_spacing_nano"
            app:layout_constraintBottom_toTopOf="@id/subtitle2"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_goneMarginBottom="@dimen/sushi_spacing_extra" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkitbutton.BlinkitButtonViewStub
            android:textColor="@color/black"
            android:id="@id/button"
            android:paddingTop="@dimen/sushi_spacing_nano"
            android:paddingBottom="@dimen/sushi_spacing_nano"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/okra_bold"
            android:paddingVertical="@dimen/sushi_spacing_nano"
            app:textViewType="SEMIBOLD_200" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/font_icon_size_22"
            android:textColor="@color/black"
            android:gravity="center_horizontal"
            android:layout_gravity="center"
            android:id="@id/header_over_map"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingTop="@dimen/sushi_spacing_mini"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/qd_margin_22"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:fontFamily="@font/okra_bold"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            app:layout_constraintTop_toTopOf="parent" />
        <FrameLayout
            android:id="@id/container"
            android:clipChildren="true"
            android:layout_width="@dimen/size_120"
            android:layout_height="0.0dip"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_base"
            android:outlineProvider="background"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            android:layout_marginVertical="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1.4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.blinkit.commons.ui.ui.customviews.bmediaview.BMediaView
                android:id="@id/map_image_lottie_view"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:scaleType="centerCrop"
                android:elevation="@dimen/elevation_1dp"
                android:stateListAnimator="@animator/scale_animator" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_spacing_base"
                android:textColor="?attr_7f040466"
                android:gravity="center"
                android:layout_gravity="end"
                android:id="@id/expand_collapse_icon"
                android:background="@drawable/qd_white_circle"
                android:padding="@dimen/sushi_spacing_micro"
                android:layout_width="@dimen/sushi_spacing_loose"
                android:layout_height="@dimen/sushi_spacing_loose"
                android:layout_margin="@dimen/sushi_spacing_mini"
                android:elevation="@dimen/sushi_spacing_nano"
                android:backgroundTint="?attr_7f04017d"
                android:outlineProvider="background" />
            <ViewStub
                android:id="@id/map_view"
                android:visibility="gone"
                android:layout="@layout/layout_crystal_map_view"
                android:inflatedId="@id/embedded_map_view"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" />
        </FrameLayout>
        <View
            android:id="@id/map_container_click_view"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="@dimen/sushi_spacing_femto"
            app:layout_constraintBottom_toBottomOf="@id/container"
            app:layout_constraintEnd_toEndOf="@id/container"
            app:layout_constraintStart_toStartOf="@id/container"
            app:layout_constraintTop_toTopOf="@id/container" />
    </androidx.constraintlayout.motion.widget.MotionLayout>
    <ViewStub
        android:id="@id/footer"
        android:visibility="gone"
        android:layout="@layout/layout_crystal_map_footer"
        android:inflatedId="@id/footer_layout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/motion_layout" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/font_icon_size_22"
        android:textColor="@color/black"
        android:gravity="center_horizontal"
        android:layout_gravity="center"
        android:id="@id/header_strip"
        android:paddingLeft="@dimen/sushi_spacing_macro"
        android:paddingTop="@dimen/sushi_spacing_mini"
        android:paddingRight="@dimen/sushi_spacing_macro"
        android:paddingBottom="@dimen/sushi_spacing_mini"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_femto"
        android:fontFamily="@font/okra_bold"
        android:paddingHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constrainedHeight="false"
        app:layout_constraintTop_toBottomOf="@id/motion_layout" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/bottom_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="footer,header_strip" />
</androidx.constraintlayout.widget.ConstraintLayout>