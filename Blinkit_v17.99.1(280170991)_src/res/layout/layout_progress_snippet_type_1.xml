<?xml version="1.0" encoding="utf-8"?>
<merge
    android:gravity="center_vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZProgressBar
        android:layout_gravity="start|center"
        android:id="@id/progress"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="@dimen/size_20"
        android:progress="0"
        android:progressDrawable="@drawable/horizontal_green_rounded_progress"
        android:layout_weight="1.0"
        style="?android:progressBarStyleHorizontal" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="end|center"
        android:id="@id/right_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/sushi_spacing_femto"
        android:layout_marginStart="@dimen/sushi_spacing_loose" />
</merge>