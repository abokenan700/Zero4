<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_gravity="center"
        android:id="@id/container"
        android:paddingLeft="@dimen/sushi_spacing_mini"
        android:paddingRight="@dimen/sushi_spacing_mini"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/sushi_spacing_mini">
        <FrameLayout
            android:layout_gravity="center"
            android:id="@id/progress_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <View
                android:layout_gravity="center"
                android:id="@id/shadow_view"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <View
                android:layout_gravity="center"
                android:id="@id/bg_view"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:translationY="@dimen/size_3" />
            <View
                android:layout_gravity="start|center"
                android:id="@id/progress_view"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content" />
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:id="@id/leading_container"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_nano_negative"
            android:layout_marginEnd="@dimen/sushi_spacing_macro">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center"
                android:id="@id/leading_image"
                android:visibility="gone"
                android:layout_width="@dimen/size_28"
                android:layout_height="@dimen/size_28"
                android:scaleType="centerCrop" />
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:layout_gravity="center"
                android:id="@id/leading_animation_view"
                android:visibility="gone"
                android:layout_width="@dimen/size_28"
                android:layout_height="@dimen/size_28"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />
        </FrameLayout>
        <FrameLayout
            android:layout_gravity="end|center"
            android:id="@id/trailing_container"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            android:layout_marginEnd="@dimen/sushi_spacing_nano_negative">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center"
                android:id="@id/trailing_image"
                android:visibility="gone"
                android:layout_width="@dimen/size_28"
                android:layout_height="@dimen/size_28"
                android:scaleType="centerCrop" />
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:layout_gravity="center"
                android:id="@id/trailing_animation_view"
                android:visibility="gone"
                android:layout_width="@dimen/size_28"
                android:layout_height="@dimen/size_28"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />
        </FrameLayout>
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_900"
        android:ellipsize="end"
        android:layout_gravity="start|center"
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_mini"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_mini"
        android:maxLines="2"
        android:layout_marginHorizontal="@dimen/sushi_spacing_mini"
        app:textViewType="SEMIBOLD_400" />
</merge>