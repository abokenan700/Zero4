<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:background="@color/color_transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/image_tag"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        android:translationZ="12.0dip">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/leftImage"
            android:visibility="gone"
            android:layout_width="101.0dip"
            android:layout_height="wrap_content"
            android:scaleType="fitXY"
            android:adjustViewBounds="true" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_white"
            android:id="@id/image_tag_text"
            android:background="@drawable/bg_image_tag"
            android:padding="@dimen/sushi_spacing_between"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:textViewType="MEDIUM_100" />
        <View
            android:id="@id/tag_triangle_view"
            android:background="@drawable/bg_image_tag_triangle"
            android:layout_width="@dimen/sushi_spacing_mini"
            android:layout_height="@dimen/sushi_spacing_micro" />
    </LinearLayout>
    <include
        android:id="@id/left_container"
        layout="@layout/item_left_image_tag_container" />
    <include
        android:id="@id/right_container"
        layout="@layout/item_right_image_tag_container" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/imageContainer"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:paddingStart="@dimen/sushi_spacing_page_side"
        android:paddingEnd="@dimen/sushi_spacing_page_side">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/image"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            app:cornerRadius="@dimen/sushi_spacing_macro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/rightImage"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/snippet_type_17_right_image_size"
            android:layout_margin="@dimen/sushi_spacing_extra"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"
            android:maxWidth="@dimen/snippet_type_17_right_image_max_size"
            android:contentDescription="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/rightGuideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.85" />
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/linearLayout"
            android:background="@color/sushi_grey_100"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/sushi_spacing_page_side"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sushi_spacing_extra"
            android:paddingEnd="@dimen/sushi_spacing_extra"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/image">
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/textLayout"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/title"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1" />
                <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                    android:id="@id/ratingBar"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:ratedBlockDimenConfig="300"
                    app:ratingType="stars" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle1"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:lineSpacingExtra="-6.0dip" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle2"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1" />
                <com.zomato.ui.atomiclib.atom.ZTag
                    android:id="@id/bottomTag"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_micro"
                    app:tagColor="@color/sushi_black"
                    app:tagSize="small" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle3"
                    android:paddingTop="@dimen/sushi_spacing_base"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZButton
                android:textSize="9.0sp"
                android:gravity="end"
                android:id="@id/rightAction"
                android:padding="@dimen/dimen_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_nano"
                app:buttonDimension="medium"
                app:buttonType="text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/imageParentLayout" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>