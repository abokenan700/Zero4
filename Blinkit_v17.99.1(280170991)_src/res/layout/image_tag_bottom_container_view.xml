<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:id="@id/image_bottom_container"
    android:clipChildren="false"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/mainContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/bottom_container_image"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/sushi_spacing_extra" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/bottom_container_text_layout"
            android:paddingLeft="@dimen/sushi_spacing_mini"
            android:paddingTop="@dimen/size_3"
            android:paddingRight="@dimen/sushi_spacing_mini"
            android:paddingBottom="@dimen/size_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_mini"
            android:paddingVertical="@dimen/size_3">
            <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
                android:textColor="@color/sushi_white"
                android:id="@id/bottom_container_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@id/bottom_container_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/bottom_container_title" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/bottom_container_left_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                android:layout_marginBottom="@dimen/sushi_spacing_micro"
                android:scaleType="centerInside"
                android:layout_marginVertical="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/icon_image_barrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="end"
                app:constraint_referenced_ids="bottom_container_icon,bottom_container_left_image" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:ellipsize="end"
                android:id="@id/bottom_container_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/sushi_spacing_between"
                app:layout_constraintBottom_toTopOf="@id/bottom_container_subtitle"
                app:layout_constraintStart_toEndOf="@id/icon_image_barrier"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:ellipsize="end"
                android:id="@id/bottom_container_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/bottom_container_title"
                app:layout_constraintTop_toBottomOf="@id/bottom_container_title" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <com.zomato.ui.lib.organisms.snippets.rescards.imagebottomcontainer.ZRightAngledTriangleView
        android:id="@id/z_right_angled_triangle_view"
        android:visibility="gone"
        android:layout_width="@dimen/size_6"
        android:layout_height="@dimen/size_5"
        android:layout_marginBottom="-5.0dip" />
</merge>