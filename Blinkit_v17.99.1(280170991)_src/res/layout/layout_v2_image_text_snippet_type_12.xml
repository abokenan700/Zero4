<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/rootContainerView"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="end|center"
        android:id="@id/topImage"
        android:layout_width="@dimen/size_48"
        android:layout_height="@dimen/size_48"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:scaleType="centerCrop"
        android:layout_marginEnd="@dimen/sushi_spacing_macro" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="start"
        android:id="@id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:layout_marginStart="@dimen/sushi_spacing_macro" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:gravity="center"
        android:layout_gravity="end|bottom|center"
        android:id="@id/bottomTag"
        android:padding="@dimen/sushi_spacing_nano"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/listing_rating_min_width"
        android:includeFontPadding="false"
        app:tagSize="large" />
</merge>