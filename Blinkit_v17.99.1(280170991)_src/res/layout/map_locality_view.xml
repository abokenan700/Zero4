<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:padding="@dimen/padding_12"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040466"
        android:ellipsize="end"
        android:id="@id/heading"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="@string/delivering_to"
        android:maxLines="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:textViewType="BOLD_400" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="@dimen/size_40"
        android:layout_height="@dimen/size_40"
        android:src="@drawable/location_map_pin"
        android:scaleType="centerInside"
        android:layout_marginStart="@dimen/margin_8"
        app:layout_constraintBottom_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="@id/heuristics_bg"
        app:layout_constraintTop_toTopOf="@id/title" />
    <View
        android:id="@id/dummy_top_view"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/size_12"
        app:layout_constraintBottom_toTopOf="@id/top_barrier"
        app:layout_constraintTop_toTopOf="@id/heuristics_bg" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/top_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="image,title" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/margin_8"
        android:layout_marginRight="@dimen/margin_8"
        android:maxLines="1"
        android:layout_marginHorizontal="@dimen/margin_8"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintEnd_toStartOf="@id/btn_change"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toBottomOf="@id/dummy_top_view"
        app:layout_constraintVertical_chainStyle="packed"
        app:textViewType="BOLD_400" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/subtitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_2"
        android:maxLines="2"
        android:layout_marginEnd="@dimen/margin_8"
        app:layout_constraintEnd_toEndOf="@id/title"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:textViewType="REGULAR_100" />
    <com.blinkit.commons.ui.ui.customviews.customStripView.CustomStripView
        android:id="@id/bottom_strip"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/subtitle"
        app:layout_constraintTop_toBottomOf="@id/subtitle" />
    <View
        android:id="@id/separator"
        android:background="?attr_7f040296"
        android:visibility="invisible"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/divider_view_height"
        android:layout_marginTop="@dimen/margin_12"
        app:layout_constraintBottom_toTopOf="@id/subtitle2"
        app:layout_constraintTop_toBottomOf="@id/bottom_strip" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/bottom_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="subtitle2,subtitle" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_orange_500"
        android:ellipsize="end"
        android:id="@id/subtitle2"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/margin_12"
        android:layout_marginTop="@dimen/margin_6"
        android:layout_marginRight="@dimen/margin_12"
        android:layout_marginBottom="@dimen/margin_6"
        android:maxLines="1"
        android:layout_marginHorizontal="@dimen/margin_12"
        android:layout_marginVertical="@dimen/margin_6"
        app:layout_constraintBottom_toBottomOf="@id/heuristics_bg"
        app:layout_constraintEnd_toEndOf="@id/heuristics_bg"
        app:layout_constraintStart_toStartOf="@id/heuristics_bg"
        app:layout_constraintTop_toBottomOf="@id/separator"
        app:textViewType="REGULAR_100" />
    <View
        android:id="@id/heuristics_bg"
        android:background="@color/sushi_teal_300"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/margin_12"
        android:layout_marginBottom="@dimen/margin_16"
        android:elevation="-0.100000024dip"
        app:layout_constraintBottom_toTopOf="@id/info_strip"
        app:layout_constraintTop_toBottomOf="@id/heading" />
    <com.blinkit.blink.elements.ui.atoms.button.BlinkitButtonView
        android:id="@id/btn_change"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:text="@string/change_cta"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/title"
        app:textViewType="SEMIBOLD_200" />
    <com.blinkit.commons.ui.ui.customviews.customStripView.CustomStripView
        android:id="@id/info_strip"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/bottom_barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/heuristics_bg" />
    <include
        android:id="@id/info_banner"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/qd_margin_12"
        app:layout_constraintBottom_toTopOf="@id/enter_address"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
        layout="@layout/map_info_banner_view" />
    <com.blinkit.blink.elements.ui.atoms.button.BlinkitButtonView
        android:id="@id/enter_address"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qd_margin_12"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/info_banner"
        app:textViewType="MEDIUM_500" />
    <com.blinkit.commons.ui.ui.customviews.swipebutton.SwipeButton
        android:id="@id/swipe_button"
        android:paddingBottom="@dimen/margin_12"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/bottom_button"
        android:paddingTop="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:paddingVertical="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/enter_address"
        app:textViewType="MEDIUM_500" />
</androidx.constraintlayout.widget.ConstraintLayout>