<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/root"
    android:background="@color/sushi_white"
    android:layout_width="fill_parent"
    android:layout_height="@dimen/type_11_view_height"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.lib.atom.ZTicketBackground
        android:id="@id/ticketView"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:ticketBackgroundColor="@color/sushi_white"
        app:ticketBorderColor="@color/sushi_grey_100"
        app:ticketBorderWidth="@dimen/sushi_spacing_pico"
        app:ticketCornerRadius="@dimen/sushi_spacing_macro"
        app:ticketCornerType="rounded"
        app:ticketDividerColor="@color/sushi_grey_200"
        app:ticketDividerDashGap="@dimen/sushi_spacing_between_small"
        app:ticketDividerDashLength="@dimen/type_11_dash_length"
        app:ticketDividerType="dash"
        app:ticketDividerWidth="@dimen/type_11_dash_width"
        app:ticketElevation="@dimen/elevation_medium"
        app:ticketOrientation="horizontal"
        app:ticketScallopPositionPercent="62.0"
        app:ticketScallopRadius="@dimen/sushi_spacing_between_large"
        app:ticketShowBorder="true"
        app:ticketShowDivider="true" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_page_side"
        android:src="@drawable/ic_bg"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        android:maxHeight="@dimen/type_11_image_height"
        android:contentDescription="@null"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/title"
        android:paddingTop="@dimen/sushi_spacing_page_side"
        android:paddingBottom="@dimen/sushi_spacing_page_side"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:lines="2"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:layout_gravity="center"
        android:id="@id/button"
        android:padding="@dimen/sushi_spacing_macro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>