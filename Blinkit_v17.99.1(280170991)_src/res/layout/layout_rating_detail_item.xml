<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/leading_title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0" />
    <com.zomato.ui.atomiclib.atom.ZProgressBar
        android:id="@id/progressBar"
        android:layout_width="@dimen/rating_detail_progressbar_width"
        android:layout_height="@dimen/sushi_spacing_mini"
        android:progressDrawable="@drawable/gold_progressive_view_progress_bar_bg"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        style="?android:progressBarStyleHorizontal" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/trailing_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:drawablePadding="@dimen/sushi_spacing_between" />
</LinearLayout>