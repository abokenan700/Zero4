<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_image"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toTopOf="@id/shimmer_title"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="1.0"
        app:shimmer_corner_radius="@dimen/sushi_spacing_base" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_title"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/dimen_10"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/shimmer_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shimmer_image"
        app:layout_constraintWidth_percent="0.7"
        app:shimmer_corner_radius="@dimen/sushi_spacing_base" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_subtitle"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/dimen_10"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shimmer_title"
        app:layout_constraintWidth_percent="1.0"
        app:shimmer_corner_radius="@dimen/sushi_spacing_base" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_subtitle_2"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/dimen_10"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shimmer_subtitle"
        app:layout_constraintWidth_percent="0.7"
        app:shimmer_corner_radius="@dimen/sushi_spacing_base" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_subtitle_3"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/dimen_10"
        android:layout_marginTop="@dimen/sushi_spacing_mini"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shimmer_subtitle_2"
        app:layout_constraintWidth_percent="0.7"
        app:shimmer_corner_radius="@dimen/sushi_spacing_base" />
</androidx.constraintlayout.widget.ConstraintLayout>