<?xml version="1.0" encoding="utf-8"?>
<androidx.core.view.insets.ProtectionLayout
    android:id="@id/protection_view"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/cl_root_container"
        android:background="?attr_7f04017d"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <FrameLayout
            android:id="@id/fragment_container"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <include
            android:id="@id/splash"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            layout="@layout/layout_splash" />
        <FrameLayout
            android:id="@id/aerobar_container"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">
            <View
                android:id="@id/aerobar_shadow"
                android:background="@drawable/bg_above_aerobar"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </FrameLayout>
        <View
            android:id="@id/onboarding_view_backdrop"
            android:background="@color/color_black_alpha_eighty"
            android:focusable="true"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:alpha="0.0" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.image.ZLottieAnimationViewStub
            android:id="@id/on_boarding_iv"
            android:focusable="true"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:translationY="1000.0dip"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_bar_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
            android:textColor="@color/color_black_alpha_eighty"
            android:gravity="center"
            android:id="@id/on_boarding_cross_icon"
            android:focusable="true"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/sushi_spacing_alone"
            android:layout_height="@dimen/sushi_spacing_alone"
            android:layout_margin="@dimen/sushi_spacing_macro"
            android:translationY="1000.0dip"
            app:layout_constraintEnd_toEndOf="@id/on_boarding_iv"
            app:layout_constraintTop_toTopOf="@id/on_boarding_iv" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/bottom_nav_bar_container"
            android:background="?attr_7f0403d7"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:elevation="@dimen/elevation_huge"
            app:layout_constraintBottom_toBottomOf="parent">
            <com.blinkit.consumerapp.ui.bottomnavbar.indicators.BottomNavBarIndicator
                android:id="@id/bottom_nav_bar_indicator"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginTop="-0.5dip"
                app:layout_constraintTop_toTopOf="@id/bottom_nav_bar"
                app:targetBottomNavBar="@id/bottom_nav_bar" />
            <com.blinkit.consumerapp.ui.bottomnavbar.BottomNavBar
                android:id="@id/bottom_nav_bar"
                android:background="@color/transparent_white"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.blinkit.consumerapp.ui.nitroerroroverlay.NitroOverlay
            android:id="@id/nitro_overlay"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:elevation="@dimen/sushi_spacing_micro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/shimmer_background"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginTop="@dimen/demarcation_shadow_depth_neg">
            <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
                android:textSize="@dimen/font_icon_size_22"
                android:textColor="?attr_7f040466"
                android:gravity="center_horizontal"
                android:id="@id/tv1l"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_16"
                android:text="@string/waiting_for_location"
                android:fontFamily="@font/okra_bold"
                android:layout_marginStart="@dimen/margin_16"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout
                android:id="@id/shimmer_view_container"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginTop="@dimen/margin_8"
                app:zanimated_shimmer_duration="800">
                <include
                    layout="@layout/shimmer_background_onboarding" />
            </com.zomato.ui.atomiclib.atom.AnimatedShimmerFrameLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.view.insets.ProtectionLayout>