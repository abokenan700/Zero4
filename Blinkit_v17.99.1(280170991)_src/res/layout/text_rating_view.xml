<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/ratingStarItemTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingEnd="@dimen/sushi_spacing_micro"
        app:drawablePadding="@dimen/sushi_spacing_nano"
        app:textViewType="SEMIBOLD_300" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/ratingStarItemSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:drawablePadding="@dimen/sushi_spacing_nano"
        app:textViewType="MEDIUM_300" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/ratingStar"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_16"
        android:layout_height="@dimen/dimen_16" />
</LinearLayout>