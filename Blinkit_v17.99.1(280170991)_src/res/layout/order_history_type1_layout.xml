<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:gravity="start"
        android:orientation="vertical"
        android:id="@id/internalContainer"
        android:paddingTop="@dimen/z_spacing_10"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/titleContainer"
            android:paddingLeft="@dimen/sushi_spacing_page_side"
            android:paddingRight="@dimen/sushi_spacing_page_side"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_page_side">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/image"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/size_56"
                android:adjustViewBounds="true" />
            <LinearLayout
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/sushi_spacing_base">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_pico" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZTag
                android:id="@id/tag1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:tagSize="small"
                app:tagType="capsule" />
        </LinearLayout>
        <View
            android:id="@id/separator1"
            android:background="@color/sushi_grey_200"
            android:layout_width="fill_parent"
            android:layout_height="0.5dip"
            android:layout_marginLeft="@dimen/sushi_spacing_page_side"
            android:layout_marginTop="@dimen/sushi_spacing_page_side"
            android:layout_marginRight="@dimen/sushi_spacing_page_side"
            android:layout_marginHorizontal="@dimen/sushi_spacing_page_side" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@id/infoContainer"
            android:paddingLeft="@dimen/sushi_spacing_page_side"
            android:paddingTop="@dimen/z_spacing_10"
            android:paddingRight="@dimen/sushi_spacing_page_side"
            android:paddingBottom="@dimen/sushi_spacing_page_side"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_page_side" />
        <View
            android:id="@id/separator2"
            android:background="@color/sushi_grey_200"
            android:layout_width="fill_parent"
            android:layout_height="0.5dip"
            android:layout_marginLeft="@dimen/sushi_spacing_page_side"
            android:layout_marginRight="@dimen/sushi_spacing_page_side"
            android:layout_marginHorizontal="@dimen/sushi_spacing_page_side" />
        <FrameLayout
            android:id="@id/bottom_container_bg"
            android:paddingLeft="@dimen/sushi_spacing_page_side"
            android:paddingTop="@dimen/sushi_spacing_base"
            android:paddingRight="@dimen/sushi_spacing_page_side"
            android:paddingBottom="@dimen/sushi_spacing_base"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_page_side">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/bottom_container_bg_image"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:id="@id/bottom_container"
                android:paddingLeft="@dimen/sushi_spacing_page_side"
                android:paddingTop="@dimen/sushi_spacing_base"
                android:paddingRight="@dimen/sushi_spacing_page_side"
                android:paddingBottom="@dimen/sushi_spacing_base"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:paddingHorizontal="@dimen/sushi_spacing_page_side">
                <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                    android:id="@id/bottom_container_title"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                    android:id="@id/bottom_container_subtitle"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </FrameLayout>
        <View
            android:id="@id/separator3"
            android:background="@color/sushi_grey_200"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="0.5dip"
            android:layout_marginLeft="@dimen/sushi_spacing_page_side"
            android:layout_marginRight="@dimen/sushi_spacing_page_side"
            android:layout_marginHorizontal="@dimen/sushi_spacing_page_side" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/statusContainer"
            android:paddingLeft="@dimen/sushi_spacing_page_side"
            android:paddingTop="@dimen/sushi_spacing_base"
            android:paddingRight="@dimen/sushi_spacing_page_side"
            android:paddingBottom="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/sushi_spacing_page_side">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:gravity="center_vertical"
                android:id="@id/itemsBottomImage"
                android:layout_width="@dimen/size_20"
                android:layout_height="@dimen/size_20"
                android:layout_marginEnd="@dimen/sushi_spacing_macro" />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginEnd="@dimen/sushi_spacing_macro">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/itemsBottomTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/sushi_spacing_macro" />
                <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                    android:layout_gravity="center_vertical"
                    android:id="@id/rating_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZButton
                android:layout_gravity="end|center"
                android:id="@id/rightButton"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonDimension="large"
                app:buttonType="solid" />
        </LinearLayout>
    </LinearLayout>
</merge>