<?xml version="1.0" encoding="utf-8"?>
<merge
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:animateLayoutChanges="true"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:layout_gravity="start|center"
            android:id="@id/prefix_text"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_mini"
            android:layout_marginEnd="-7.0dip" />
        <com.google.android.material.textfield.TextInputLayout
            android:gravity="center_horizontal"
            android:layout_gravity="center_horizontal"
            android:id="@id/input_field"
            android:background="@null"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="none"
            style="@style/Widget.Sushi.TextInputField">
            <com.google.android.material.textfield.TextInputEditText
                android:gravity="start"
                android:layout_gravity="center_horizontal"
                android:id="@id/text_input_field"
                android:background="@null"
                android:paddingLeft="@dimen/sushi_spacing_base"
                android:paddingRight="@dimen/sushi_spacing_base"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/sushi_spacing_base" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:id="@id/error_text"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base" />
    <com.zomato.ui.lib.organisms.snippets.textsnippet.type17.TextSnippetType17
        android:id="@id/pills_container"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/dimen_20"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/info_title"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingTop="@dimen/sushi_spacing_mini"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/sushi_spacing_mini"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_loose"
        android:paddingHorizontal="@dimen/sushi_spacing_base"
        android:paddingVertical="@dimen/sushi_spacing_mini" />
    <LinearLayout
        android:id="@id/bottom_container"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingTop="@dimen/sushi_spacing_macro"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/sushi_spacing_macro"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/dimen_20"
        android:layout_marginRight="@dimen/sushi_spacing_base"
        android:layout_marginHorizontal="@dimen/sushi_spacing_base"
        android:paddingHorizontal="@dimen/sushi_spacing_base"
        android:paddingVertical="@dimen/sushi_spacing_macro">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/bottom_container_image"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/size14"
            android:layout_marginTop="@dimen/sushi_spacing_nano" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/bottom_container_title"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_macro" />
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/checkbox_parent_container"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra">
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/checkbox_container_top_separator"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/payments_container"
            app:zseparator_type="STRAIGHT" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/checkbox_container"
            android:padding="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base">
            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:layout_gravity="center_vertical"
                    android:id="@id/checkbox_container_left_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:layout_gravity="center_vertical"
                    android:id="@id/checkbox_container_title"
                    android:visibility="gone"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:layout_marginStart="@dimen/sushi_spacing_base" />
                <FrameLayout
                    android:layout_gravity="center_vertical"
                    android:id="@id/checkbox_right_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_base">
                    <com.zomato.ui.atomiclib.atom.ZCheckBox
                        android:layout_gravity="center_vertical"
                        android:id="@id/checkbox_container_checkbox"
                        android:padding="@dimen/dimen_0"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="0.9"
                        android:scaleY="0.9"
                        android:layout_marginEnd="-8.0dip" />
                    <com.zomato.ui.atomiclib.atom.ZButton
                        android:id="@id/checkbox_container_right_button"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonType="solid"
                        app:layout_constraintBottom_toBottomOf="@id/payments_container"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/payments_container" />
                </FrameLayout>
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:layout_gravity="center_vertical"
                android:id="@id/checkbox_container_subtitle"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_base"
                android:layout_marginStart="@dimen/size_44" />
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/checkbox_expanded_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.molecules.ZTextInputField
                    android:textColorHint="?attr_7f04048a"
                    android:gravity="center_vertical"
                    android:id="@id/expanded_textfield"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_base"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:translationZ="10.0dip"
                    android:elevation="@dimen/sushi_spacing_pico"
                    app:boxBackgroundColor="?attr_7f04017d"
                    app:boxCornerRadiusBottomEnd="@dimen/dimen_12"
                    app:boxCornerRadiusBottomStart="@dimen/dimen_12"
                    app:boxCornerRadiusTopEnd="@dimen/dimen_12"
                    app:boxCornerRadiusTopStart="@dimen/dimen_12"
                    app:boxStrokeColor="?attr_7f040297"
                    app:editTextType="REGULAR_400"
                    app:endIconMode="none"
                    app:endIconTint="?attr_7f04048a"
                    app:hintEnabled="true"
                    app:prefixTextAppearance="@style/OrderTextInputLayout"
                    app:prefixTextColor="?attr_7f04048a"
                    style="@style/OrderTextInputLayout" />
                <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                    android:gravity="start"
                    android:layout_gravity="center_horizontal"
                    android:id="@id/expanded_error_text"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_macro" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</merge>