<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="bottom"
        android:id="@id/image1"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/size_72"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        app:aspectRatio="1.0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <LinearLayout
        android:gravity="top"
        android:orientation="vertical"
        android:id="@id/topLeftImageContainer"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_12"
        android:weightSum="1.0"
        android:elevation="@dimen/sushi_spacing_nano"
        app:layout_constraintStart_toStartOf="@id/root_container"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/topImage1"
            android:layout_width="wrap_content"
            android:layout_height="16.0dip"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"
            app:aspectRatio="2.5" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/topImage2"
            android:layout_width="wrap_content"
            android:layout_height="16.0dip"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"
            app:aspectRatio="2.5" />
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/root_container"
        android:background="?attr_7f0403d7"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/image1">
        <LinearLayout
            android:gravity="center"
            android:id="@id/top_title_container"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/top_text_title_prefix_image"
                android:visibility="gone"
                android:layout_width="@dimen/dimen_16"
                android:layout_height="@dimen/dimen_16"
                android:layout_marginEnd="@dimen/dimen_4" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:gravity="center"
                android:id="@id/top_text_title"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
        <FrameLayout
            android:id="@id/image_frame_layout"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/image"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:aspectRatio="1.45" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:gravity="center_vertical"
                android:layout_gravity="start|bottom|center"
                android:orientation="horizontal"
                android:id="@id/tag_text"
                android:padding="@dimen/sushi_spacing_micro"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_macro" />
            <LinearLayout
                android:layout_gravity="bottom|center"
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="end"
                    android:orientation="horizontal"
                    android:id="@id/imageTagContainer"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_macro"
                    android:layout_marginTop="@dimen/sushi_spacing_micro"
                    android:layout_marginRight="@dimen/sushi_spacing_macro"
                    android:layout_marginBottom="@dimen/sushi_spacing_micro"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
                    android:layout_marginVertical="@dimen/sushi_spacing_micro">
                    <com.zomato.ui.atomiclib.atom.ZTag
                        android:layout_gravity="start"
                        android:id="@id/bottom_left_tag"
                        android:paddingLeft="@dimen/sushi_spacing_micro"
                        android:paddingTop="@dimen/sushi_spacing_nano"
                        android:paddingRight="@dimen/sushi_spacing_micro"
                        android:paddingBottom="@dimen/sushi_spacing_nano"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/sushi_spacing_micro"
                        android:paddingHorizontal="@dimen/sushi_spacing_micro"
                        android:paddingVertical="@dimen/sushi_spacing_nano"
                        app:tagSize="tiny"
                        app:tagType="rounded" />
                    <com.zomato.ui.lib.snippets.ZImageTagView
                        android:gravity="start"
                        android:layout_gravity="start"
                        android:id="@id/image_tag"
                        android:visibility="gone"
                        android:layout_width="0.0dip"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        app:tagSize="large"
                        app:tagType="rounded_outline" />
                    <com.zomato.ui.atomiclib.atom.ZTag
                        android:layout_gravity="end"
                        android:id="@id/bottom_right_tag"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:tagSize="tiny"
                        app:tagType="rounded" />
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@id/info_container"
                    android:paddingTop="@dimen/sushi_spacing_micro"
                    android:paddingBottom="@dimen/sushi_spacing_micro"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/sushi_spacing_micro">
                    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                        android:layout_gravity="center_vertical"
                        android:id="@id/info_container_image"
                        android:layout_width="@dimen/dimen_16"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:layout_marginStart="@dimen/dimen_10" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:layout_gravity="center_vertical"
                        android:id="@id/info_container_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sushi_spacing_mini"
                        android:layout_marginRight="@dimen/sushi_spacing_mini"
                        android:layout_marginHorizontal="@dimen/sushi_spacing_mini" />
                </LinearLayout>
            </LinearLayout>
            <FrameLayout
                android:layout_gravity="end|center|top"
                android:id="@id/rightActionLottieContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_macro"
                android:layout_marginEnd="@dimen/sushi_spacing_nano">
                <FrameLayout
                    android:layout_gravity="end|center|top"
                    android:id="@id/rightActionContainer"
                    android:paddingTop="@dimen/dimen_two_point_two"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_28"
                    android:layout_height="@dimen/size_28"
                    android:layout_margin="@dimen/dimen_one_point_five"
                    android:translationZ="@dimen/sushi_spacing_pico">
                    <com.zomato.ui.atomiclib.atom.ZButton
                        android:layout_gravity="center"
                        android:id="@id/rightAction"
                        android:padding="@dimen/dimen_0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/dimen_0"
                        app:buttonDimension="small"
                        app:buttonType="text" />
                </FrameLayout>
                <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                    android:layout_gravity="center"
                    android:id="@id/lottieAnimationView"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_28"
                    android:layout_height="@dimen/size_28"
                    android:translationZ="@dimen/sushi_spacing_nano" />
            </FrameLayout>
            <FrameLayout
                android:id="@id/top_info_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/top_info_container_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_mini"
                    android:layout_marginTop="@dimen/sushi_spacing_micro"
                    android:layout_marginRight="@dimen/sushi_spacing_mini"
                    android:layout_marginBottom="@dimen/sushi_spacing_micro"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_mini"
                    android:layout_marginVertical="@dimen/sushi_spacing_micro" />
            </FrameLayout>
            <LinearLayout
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:id="@id/llImageBottomSubtitles"
                android:background="@drawable/gradient_bottom_black"
                android:padding="@dimen/sushi_spacing_macro"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <LinearLayout
                    android:gravity="start|center"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                        android:id="@id/subtitle5_image"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/size_9" />
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:id="@id/subtitle5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
            <View
                android:layout_gravity="bottom"
                android:background="@color/sushi_grey_100"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/dimen_point_five" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center"
                android:id="@id/overlay_image"
                android:visibility="gone"
                android:layout_width="@dimen/size_56"
                android:layout_height="@dimen/size_56"
                app:cornerRadius="@dimen/size28" />
        </FrameLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/textContainer"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f040490"
                android:ellipsize="end"
                android:gravity="top"
                android:layout_gravity="top"
                android:id="@id/restaurant_name"
                android:paddingTop="@dimen/spacing_between_4_45dp"
                android:paddingBottom="@dimen/spacing_between_4_45dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_macro"
                android:layout_marginRight="@dimen/sushi_spacing_macro"
                android:text="Om Sweets"
                android:maxLines="1"
                android:singleLine="true"
                android:layout_marginHorizontal="@dimen/sushi_spacing_macro" />
            <com.zomato.ui.atomiclib.atom.ZSeparator
                android:id="@id/seperator"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/border_stroke_width"
                app:zseparator_color="@color/sushi_grey_100" />
            <LinearLayout
                android:gravity="top"
                android:layout_gravity="top"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0">
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:ellipsize="end"
                        android:id="@id/title"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sushi_spacing_macro"
                        android:layout_marginTop="@dimen/sushi_spacing_macro"
                        android:layout_marginRight="@dimen/sushi_spacing_macro"
                        android:layout_marginBottom="@dimen/spacing_between_3dp"
                        android:maxLines="2"
                        android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
                        app:textViewType="MEDIUM_400" />
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@id/verticalSubtitlesLL"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sushi_spacing_macro"
                        android:layout_marginRight="@dimen/sushi_spacing_macro"
                        android:layout_marginHorizontal="@dimen/sushi_spacing_macro" />
                    <com.zomato.ui.lib.utils.VerticalSubtitleView
                        android:id="@id/verticalSubtitleView"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/sushi_spacing_macro"
                        android:layout_marginRight="@dimen/sushi_spacing_macro"
                        android:layout_marginHorizontal="@dimen/sushi_spacing_macro" />
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="@dimen/sushi_spacing_macro"
                        android:paddingEnd="@dimen/sushi_spacing_macro">
                        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                            android:id="@id/subtitle_image"
                            android:layout_width="@dimen/dimen_12"
                            android:layout_height="@dimen/dimen_12" />
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:textColor="?attr_7f040490"
                            android:ellipsize="end"
                            android:id="@id/subtitle"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            app:textViewType="MEDIUM_100" />
                    </LinearLayout>
                </LinearLayout>
                <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                    android:layout_gravity="top"
                    android:id="@id/ratingSnippet"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_macro"
                    android:layout_marginBottom="@dimen/spacing_between_3dp"
                    android:layout_marginEnd="@dimen/sushi_spacing_macro"
                    app:layout_constraintEnd_toStartOf="@id/end_guideline"
                    app:layout_constraintTop_toBottomOf="@id/media_barrier"
                    app:ratedBlockDimenConfig="300"
                    app:ratingType="tag_v2" />
            </LinearLayout>
            <FrameLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <LinearLayout
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@id/price_stepper_container"
                        android:paddingBottom="@dimen/sushi_spacing_micro"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/sushi_spacing_micro">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:layout_gravity="center_vertical"
                            android:orientation="vertical"
                            android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0">
                            <com.zomato.ui.atomiclib.atom.ZTextView
                                android:textColor="?attr_7f040490"
                                android:ellipsize="end"
                                android:id="@id/subtitle2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/sushi_spacing_macro"
                                android:layout_marginRight="@dimen/sushi_spacing_macro"
                                android:maxLines="1"
                                android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
                                app:textViewType="MEDIUM_100" />
                            <com.zomato.ui.atomiclib.atom.ZTextView
                                android:textColor="?attr_7f040490"
                                android:ellipsize="end"
                                android:id="@id/subtitle3"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/sushi_spacing_macro"
                                android:layout_marginRight="@dimen/sushi_spacing_macro"
                                android:maxLines="1"
                                android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
                                app:textViewType="MEDIUM_100" />
                        </LinearLayout>
                        <com.zomato.ui.atomiclib.molecules.ZStepper
                            android:layout_gravity="center_vertical"
                            android:id="@id/stepper"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/sushi_spacing_macro"
                            android:layout_marginTop="@dimen/sushi_spacing_pico"
                            android:layout_marginRight="@dimen/sushi_spacing_macro"
                            android:layout_marginBottom="@dimen/sushi_spacing_pico"
                            android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
                            android:layout_marginVertical="@dimen/sushi_spacing_pico"
                            app:stepper_type="SMALL"
                            app:stepper_version="V2" />
                    </LinearLayout>
                    <com.zomato.ui.lib.snippets.GenericSeparatorView
                        android:id="@id/bottomContainerTopSeparator"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content" />
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@id/bottomContainer"
                        android:paddingTop="@dimen/sushi_spacing_mini"
                        android:paddingBottom="@dimen/sushi_spacing_macro"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="@dimen/sushi_spacing_macro"
                        android:paddingEnd="@dimen/sushi_spacing_mini">
                        <com.zomato.ui.atomiclib.atom.ZTextView
                            android:ellipsize="end"
                            android:layout_gravity="center_vertical"
                            android:id="@id/bottomContainerTitle"
                            android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            android:layout_weight="1.0"
                            app:textViewType="MEDIUM_100" />
                        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                            android:textSize="@dimen/sushi_textsize_200"
                            android:layout_gravity="center_vertical"
                            android:id="@id/bottomContainerIcon"
                            android:paddingTop="@dimen/sushi_spacing_nano"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/sushi_spacing_nano" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
    <com.zomato.ui.lib.snippets.ZMultiTagView
        android:id="@id/multitag_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        app:layout_constraintStart_toEndOf="@id/image1"
        app:layout_constraintTop_toTopOf="@id/root_container"
        app:tag_size_type="SMALL"
        app:tagsVerticalSpacing="@dimen/sushi_spacing_micro" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:layout_gravity="end"
        android:id="@id/top_left_tag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen_10"
        android:elevation="@dimen/dimen_4"
        app:layout_constraintStart_toStartOf="@id/root_container"
        app:layout_constraintTop_toTopOf="@id/root_container"
        app:tagSize="tiny"
        app:tagType="rounded" />
</merge>