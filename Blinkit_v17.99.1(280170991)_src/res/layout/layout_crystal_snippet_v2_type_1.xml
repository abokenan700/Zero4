<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/root"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/header_container"
        android:paddingBottom="@dimen/sushi_spacing_loose"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/header_title"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/sushi_spacing_macro"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_extra"
            android:layout_marginRight="@dimen/sushi_spacing_extra"
            android:layout_marginHorizontal="@dimen/sushi_spacing_extra"
            android:paddingVertical="@dimen/sushi_spacing_macro" />
    </FrameLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/main_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/left_barrier"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            app:barrierDirection="end"
            app:constraint_referenced_ids="containerView,left_top_image" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/right_barrier"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            app:barrierDirection="start"
            app:constraint_referenced_ids="right_button,right_button_1,right_icon" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/left_top_image"
            android:visibility="gone"
            android:layout_width="@dimen/size_48"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/ll_container" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/containerView"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/image"
                android:layout_width="@dimen/size_32"
                android:layout_height="@dimen/size_32"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <View
                android:id="@id/image_gradient"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                android:layout_marginStart="@dimen/sushi_spacing_base"
                app:layout_constraintBottom_toBottomOf="@id/image"
                app:layout_constraintEnd_toEndOf="@id/image"
                app:layout_constraintStart_toStartOf="@id/image"
                app:layout_constraintTop_toTopOf="@id/image" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_spacing_extra"
                android:textColor="@color/sushi_white"
                android:id="@id/overlay_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_macro"
                android:layout_marginStart="@dimen/sushi_spacing_base"
                android:layout_marginEnd="@dimen/sushi_spacing_macro"
                app:layout_constraintBottom_toBottomOf="@id/image"
                app:layout_constraintEnd_toEndOf="@id/image" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f040475"
                android:gravity="center"
                android:id="@id/overlay_text"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@id/image"
                app:layout_constraintEnd_toEndOf="@id/image"
                app:layout_constraintStart_toStartOf="@id/image"
                app:textViewType="MEDIUM_100" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:id="@id/ll_container"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:paddingStart="@dimen/sushi_spacing_macro"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toTopOf="@id/scroll_view"
            app:layout_constraintEnd_toStartOf="@id/right_button"
            app:layout_constraintStart_toEndOf="@id/left_barrier"
            app:layout_constraintTop_toTopOf="parent">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f040475"
                android:ellipsize="end"
                android:id="@id/title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:textViewType="MEDIUM_400" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@id/subtitle1_container"
                android:paddingTop="@dimen/sushi_spacing_micro"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_grey_500"
                    android:ellipsize="end"
                    android:id="@id/subtitle1"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    app:layout_constraintEnd_toStartOf="@id/subtitle1_tag"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintHorizontal_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_default="wrap"
                    app:textViewType="MEDIUM_100" />
                <com.zomato.ui.atomiclib.atom.ZTag
                    android:gravity="center"
                    android:id="@id/subtitle1_tag"
                    android:padding="@dimen/corner_radius_nano"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/listing_rating_min_width"
                    android:includeFontPadding="true"
                    android:layout_marginStart="@dimen/sushi_spacing_macro"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/subtitle1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tagSize="nano" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_500"
                android:ellipsize="end"
                android:layout_gravity="start"
                android:id="@id/subtitle2"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                app:drawablePadding="@dimen/sushi_spacing_micro"
                app:textViewType="MEDIUM_100" />
            <com.zomato.ui.atomiclib.atom.ZButton
                android:layout_gravity="center_vertical"
                android:id="@id/bottom_button"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="@id/subtitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/title" />
            <com.zomato.ui.lib.organisms.snippets.crystal.ImageTextTag
                android:id="@id/image_text_tag"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/right_button"
            android:padding="@dimen/sushi_spacing_macro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/right_icon"
            app:layout_constraintStart_toEndOf="@id/ll_container"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textColor="?attr_7f040475"
            android:gravity="center"
            android:id="@id/right_icon"
            android:background="@drawable/nitro_toolbar_feedback"
            android:visibility="gone"
            android:layout_width="@dimen/size_38"
            android:layout_height="@dimen/size_38"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/right_button"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:id="@id/subtitle3"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_between"
            app:layout_constraintBottom_toTopOf="@id/scroll_view"
            app:layout_constraintEnd_toStartOf="@id/ratingSnippet"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
            android:id="@id/ratingSnippet"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_base"
            app:layout_constraintBottom_toTopOf="@id/scroll_view"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:ratedBlockDimenConfig="400" />
        <HorizontalScrollView
            android:id="@id/scroll_view"
            android:paddingTop="@dimen/sushi_spacing_between"
            android:paddingBottom="@dimen/sushi_spacing_between"
            android:visibility="gone"
            android:scrollbars="none"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            android:layout_marginEnd="@dimen/sushi_spacing_macro"
            android:paddingVertical="@dimen/sushi_spacing_between"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/right_barrier"
            app:layout_constraintStart_toEndOf="@id/left_barrier"
            app:layout_constraintTop_toBottomOf="@id/ll_container">
            <LinearLayout
                android:gravity="start|center"
                android:orientation="horizontal"
                android:id="@id/instructions_container"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </HorizontalScrollView>
        <View
            android:id="@id/right_gradient"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_base"
            android:layout_height="@dimen/sushi_spacing_femto"
            app:layout_constraintBottom_toBottomOf="@id/scroll_view"
            app:layout_constraintEnd_toEndOf="@id/scroll_view"
            app:layout_constraintTop_toTopOf="@id/scroll_view" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:textColor="@color/sushi_red_500"
            android:gravity="center"
            android:id="@id/right_button_1"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            android:layout_marginEnd="@dimen/sushi_spacing_page_side"
            app:buttonDimension="medium"
            app:buttonType="text"
            app:layout_constraintBottom_toBottomOf="@id/scroll_view"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/scroll_view" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040475"
            android:id="@id/footer_data"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/sushi_spacing_macro"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:paddingStart="@dimen/sushi_spacing_macro"
            android:paddingEnd="@dimen/sushi_spacing_macro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_container"
            app:textViewType="MEDIUM_400" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>