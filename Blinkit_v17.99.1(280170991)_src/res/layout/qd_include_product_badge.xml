<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:id="@id/cl_product_badge"
    android:paddingTop="@dimen/qd_padding_2"
    android:paddingBottom="@dimen/qd_padding_2"
    android:visibility="visible"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingEnd="@dimen/qd_padding_2"
    android:paddingVertical="@dimen/qd_padding_2"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center_vertical"
        android:id="@id/badge_image"
        android:layout_width="@dimen/size_8"
        android:layout_height="@dimen/size_8"
        android:layout_marginStart="@dimen/qd_margin_2" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:layout_gravity="center_vertical"
        android:id="@id/badge_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lines="1"
        android:maxEms="7"
        android:layout_marginStart="@dimen/qd_margin_2"
        app:textViewType="LIGHT_50" />
</LinearLayout>