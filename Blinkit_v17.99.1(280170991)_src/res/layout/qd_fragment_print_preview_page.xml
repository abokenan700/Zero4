<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="?attr_7f040180"
    android:focusable="true"
    android:fitsSystemWindows="true"
    android:clickable="true"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/toolbar_spacing"
        android:background="@color/color_transparent"
        android:layout_width="fill_parent"
        android:layout_height="?actionBarSize"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:gravity="center"
        android:id="@id/ivToolbarLeft"
        android:background="@drawable/white_circle_dark_mode"
        android:layout_width="@dimen/font_icon_size_36"
        android:layout_height="@dimen/font_icon_size_36"
        android:scaleType="centerInside"
        android:layout_marginStart="@dimen/qd_margin_20"
        app:layout_constraintBottom_toBottomOf="@id/toolbar_spacing"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/toolbar_spacing" />
    <View
        android:id="@id/rightToolbarBackground"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/font_icon_size_36"
        app:layout_constrainedHeight="true"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@id/ivToolbarRightText"
        app:layout_constraintEnd_toEndOf="@id/ivToolbarRightText"
        app:layout_constraintStart_toStartOf="@id/ivToolbarRightIcon"
        app:layout_constraintTop_toTopOf="@id/ivToolbarRightText" />
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:id="@id/ivToolbarRightIcon"
        android:paddingTop="@dimen/sushi_spacing_mini"
        android:paddingBottom="@dimen/sushi_spacing_mini"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/toolbar_spacing"
        app:layout_constraintEnd_toStartOf="@id/ivToolbarRightText"
        app:layout_constraintTop_toTopOf="@id/toolbar_spacing" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:id="@id/ivToolbarRightText"
        android:paddingTop="@dimen/sushi_spacing_mini"
        android:paddingBottom="@dimen/sushi_spacing_mini"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/sushi_spacing_micro"
        android:paddingEnd="@dimen/qd_padding_10"
        android:layout_marginEnd="@dimen/qd_margin_14"
        app:layout_constraintBottom_toBottomOf="@id/toolbar_spacing"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/toolbar_spacing" />
    <com.blinkit.commons.ui.ui.customviews.recyclerview.BContainer
        android:id="@id/print_preview_page_rv"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/indicator"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_spacing" />
    <com.blinkit.commons.ui.ui.customviews.FiveDotIndicatorWithCount
        android:id="@id/indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toTopOf="@id/bottom_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/print_preview_page_rv" />
    <com.blinkit.commons.ui.ui.snippets.bPrintItemConfig.BPrintItemPreviewConfigVH
        android:id="@id/bottom_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toTopOf="@id/bottom_strip_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <com.zomato.ui.atomiclib.molecules.ShimmerView
        android:id="@id/bottom_container_shimmer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/qd_margin_10"
        android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/bottom_container" />
    <View
        android:id="@id/info_container"
        android:background="?attr_7f040295"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_button_medium_minheight"
        app:layout_constraintBottom_toTopOf="@id/bottom_strip_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/info_image"
        android:layout_width="@dimen/sushi_action_item_drawable_size"
        android:layout_height="@dimen/sushi_action_item_drawable_size"
        android:scaleType="fitCenter"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/info_container"
        app:layout_constraintEnd_toStartOf="@id/info_title"
        app:layout_constraintStart_toStartOf="@id/info_container"
        app:layout_constraintTop_toTopOf="@id/info_container" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/info_title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/info_container"
        app:layout_constraintEnd_toEndOf="@id/info_container"
        app:layout_constraintStart_toEndOf="@id/info_image"
        app:layout_constraintTop_toTopOf="@id/info_container" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/bottom_strip_layout"
        android:background="@drawable/all_white_grey_top_border"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/page_count_and_pricing"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/qd_margin_20"
            android:layout_marginBottom="@dimen/qd_margin_20"
            android:layout_marginStart="@dimen/qd_margin_16"
            android:layout_marginVertical="@dimen/qd_margin_20">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/page_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/print_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/qd_margin_4" />
        </LinearLayout>
        <Space
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1.0" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/add_to_cart_btn"
            android:visibility="gone"
            android:layout_width="@dimen/size_200"
            android:layout_height="@dimen/size_54"
            android:layout_marginLeft="@dimen/qd_margin_12"
            android:layout_marginTop="@dimen/qd_margin_12"
            android:layout_marginRight="@dimen/qd_margin_12"
            android:layout_marginBottom="@dimen/qd_margin_12"
            android:layout_marginHorizontal="@dimen/qd_margin_12"
            android:layout_marginVertical="@dimen/qd_margin_12"
            app:buttonColor="?themeColor500" />
    </LinearLayout>
    <com.blinkit.commons.ui.ui.customviews.loadingErrorOverlay.LoadingErrorOverlay
        android:id="@id/loading_error_overlay"
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        android:elevation="@dimen/elevation_regular"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.Group
        android:id="@id/shimmer_group"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:constraint_referenced_ids="shimmer_title,shimmer_subtitle,shimmer_button"
        app:layout_constraintBottom_toBottomOf="@id/bottom_strip_layout"
        app:layout_constraintEnd_toEndOf="@id/bottom_strip_layout"
        app:layout_constraintStart_toStartOf="@id/bottom_strip_layout"
        app:layout_constraintTop_toTopOf="@id/bottom_strip_layout" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_title"
        android:layout_width="@dimen/size_80"
        android:layout_height="@dimen/sushi_spacing_base"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/qd_margin_16"
        app:bgColor="@color/sushi_grey_200"
        app:layout_constraintBottom_toTopOf="@id/shimmer_subtitle"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/bottom_strip_layout"
        app:layout_constraintTop_toTopOf="@id/bottom_strip_layout"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintWidth_percent="0.7" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_subtitle"
        android:layout_width="@dimen/size_30"
        android:layout_height="@dimen/sushi_spacing_extra"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:layout_marginStart="@dimen/qd_margin_16"
        app:bgColor="@color/sushi_grey_200"
        app:layout_constraintBottom_toBottomOf="@id/bottom_strip_layout"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/bottom_strip_layout"
        app:layout_constraintTop_toBottomOf="@id/shimmer_title"
        app:layout_constraintVertical_bias="0.0" />
    <com.zomato.ui.atomiclib.molecules.ShimmerChildView
        android:id="@id/shimmer_button"
        android:padding="@dimen/qd_margin_0.5"
        android:clickable="true"
        android:layout_width="@dimen/size_200"
        android:layout_height="@dimen/size_56"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:bgColor="@color/sushi_grey_200"
        app:cornerRadius="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="@id/bottom_strip_layout"
        app:layout_constraintEnd_toEndOf="@id/bottom_strip_layout"
        app:layout_constraintTop_toTopOf="@id/bottom_strip_layout"
        app:layout_constraintVertical_bias="0.5"
        app:shimmer_corner_radius="@dimen/sushi_spacing_macro" />
</androidx.constraintlayout.widget.ConstraintLayout>