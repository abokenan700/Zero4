<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center"
    android:orientation="horizontal"
    android:id="@id/container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_weight="1.0"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/left_image"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"
        android:layout_marginStart="@dimen/sushi_spacing_macro" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:ellipsize="end"
        android:layout_gravity="center_vertical"
        android:id="@id/title_tv"
        android:paddingTop="@dimen/sushi_spacing_nano"
        android:paddingBottom="@dimen/sushi_spacing_nano"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:paddingStart="@dimen/sushi_spacing_micro"
        android:paddingVertical="@dimen/sushi_spacing_nano" />
    <com.blinkit.blink.elements.ui.atoms.icon.BlinkitIconView
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/icon"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/icon_font_min_arrow"
        android:paddingStart="@dimen/sushi_spacing_nano"
        android:paddingEnd="@dimen/sushi_spacing_nano"
        android:paddingVertical="@dimen/sushi_spacing_micro" />
</LinearLayout>