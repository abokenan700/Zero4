<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/bg_image"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/size_12"
            android:layout_marginTop="@dimen/size_12"
            android:layout_marginRight="@dimen/size_12"
            android:layout_marginBottom="@dimen/size_12"
            android:layout_marginHorizontal="@dimen/size_12"
            android:layout_marginVertical="@dimen/size_12">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/image"
                android:layout_width="@dimen/size_80"
                android:layout_height="@dimen/size_80"
                android:layout_marginEnd="@dimen/size_12"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sushi_spacing_femto"
                android:layout_marginStart="@dimen/size14"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/image"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:textViewType="REGULAR_400" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:textViewType="SEMIBOLD_600" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subitle2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:textViewType="SEMIBOLD_300" />
            </LinearLayout>
            <com.zomato.ui.lib.snippets.ZImageTagView
                android:layout_gravity="end|center"
                android:id="@id/imageTag"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sushi_spacing_femto"
                android:layout_marginEnd="@dimen/sushi_spacing_extra"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/separator"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/sushi_spacing_pico"
            app:zseparator_color="@color/sushi_grey_200" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:id="@id/subitle1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_page_side"
            android:layout_marginTop="@dimen/sushi_spacing_macro"
            android:layout_marginRight="@dimen/sushi_spacing_page_side"
            android:layout_marginBottom="@dimen/sushi_spacing_macro"
            android:layout_marginHorizontal="@dimen/sushi_spacing_page_side"
            android:layout_marginVertical="@dimen/sushi_spacing_macro" />
        <FrameLayout
            android:id="@id/dummyButtonWrapper"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:background="?themeColor500"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/size_45">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_white"
                    android:gravity="center|left"
                    android:id="@id/dummyButton"
                    android:layout_width="0.0dip"
                    android:layout_height="@dimen/size_45"
                    android:layout_marginLeft="@dimen/sushi_spacing_page_side"
                    android:layout_weight="1.0"
                    app:textViewType="MEDIUM_400" />
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:textSize="@dimen/sushi_textsize_400"
                    android:textColor="@color/sushi_white"
                    android:gravity="end|center"
                    android:id="@id/icon"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/sushi_spacing_page_side" />
            </LinearLayout>
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_gravity="center"
                android:id="@id/button_loader"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="@color/sushi_white"
                app:indicatorSize="@dimen/size24" />
        </FrameLayout>
    </LinearLayout>
</merge>