<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/sticky_footer_view"
    android:padding="@dimen/sushi_spacing_base"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/end_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="sticky_footer_view_left_image, sticky_footer_view_checkbox_frame" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/sticky_footer_view_left_image"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_16"
        android:layout_height="@dimen/dimen_16"
        android:scaleType="fitXY"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/sticky_footer_view_title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/size_3"
        app:layout_constraintEnd_toStartOf="@id/sticky_footer_view_title_suffix_image"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/end_barrier"
        app:layout_constraintTop_toTopOf="@id/sticky_footer_view_left_image" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/sticky_footer_view_title_suffix_image"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toBottomOf="@id/sticky_footer_view_title"
        app:layout_constraintEnd_toStartOf="@id/sticky_footer_view_right_icon"
        app:layout_constraintStart_toEndOf="@id/sticky_footer_view_title"
        app:layout_constraintTop_toTopOf="@id/sticky_footer_view_title" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/sticky_footer_view_subtitle"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toStartOf="@id/subtitle_button"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/sticky_footer_view_title"
        app:layout_constraintTop_toBottomOf="@id/sticky_footer_view_title"
        app:layout_constraintWidth_default="wrap" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/subtitle_button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_3"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/dimen_10"
        app:layout_constraintEnd_toStartOf="@id/sticky_footer_view_right_icon"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/sticky_footer_view_subtitle"
        app:layout_constraintTop_toBottomOf="@id/sticky_footer_view_title" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/subtitle_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="sticky_footer_view_subtitle, subtitle_button" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/sticky_footer_view_bottom_separator"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle_barrier"
        app:zseparator_color="@color/sushi_grey_300"
        app:zseparator_type="DASHED" />
    <FrameLayout
        android:id="@id/sticky_footer_view_checkbox_frame"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="0.0dip"
        android:layout_marginTop="@dimen/size_7_negative"
        android:layout_marginStart="@dimen/size_9_negative"
        app:layout_constraintBottom_toBottomOf="@id/sticky_footer_view_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/sticky_footer_view_title">
        <com.zomato.ui.atomiclib.atom.ZCheckBox
            android:gravity="top"
            android:layout_gravity="top"
            android:id="@id/sticky_footer_view_checkbox"
            android:padding="@dimen/dimen_0"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="0.9"
            android:scaleY="0.9" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:id="@id/sticky_footer_view_right_icon"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/sticky_footer_view_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/sticky_footer_view_title" />
</androidx.constraintlayout.widget.ConstraintLayout>