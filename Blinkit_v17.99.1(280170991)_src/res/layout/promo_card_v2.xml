<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/container"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:clipToOutline="false"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.snippets.promoTicketSnippet.BTicketBackground
        android:id="@id/background"
        android:padding="@dimen/qd_ticket_border_width"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginLeft="-5.0dip"
        android:layout_marginTop="-5.0dip"
        android:layout_marginRight="-5.0dip"
        android:layout_marginBottom="-5.0dip"
        android:layout_marginHorizontal="-5.0dip"
        android:layout_marginVertical="-5.0dip"
        app:bticketBackgroundColor="@color/white"
        app:bticketBorderColor="@color/sushi_grey_300"
        app:bticketBorderType="normal"
        app:bticketBorderWidth="0.100000024dip"
        app:bticketCornerRadius="@dimen/dimen_16"
        app:bticketCornerType="rounded"
        app:bticketDividerColor="@color/sushi_grey_300"
        app:bticketDividerDashGap="@dimen/ticket_dash_gap"
        app:bticketDividerDashLength="@dimen/ticket_dash_gap"
        app:bticketDividerPadding="0.0dip"
        app:bticketDividerType="dash"
        app:bticketDividerWidth="@dimen/qd_ticket_border_width"
        app:bticketElevation="40.0dip"
        app:bticketOrientation="horizontal"
        app:bticketScallopPosition="50.0dip"
        app:bticketScallopRadius="0.0dip"
        app:bticketShowBorder="true"
        app:bticketShowDivider="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:layout_width="@dimen/dimen_60"
        android:layout_height="@dimen/dimen_60"
        android:layout_marginLeft="@dimen/dimen_20"
        android:layout_marginTop="@dimen/dimen_20"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/header_title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_15"
        android:layout_marginEnd="@dimen/dimen_20"
        app:layout_constraintBottom_toTopOf="@id/header_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/image"
        app:layout_constraintTop_toTopOf="@id/image"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/header_subtitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toBottomOf="@id/image"
        app:layout_constraintEnd_toEndOf="@id/header_title"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/header_title"
        app:layout_constraintTop_toBottomOf="@id/header_title" />
    <com.blinkit.commons.ui.base.BNitroSeparator
        android:id="@id/ticket_view"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/qd_margin_0.5"
        android:layout_marginLeft="@dimen/sushi_spacing_nano"
        android:layout_marginTop="@dimen/dimen_20"
        android:layout_marginRight="@dimen/sushi_spacing_nano"
        android:layout_marginBottom="@dimen/dimen_15"
        android:layout_marginHorizontal="@dimen/sushi_spacing_nano"
        app:layout_constraintBottom_toTopOf="@id/footer_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image"
        app:separator_color="@color/sushi_grey_300" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/footer_title"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_15"
        android:layout_marginRight="@dimen/dimen_15"
        android:layout_marginHorizontal="@dimen/dimen_15"
        app:layout_constraintBottom_toTopOf="@id/footer_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/footer_subtitle"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_15"
        android:layout_marginRight="@dimen/dimen_15"
        android:layout_marginBottom="@dimen/dimen_15"
        android:layout_marginHorizontal="@dimen/dimen_15"
        app:layout_constraintBottom_toTopOf="@id/terms_and_conditions_list"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent" />
    <LinearLayout
        android:gravity="left"
        android:orientation="vertical"
        android:id="@id/terms_and_conditions_list"
        android:paddingLeft="14.0dip"
        android:paddingRight="14.0dip"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_20"
        android:paddingHorizontal="14.0dip"
        app:layout_constraintBottom_toTopOf="@id/left_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/left_button"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_15"
        android:layout_marginStart="@dimen/dimen_15"
        android:layout_marginEnd="@dimen/dimen_15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/right_button"
        app:layout_constraintStart_toStartOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/right_button"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_15"
        android:layout_marginEnd="@dimen/dimen_15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/left_button"
        app:layout_constraintTop_toTopOf="@id/left_button" />
</androidx.constraintlayout.widget.ConstraintLayout>