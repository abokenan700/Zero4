<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/separator1"
        android:background="@color/sushi_grey_200"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip" />
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="@dimen/sushi_spacing_page_side"
        android:paddingBottom="@dimen/sushi_spacing_page_side"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/sushi_spacing_page_side">
        <LinearLayout
            android:gravity="start"
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:layout_gravity="start"
                android:id="@id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_nano"
                app:drawablePadding="@dimen/sushi_spacing_mini" />
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.molecules.ZStepper
                android:id="@id/stepper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:stepper_type="NORMAL" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:layout_gravity="center_horizontal"
                android:id="@id/subtitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_micro" />
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@id/separator2"
        android:background="@color/sushi_grey_200"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip" />
</merge>