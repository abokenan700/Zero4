<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/root_container"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.lib.molecules.toolbar.ZToolBar
        android:id="@id/z_toolbar"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:left_icon_type="TYPE_LEFT_ARROW" />
    <FrameLayout
        android:id="@id/frame_layout_container"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <FrameLayout
            android:id="@id/fragment_container"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
        <LinearLayout
            android:layout_gravity="top"
            android:orientation="vertical"
            android:id="@id/toolbar_layout"
            android:visibility="visible"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:id="@id/status_bar_dummy"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <View
                    android:id="@id/view_toolbar_dummy"
                    android:background="@color/z_text_color"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.0" />
                <View
                    android:id="@id/view_toolbar_gradient_status_bar"
                    android:background="@drawable/gradient_top"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.2" />
            </FrameLayout>
            <androidx.appcompat.widget.Toolbar
                android:theme="@style/ToolbarBaseTheme"
                android:id="@id/toolbar"
                android:background="@color/color_transparent"
                android:layout_width="fill_parent"
                android:layout_height="?actionBarSize"
                android:elevation="@dimen/elevation_regular"
                android:popupTheme="@android:style/ThemeOverlay.Material.Light"
                app:contentInsetLeft="0.0dip"
                app:contentInsetStart="0.0dip">
                <RelativeLayout
                    android:background="@color/color_transparent"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent">
                    <View
                        android:id="@id/actionbar_background"
                        android:background="@color/color_white"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:alpha="0.0" />
                    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                        android:textSize="@dimen/iconfont_size"
                        android:textStyle="bold"
                        android:textColor="?attr_7f040475"
                        android:gravity="center"
                        android:id="@id/back_icon"
                        android:background="@drawable/photo_feedback_circle"
                        android:padding="@dimen/padding_regular"
                        android:clickable="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/icon_font_back"
                        android:layout_centerVertical="true"
                        android:paddingStart="@dimen/padding_side"
                        android:layout_alignParentStart="true" />
                    <com.zomato.android.zcommons.legacyViews.NitroTextView
                        android:ellipsize="end"
                        android:gravity="center"
                        android:id="@id/toolbar_heading"
                        android:background="@null"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:layout_centerInParent="true"
                        android:paddingStart="@dimen/toolbar_title_left_margin"
                        android:paddingEnd="@dimen/toolbar_title_left_margin"
                        app:newztextview_type="ACTION_TITLE"
                        app:ztextview_color="BLACK" />
                </RelativeLayout>
            </androidx.appcompat.widget.Toolbar>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>