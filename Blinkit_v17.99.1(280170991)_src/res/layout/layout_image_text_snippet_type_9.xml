<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:orientation="vertical"
    android:id="@id/type_9_root"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:elevation="@dimen/sushi_spacing_micro"
    app:cardCornerRadius="@dimen/sushi_spacing_macro"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/type9Image"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"
            app:aspectRatio="1.0" />
        <LinearLayout
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:background="@color/sushi_white"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:gravity="center"
                android:id="@id/type9Text"
                android:paddingTop="@dimen/sushi_spacing_macro"
                android:paddingBottom="@dimen/sushi_spacing_macro"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_weight="1.0"
                android:textAlignment="center"
                android:paddingStart="@dimen/sushi_spacing_page_side"
                android:paddingEnd="@dimen/sushi_spacing_page_side"
                app:textViewType="MEDIUM_300" />
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:layout_gravity="end|center"
                android:id="@id/rightIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_page_side" />
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>