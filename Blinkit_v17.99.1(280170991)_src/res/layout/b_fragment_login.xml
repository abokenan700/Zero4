<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/login_container"
    android:background="?attr_7f04017d"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:animateLayoutChanges="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/lottie"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:lottie_autoPlay="false"
        app:lottie_cacheComposition="false"
        app:lottie_loop="true" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:gravity="center"
        android:id="@id/back_button"
        android:background="@drawable/qd_white_circle"
        android:visibility="gone"
        android:layout_width="@dimen/margin_48"
        android:layout_height="@dimen/margin_48"
        android:layout_marginTop="@dimen/qd_margin_24"
        android:contentDescription="@string/go_back"
        android:layout_marginStart="@dimen/qd_margin_14"
        android:elevation="@dimen/dimen_4"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f040466"
        android:id="@id/skip_login"
        android:background="@drawable/ic_back_skip_login"
        android:paddingLeft="@dimen/qd_padding_12"
        android:paddingTop="@dimen/qd_padding_6"
        android:paddingRight="@dimen/qd_padding_12"
        android:paddingBottom="@dimen/qd_padding_6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qd_margin_24"
        android:text="@string/skip_login"
        android:layout_marginEnd="@dimen/qd_margin_14"
        android:elevation="@dimen/dimen_4"
        android:paddingHorizontal="@dimen/qd_padding_12"
        android:paddingVertical="@dimen/qd_padding_6"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:textViewType="MEDIUM_200" />
    <com.blinkit.consumerapp.ui.nitroerroroverlay.NitroOverlay
        android:id="@id/nitro_overlay"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:elevation="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/bg_view"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/text_main_terms_container"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
        <View
            android:id="@id/gr1"
            android:background="@drawable/ic_gradient"
            android:visibility="visible"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_48"
            android:layout_marginBottom="@dimen/dimen_12"
            android:elevation="@dimen/dimen_4"
            app:layout_constraintBottom_toTopOf="@id/iv_logo"
            app:layout_constraintLeft_toLeftOf="parent" />
        <View
            android:background="?attr_7f04017d"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gr1" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/iv_logo"
            android:layout_width="@dimen/qd_size_64"
            android:layout_height="@dimen/qd_size_64"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            app:layout_constraintBottom_toTopOf="@id/tv_header"
            app:layout_constraintLeft_toLeftOf="@id/bg_view"
            app:layout_constraintRight_toRightOf="@id/bg_view" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040466"
            android:gravity="center_horizontal"
            android:id="@id/tv_header"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/qd_margin_24"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:layout_marginRight="@dimen/qd_margin_24"
            android:text="@string/login_intent"
            android:layout_marginHorizontal="@dimen/qd_margin_24"
            app:layout_constraintBottom_toTopOf="@id/barrier"
            app:layout_constraintLeft_toLeftOf="@id/bg_view"
            app:layout_constraintRight_toRightOf="@id/bg_view" />
        <include
            android:id="@id/zomato_login_card"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            layout="@layout/zomato_login_card_layout" />
        <include
            android:id="@id/cl_phone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            layout="@layout/login_phone_layout" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="top"
            app:constraint_referenced_ids="cl_phone,zomato_login_card" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="?attr_7f04024d"
        android:gravity="center"
        android:id="@id/text_main_terms_container"
        android:background="@drawable/tnc_border"
        android:padding="@dimen/size_8"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:textViewType="REGULAR_50" />
</androidx.constraintlayout.widget.ConstraintLayout>