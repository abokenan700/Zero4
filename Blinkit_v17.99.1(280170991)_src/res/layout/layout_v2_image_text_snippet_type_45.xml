<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/containerView"
    android:padding="@dimen/size_8"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:elevation="@dimen/sushi_spacing_pico"
    android:stateListAnimator="@animator/scale_animator"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/top_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/size_6">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/icon_font_size_small"
            android:layout_gravity="center"
            android:id="@id/top_container_icon"
            android:padding="@dimen/dimen_two_point_five"
            android:layout_width="@dimen/dimen_15"
            android:layout_height="@dimen/dimen_15" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_700"
            android:ellipsize="end"
            android:layout_gravity="center"
            android:id="@id/top_container_text"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_marginStart="@dimen/sushi_spacing_micro"
            app:textViewType="MEDIUM_100" />
    </LinearLayout>
    <com.zomato.ui.lib.organisms.snippets.imagetext.type10.ZImageTextSnippetType10
        android:id="@id/childContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />
</LinearLayout>