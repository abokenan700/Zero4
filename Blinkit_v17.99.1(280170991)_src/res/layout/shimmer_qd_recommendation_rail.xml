<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/transparent_white"
    app:cardCornerRadius="@dimen/dimen_0"
    app:cardElevation="@dimen/dimen_0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <include
            android:layout_gravity="center_vertical"
            android:id="@id/shimmer_rec_3"
            android:layout_width="@dimen/size210"
            android:layout_height="@dimen/dimen_12"
            android:layout_marginTop="@dimen/size_20"
            android:layout_marginBottom="@dimen/size_20"
            android:layout_marginStart="@dimen/dimen_16"
            layout="@layout/qd_shimmer_rectangle" />
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:layout_weight="4.0"
            app:layout_constraintTop_toBottomOf="@id/shimmer_rec_3">
            <include
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_marginLeft="@dimen/dimen_16"
                android:layout_marginBottom="@dimen/dimen_18"
                android:layout_marginEnd="@dimen/dimen_16"
                layout="@layout/shimmer_qd_slp_rail_item" />
            <include
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_marginBottom="@dimen/dimen_18"
                android:layout_marginEnd="@dimen/dimen_16"
                layout="@layout/shimmer_qd_slp_rail_item" />
            <include
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                android:layout_marginBottom="@dimen/dimen_18"
                android:layout_weight="0.8"
                layout="@layout/shimmer_qd_slp_rail_item" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>