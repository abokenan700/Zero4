<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:id="@id/root"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr_7f0403d7"
    app:cardCornerRadius="@dimen/corner_radius_large"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
            android:id="@id/recycler_view"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <com.zomato.ui.lib.snippets.GenericSeparatorView
            android:id="@id/footer_separator"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/footer_container"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f04048a"
                android:id="@id/footer_title"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/sushi_spacing_base"
                android:layout_marginEnd="@dimen/sushi_spacing_base" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="?attr_7f040490"
                android:id="@id/footer_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@id/bottom_container"
            android:padding="@dimen/sushi_spacing_macro"
            android:visibility="gone"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:layout_marginStart="@dimen/sushi_spacing_base"
            android:layout_marginEnd="@dimen/sushi_spacing_base">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center"
                android:id="@id/bottom_container_start_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="centerInside"
                android:layout_marginEnd="@dimen/sushi_spacing_macro" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/bottom_container_title"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/bottom_button"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            android:layout_marginVertical="@dimen/sushi_spacing_extra" />
        <com.zomato.ui.lib.snippets.GenericSeparatorView
            android:id="@id/footer_separator_2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_extra" />
        <com.zomato.ui.atomiclib.atom.ZButton
            android:id="@id/bottom_button_2"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base" />
    </LinearLayout>
</androidx.cardview.widget.CardView>