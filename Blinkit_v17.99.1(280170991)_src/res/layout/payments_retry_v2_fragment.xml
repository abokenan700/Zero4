<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/container"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/cross_button_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_800"
            android:textColor="@color/white"
            android:layout_gravity="center_horizontal"
            android:id="@id/cross_button"
            android:background="@drawable/payments_circle_background"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingTop="@dimen/sushi_spacing_macro"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:paddingBottom="@dimen/sushi_spacing_macro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:text="@string/icon_font_cross"
            android:backgroundTint="@color/tokenised_slate_700"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            android:paddingVertical="@dimen/sushi_spacing_macro" />
    </FrameLayout>
    <FrameLayout
        android:id="@id/root_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/data_container"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <com.zomato.ui.atomiclib.atom.ZTouchInterceptRecyclerView
                android:id="@id/recycler_view"
                android:paddingLeft="@dimen/sushi_spacing_base"
                android:paddingRight="@dimen/sushi_spacing_base"
                android:clipToPadding="false"
                android:layout_width="fill_parent"
                android:layout_height="0.0dip"
                android:layout_weight="1.0"
                android:paddingHorizontal="@dimen/sushi_spacing_base" />
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:id="@id/bottom_container"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.zomato.ui.lib.snippets.ZCheckBoxType3Snippet
                    android:id="@id/zbalance_checkbox"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <com.zomato.ui.lib.snippets.GenericCartButton
                    android:layout_gravity="bottom"
                    android:id="@id/genericCartButton"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:checkoutButtonColor="?themeColor500" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:layout_gravity="bottom"
                    android:id="@id/bottom_button_1"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_loose"
                    android:layout_marginRight="@dimen/sushi_spacing_loose"
                    android:layout_marginBottom="@dimen/sushi_spacing_base"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_loose" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:layout_gravity="bottom"
                    android:id="@id/bottom_button_2"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_loose"
                    android:layout_marginRight="@dimen/sushi_spacing_loose"
                    android:layout_marginBottom="@dimen/sushi_spacing_loose"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_loose" />
            </LinearLayout>
        </LinearLayout>
        <FrameLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@id/refresh_progress_container"
            android:background="@color/color_white_trans_seventy"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <ProgressBar
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_macro" />
        </FrameLayout>
        <payments.zomato.paymentkit.ui.molecules.PaymentsNoContentView
            android:layout_gravity="center"
            android:id="@id/payments_ncv"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" />
    </FrameLayout>
</LinearLayout>