<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/parent_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:stateListAnimator="@anim/anim_high_raise">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start"
            android:orientation="vertical"
            android:id="@id/top_container"
            android:background="@color/sushi_grey_050"
            android:paddingTop="@dimen/sushi_spacing_base"
            android:paddingBottom="@dimen/sushi_spacing_base"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_pico"
            android:layout_marginTop="@dimen/dimen_one_point_five"
            android:paddingStart="@dimen/sushi_spacing_base"
            android:layout_marginEnd="@dimen/sushi_spacing_pico">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@id/image_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:id="@id/image_wrapper"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                            android:id="@id/image"
                            android:layout_width="@dimen/size_48"
                            android:layout_height="@dimen/size_48"
                            android:scaleType="centerCrop"
                            android:adjustViewBounds="true" />
                    </FrameLayout>
                    <FrameLayout
                        android:id="@id/overlap_image_wrapper"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/sushi_spacing_macro"
                        android:layout_marginStart="@dimen/sushi_spacing_macro">
                        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                            android:id="@id/overlap_image"
                            android:layout_width="@dimen/size_48"
                            android:layout_height="@dimen/size_48"
                            android:scaleType="centerCrop"
                            android:adjustViewBounds="true" />
                    </FrameLayout>
                </FrameLayout>
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:layout_gravity="center_vertical"
                    android:id="@id/tv_left_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_base"
                    app:textViewType="MEDIUM_200" />
                <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                    android:id="@id/image_secondary"
                    android:layout_width="@dimen/size_48"
                    android:layout_height="@dimen/size_48"
                    android:scaleType="centerCrop"
                    android:layout_marginStart="@dimen/sushi_spacing_base"
                    app:cornerRadius="@dimen/sushi_spacing_macro" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="start|bottom|center"
                android:id="@id/bottom_left_image"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sushi_spacing_base"
                android:layout_marginBottom="@dimen/sushi_spacing_macro"
                app:layout_constraintBottom_toBottomOf="@id/image_container"
                app:layout_constraintStart_toStartOf="@id/image_container" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="start|center|top"
                android:id="@id/top_left_image"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/sushi_spacing_base"
                android:layout_marginTop="@dimen/sushi_spacing_macro"
                app:layout_constraintStart_toStartOf="@id/image_container"
                app:layout_constraintTop_toTopOf="@id/image_container" />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:id="@id/title_layout"
                android:layout_width="@dimen/sushi_spacing_femto"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tab_barrier"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@id/image_container"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_base"
                    android:layout_marginRight="@dimen/sushi_spacing_base"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_base" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_base"
                    android:layout_marginTop="@dimen/sushi_spacing_pico"
                    android:layout_marginRight="@dimen/sushi_spacing_base"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_base" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/sushi_spacing_base"
                    android:layout_marginTop="@dimen/sushi_spacing_pico"
                    android:layout_marginRight="@dimen/sushi_spacing_base"
                    android:layout_marginHorizontal="@dimen/sushi_spacing_base" />
            </LinearLayout>
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:id="@id/order_anim"
                android:layout_width="@dimen/size_30"
                android:layout_height="@dimen/sushi_spacing_femto"
                android:layout_marginEnd="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="@id/order_tag"
                app:layout_constraintEnd_toStartOf="@id/order_tag"
                app:layout_constraintTop_toTopOf="parent"
                app:lottie_loop="true"
                app:lottie_repeatMode="restart" />
            <com.zomato.ui.atomiclib.atom.ZTag
                android:id="@id/order_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:layout_constraintEnd_toStartOf="@id/top_container_right_icon_container"
                app:layout_constraintTop_toTopOf="parent"
                app:tagSize="small"
                app:tagType="rounded" />
            <FrameLayout
                android:id="@id/top_container_right_icon_container"
                android:paddingLeft="@dimen/dimen_10"
                android:paddingTop="@dimen/dimen_18"
                android:paddingRight="@dimen/dimen_10"
                android:paddingBottom="@dimen/dimen_18"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/dimen_10"
                android:paddingVertical="@dimen/dimen_18"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
                    android:id="@id/top_container_right_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:tagSize="small"
                    app:tagType="rounded" />
            </FrameLayout>
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/tv_right_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_macro"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/order_tag"
                app:textViewType="REGULAR_200" />
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/tab_barrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="start"
                app:constraint_referenced_ids="order_tag,order_anim,top_container_right_button" />
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/top_container_right_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:buttonDimension="small"
                app:buttonType="text"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/top_container_bottom_tag_container"
            android:padding="@dimen/sushi_spacing_macro"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginBottom="@dimen/sushi_spacing_base"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:layout_gravity="center_vertical"
                android:id="@id/top_container_bottom_tag_left_image_view"
                android:visibility="gone"
                android:layout_width="@dimen/dimen_16"
                android:layout_height="@dimen/dimen_16"
                android:layout_marginEnd="@dimen/sushi_spacing_macro" />
            <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
                android:layout_gravity="center_vertical"
                android:id="@id/top_container_bottom_tag_text_view"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/top_container_divider"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/sushi_spacing_pico"
            app:zseparator_color="@color/sushi_grey_200"
            app:zseparator_type="STRAIGHT" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/item_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_base"
            android:animateLayoutChanges="true" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="start"
            android:orientation="vertical"
            android:id="@id/bottom_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true">
            <com.zomato.ui.atomiclib.atom.ZSeparator
                android:id="@id/subtitle4_top_divider"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/sushi_spacing_pico"
                android:layout_marginLeft="@dimen/sushi_spacing_base"
                android:layout_marginRight="@dimen/sushi_spacing_base"
                android:layout_marginHorizontal="@dimen/sushi_spacing_base"
                app:layout_constraintTop_toTopOf="parent"
                app:zseparator_color="@color/sushi_grey_200"
                app:zseparator_type="DASHED" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:gravity="start"
                android:id="@id/subtitle4"
                android:layout_width="@dimen/sushi_spacing_femto"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_base"
                android:layout_marginTop="@dimen/sushi_spacing_base"
                android:layout_marginRight="@dimen/sushi_spacing_base"
                android:layout_marginHorizontal="@dimen/sushi_spacing_base"
                app:layout_constraintEnd_toStartOf="@id/subtitle5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/subtitle4_top_divider" />
            <com.zomato.ui.atomiclib.atom.ZTag
                android:id="@id/order_tag_bottom_container"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_nano"
                android:layout_marginStart="@dimen/sushi_spacing_macro"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/subtitle4"
                app:tagSize="small"
                app:tagType="rounded" />
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:id="@id/order_anim_bottom_container"
                android:layout_width="@dimen/size_30"
                android:layout_height="@dimen/sushi_spacing_femto"
                android:layout_marginEnd="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="@id/order_tag_bottom_container"
                app:layout_constraintStart_toEndOf="@id/order_tag_bottom_container"
                app:layout_constraintTop_toTopOf="@id/order_tag_bottom_container"
                app:lottie_loop="true"
                app:lottie_repeatMode="restart" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/subtitle5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_base"
                android:layout_marginEnd="@dimen/sushi_spacing_base"
                app:layout_constraintBottom_toBottomOf="@id/order_tag_bottom_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/subtitle4_top_divider" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:orientation="vertical"
                android:id="@id/cl_bottom_container"
                android:paddingLeft="@dimen/sushi_spacing_page_side"
                android:paddingTop="@dimen/dimen_10"
                android:paddingRight="@dimen/sushi_spacing_page_side"
                android:paddingBottom="@dimen/dimen_10"
                android:visibility="gone"
                android:layout_width="@dimen/sushi_spacing_femto"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/sushi_spacing_base"
                android:layout_marginTop="@dimen/size_12"
                android:layout_marginRight="@dimen/sushi_spacing_base"
                android:layout_marginHorizontal="@dimen/sushi_spacing_base"
                android:paddingHorizontal="@dimen/sushi_spacing_page_side"
                android:paddingVertical="@dimen/dimen_10"
                app:layout_constraintBottom_toTopOf="@id/item_container_divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/item_container_bottom_barrier">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:textColor="@color/sushi_blue_500"
                    android:id="@id/subtitle9"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:textViewType="SEMIBOLD_400" />
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:textSize="@dimen/sushi_textsize_400"
                    android:textColor="@color/sushi_blue_500"
                    android:id="@id/subtitle9_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/size_3"
                    android:text="@string/icon_font_z_pay_2"
                    android:layout_marginStart="@dimen/size_4"
                    app:layout_constraintBottom_toBottomOf="@id/subtitle9"
                    app:layout_constraintStart_toEndOf="@id/subtitle9"
                    app:layout_constraintTop_toTopOf="@id/subtitle9" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.Barrier
                android:id="@id/item_container_bottom_barrier"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="subtitle4,subtitle5, order_tag_bottom_container" />
            <com.zomato.ui.atomiclib.atom.ZSeparator
                android:id="@id/item_container_divider"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/sushi_spacing_pico"
                android:layout_marginLeft="@dimen/sushi_spacing_base"
                android:layout_marginTop="@dimen/dimen_10"
                android:layout_marginRight="@dimen/sushi_spacing_base"
                android:layout_marginHorizontal="@dimen/sushi_spacing_base"
                app:layout_constraintTop_toBottomOf="@id/cl_bottom_container"
                app:zseparator_color="@color/sushi_grey_200"
                app:zseparator_type="STRAIGHT" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:gravity="start|center"
                android:orientation="vertical"
                android:id="@id/rating_subtitles_container"
                android:paddingLeft="@dimen/sushi_spacing_base"
                android:paddingTop="@dimen/sushi_spacing_base"
                android:paddingRight="@dimen/sushi_spacing_base"
                android:paddingBottom="@dimen/sushi_spacing_base"
                android:clipToPadding="false"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:animateLayoutChanges="true"
                android:paddingHorizontal="@dimen/sushi_spacing_base"
                android:paddingVertical="@dimen/sushi_spacing_base"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/item_container_divider">
                <androidx.constraintlayout.widget.Barrier
                    android:id="@id/top_barrier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:barrierDirection="top"
                    app:constraint_referenced_ids="bottom_button_container, rating_container, subtitle7, subtitle10"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <androidx.constraintlayout.widget.Barrier
                    android:id="@id/bottom_barrier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="bottom_button_container, rating_container, subtitle7, subtitle10"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />
                <LinearLayout
                    android:gravity="start|center"
                    android:orientation="horizontal"
                    android:id="@id/rating_container"
                    android:visibility="gone"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/sushi_spacing_base"
                    app:layout_constraintBottom_toTopOf="@id/feedback_button"
                    app:layout_constraintEnd_toStartOf="@id/bottom_button_container"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_goneMarginEnd="@dimen/sushi_spacing_femto">
                    <com.zomato.ui.atomiclib.atom.ZTextView
                        android:gravity="start|center"
                        android:id="@id/subtitle6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
                        android:layout_gravity="center"
                        android:id="@id/rating_snippet_item"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sushi_spacing_macro"
                        app:ratedBlockDimenConfig="200"
                        app:ratingType="tag_v2" />
                    <com.zomato.ui.atomiclib.snippets.FeedbackRatingBar
                        android:layout_gravity="center"
                        android:id="@id/rating_star_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/sushi_spacing_macro" />
                </LinearLayout>
                <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                    android:id="@id/max_rating_lottie"
                    android:visibility="gone"
                    android:layout_width="@dimen/size_40"
                    android:layout_height="@dimen/size_40"
                    android:layout_marginTop="-10.0dip"
                    app:layout_constraintStart_toStartOf="@id/rating_container"
                    app:layout_constraintTop_toTopOf="parent" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:id="@id/feedback_button"
                    android:padding="@dimen/sushi_spacing_nano"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_nano"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/bottom_button_container"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rating_container" />
                <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                    android:id="@id/subtitle2_icon"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/subtitle7"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/subtitle7" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle7"
                    android:visibility="gone"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/sushi_spacing_mini"
                    android:layout_marginEnd="@dimen/sushi_spacing_base"
                    app:layout_constraintBottom_toTopOf="@id/subtitle10"
                    app:layout_constraintEnd_toStartOf="@id/bottom_button_container"
                    app:layout_constraintStart_toEndOf="@id/subtitle2_icon"
                    app:layout_constraintTop_toTopOf="@id/top_barrier"
                    app:layout_goneMarginStart="@dimen/sushi_spacing_femto" />
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/subtitle10"
                    android:visibility="gone"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sushi_spacing_nano"
                    android:layout_marginEnd="@dimen/sushi_spacing_base"
                    app:layout_constraintBottom_toTopOf="@id/bottom_left_button_2"
                    app:layout_constraintEnd_toStartOf="@id/bottom_button_container"
                    app:layout_constraintStart_toStartOf="@id/subtitle7"
                    app:layout_constraintTop_toBottomOf="@id/subtitle7" />
                <com.zomato.ui.atomiclib.atom.ZButtonWithLoader
                    android:id="@id/bottom_left_button_2"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/sushi_spacing_base"
                    app:layout_constraintBottom_toBottomOf="@id/bottom_barrier"
                    app:layout_constraintEnd_toStartOf="@id/bottom_button_container"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/subtitle7" />
                <com.zomato.ui.atomiclib.atom.ZButton
                    android:id="@id/bottom_left_button"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <LinearLayout
                    android:gravity="end"
                    android:orientation="horizontal"
                    android:id="@id/bottom_button_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.zomato.ui.atomiclib.atom.ZSeparator
            android:id="@id/footer_separator"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/sushi_spacing_pico"
            android:layout_marginLeft="@dimen/sushi_spacing_base"
            android:layout_marginRight="@dimen/sushi_spacing_base"
            android:layout_marginHorizontal="@dimen/sushi_spacing_base"
            app:layout_constraintTop_toBottomOf="@id/cl_bottom_container"
            app:zseparator_color="@color/sushi_grey_200"
            app:zseparator_type="STRAIGHT" />
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/footer_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_extra"
            android:layout_marginBottom="@dimen/sushi_spacing_extra"
            android:layout_marginVertical="@dimen/sushi_spacing_extra">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/footer_title"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
