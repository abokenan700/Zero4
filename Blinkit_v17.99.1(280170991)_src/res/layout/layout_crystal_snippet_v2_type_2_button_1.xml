<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:paddingTop="@dimen/sushi_spacing_micro"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/sushi_spacing_base"
    android:paddingEnd="@dimen/sushi_spacing_base"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <Space
        android:id="@id/space_view"
        android:layout_width="@dimen/size_32"
        android:layout_height="fill_parent"
        android:layout_marginEnd="@dimen/sushi_spacing_base" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/only_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lines="1"
        android:drawablePadding="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_mini"
        app:buttonColor="@color/sushi_grey_500"
        app:iconPadding="@dimen/sushi_spacing_base" />
</LinearLayout>