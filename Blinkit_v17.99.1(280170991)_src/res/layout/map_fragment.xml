<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/map_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <FrameLayout
        android:id="@id/poi_title_container"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:layout_constraintStart_toStartOf="parent" />
    <com.blinkit.commons.ui.ui.snippets.searchBar.QdSearchBar
        android:id="@id/search_bar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <include
        android:id="@id/location_off"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_bar"
        layout="@layout/location_off_layout" />
    <View
        android:id="@id/shadow"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_mini"
        android:rotation="180.0"
        app:layout_constraintTop_toBottomOf="@id/location_off" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/pin_message_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="@dimen/size_4"
        app:layout_constraintBottom_toTopOf="@id/guide_view"
        app:layout_constraintEnd_toEndOf="@id/guide_view"
        app:layout_constraintStart_toStartOf="@id/guide_view">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@id/pin_message_text_layout"
            android:background="@drawable/rounded_rectangle_background_black"
            android:padding="@dimen/padding_8"
            android:layout_width="@dimen/sushi_spacing_femto"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/negative_point_eight"
            app:layout_constraintBottom_toTopOf="@id/triangle_view"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_max="@dimen/size_252"
            app:layout_constraintWidth_min="wrap">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_white"
                android:gravity="center_horizontal"
                android:id="@id/pin_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/your_order_will_be_delivered_here"
                app:textViewType="SEMIBOLD_300" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_white"
                android:gravity="center_horizontal"
                android:id="@id/pin_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/move_pin_to_exact_location"
                app:textViewType="REGULAR_200" />
        </LinearLayout>
        <View
            android:layout_gravity="center"
            android:id="@id/triangle_view"
            android:layout_width="@dimen/dimen_24"
            android:layout_height="@dimen/size_8"
            android:layout_marginBottom="@dimen/size_8"
            app:color="?attr_7f040498"
            app:layout_constraintBottom_toTopOf="@id/pin_marker"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/pin_marker"
            android:layout_width="@dimen/size_36"
            android:layout_height="@dimen/size_52"
            android:src="@drawable/location_map_pin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:id="@id/use_my_location"
        android:background="@drawable/all_rounded_white_green_border"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingTop="@dimen/sushi_spacing_macro"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/sushi_spacing_macro"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_extra"
        android:elevation="@dimen/size_5"
        android:paddingHorizontal="@dimen/sushi_spacing_base"
        android:paddingVertical="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toTopOf="@id/prompt_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/iconfont_size"
            android:textColor="?themeColor600"
            android:gravity="center"
            android:id="@id/use_my_location_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/iconfont_my_location_precise"
            android:textAlignment="center"
            android:layout_marginEnd="@dimen/sushi_spacing_mini" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?themeColor500"
            android:gravity="center"
            android:id="@id/use_my_location_icon_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/use_current_location"
            app:textViewType="MEDIUM_300" />
    </LinearLayout>
    <View
        android:id="@id/guide_view"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/sushi_spacing_pico"
        app:layout_constraintBottom_toBottomOf="@id/map_view"
        app:layout_constraintTop_toTopOf="@id/map_view" />
    <View
        android:id="@id/prompt_shadow"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_20"
        android:translationY="@dimen/size_8"
        app:layout_constraintBottom_toTopOf="@id/prompt_layout" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/prompt_layout"
        android:background="@drawable/all_rounded_white_shadow_16"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        app:layout_constraintBottom_toBottomOf="parent">
        <include
            android:id="@id/map_locality_view"
            android:visibility="gone"
            layout="@layout/map_locality_view" />
        <include
            android:id="@id/nsa_layout"
            android:visibility="gone"
            layout="@layout/non_serviceable_map_view" />
        <include
            android:id="@id/prompt_shimmer"
            layout="@layout/map_prompt_shimmer_layout" />
    </LinearLayout>
    <com.blinkit.consumerapp.ui.nitroerroroverlay.NitroOverlay
        android:id="@id/nitro_overlay"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:elevation="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>