<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/top_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="left_container_image,title_container,imageContainer" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/left_container_image"
        android:layout_width="@dimen/size_100"
        android:layout_height="@dimen/size_100"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        app:cornerRadius="@dimen/sushi_spacing_femto"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <FrameLayout
        android:id="@id/imageContainer"
        android:layout_width="@dimen/size_64"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/left_container_image"
        app:layout_constraintEnd_toEndOf="@id/left_container_image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/left_container_image">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center"
            android:id="@id/left_overlay_image"
            android:visibility="visible"
            android:layout_width="@dimen/size_64"
            android:layout_height="@dimen/size_64"
            app:aspectRatio="1.0"
            app:cornerRadius="@dimen/sushi_corner_radius" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.ZTag
        android:id="@id/image_bottom_tag"
        android:padding="@dimen/sushi_spacing_micro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_between"
        android:layout_marginTop="@dimen/sushi_spacing_base_negative"
        android:layout_marginRight="@dimen/sushi_spacing_between"
        android:layout_marginHorizontal="@dimen/sushi_spacing_between"
        app:layout_constraintEnd_toEndOf="@id/left_container_image"
        app:layout_constraintStart_toStartOf="@id/left_container_image"
        app:layout_constraintTop_toBottomOf="@id/left_container_image"
        app:tagSize="tiny"
        app:tagType="rounded" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/image_end_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="imageContainer,left_container_image" />
    <LinearLayout
        android:gravity="start|center"
        android:orientation="vertical"
        android:id="@id/title_container"
        android:padding="@dimen/sushi_spacing_base"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_3"
        android:layout_marginBottom="@dimen/size_3"
        android:layout_marginVertical="@dimen/size_3"
        app:layout_constraintBottom_toBottomOf="@id/bottom_barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/image_end_barrier"
        app:layout_constraintTop_toBottomOf="@id/top_barrier">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040475"
            android:ellipsize="end"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            app:textViewType="SEMIBOLD_500" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040475"
            android:ellipsize="end"
            android:id="@id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_between"
            android:maxLines="3"
            app:textViewType="MEDIUM_300" />
    </LinearLayout>
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/bottom_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="left_container_image,title_container,imageContainer" />
</merge>