<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:id="@id/bts_coordinator"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/layout_generic_form_bottomsheet_ll"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <FrameLayout
            android:id="@id/crossButtonContainer"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZIconFontTextView
                android:textSize="@dimen/sushi_textsize_800"
                android:textColor="@color/color_white"
                android:layout_gravity="center_horizontal"
                android:id="@id/crossButton"
                android:background="@drawable/grey_circle"
                android:paddingLeft="@dimen/sushi_spacing_macro"
                android:paddingTop="@dimen/size_8"
                android:paddingRight="@dimen/sushi_spacing_macro"
                android:paddingBottom="@dimen/size_8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/sushi_spacing_extra"
                android:text="@string/icon_font_cross"
                android:backgroundTint="@color/tokenised_slate_700"
                android:paddingHorizontal="@dimen/sushi_spacing_macro"
                android:paddingVertical="@dimen/size_8" />
        </FrameLayout>
        <include
            android:id="@id/dataContainer"
            layout="@layout/layout_generic_form_bottomsheet_content" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>