<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/bg_image"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/content_container"
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        android:layout_marginVertical="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/text_box"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <View
            android:id="@id/left_image_border"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/left_image"
            app:layout_constraintEnd_toEndOf="@id/left_image"
            app:layout_constraintStart_toStartOf="@id/left_image"
            app:layout_constraintTop_toTopOf="@id/left_image" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:id="@id/left_image"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_14"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/left_image_barrier"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="end"
            app:constraint_referenced_ids="left_image,left_image_border" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/title"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_macro"
            android:layout_marginRight="@dimen/sushi_spacing_macro"
            android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toTopOf="@id/subtitle1"
            app:layout_constraintEnd_toStartOf="@id/rating_view"
            app:layout_constraintStart_toEndOf="@id/left_image_barrier"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
            android:id="@id/rating_view"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/subtitle1"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_macro"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:layout_marginRight="@dimen/sushi_spacing_macro"
            android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toTopOf="@id/view_flipper"
            app:layout_constraintEnd_toStartOf="@id/rating_view"
            app:layout_constraintStart_toEndOf="@id/left_image_barrier"
            app:layout_constraintTop_toBottomOf="@id/title" />
        <com.zomato.ui.atomiclib.molecules.ZViewFlipper
            android:id="@id/view_flipper"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_macro"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            android:layout_marginRight="@dimen/sushi_spacing_macro"
            android:textAlignment="viewStart"
            android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/rating_view"
            app:layout_constraintStart_toEndOf="@id/left_image_barrier"
            app:layout_constraintTop_toBottomOf="@id/subtitle1" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <include
        android:id="@id/text_box"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/right_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/content_container"
        layout="@layout/layout_custom_text_box" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
        android:gravity="center"
        android:id="@id/right_icon"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/text_box"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/text_box"
        app:layout_constraintTop_toTopOf="@id/text_box" />
</merge>