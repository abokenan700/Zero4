<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/sushi_spacing_mini"
    android:paddingBottom="@dimen/sushi_spacing_mini"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/dimen_10"
    android:paddingEnd="@dimen/dimen_10"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/tag_image"
        android:layout_width="@dimen/sushi_spacing_extra"
        android:layout_height="@dimen/sushi_spacing_extra"
        android:layout_marginEnd="@dimen/sushi_spacing_micro" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/tag_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
</LinearLayout>