<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/left_container_image"
        android:layout_width="@dimen/size_108"
        android:layout_height="@dimen/sushi_spacing_femto"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        app:cornerRadius="@dimen/sushi_spacing_femto"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center"
        android:id="@id/left_container_overlay_image"
        android:visibility="gone"
        android:layout_width="@dimen/size_77"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_extra"
        android:layout_marginVertical="@dimen/sushi_spacing_macro"
        app:aspectRatio="2.31"
        app:cornerRadius="@dimen/sushi_spacing_femto"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/left_container_overlay_animation"
        android:visibility="gone"
        android:layout_width="@dimen/size_77"
        android:layout_height="@dimen/size_33"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/title_container_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="left_container_image,left_container_overlay_image,left_container_overlay_animation" />
    <LinearLayout
        android:gravity="start|center"
        android:orientation="vertical"
        android:id="@id/title_container"
        android:padding="@dimen/dimen_10"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/check_box_barrier"
        app:layout_constraintStart_toEndOf="@id/title_container_barrier"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.lib.snippets.ZImageWithTextView
            android:textColor="?attr_7f040475"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_900"
            android:id="@id/subtitle1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_nano"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:textViewType="MEDIUM_100" />
    </LinearLayout>
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/check_box_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="start"
        app:constraint_referenced_ids="check_box_container" />
    <LinearLayout
        android:gravity="end|center"
        android:orientation="vertical"
        android:id="@id/check_box_container"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZCheckBox
            android:gravity="end"
            android:id="@id/checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="?attr_7f040475"
            android:layout_gravity="end"
            android:id="@id/subtitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro_negative"
            android:includeFontPadding="false"
            android:layout_marginEnd="@dimen/dimen_13"
            app:textViewType="MEDIUM_200" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/dimen_16"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/right_icon"
            android:padding="@dimen/sushi_spacing_page_side"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/icon_font_arrow_next_circle" />
    </LinearLayout>
</merge>