<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/container"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:id="@id/leftIcon"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:visibility="visible"
        android:layout_width="@dimen/dimen_14"
        android:layout_height="@dimen/dimen_14"
        android:scaleType="centerCrop"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/lottieImageAnimaation"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_18"
        android:layout_height="@dimen/dimen_18"
        android:contentDescription="@null"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/title"
        app:lottie_autoPlay="false"
        app:lottie_loop="false" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrier"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        app:barrierDirection="right"
        app:constraint_referenced_ids="lottieImageAnimaation,image,leftIcon" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/topBarrier"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:barrierDirection="top"
        app:constraint_referenced_ids="lottieImageAnimaation,image,leftIcon,topButton,title" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/imageViewsBottomBarrier"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="lottieImageAnimaation,image,leftIcon,title" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/bottomBarrier"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="lottieImageAnimaation,image, title, subtitle,leftIcon,topButton, rightButton2" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/rightBarrier"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        app:barrierAllowsGoneWidgets="false"
        app:barrierDirection="start"
        app:constraint_referenced_ids="rightAction,rightIcon,subtitle2,zstepper, rightButton2, dummyEndView" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/rightAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        app:buttonColor="?themeColor500"
        app:buttonDimension="small"
        app:buttonType="text"
        app:layout_constraintBottom_toBottomOf="@id/imageViewsBottomBarrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBarrier" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center_vertical"
        android:id="@id/subtitle2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_mini"
        app:layout_constraintBottom_toBottomOf="@id/imageViewsBottomBarrier"
        app:layout_constraintEnd_toStartOf="@id/rightIcon"
        app:layout_constraintTop_toTopOf="@id/topBarrier" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/endBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierAllowsGoneWidgets="false"
        app:barrierDirection="end"
        app:constraint_referenced_ids="subtitle2,rightIcon,rightAction, dummyEndView" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:id="@id/rightIcon"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        app:buttonColor="?themeColor400"
        app:buttonDimension="small"
        app:buttonType="text"
        app:layout_constraintBottom_toBottomOf="@id/imageViewsBottomBarrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBarrier" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/topButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingEnd="@dimen/sushi_spacing_page_side"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toStartOf="@id/rightBarrier"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/barrier"
        app:layout_constraintTop_toTopOf="parent"
        app:textFontWeight="regular" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:paddingEnd="@dimen/sushi_spacing_page_side"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        app:layout_constraintEnd_toStartOf="@id/rightBarrier"
        app:layout_constraintStart_toEndOf="@id/barrier"
        app:layout_constraintTop_toBottomOf="@id/topButton"
        app:textViewType="REGULAR_200" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:ellipsize="end"
        android:id="@id/subtitle"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:paddingStart="@dimen/sushi_spacing_mini"
        android:paddingEnd="@dimen/sushi_spacing_page_side"
        app:layout_constraintEnd_toStartOf="@id/rightBarrier"
        app:layout_constraintStart_toEndOf="@id/barrier"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:textViewType="REGULAR_200" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:id="@id/rightButton2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        app:layout_constraintEnd_toStartOf="@id/endBarrier"
        app:layout_constraintTop_toBottomOf="@id/subtitle2" />
    <com.zomato.ui.atomiclib.molecules.ZStepper
        android:id="@id/zstepper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toTopOf="@id/bottomBarrier"
        app:layout_constraintEnd_toStartOf="@id/endBarrier"
        app:layout_constraintTop_toBottomOf="@id/subtitle2"
        app:stepper_type="SMALL" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:gravity="start"
        android:id="@id/button"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        android:includeFontPadding="false"
        android:textAlignment="viewStart"
        android:layout_marginStart="@dimen/sushi_spacing_mini"
        android:layout_marginEnd="@dimen/sushi_spacing_extra"
        app:buttonColor="?themeColor500"
        app:buttonDimension="medium"
        app:buttonType="text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/barrier"
        app:layout_constraintTop_toBottomOf="@id/bottomBarrier" />
    <FrameLayout
        android:id="@id/dummyEndView"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="@dimen/sushi_spacing_femto"
        android:layout_marginEnd="@dimen/sushi_spacing_page_side"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <FrameLayout
        android:id="@id/rightShimmerContainer"
        android:background="@color/sushi_white"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/bottomBarrier"
        app:layout_constraintEnd_toEndOf="@id/endBarrier"
        app:layout_constraintStart_toStartOf="@id/rightBarrier"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>