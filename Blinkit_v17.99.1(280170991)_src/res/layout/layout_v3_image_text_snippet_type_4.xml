<?xml version="1.0" encoding="utf-8"?>
<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/right_holder_title"
        android:paddingRight="@dimen/spacing_between_2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/left_holder_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/left_holder_title" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/left_holder_subtitle"
        android:paddingBottom="@dimen/sushi_spacing_base"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_between_2dp"
        android:textAlignment="viewStart"
        android:paddingStart="@dimen/size_12"
        android:paddingEnd="@dimen/sushi_spacing_base"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/left_holder_title" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/large_stepper_buttons_text_size"
        android:id="@id/left_holder_title"
        android:paddingTop="@dimen/sushi_spacing_base"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAlignment="viewStart"
        android:paddingStart="@dimen/sushi_spacing_base"
        android:paddingEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/left_holder_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageView
        android:id="@id/right_holder_image"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/size_20"
        android:scaleType="centerCrop"
        android:layout_marginEnd="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/right_holder_title"
        app:layout_constraintEnd_toStartOf="@id/right_holder_title"
        app:layout_constraintTop_toTopOf="@id/right_holder_title" />
</merge>