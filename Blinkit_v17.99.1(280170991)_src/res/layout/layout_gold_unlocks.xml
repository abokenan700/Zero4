<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/parent_layout"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:stateListAnimator="@animator/scale_animator"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/iconImageView"
        android:layout_width="@dimen/size_36"
        android:layout_height="@dimen/size_36"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <FrameLayout
        android:layout_gravity="center"
        android:id="@id/iconImageOverlayTextContainer"
        android:visibility="gone"
        android:layout_width="@dimen/size_36"
        android:layout_height="@dimen/size_36"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:gravity="center"
            android:id="@id/iconImageOverlayText"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:includeFontPadding="false" />
    </FrameLayout>
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/image_end_barrier"
        android:layout_width="wrap_content"
        android:layout_height="fill_parent"
        app:barrierDirection="end"
        app:constraint_referenced_ids="iconImageView, iconImageOverlayTextContainer" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/title"
        android:paddingBottom="@dimen/sushi_spacing_micro"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_page_side"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/image_end_barrier"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/title_bottom_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="title" />
    <com.zomato.ui.atomiclib.atom.ZProgressBar
        android:id="@id/progress"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/sushi_spacing_mini"
        android:layout_marginBottom="@dimen/sushi_spacing_micro"
        android:progressDrawable="@drawable/gold_progressive_view_progress_bar_bg"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/image_end_barrier"
        app:layout_constraintTop_toBottomOf="@id/title_bottom_barrier"
        style="?android:progressBarStyleHorizontal" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/subtitle"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:drawableRight="@string/icon_right_triangle"
        app:drawableTint="@color/sushi_green_500"
        app:layout_constraintBottom_toTopOf="@id/subtitle2"
        app:layout_constraintStart_toEndOf="@id/image_end_barrier"
        app:layout_constraintTop_toBottomOf="@id/progress" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/subtitle2"
        android:paddingTop="@dimen/sushi_spacing_micro"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/image_end_barrier"
        app:layout_constraintTop_toBottomOf="@id/subtitle" />
</androidx.constraintlayout.widget.ConstraintLayout>