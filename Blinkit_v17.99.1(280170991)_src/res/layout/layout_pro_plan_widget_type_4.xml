<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:id="@id/root"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/main_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/top_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:id="@id/title_container"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_12"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.zomato.ui.atomiclib.atom.ZTextView
                    android:id="@id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <View
                    android:id="@id/title_shine"
                    android:background="@drawable/white_shimmer"
                    android:visibility="gone"
                    android:layout_width="@dimen/dimen_20"
                    android:layout_height="@dimen/dimen_20"
                    android:rotation="30.0" />
            </FrameLayout>
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/title_end_image"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_4"
                app:layout_constraintStart_toEndOf="@id/title_container"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="@id/title_container"
                app:layout_constraintTop_toBottomOf="@id/title_container" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/right_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen_12"
                app:layout_constraintBottom_toBottomOf="@id/title_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/title_container" />
            <FrameLayout
                android:id="@id/image_items_container"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_12"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/subtitle">
                <FrameLayout
                    android:id="@id/image_container"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                        android:layout_gravity="end|bottom|center"
                        android:id="@id/bg_image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </FrameLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@id/items_container"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">
                    <com.zomato.ui.lib.snippets.GenericSeparatorView
                        android:id="@id/items_top_separtor"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content" />
                    <com.zomato.ui.lib.organisms.snippets.accordion.type8.AccordionSnippetType8View
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content" />
                    <com.zomato.ui.lib.organisms.snippets.accordion.type8.AccordionSnippetType8View
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content" />
                    <com.zomato.ui.lib.organisms.snippets.accordion.type8.AccordionSnippetType8View
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content" />
                    <com.zomato.ui.lib.snippets.GenericSeparatorView
                        android:id="@id/items_bottom_separtor"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="center_vertical"
            android:id="@id/bottom_container"
            android:paddingTop="@dimen/dimen_12"
            android:paddingBottom="@dimen/dimen_12"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dimen_12"
            android:paddingEnd="@dimen/dimen_12">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/bottom_container_prefix_image"
                android:visibility="gone"
                android:layout_width="@dimen/dimen_20"
                android:layout_height="@dimen/dimen_20"
                android:scaleType="fitCenter"
                android:layout_marginEnd="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/bottom_container_title"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
                android:id="@id/bottom_container_prefix_animation"
                android:visibility="gone"
                android:layout_width="@dimen/dimen_14"
                android:layout_height="@dimen/dimen_14"
                android:layout_marginEnd="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/bottom_container_title"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:id="@id/bottom_container_title"
                android:layout_width="@dimen/sushi_spacing_femto"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sushi_spacing_page_side"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/bottom_container_right_button"
                app:layout_constraintStart_toEndOf="@id/bottom_container_prefix_image"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.ZButton
                android:id="@id/bottom_container_right_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/bottom_strip"
        android:paddingLeft="@dimen/sushi_spacing_base"
        android:paddingTop="@dimen/size_9"
        android:paddingRight="@dimen/sushi_spacing_base"
        android:paddingBottom="@dimen/size_9"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/sushi_spacing_base"
        android:paddingVertical="@dimen/size_9" />
</LinearLayout>