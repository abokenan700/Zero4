<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/strip_container"
    android:background="@color/color_transparent"
    android:clipChildren="false"
    android:layout_width="fill_parent"
    android:layout_height="@dimen/qd_bottom_cart_strip_v3_height_full"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.BLottieAnimationView
        android:id="@id/bg_lottie"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/container"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintTop_toTopOf="@id/container" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/strip_timer_container"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
            android:id="@id/top_strip_title"
            android:paddingTop="@dimen/sushi_spacing_micro"
            android:paddingBottom="@dimen/sushi_spacing_micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/sushi_spacing_macro"
            android:paddingEnd="@dimen/sushi_spacing_micro"
            android:paddingVertical="@dimen/sushi_spacing_micro"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
            android:id="@id/top_strip_timer"
            android:paddingTop="@dimen/sushi_spacing_micro"
            android:paddingBottom="@dimen/sushi_spacing_micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="@dimen/sushi_spacing_macro"
            android:paddingVertical="@dimen/sushi_spacing_micro"
            app:layout_constraintStart_toEndOf="@id/top_strip_title"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="bottom|center"
        android:id="@id/container"
        android:background="@drawable/qd_rounded_green"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:elevation="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <FrameLayout
            android:id="@id/fl_lottie"
            android:clipToPadding="false"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.blinkit.commons.ui.ui.customviews.BLottieAnimationView
                android:layout_gravity="center"
                android:id="@id/lottie"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" />
        </FrameLayout>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="horizontal"
            android:id="@id/guideline_top"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintGuide_begin="@dimen/qd_margin_6"
            app:layout_constraintStart_toStartOf="parent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/guideline_end"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_end="@dimen/qd_margin_6"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="horizontal"
            android:id="@id/guideline_bottom"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintGuide_end="@dimen/qd_margin_6"
            app:layout_constraintStart_toStartOf="parent" />
        <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
            android:id="@id/left_image"
            android:layout_width="@dimen/size_52"
            android:layout_height="@dimen/size_52"
            android:scaleType="fitXY"
            android:translationZ="@dimen/sushi_spacing_nano"
            android:outlineProvider="none"
            android:outlineSpotShadowColor="@color/color_transparent"
            android:outlineAmbientShadowColor="@color/color_transparent"
            app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
            app:layout_constraintEnd_toStartOf="@id/left_image_2"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/guideline_top" />
        <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
            android:id="@id/left_image_2"
            android:visibility="gone"
            android:layout_width="@dimen/size_42"
            android:layout_height="@dimen/size_42"
            android:scaleType="fitXY"
            android:layout_marginStart="@dimen/negative_qd_margin_20"
            android:translationZ="@dimen/sushi_spacing_micro"
            android:outlineProvider="none"
            android:outlineSpotShadowColor="@color/color_transparent"
            android:outlineAmbientShadowColor="@color/color_transparent"
            app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
            app:layout_constraintEnd_toStartOf="@id/left_image_3"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/left_image"
            app:layout_constraintTop_toTopOf="@id/guideline_top"
            app:layout_goneMarginStart="@dimen/qd_margin_6" />
        <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
            android:id="@id/left_image_3"
            android:visibility="gone"
            android:layout_width="@dimen/size_42"
            android:layout_height="@dimen/size_42"
            android:scaleType="fitXY"
            android:layout_marginStart="@dimen/negative_qd_margin_20"
            android:translationZ="@dimen/sushi_spacing_mini"
            android:outlineProvider="none"
            android:outlineSpotShadowColor="@color/color_transparent"
            android:outlineAmbientShadowColor="@color/color_transparent"
            app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/left_image_2"
            app:layout_constraintTop_toTopOf="@id/guideline_top" />
        <View
            android:id="@id/left_image_placeholder"
            android:background="@drawable/qd_transparent_bg"
            android:visibility="gone"
            android:layout_width="@dimen/size_42"
            android:layout_height="@dimen/size_42"
            android:layout_marginStart="@dimen/negative_qd_margin_20"
            android:translationZ="8.0dip"
            android:outlineSpotShadowColor="@color/color_transparent"
            android:outlineAmbientShadowColor="@color/color_transparent"
            app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/left_image_3"
            app:layout_constraintTop_toTopOf="@id/guideline_top" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:id="@id/view_cart"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toTopOf="@id/tv_quantity"
            app:layout_constraintEnd_toStartOf="@id/barrier"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/left_image_placeholder"
            app:layout_constraintTop_toTopOf="@id/guideline_top"
            app:layout_constraintVertical_chainStyle="packed" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_black"
            android:id="@id/tv_quantity"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_marginStart="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
            app:layout_constraintEnd_toStartOf="@id/barrier"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/left_image_placeholder"
            app:layout_constraintTop_toBottomOf="@id/view_cart"
            app:layout_constraintVertical_chainStyle="packed" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
            android:id="@id/tv_free_count"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_marginStart="@dimen/sushi_spacing_micro"
            app:layout_constraintBottom_toBottomOf="@id/tv_quantity"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/tv_quantity"
            app:layout_constraintTop_toTopOf="@id/tv_quantity"
            app:layout_constraintVertical_chainStyle="packed" />
        <androidx.constraintlayout.widget.Barrier
            android:id="@id/barrier"
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            app:barrierDirection="right"
            app:constraint_referenced_ids="tv_quantity,tv_free_count,view_cart"
            app:layout_constraintHorizontal_chainStyle="packed" />
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textColor="@color/sushi_white"
            android:gravity="center"
            android:id="@id/ic_cart"
            android:visibility="gone"
            android:layout_width="@dimen/size_40"
            android:layout_height="@dimen/size_40"
            android:text="@string/icon_right_triangle"
            android:layout_marginStart="@dimen/dimen_10"
            android:layout_marginEnd="@dimen/dimen_2"
            app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
            app:layout_constraintEnd_toEndOf="@id/guideline_end"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/barrier"
            app:layout_constraintTop_toTopOf="@id/guideline_top" />
        <com.blinkit.commons.ui.ui.customviews.viewstub.blinkittext.BlinkitTextViewStub
            android:gravity="center"
            android:id="@id/suffix_tv"
            android:padding="@dimen/sushi_spacing_micro"
            android:paddingLeft="@dimen/sushi_spacing_macro"
            android:paddingRight="@dimen/sushi_spacing_macro"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/size_26"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:layout_marginBottom="@dimen/sushi_spacing_micro"
            android:minWidth="52.0dip"
            android:layout_marginStart="@dimen/size_8"
            android:layout_marginEnd="@dimen/dimen_2"
            android:layout_marginVertical="@dimen/sushi_spacing_micro"
            android:paddingHorizontal="@dimen/sushi_spacing_macro"
            app:layout_constraintBottom_toBottomOf="@id/guideline_bottom"
            app:layout_constraintEnd_toEndOf="@id/guideline_end"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/barrier"
            app:layout_constraintTop_toTopOf="@id/guideline_top" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.blinkit.commons.ui.ui.customviews.viewstub.media.BMediaViewStub
        android:id="@id/fab"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:layout_marginEnd="@dimen/qd_margin_12"
        android:elevation="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>