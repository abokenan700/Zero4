<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="horizontal"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@id/attachment_icons_list"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_mini"
        android:layout_marginRight="@dimen/sushi_spacing_mini"
        android:layout_weight="1.0"
        android:layout_marginHorizontal="@dimen/sushi_spacing_mini" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="center_vertical"
        android:id="@id/right_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_macro" />
</merge>