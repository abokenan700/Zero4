<?xml version="1.0" encoding="utf-8"?>
<merge
    android:id="@id/messageContainer"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_weight="1.0">
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:id="@id/containerTagView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_between">
            <include
                android:id="@id/tagContainer"
                layout="@layout/universal_tag_view" />
            <com.zomato.ui.atomiclib.atom.ZTag
                android:gravity="start|center"
                android:layout_gravity="start|center"
                android:id="@id/ztag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sushi_spacing_between"
                app:tagColor="@color/sushi_blue_500"
                app:tagSize="small"
                app:tagType="rounded" />
        </FrameLayout>
        <com.zomato.ui.atomiclib.atom.ZIconFontTextView
            android:textSize="@dimen/sushi_textsize_400"
            android:layout_gravity="center_vertical"
            android:id="@id/icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/sushi_spacing_between" />
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center_vertical"
            android:id="@id/image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/sushi_spacing_macro" />
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:padding="@dimen/sushi_spacing_micro"
            android:visibility="visible"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_blue_500"
                android:layout_gravity="center_vertical"
                android:id="@id/title"
                android:visibility="visible"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:textViewType="MEDIUM_100" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_800"
                android:layout_gravity="center_vertical"
                android:id="@id/subitle"
                android:visibility="visible"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sushi_spacing_nano"
                app:textViewType="MEDIUM_100" />
        </LinearLayout>
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZButton
        android:gravity="end"
        android:layout_gravity="center_vertical"
        android:id="@id/actionButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:buttonColor="?themeColor500"
        app:buttonDimension="medium"
        app:buttonType="text" />
</merge>