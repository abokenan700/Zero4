<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr_7f0403d7"
    app:cardCornerRadius="@dimen/sushi_spacing_base"
    app:cardElevation="@dimen/dimen_0"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="?attr_7f0403d7"
        android:padding="@dimen/sushi_spacing_base"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/section_guideline_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.4" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/section_guideline_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.6" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/section_guideline_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.55" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:id="@id/item1"
            android:background="@drawable/qd_white_circle"
            android:layout_width="35.0dip"
            android:layout_height="35.0dip"
            app:bgColor="?attr_7f0403d0"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/right_item"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <View
            android:id="@id/right_item"
            android:background="@drawable/bg_rounded_white"
            android:layout_width="0.0dip"
            android:layout_height="12.0dip"
            android:layout_marginStart="@dimen/nitro_side_padding"
            app:bgColor="?attr_7f0403d0"
            app:layout_constraintEnd_toEndOf="@id/section_guideline_2"
            app:layout_constraintStart_toEndOf="@id/item1"
            app:layout_constraintTop_toTopOf="parent"
            app:shimmer_corner_radius="4.0dip" />
        <View
            android:id="@id/itemLine2"
            android:background="?attr_7f0403d0"
            android:layout_width="0.0dip"
            android:layout_height="10.0dip"
            android:layout_marginTop="@dimen/nitro_side_padding"
            android:layout_marginStart="@dimen/nitro_side_padding"
            app:layout_constraintEnd_toEndOf="@id/section_guideline_3"
            app:layout_constraintStart_toEndOf="@id/item1"
            app:layout_constraintTop_toBottomOf="@id/right_item"
            app:shimmer_corner_radius="2.0dip" />
        <View
            android:id="@id/separator"
            android:background="?attr_7f040180"
            android:layout_width="0.0dip"
            android:layout_height="1.0dip"
            android:layout_marginTop="12.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/item1" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:id="@id/product1"
            android:layout_width="@dimen/size_58"
            android:layout_height="@dimen/size_58"
            android:layout_marginTop="@dimen/dimen_12"
            app:layout_constraintStart_toStartOf="@id/item1"
            app:layout_constraintTop_toBottomOf="@id/separator"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:id="@id/product2"
            android:layout_width="@dimen/size_58"
            android:layout_height="@dimen/size_58"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginStart="@dimen/dimen_12"
            app:layout_constraintStart_toEndOf="@id/product1"
            app:layout_constraintTop_toBottomOf="@id/separator"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:id="@id/product3"
            android:layout_width="@dimen/size_58"
            android:layout_height="@dimen/size_58"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginStart="@dimen/dimen_12"
            app:layout_constraintStart_toEndOf="@id/product2"
            app:layout_constraintTop_toBottomOf="@id/separator"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:id="@id/product4"
            android:layout_width="@dimen/size_58"
            android:layout_height="@dimen/size_58"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginStart="@dimen/dimen_12"
            app:layout_constraintStart_toEndOf="@id/product3"
            app:layout_constraintTop_toBottomOf="@id/separator"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:id="@id/product5"
            android:layout_width="@dimen/size_58"
            android:layout_height="@dimen/size_58"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginStart="@dimen/dimen_12"
            app:layout_constraintStart_toEndOf="@id/product4"
            app:layout_constraintTop_toBottomOf="@id/separator"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <com.zomato.ui.atomiclib.molecules.ShimmerChildView
            android:id="@id/product6"
            android:layout_width="@dimen/size_58"
            android:layout_height="@dimen/size_58"
            android:layout_marginTop="@dimen/dimen_12"
            android:layout_marginStart="@dimen/dimen_12"
            app:layout_constraintStart_toEndOf="@id/product5"
            app:layout_constraintTop_toBottomOf="@id/separator"
            app:shimmer_corner_radius="@dimen/dimen_12" />
        <View
            android:id="@id/bottom_separator"
            android:background="?attr_7f040180"
            android:layout_width="0.0dip"
            android:layout_height="1.0dip"
            android:layout_marginTop="12.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/product1" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bottom_separator">
            <com.zomato.ui.atomiclib.molecules.ShimmerChildView
                android:id="@id/first_button"
                android:layout_width="58.0dip"
                android:layout_height="@dimen/dimen_12"
                android:layout_marginTop="12.0dip"
                app:bgColor="?attr_7f0403d0"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/vertical_separator"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shimmer_corner_radius="@dimen/size_8" />
            <View
                android:id="@id/vertical_separator"
                android:background="?attr_7f040295"
                android:layout_width="1.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="@id/first_button"
                app:layout_constraintEnd_toStartOf="@id/middle_button"
                app:layout_constraintStart_toEndOf="@id/first_button"
                app:layout_constraintTop_toTopOf="@id/first_button" />
            <com.zomato.ui.atomiclib.molecules.ShimmerChildView
                android:id="@id/middle_button"
                android:layout_width="58.0dip"
                android:layout_height="@dimen/dimen_12"
                android:layout_marginTop="12.0dip"
                android:layout_marginStart="@dimen/sushi_spacing_mini"
                android:layout_marginEnd="@dimen/sushi_spacing_mini"
                app:bgColor="?attr_7f0403d0"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/vertical_separator"
                app:layout_constraintTop_toTopOf="parent"
                app:shimmer_corner_radius="@dimen/size_8" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>