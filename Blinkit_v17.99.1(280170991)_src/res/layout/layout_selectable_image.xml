<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android">
    <FrameLayout
        android:layout_gravity="center"
        android:id="@id/image_frame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center_vertical"
            android:id="@id/image"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/sushi_spacing_mini"
            android:layout_marginTop="@dimen/sushi_spacing_mini"
            android:layout_marginRight="@dimen/sushi_spacing_mini"
            android:layout_marginBottom="@dimen/sushi_spacing_micro"
            android:layout_marginHorizontal="@dimen/sushi_spacing_mini" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticIconView
            android:layout_gravity="end|center|top"
            android:id="@id/icon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:id="@id/title"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:lines="1"
        android:includeFontPadding="false" />
</merge>