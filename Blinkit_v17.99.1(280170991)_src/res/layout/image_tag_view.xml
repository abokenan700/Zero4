<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="horizontal"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center_vertical"
        android:id="@id/ztag_image"
        android:layout_width="@dimen/dimen_10"
        android:layout_height="@dimen/dimen_10" />
    <ViewStub
        android:layout_gravity="center_vertical"
        android:id="@id/ztag_anim_view_stub"
        android:layout="@layout/layout_image_tag_view_lottie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textColor="@color/sushi_grey_500"
        android:layout_gravity="center_vertical"
        android:id="@id/ztag_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:textViewType="MEDIUM_100" />
</merge>