<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_gravity="center"
    android:id="@id/ratingContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.commons.ui.ui.customviews.starRating3D.BRatingItem3D
        android:id="@id/one"
        android:layout_width="@dimen/star_rating_size_large"
        android:layout_height="@dimen/star_rating_size_large"
        android:layout_marginEnd="@dimen/sushi_spacing_nano"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.blinkit.commons.ui.ui.customviews.starRating3D.BRatingItem3D
        android:id="@id/two"
        android:layout_width="@dimen/star_rating_size_large"
        android:layout_height="@dimen/star_rating_size_large"
        android:layout_marginEnd="@dimen/sushi_spacing_nano"
        app:layout_constraintStart_toEndOf="@id/one"
        app:layout_constraintTop_toTopOf="@id/one" />
    <com.blinkit.commons.ui.ui.customviews.starRating3D.BRatingItem3D
        android:id="@id/three"
        android:layout_width="@dimen/star_rating_size_large"
        android:layout_height="@dimen/star_rating_size_large"
        android:layout_marginEnd="@dimen/sushi_spacing_nano"
        app:layout_constraintStart_toEndOf="@id/two"
        app:layout_constraintTop_toTopOf="@id/one" />
    <com.blinkit.commons.ui.ui.customviews.starRating3D.BRatingItem3D
        android:id="@id/four"
        android:layout_width="@dimen/star_rating_size_large"
        android:layout_height="@dimen/star_rating_size_large"
        android:layout_marginEnd="@dimen/sushi_spacing_nano"
        app:layout_constraintStart_toEndOf="@id/three"
        app:layout_constraintTop_toTopOf="@id/one" />
    <com.blinkit.commons.ui.ui.customviews.starRating3D.BRatingItem3D
        android:id="@id/five"
        android:layout_width="@dimen/star_rating_size_large"
        android:layout_height="@dimen/star_rating_size_large"
        app:layout_constraintStart_toEndOf="@id/four"
        app:layout_constraintTop_toTopOf="@id/one" />
    <com.blinkit.blink.elements.ui.atoms.text.BlinkitTextView
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/ratingText"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@id/one"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/five"
        app:layout_constraintTop_toTopOf="@id/one"
        app:textViewType="MEDIUM_100" />
</androidx.constraintlayout.widget.ConstraintLayout>