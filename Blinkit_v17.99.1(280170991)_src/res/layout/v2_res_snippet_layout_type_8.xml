<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:clipChildren="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/image"
        android:background="@color/sushi_black"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toTopOf="@id/image_bottom_barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.lib.organisms.snippets.timer.type6.TimerSnippetType6
        android:id="@id/timer_type_6"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/size_40"
        android:layout_marginRight="@dimen/size_40"
        android:layout_marginBottom="@dimen/size_8"
        android:elevation="@dimen/size_5"
        android:outlineProvider="none"
        android:layout_marginHorizontal="@dimen/size_40"
        app:layout_constraintBottom_toBottomOf="@id/image_bottom_barrier" />
    <ViewStub
        android:id="@id/media_container_view_stub"
        android:visibility="gone"
        android:layout="@layout/layout_res_card_type_3_media_container"
        android:inflatedId="@id/media_container_view_stub"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
        android:id="@id/bottom_right_image"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:layout_marginStart="@dimen/sushi_spacing_base_negative"
        android:layout_marginEnd="@dimen/sushi_spacing_base_negative"
        app:layout_constraintBottom_toBottomOf="@id/bottom_right_text"
        app:layout_constraintEnd_toEndOf="@id/bottom_right_text"
        app:layout_constraintStart_toStartOf="@id/bottom_right_text"
        app:layout_constraintTop_toTopOf="@id/bottom_right_text"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/bottom_right_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/size_36"
        android:layout_marginEnd="@dimen/size_28"
        app:layout_constraintBottom_toBottomOf="@id/image_bottom_barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:textViewType="SEMIBOLD_200" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/image_bottom_barrier"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierAllowsGoneWidgets="true"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="image, media_container_view_stub" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:ellipsize="end"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_12"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/subtitle1"
        app:layout_constraintEnd_toStartOf="@id/left_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/horizontalScrollVIew"
        app:layout_goneMarginBottom="@dimen/dimen_16"
        app:textViewType="SEMIBOLD_900" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:textColor="@color/sushi_grey_600"
        android:id="@id/subtitle1"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toTopOf="@id/note_image"
        app:layout_constraintEnd_toStartOf="@id/left_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:textViewType="REGULAR_500" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:textColor="@color/sushi_grey_600"
        android:gravity="end"
        android:id="@id/subtitle2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="@id/subtitle1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/subtitle1"
        app:layout_goneMarginBottom="@dimen/dimen_16"
        app:textViewType="REGULAR_500" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/note_image"
        android:visibility="gone"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_12"
        android:scaleType="fitXY"
        android:layout_marginStart="@dimen/sushi_spacing_extra"
        android:layout_marginEnd="@dimen/size_12"
        app:layout_constraintBottom_toTopOf="@id/subtitle3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle1" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:textColor="@color/sushi_grey_600"
        android:id="@id/subtitle3"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginBottom="@dimen/dimen_16"
        android:layout_marginStart="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/subtitle4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/note_image"
        app:layout_constraintVertical_bias="0.0"
        app:layout_goneMarginBottom="@dimen/sushi_spacing_extra"
        app:layout_goneMarginEnd="@dimen/dimen_16"
        app:textViewType="REGULAR_500" />
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:textColor="@color/sushi_grey_600"
        android:gravity="end"
        android:id="@id/subtitle4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_extra"
        app:layout_constraintBottom_toBottomOf="@id/subtitle3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/subtitle3"
        app:layout_constraintTop_toBottomOf="@id/subtitle1"
        app:layout_constraintVertical_bias="0.0"
        app:layout_goneMarginBottom="@dimen/sushi_spacing_extra"
        app:textViewType="REGULAR_500" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/bottom_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="subtitle3,subtitle4" />
    <com.zomato.ui.atomiclib.snippets.RatingSnippetItem
        android:id="@id/rating_snippet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_extra"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/title"
        app:ratedBlockDimenConfig="300"
        app:ratingType="stars" />
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@id/price_box"
        android:padding="@dimen/dimen_4"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_12"
        android:layout_marginBottom="@dimen/size_12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/horizontalScrollVIew"
        app:layout_constraintVertical_bias="0.0">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:layout_gravity="center_horizontal"
            android:id="@id/price_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:layout_gravity="center_horizontal"
            android:id="@id/price_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/left_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="left"
        app:constraint_referenced_ids="rating_snippet,price_box" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:id="@id/topLeftTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_12"
        android:alpha="0.0"
        android:layout_marginStart="@dimen/size_12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topTitle"
        app:tagColor="@color/sushi_white"
        app:tagSize="tiny"
        app:tagType="rounded" />
    <com.zomato.ui.lib.organisms.snippets.rescards.imagebottomcontainer.ImageBottomContainerView
        android:id="@id/image_tag_top_container"
        android:clipChildren="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topTitle" />
    <com.zomato.ui.lib.organisms.snippets.rescards.imagebottomcontainer.ImageBottomContainerView
        android:id="@id/image_tag_top_container_1"
        android:clipChildren="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_10"
        app:layout_constraintBottom_toTopOf="@id/image_tag_top_container_2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_goneMarginBottom="@dimen/size_30" />
    <com.zomato.ui.lib.organisms.snippets.rescards.imagebottomcontainer.ImageBottomContainerView
        android:id="@id/image_tag_top_container_2"
        android:clipChildren="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/size_30"
        app:layout_constraintBottom_toBottomOf="@id/image_bottom_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_goneMarginBottom="@dimen/size_30" />
    <com.zomato.ui.atomiclib.atom.ZTag
        android:id="@id/bottom_tag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image_bottom_barrier" />
    <HorizontalScrollView
        android:id="@id/horizontalScrollVIew"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_10"
        android:layout_marginTop="@dimen/size_12"
        android:layout_marginRight="@dimen/dimen_10"
        android:overScrollMode="never"
        android:elevation="@dimen/sushi_spacing_femto"
        android:layout_marginHorizontal="@dimen/dimen_10"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottom_tag">
        <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
            android:id="@id/bottom_text"
            android:paddingLeft="@dimen/size_6"
            android:paddingTop="@dimen/dimen_2"
            android:paddingRight="@dimen/size_6"
            android:paddingBottom="@dimen/dimen_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/size_6"
            android:paddingVertical="@dimen/dimen_2" />
    </HorizontalScrollView>
    <FrameLayout
        android:layout_gravity="center"
        android:id="@id/top_right_action_container"
        android:paddingTop="@dimen/dimen_two_point_two"
        android:paddingRight="@dimen/size_3_and_half"
        android:visibility="visible"
        android:layout_width="@dimen/size_37"
        android:layout_height="@dimen/size_37"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_marginEnd="@dimen/sushi_spacing_extra"
        android:translationZ="@dimen/sushi_spacing_nano"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topTitle">
        <com.zomato.ui.atomiclib.atom.ZButton
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/top_right_action"
            android:padding="@dimen/dimen_0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen_0"
            app:buttonDimension="medium"
            app:buttonType="text" />
    </FrameLayout>
    <com.zomato.ui.atomiclib.atom.staticviews.StaticTextView
        android:gravity="center"
        android:id="@id/topTitle"
        android:paddingTop="@dimen/size_8"
        android:paddingBottom="@dimen/size_8"
        android:layout_width="@dimen/sushi_spacing_femto"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/size_8"
        app:layout_constraintBottom_toTopOf="@id/top_right_action_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>