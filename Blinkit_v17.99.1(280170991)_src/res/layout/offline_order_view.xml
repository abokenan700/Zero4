<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:paddingLeft="@dimen/sushi_spacing_macro"
    android:paddingTop="@dimen/sushi_spacing_base"
    android:paddingRight="@dimen/sushi_spacing_macro"
    android:paddingBottom="@dimen/sushi_spacing_base"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/sushi_spacing_micro"
    android:foreground="@drawable/feedback_ripple_white_overlay"
    android:maxWidth="320.0dip"
    android:paddingHorizontal="@dimen/sushi_spacing_macro"
    android:paddingVertical="@dimen/sushi_spacing_base"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:layout_gravity="center_vertical"
        android:id="@id/circle"
        android:background="@drawable/bg_circle_favourite"
        android:layout_width="@dimen/size_50"
        android:layout_height="@dimen/size_50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZRoundedImageView
            android:layout_gravity="center"
            android:id="@id/image"
            android:layout_width="@dimen/size_48"
            android:layout_height="@dimen/size_48"
            android:scaleType="centerCrop"
            app:cornerRadius="@dimen/size_24" />
        <com.zomato.ui.atomiclib.animation.ZLottieAnimationView
            android:layout_gravity="center"
            android:id="@id/animation_view"
            android:visibility="gone"
            android:layout_width="@dimen/sushi_spacing_alone"
            android:layout_height="@dimen/sushi_spacing_alone"
            app:lottie_autoPlay="true"
            app:lottie_loop="true" />
    </FrameLayout>
    <LinearLayout
        android:gravity="start"
        android:orientation="vertical"
        android:id="@id/title_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/sushi_spacing_macro"
        android:layout_marginRight="@dimen/sushi_spacing_macro"
        android:layout_marginHorizontal="@dimen/sushi_spacing_macro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/button"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/circle"
        app:layout_constraintTop_toTopOf="parent">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_900"
            android:gravity="start"
            android:layout_gravity="start"
            android:id="@id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/size_200"
            app:textViewType="SEMIBOLD_400" />
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textColor="@color/sushi_grey_600"
            android:gravity="start"
            android:layout_gravity="start"
            android:id="@id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sushi_spacing_micro"
            android:maxWidth="@dimen/size_200"
            app:textViewType="REGULAR_300" />
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZButton
        android:gravity="center_vertical"
        android:id="@id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:buttonDimension="large"
        app:buttonType="text"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>