    <com.blinkit.commons.ui.ui.customviews.BShapeableImageView
        android:id="@id/pointer_image"
        android:layout_width="48.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/wheel_container"
        app:layout_constraintDimensionRatio="0.7"
        app:layout_constraintEnd_toEndOf="@id/wheel_container"
        app:layout_constraintStart_toStartOf="@id/wheel_container"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />
    <com.blinkit.quickdelivery.ui.screens.stories.spinwheel.views.WheelOverlayView
        android:id="@id/wheel_overlay"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dip"
        app:layout_constraintBottom_toBottomOf="@id/wheel_container"
        app:layout_constraintDimensionRatio="0.92"
        app:layout_constraintEnd_toEndOf="@id/wheel_container"
        app:layout_constraintStart_toStartOf="@id/wheel_container"
        app:layout_constraintTop_toTopOf="@id/wheel_container"
        app:layout_constraintWidth_percent="0.96" />
