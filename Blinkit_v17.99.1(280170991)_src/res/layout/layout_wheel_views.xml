<?xml version="1.0" encoding="utf-8"?>
<merge
    android:clipChildren="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.blinkit.quickdelivery.ui.screens.stories.spinwheel.views.GlowView
        android:id="@id/glow_view"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/wheel_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/wheel_container" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/wheel_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_42"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.blinkit.quickdelivery.ui.screens.stories.spinwheel.views.WheelItemView
            android:id="@id/wheel_item_1"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_margin="@dimen/dimen_7"
            app:layout_constraintBottom_toBottomOf="@id/rim_image"
            app:layout_constraintDimensionRatio="1"
            app:layout_constraintEnd_toEndOf="@id/rim_image"
            app:layout_constraintStart_toStartOf="@id/rim_image"
            app:layout_constraintTop_toTopOf="@id/rim_image" />
        <com.blinkit.quickdelivery.ui.screens.stories.spinwheel.views.WheelItemView
