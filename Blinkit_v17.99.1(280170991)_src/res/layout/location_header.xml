<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:id="@id/location_background"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/sushi_spacing_micro"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/left_action_image_view"
        android:visibility="gone"
        android:layout_width="@dimen/dimen_20"
        android:layout_height="@dimen/size_24"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        android:src="@drawable/location_icon"
        android:scaleType="fitXY"
        android:layout_marginStart="@dimen/sushi_spacing_micro"
        android:layout_marginEnd="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/location_inner_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/location_inner_container" />
    <include
        android:id="@id/left_action"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/left_action_image_view"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/layout_icon_font_with_count_badge" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/location_inner_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/sushi_spacing_macro"
        android:layout_marginEnd="@dimen/sushi_spacing_mini"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/left_action"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:textSize="@dimen/text_size_16"
            android:textColor="?themeColor500"
            android:ellipsize="end"
            android:layout_gravity="start|center"
            android:id="@id/location_header_container"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:includeFontPadding="false"
            app:fontFamily="@font/okra_bold">
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@id/left_action_image_view_minimised"
                android:visibility="gone"
                android:layout_width="@dimen/dimen_14"
                android:layout_height="@dimen/dimen_16"
                android:src="@drawable/location_icon"
                android:scaleType="fitCenter"
                android:layout_marginEnd="@dimen/sushi_spacing_micro"
                app:layout_constraintBottom_toBottomOf="@id/location_title"
                app:layout_constraintEnd_toStartOf="@id/location_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/location_title" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textSize="@dimen/text_size_16"
                android:textColor="@color/sushi_red_500"
                android:ellipsize="end"
                android:layout_gravity="start|center"
                android:id="@id/location_title"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:includeFontPadding="false"
                app:fontFamily="@font/okra_bold"
                app:layout_constrainedWidth="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tv_location_tag"
                app:layout_constraintStart_toEndOf="@id/left_action_image_view_minimised"
                app:layout_constraintTop_toTopOf="parent" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:layout_gravity="center_vertical"
                android:id="@id/tv_location_tag"
                android:paddingTop="@dimen/sushi_spacing_pico"
                android:paddingBottom="@dimen/sushi_spacing_pico"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:paddingStart="@dimen/sushi_spacing_micro"
                android:paddingEnd="@dimen/sushi_spacing_micro"
                android:layout_marginStart="@dimen/sushi_spacing_macro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/location_title"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_900"
                android:ellipsize="end"
                android:id="@id/location_subtitle"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                app:textViewType="MEDIUM_200" />
            <com.zomato.ui.atomiclib.atom.ZRoundedImageView
                android:id="@id/subtitle_suffix_image"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/sushi_spacing_between" />
            <com.zomato.ui.atomiclib.atom.ZTextView
                android:textColor="@color/sushi_grey_900"
                android:ellipsize="end"
                android:id="@id/location_subtitle2"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_marginStart="@dimen/sushi_spacing_between"
                app:textViewType="MEDIUM_200" />
        </LinearLayout>
    </LinearLayout>
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/location_dashed_underline"
        android:layout_width="0.0dip"
        android:layout_height="@dimen/sushi_spacing_nano"
        android:layout_marginTop="@dimen/size_3"
        android:src="@drawable/horizontal_dashed_line_grey"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/location_inner_container"
        app:layout_constraintStart_toStartOf="@id/location_inner_container"
        app:layout_constraintTop_toBottomOf="@id/location_inner_container"
        app:layout_constraintVertical_bias="0.0" />
</androidx.constraintlayout.widget.ConstraintLayout>