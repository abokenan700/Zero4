<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="?attr_7f0403d7"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <include
        android:id="@id/primary"
        android:layout_width="@dimen/size_100"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/filter_page_shimmer" />
    <include
        android:id="@id/detail"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/primary"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/filter_detail_page_shimmer" />
    <View
        android:id="@id/separator"
        android:background="?attr_7f040296"
        android:layout_width="@dimen/corner_stroke_one"
        android:layout_height="fill_parent"
        app:layout_constraintEnd_toStartOf="@id/detail"
        app:layout_constraintStart_toEndOf="@id/primary" />
</androidx.constraintlayout.widget.ConstraintLayout>