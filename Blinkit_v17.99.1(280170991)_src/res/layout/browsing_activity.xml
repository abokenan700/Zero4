<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:textSize="@dimen/loading_text_size"
        android:textColor="@color/user_context_msg_color"
        android:gravity="center"
        android:id="@id/loading_text"
        android:paddingLeft="@dimen/texts_padding"
        android:paddingRight="@dimen/texts_padding"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:fontFamily="sans-serif" />
    <ProgressBar
        android:id="@id/loading_spinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15.0sp"
        android:layout_below="@id/loading_text"
        android:layout_centerHorizontal="true" />
</RelativeLayout>