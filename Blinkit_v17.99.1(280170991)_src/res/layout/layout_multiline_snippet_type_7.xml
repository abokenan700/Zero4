<?xml version="1.0" encoding="utf-8"?>
<merge
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:id="@id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_macro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/separator1"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_marginTop="@dimen/size_20"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:zseparator_color="@color/sushi_grey_200" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/middle_container"
        android:paddingBottom="@dimen/sushi_spacing_extra"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/separator1" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/separator2"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_marginTop="@dimen/sushi_spacing_micro"
        app:layout_constraintTop_toBottomOf="@id/middle_container"
        app:zseparator_color="?themeColor100" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="center"
        android:id="@id/button1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_weight="1.0"
        app:buttonType="text" />
    <com.zomato.ui.atomiclib.atom.ZSeparator
        android:id="@id/separator3"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/dimen_point_five"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        app:layout_constraintTop_toBottomOf="@id/middle_container"
        app:zseparator_color="?themeColor100" />
    <com.zomato.ui.atomiclib.atom.ZButton
        android:layout_gravity="center"
        android:id="@id/button2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_extra"
        android:layout_weight="1.0"
        app:buttonType="text" />
</merge>