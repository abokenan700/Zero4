<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/container"
    android:paddingTop="@dimen/sushi_spacing_base"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/option_logo"
        android:layout_width="@dimen/size_36"
        android:layout_height="@dimen/size_24"
        android:layout_marginBottom="@dimen/sushi_spacing_base"
        android:scaleType="fitCenter"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintEnd_toStartOf="@id/barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_300"
        android:textColor="?attr_7f04048a"
        android:id="@id/title"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:fontFamily="@font/okra_medium"
        android:paddingStart="@dimen/sushi_spacing_base"
        android:paddingEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/subtitle"
        app:layout_constraintEnd_toStartOf="@id/right_tv"
        app:layout_constraintStart_toEndOf="@id/option_logo"
        app:layout_constraintTop_toTopOf="@id/option_logo"
        app:layout_constraintVertical_chainStyle="spread"
        app:textFontWeight="medium" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_200"
        android:id="@id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/size_3"
        android:fontFamily="@font/okra"
        android:paddingStart="@dimen/sushi_spacing_base"
        android:paddingEnd="@dimen/sushi_spacing_base"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/subtitle2"
        app:layout_constraintEnd_toStartOf="@id/right_tv"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@id/option_logo"
        app:layout_constraintTop_toBottomOf="@id/title" />
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:id="@id/subtitle_right_image"
        android:visibility="gone"
        android:layout_width="@dimen/size_40"
        android:layout_height="@dimen/size_20"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toEndOf="@id/subtitle"
        app:layout_constraintTop_toTopOf="@id/subtitle" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_100"
        android:id="@id/subtitle2"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        android:fontFamily="@font/okra"
        android:paddingStart="@dimen/sushi_spacing_base"
        android:paddingEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toTopOf="@id/description"
        app:layout_constraintEnd_toStartOf="@id/barrier2"
        app:layout_constraintStart_toEndOf="@id/option_logo"
        app:layout_constraintTop_toBottomOf="@id/subtitle" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_100"
        android:id="@id/description"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/sushi_spacing_nano"
        android:fontFamily="@font/okra"
        android:paddingStart="@dimen/sushi_spacing_base"
        android:paddingEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/option_logo"
        app:layout_constraintEnd_toStartOf="@id/barrier2"
        app:layout_constraintStart_toEndOf="@id/option_logo"
        app:layout_constraintTop_toBottomOf="@id/subtitle2" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_300"
        android:gravity="center_vertical"
        android:id="@id/right_tv"
        android:background="?android:selectableItemBackground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/okra_medium"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/refresh_loader"
        app:layout_constraintEnd_toStartOf="@id/barrier2"
        app:layout_constraintTop_toTopOf="@id/refresh_loader" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_300"
        android:gravity="center_vertical"
        android:id="@id/prefix_icon_right_tv"
        android:background="?android:selectableItemBackground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/okra_medium"
        android:layout_marginEnd="@dimen/sushi_spacing_micro"
        app:layout_constraintBottom_toBottomOf="@id/right_tv"
        app:layout_constraintEnd_toStartOf="@id/right_tv"
        app:layout_constraintTop_toTopOf="@id/right_tv" />
    <ProgressBar
        android:id="@id/refresh_loader"
        android:layout_width="@dimen/size_36"
        android:layout_height="0.0dip"
        android:progressTint="?colorAccent"
        android:indeterminateTint="?colorAccent"
        app:layout_constraintBottom_toBottomOf="@id/right_icon"
        app:layout_constraintEnd_toStartOf="@id/right_icon"
        app:layout_constraintTop_toTopOf="@id/right_icon" />
    <com.zomato.ui.atomiclib.atom.ZIconFontTextView
        android:textSize="@dimen/sushi_textsize_200"
        android:id="@id/right_icon"
        android:background="?android:selectableItemBackgroundBorderless"
        android:padding="@dimen/sushi_spacing_micro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/sushi_spacing_base"
        app:layout_constraintBottom_toBottomOf="@id/option_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/option_logo" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrier2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="left"
        app:constraint_referenced_ids="refresh_loader,right_icon" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="left"
        app:constraint_referenced_ids="subtitle,title" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrier3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="title, subtitle, subtitle2, description, option_logo" />
    <View
        android:id="@id/divider"
        android:background="?attr_7f04029b"
        android:layout_width="@dimen/dimen_0"
        android:layout_height="@dimen/border_stroke_width"
        android:layout_marginTop="@dimen/sushi_spacing_base"
        android:layout_marginStart="@dimen/sushi_spacing_base"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/barrier3" />
</androidx.constraintlayout.widget.ConstraintLayout>