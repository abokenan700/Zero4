<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:paddingTop="@dimen/size_30"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:layout_margin="@dimen/size_20"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.zomato.ui.atomiclib.atom.ZRoundedImageView
        android:layout_gravity="center_horizontal"
        android:id="@id/zcustomdialog_image"
        android:layout_width="@dimen/size_80"
        android:layout_height="@dimen/size_80"
        android:scaleType="fitXY" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_500"
        android:textColor="?attr_7f040475"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/zcustomdialog_title"
        android:paddingTop="@dimen/size_20"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sushi_spacing_macro"
        android:paddingStart="@dimen/sushi_spacing_alone"
        android:paddingEnd="@dimen/sushi_spacing_alone"
        app:textFontWeight="medium"
        app:textViewType="MEDIUM_400" />
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@id/message_container"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_10">
        <com.zomato.ui.atomiclib.atom.ZTextView
            android:textSize="@dimen/sushi_textsize_200"
            android:textColor="?attr_7f040490"
            android:gravity="center"
            android:id="@id/zcustomdialog_message"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dimen_10"
            android:paddingEnd="@dimen/dimen_10"
            app:textViewType="REGULAR_300" />
        <ListView
            android:layout_gravity="start|center"
            android:id="@id/listViewContainer"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <View
        android:id="@id/separator1"
        android:background="@color/sushi_grey_200"
        android:layout_width="fill_parent"
        android:layout_height="0.5dip"
        android:layout_below="@id/message_container" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_400"
        android:textColor="?themeColor500"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/zcustomdialog_positive_button"
        android:background="@drawable/feedback_zcustomdialog"
        android:padding="@dimen/dimen_15"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:textViewType="SEMIBOLD_500" />
    <View
        android:id="@id/separator2"
        android:background="@color/sushi_grey_200"
        android:layout_width="fill_parent"
        android:layout_height="0.5dip" />
    <com.zomato.ui.atomiclib.atom.ZTextView
        android:textSize="@dimen/sushi_textsize_200"
        android:textColor="@color/sushi_grey_600"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/zcustomdialog_negative_button"
        android:background="@drawable/feedback_zcustomimagedialog"
        android:padding="@dimen/dimen_15"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:textViewType="REGULAR_500" />
</LinearLayout>