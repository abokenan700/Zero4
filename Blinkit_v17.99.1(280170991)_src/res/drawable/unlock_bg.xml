<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@android:id/background">
        <shape
            android:shape="rectangle">
            <size
                android:height="@dimen/size_78" />
            <corners
                android:radius="@dimen/size_25" />
            <stroke
                android:width="@dimen/sushi_spacing_pico"
                android:color="@color/sushi_onion_800" />
            <solid
                android:color="@color/sushi_onion_100" />
        </shape>
    </item>
    <item
        android:id="@android:id/progress"
        android:left="@dimen/size_4"
        android:top="@dimen/size_4"
        android:right="@dimen/size_4"
        android:bottom="@dimen/size_4">
        <scale
            android:scaleWidth="100%"
            android:useIntrinsicSizeAsMinimum="true">
            <shape
                android:shape="rectangle">
                <corners
                    android:radius="@dimen/size_25" />
                <size
                    android:height="@dimen/size_48"
                    android:width="@dimen/size50" />
                <stroke
                    android:width="@dimen/sushi_spacing_pico"
                    android:color="@color/sushi_onion_100" />
                <solid
                    android:color="@color/sushi_onion_800" />
            </shape>
        </scale>
    </item>
</layer-list>