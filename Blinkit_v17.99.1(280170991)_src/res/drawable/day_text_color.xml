<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <item
        android:state_selected="false"
        android:color="@color/sushi_color_green"
        app:tsquare_state_current_month="true"
        app:tsquare_state_today="true"
        app:tsquare_state_unavailable="false" />
    <item
        android:state_selected="true"
        android:color="@color/dateRangePickerRangeFirstLast"
        app:tsquare_state_range_middle="false" />
    <item
        android:color="@color/dateRangePickerStateDefault"
        app:tsquare_state_range_middle="true" />
    <item
        android:state_selected="false"
        android:color="@color/dateTimeRangePickerRangeTextColorInactive"
        app:tsquare_state_deactivated="true"
        app:tsquare_state_today="false" />
    <item
        android:color="@color/dateTimeRangePickerRangeTextColorNonSelectable"
        app:tsquare_state_selectable="false" />
    <item
        android:color="@color/dateRangePickerStateDefault" />
</selector>