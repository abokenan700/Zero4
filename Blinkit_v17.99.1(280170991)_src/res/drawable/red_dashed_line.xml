<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/color_transparent" />
        </shape>
    </item>
    <item
        android:id="@id/dashed_line"
        android:left="-2.0dip"
        android:top="-2.0dip"
        android:right="-2.0dip">
        <shape>
            <solid
                android:color="@android:color/transparent" />
            <stroke
                android:width="1.0dip"
                android:color="@color/z_red"
                android:dashWidth="10.0px"
                android:dashGap="5.0px" />
        </shape>
    </item>
</layer-list>