    <item
        android:id="@android:id/mask">
        <shape
            android:shape="rectangle">
            <corners
                android:radius="@dimen/sushi_corner_radius" />
            <solid
                android:color="@color/light_grey_with_alpha" />
        </shape>
    </item>
    <item>
        <shape
            android:shape="rectangle">
            <corners
                android:radius="@dimen/sushi_corner_radius" />
