<?xml version="1.0" encoding="utf-8"?>
<selector
    android:enterFadeDuration="100"
    android:exitFadeDuration="100"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <item
        android:drawable="@drawable/state_range_middle"
        app:tsquare_state_range_middle="true" />
    <item
        android:state_selected="true"
        android:drawable="@drawable/state_selected"
        app:tsquare_state_highlighted="false"
        app:tsquare_state_range_first="false"
        app:tsquare_state_range_last="false" />
    <item
        android:drawable="@drawable/state_range_first"
        app:tsquare_state_range_first="true" />
    <item
        android:drawable="@drawable/state_range_last"
        app:tsquare_state_range_last="true" />
    <item
        android:drawable="@drawable/state_unavailable"
        app:tsquare_state_highlighted="true" />
    <item
        android:drawable="@drawable/state_today"
        app:tsquare_state_current_month="true"
        app:tsquare_state_today="true"
        app:tsquare_state_unavailable="false" />
    <item
        android:drawable="@drawable/state_range_middle_unavailable"
        app:tsquare_state_unavailable="true" />
</selector>