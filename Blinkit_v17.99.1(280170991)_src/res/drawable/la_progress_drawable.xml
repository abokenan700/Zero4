<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity="center_vertical"
        android:id="@android:id/secondaryProgress"
        android:height="4.0dip">
        <scale
            android:scaleWidth="100%"
            android:scaleHeight="50%">
            <shape>
                <solid
                    android:color="@color/sushi_grey_500" />
                <corners
                    android:radius="@dimen/sushi_spacing_macro" />
            </shape>
        </scale>
    </item>
    <item
        android:gravity="center_vertical"
        android:id="@android:id/progress"
        android:height="@dimen/sushi_spacing_micro">
        <scale
            android:scaleWidth="100%"
            android:scaleHeight="50%">
            <layer-list>
                <item
                    android:gravity="center_vertical"
                    android:height="4.0dip">
                    <shape>
                        <solid
                            android:color="@color/tokenised_green_600" />
                        <corners
                            android:radius="@dimen/sushi_spacing_macro" />
                    </shape>
                </item>
            </layer-list>
        </scale>
    </item>
</layer-list>