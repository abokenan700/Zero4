<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@android:id/background">
        <shape>
            <corners
                android:radius="@dimen/sushi_spacing_alone" />
        </shape>
    </item>
    <item
        android:id="@android:id/progress">
        <clip>
            <shape>
                <corners
                    android:radius="@dimen/sushi_spacing_alone" />
                <gradient
                    android:startColor="@color/sushi_green_300"
                    android:endColor="@color/sushi_teal_400"
                    android:angle="180.0"
                    android:type="linear" />
            </shape>
        </clip>
    </item>
</layer-list>