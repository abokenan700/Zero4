<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@id/corner_gradient_layer_1">
        <shape
            android:shape="rectangle">
            <gradient
                android:endColor="@color/white"
                android:angle="315.0"
                android:type="linear"
                android:centerColor="@color/sushi_red_300" />
            <corners
                android:radius="@dimen/dimen_16" />
        </shape>
    </item>
    <item
        android:id="@id/corner_gradient_layer_2">
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/sushi_white" />
            <corners
                android:topLeftRadius="@dimen/dimen_16"
                android:topRightRadius="@dimen/dimen_16"
                android:bottomLeftRadius="@dimen/dimen_16"
                android:bottomRightRadius="@dimen/size_96" />
        </shape>
    </item>
</layer-list>