<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape
            android:shape="oval">
            <size
                android:height="@dimen/dimen_18"
                android:width="@dimen/dimen_18" />
            <solid
                android:width="@dimen/spacing_between_3dp"
                android:color="@color/sushi_blue_500" />
        </shape>
    </item>
    <item
        android:left="@dimen/nitro_vertical_padding_6"
        android:top="@dimen/nitro_vertical_padding_6"
        android:right="@dimen/nitro_vertical_padding_6"
        android:bottom="@dimen/nitro_vertical_padding_6">
        <shape
            android:shape="rectangle">
            <solid
                android:color="@android:color/white" />
        </shape>
    </item>
</layer-list>