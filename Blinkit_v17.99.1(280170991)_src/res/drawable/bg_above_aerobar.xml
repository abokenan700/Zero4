<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/color_transparent" />
        </shape>
    </item>
    <item
        android:gravity="bottom"
        android:height="@dimen/sushi_spacing_base">
        <shape
            android:shape="rectangle">
            <gradient
                android:startColor="@color/color_transparent"
                android:endColor="#12000000"
                android:angle="270.0" />
        </shape>
    </item>
</layer-list>