<?xml version="1.0" encoding="utf-8"?>
<ripple
    android:color="@color/color_white_with_alpha"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@android:id/mask">
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/color_white_with_alpha" />
            <corners
                android:radius="@dimen/size_26" />
        </shape>
    </item>
    <item>
        <shape
            android:shape="rectangle">
            <corners
                android:radius="@dimen/size_26" />
            <padding
                android:left="@dimen/padding_medium"
                android:top="@dimen/circular_icon_padding_small"
                android:right="@dimen/padding_medium"
                android:bottom="@dimen/circular_icon_padding_small" />
        </shape>
    </item>
</ripple>