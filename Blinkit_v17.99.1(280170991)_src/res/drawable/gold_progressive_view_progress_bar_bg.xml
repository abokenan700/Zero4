<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@android:id/background">
        <shape>
            <corners
                android:radius="@dimen/sushi_spacing_nano" />
        </shape>
    </item>
    <item
        android:id="@android:id/progress">
        <clip>
            <shape>
                <corners
                    android:radius="@dimen/sushi_spacing_nano" />
                <gradient
                    android:startColor="@color/sushi_white"
                    android:endColor="@color/sushi_black"
                    android:angle="0.0" />
            </shape>
        </clip>
    </item>
</layer-list>